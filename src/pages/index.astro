---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/sections/Header.astro";
import Hero from "../components/sections/Hero.astro";
import Audience from "../components/sections/Audience.astro";
import Products from "../components/sections/Products.astro";
import Steps from "../components/sections/Steps.astro";
import Benefits from "../components/sections/Benefits.astro";
import Testimonials from "../components/sections/Testimonials.astro";
import Coverage from "../components/sections/Coverage.astro";
import FinalCta from "../components/sections/FinalCta.astro";
import Footer from "../components/sections/Footer.astro";
import Cursor from "../components/Cursor.astro";
import SiteScripts from "../components/SiteScripts.astro";
---

<BaseLayout
  title="Frío Puro — Hielo Premium para Negocios"
  description="Frío Puro — Distribuidor mayorista de hielo en Villahermosa Tabasco. Hielo en cubos, triturado y en bloque para restaurantes, bares, hoteles y eventos. Entrega rápida 24/7."
  keywords="hielo mayoreo Villahermosa Tabasco, hielo para restaurantes, hielo para bares, distribuidora de hielo Chiapas, hielo en bloque, hielo triturado"
  author="Frío Puro"
  ogTitle="Frío Puro — Hielo Premium para Negocios en Villahermosa Tabasco"
  ogDescription="Distribuidor mayorista #1 de hielo en Villahermosa Tabasco. Servicio 24/7 para restaurantes, bares, hoteles y eventos."
>
  <Cursor />
  <Header />
  <main>
    <Hero />
    <Audience />
    <Products />
    <Steps />
    <Benefits />
    <Testimonials />
    <Coverage />
    <FinalCta />
    <Footer />
  </main>
  <a href="#inicio" id="back-top">↑</a>
  <SiteScripts />
</BaseLayout>
