---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/sections/Header.astro";
import Hero from "../components/sections/Hero.astro";
import Audience from "../components/sections/Audience.astro";
import Products from "../components/sections/Products.astro";
import Process from "../components/sections/Process.astro";
import Steps from "../components/sections/Steps.astro";
import Benefits from "../components/sections/Benefits.astro";
import FinalCta from "../components/sections/FinalCta.astro";
import Footer from "../components/sections/Footer.astro";
import Cursor from "../components/Cursor.astro";
import SiteScripts from "../components/SiteScripts.astro";
---

<BaseLayout
  title="Frío Puro — Hielo Premium para Negocios"
  description="Frío Puro — Distribuidor mayorista de hielo en Villahermosa Tabasco. Hielo en cubos, triturado y en bloque para restaurantes, bares, hoteles y eventos. Entrega rápida 24/7."
  keywords="hielo mayoreo Villahermosa Tabasco, hielo para restaurantes, hielo para bares, distribuidora de hielo Chiapas, hielo en bloque, hielo triturado"
  author="Frío Puro"
  ogTitle="Frío Puro — Hielo Premium para Negocios en Villahermosa Tabasco"
  ogDescription="Distribuidor mayorista #1 de hielo en Villahermosa Tabasco. Servicio 24/7 para restaurantes, bares, hoteles y eventos."
>
  <Cursor />
  <Header />
  <main>
    <Hero />
    <Audience />
    <Products />
    <Process />
    <Steps />
    <Benefits />
    <FinalCta />
    <Footer />
  </main>
  <a href="#inicio" id="back-top" aria-label="Volver arriba">&#8593;</a>
  <SiteScripts />

  <style>
    #back-top {
      position: fixed;
      bottom: 36px;
      right: 36px;
      width: 48px;
      height: 48px;
      background: var(--color-accent);
      color: var(--color-white);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.2rem;
      text-decoration: none;
      z-index: 990;
      opacity: 0;
      transform: translateY(20px);
      transition: all var(--transition);
      box-shadow: 0 6px 25px rgba(65, 171, 226, 0.4);
    }

    #back-top.visible {
      opacity: 1;
      transform: translateY(0);
    }

    #back-top:hover {
      background: var(--color-primary);
      transform: translateY(-4px);
    }
  </style>
</BaseLayout>
