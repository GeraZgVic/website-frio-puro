---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/sections/Header.astro";
import Footer from "../../components/sections/Footer.astro";
import WhatsAppFloat from "../../components/ui/WhatsAppFloat.astro";
import Cursor from "../../components/Cursor.astro";
import SiteScripts from "../../components/SiteScripts.astro";
---

<BaseLayout
  title="Solicitar cotización corporativa | Frío Puro"
  description="Solicitud de cotización corporativa para suministro comercial de alto volumen."
  ogTitle="Solicitar cotización corporativa | Frío Puro"
  ogDescription="Stock permanente y entregas programadas para operación comercial."
>
  <Cursor />
  <Header />

  <main class="page">
    <div id="inicio" aria-hidden="true"></div>

    <section class="hero" aria-labelledby="quoteTitle">
      <div class="hero__bg" aria-hidden="true">
        <img
          src="/images/ImaForm.png"
          alt=""
          class="hero__image"
          width="1600"
          height="900"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>

      <div class="hero__overlay" aria-hidden="true"></div>

      <div class="container hero__inner">
        <div class="hero__copy">
          <p class="hero__eyebrow">FRÍO PURO · CORPORATIVO</p>

          <h1 id="quoteTitle" class="hero__title">
            Suministro de hielo<br />
            para operación comercial
          </h1>

          <p class="hero__subtitle">
            Entregas programadas, stock constante y atención directa para
            negocios que no pueden detener su operación.
          </p>

          <div class="hero__stats" aria-label="Indicadores de confianza">
            <div class="hero__stat">
              <strong>+120</strong>
              <span>negocios activos</span>
            </div>
            <div class="hero__stat">
              <strong>&lt;24h</strong>
              <span>respuesta</span>
            </div>
            <div class="hero__stat">
              <strong>MX</strong>
              <span>cobertura</span>
            </div>
          </div>
        </div>

        <aside
          class="form-card"
          role="region"
          aria-label="Formulario de cotización corporativa"
        >
          <div class="form-card__head">
            <p class="form-card__eyebrow">SOLICITUD CORPORATIVA</p>
            <h2 class="form-card__title">Solicita tu propuesta</h2>
            <p class="form-card__subtitle">Respuesta en menos de 24 horas.</p>
          </div>

          <form
            id="corpQuoteForm"
            class="form"
            method="post"
            action="/api/cotizacion-corporativa"
            novalidate
          >
            <div class="form__honeypot" aria-hidden="true">
              <label for="companyWebsite">Sitio web</label>
              <input
                id="companyWebsite"
                name="company_website"
                type="text"
                tabindex="-1"
                autocomplete="off"
              />
            </div>

            <div class="field field--full">
              <label class="field__label" for="corpName">Nombre o empresa</label
              >
              <input
                class="field__input"
                id="corpName"
                name="name_company"
                type="text"
                autocomplete="organization"
                placeholder="Hotel Vista Mar"
                required
                aria-describedby="corpNameError"
              />
              <p
                class="field__error"
                id="corpNameError"
                role="alert"
                aria-hidden="true"
              >
              </p>
            </div>

            <div class="field">
              <label class="field__label" for="corpPhone">Teléfono</label>
              <input
                class="field__input"
                id="corpPhone"
                name="phone"
                type="tel"
                inputmode="tel"
                autocomplete="tel"
                placeholder="993 123 4567"
                required
                aria-describedby="corpPhoneError"
              />
              <p
                class="field__error"
                id="corpPhoneError"
                role="alert"
                aria-hidden="true"
              >
              </p>
            </div>

            <div class="field">
              <label class="field__label" for="corpEmail">
                Correo <span class="field__badge">opcional</span>
              </label>
              <input
                class="field__input"
                id="corpEmail"
                name="email"
                type="email"
                autocomplete="email"
                placeholder="contacto@empresa.com"
                aria-describedby="corpEmailError"
              />
              <p
                class="field__error"
                id="corpEmailError"
                role="alert"
                aria-hidden="true"
              >
              </p>
            </div>

            <div class="field field--full">
              <label class="field__label" for="corpConsumptionTrigger"
                >Consumo estimado</label
              >
              <div class="dropdown" data-open="false">
                <button
                  class="dropdown__trigger"
                  id="corpConsumptionTrigger"
                  type="button"
                  aria-haspopup="listbox"
                  aria-expanded="false"
                  aria-controls="corpConsumptionListbox"
                  aria-describedby="corpConsumptionError"
                >
                  <span
                    id="corpConsumptionValue"
                    class="dropdown__value"
                    data-placeholder="true">Selecciona una opción</span
                  >
                  <svg
                    class="dropdown__chevron"
                    width="16"
                    height="16"
                    viewBox="0 0 16 16"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path
                      d="M4 6L8 10L12 6"
                      stroke="currentColor"
                      stroke-width="1.7"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </button>

                <input
                  id="corpConsumption"
                  name="consumption"
                  type="hidden"
                  value=""
                  aria-describedby="corpConsumptionError"
                />

                <div
                  class="dropdown__panel"
                  id="corpConsumptionListbox"
                  role="listbox"
                  aria-label="Consumo estimado"
                  hidden
                >
                  <button
                    class="dropdown__option"
                    type="button"
                    role="option"
                    data-value="lt_50"
                    aria-selected="false"
                  >
                    Menos de 50 bolsas / semana
                  </button>
                  <button
                    class="dropdown__option"
                    type="button"
                    role="option"
                    data-value="50_150"
                    aria-selected="false"
                  >
                    50 – 150 bolsas / semana
                  </button>
                  <button
                    class="dropdown__option"
                    type="button"
                    role="option"
                    data-value="gt_150"
                    aria-selected="false"
                  >
                    Más de 150 bolsas / semana
                  </button>
                </div>
              </div>
              <p
                class="field__error"
                id="corpConsumptionError"
                role="alert"
                aria-hidden="true"
              >
              </p>
            </div>

            <button class="btn-submit" type="submit">
              <span>Solicitar propuesta</span>
              <svg
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M3 8H13M13 8L9 4M13 8L9 12"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>

            <p class="form__legal">
              Sin compromiso · Atención comercial directa
            </p>

            <div
              id="corpQuoteStatus"
              class="form__status"
              role="status"
              aria-live="polite"
              hidden
            >
            </div>
          </form>
        </aside>
      </div>
    </section>

    <Footer />
  </main>

  <WhatsAppFloat />

  <a href="#inicio" id="back-top" aria-label="Volver arriba">
    <svg
      width="14"
      height="14"
      viewBox="0 0 14 14"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M7 11V3M3.5 6.5L7 3L10.5 6.5"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </a>

  <SiteScripts />

  <style>
    :global(:root) {
      --back-top-size: 42px;
      --back-top-right: 28px;
      --back-top-bottom: 28px;

      --bg: #050505;
      --surface: rgba(9, 10, 14, 0.78);
      --surface-border: rgba(255, 255, 255, 0.09);
      --text: #ffffff;
      --text-soft: rgba(255, 255, 255, 0.7);
      --text-muted: rgba(255, 255, 255, 0.42);
      --line: rgba(255, 255, 255, 0.1);
      --accent: #8fd8ff;
      --accent-strong: #bde9ff;
      --accent-ring: rgba(143, 216, 255, 0.18);
      --danger: #ff9a9a;

      --out: cubic-bezier(0.22, 0.61, 0.36, 1);
      --spring: cubic-bezier(0.34, 1.52, 0.64, 1);
    }

    * {
      box-sizing: border-box;
    }

    .page {
      min-height: 100vh;
      background: var(--bg);
      color: var(--text);
    }

    .container {
      width: min(1180px, calc(100% - 48px));
      margin: 0 auto;
    }

    .hero {
      position: relative;
      min-height: 100svh;
      display: flex;
      align-items: center;
      overflow: hidden;
      isolation: isolate;
      background: #000;
    }

    .hero__bg,
    .hero__image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .hero__image {
      object-fit: cover;
      object-position: 72% center;
      filter: brightness(0.36) contrast(1.12) saturate(0.92);
      transform: scale(1.03);
      will-change: transform;
      animation: heroImageIn 860ms var(--out) both;
    }

    .hero__overlay {
      position: absolute;
      inset: 0;
      z-index: 1;
      background:
        linear-gradient(
          90deg,
          rgba(2, 5, 12, 0.86) 0%,
          rgba(2, 5, 12, 0.7) 30%,
          rgba(2, 5, 12, 0.38) 58%,
          rgba(2, 5, 12, 0.12) 100%
        ),
        radial-gradient(
          circle at 18% 36%,
          rgba(0, 140, 255, 0.12) 0%,
          rgba(0, 140, 255, 0.045) 22%,
          transparent 52%
        ),
        linear-gradient(
          180deg,
          rgba(0, 0, 0, 0.18) 0%,
          rgba(0, 0, 0, 0.08) 42%,
          rgba(0, 0, 0, 0.28) 100%
        );
    }

    .hero__inner {
      position: relative;
      z-index: 2;
      width: 100%;
      display: grid;
      grid-template-columns: minmax(0, 640px) minmax(380px, 460px);
      justify-content: space-between;
      align-items: center;
      gap: clamp(32px, 5vw, 72px);
      padding-top: 92px;
      padding-bottom: 54px;
    }

    .hero__copy {
      position: relative;
      max-width: 610px;
    }

    .hero__copy::before {
      content: "";
      position: absolute;
      inset: -28px -22px -32px -26px;
      background:
        radial-gradient(
          circle at 28% 22%,
          rgba(143, 216, 255, 0.12) 0%,
          rgba(143, 216, 255, 0.06) 22%,
          rgba(0, 0, 0, 0) 60%
        ),
        radial-gradient(
          circle at 22% 70%,
          rgba(0, 0, 0, 0.62) 0%,
          rgba(0, 0, 0, 0.3) 45%,
          rgba(0, 0, 0, 0) 75%
        );
      filter: blur(10px);
      opacity: 0.9;
      pointer-events: none;
      z-index: -1;
    }

    .hero__copy > * {
      opacity: 0;
      transform: translateY(8px);
      will-change: transform, opacity;
      animation: heroFadeUp 620ms var(--out) forwards;
    }

    .hero__copy .hero__eyebrow {
      animation-delay: 40ms;
    }

    .hero__copy .hero__title {
      animation-delay: 90ms;
    }

    .hero__copy .hero__subtitle {
      animation-delay: 140ms;
    }

    .hero__copy .hero__stats {
      animation-delay: 190ms;
    }

    .hero__eyebrow {
      margin: 0 0 18px;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.88);
    }

    .hero__title {
      margin: 0;
      font-size: clamp(3rem, 5vw, 4.45rem);
      line-height: 0.96;
      letter-spacing: -0.065em;
      font-weight: 680;
      max-width: 14ch;
      text-wrap: balance;
    }

    .hero__subtitle {
      margin: 22px 0 0;
      max-width: 40ch;
      font-size: 1.02rem;
      line-height: 1.72;
      color: var(--text-soft);
    }

    .hero__stats {
      display: flex;
      gap: 12px;
      margin-top: 30px;
      flex-wrap: wrap;
    }

    .hero__stat {
      min-width: 112px;
      padding: 12px 14px;
      border-radius: 14px;
      border: 1px solid rgba(255, 255, 255, 0.085);
      background: linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.04) 0%,
        rgba(255, 255, 255, 0.02) 100%
      );
      box-shadow:
        0 16px 42px rgba(0, 0, 0, 0.22),
        0 1px 0 rgba(255, 255, 255, 0.055) inset;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .hero__stat strong {
      display: block;
      font-size: 1.5rem;
      line-height: 1;
      letter-spacing: -0.05em;
      font-variant-numeric: tabular-nums;
    }

    .hero__stat span {
      display: block;
      font-size: 0.72rem;
      color: var(--text-muted);
    }

    .form-card {
      width: 100%;
      padding: 26px;
      border-radius: 22px;
      border: 1px solid var(--surface-border);
      background: linear-gradient(
        180deg,
        rgba(12, 14, 20, 0.86) 0%,
        rgba(8, 10, 16, 0.9) 100%
      );
      box-shadow:
        0 24px 80px rgba(0, 0, 0, 0.44),
        0 0 0 1px rgba(255, 255, 255, 0.03) inset;
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      opacity: 0;
      transform: translateY(14px) scale(0.986);
      will-change: transform, opacity;
      animation: heroCardIn 700ms var(--out) 140ms forwards;
    }

    .form-card__head {
      margin-bottom: 18px;
    }

    .form-card__eyebrow {
      margin: 0 0 8px;
      font-size: 0.66rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .form-card__title {
      margin: 0;
      font-size: clamp(1.7rem, 2.2vw, 2.15rem);
      line-height: 1.04;
      letter-spacing: -0.045em;
      font-weight: 660;
    }

    .form-card__subtitle {
      margin: 8px 0 0;
      color: var(--text-soft);
      font-size: 0.92rem;
      line-height: 1.55;
    }

    .form {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .form__honeypot {
      position: absolute;
      left: -9999px;
      width: 1px;
      height: 1px;
      overflow: hidden;
    }

    .field {
      display: flex;
      flex-direction: column;
    }

    .field--full {
      grid-column: 1 / -1;
    }

    .field__label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
      font-size: 0.78rem;
      font-weight: 620;
      letter-spacing: 0.01em;
      color: rgba(255, 255, 255, 0.76);
    }

    .field__badge {
      padding: 2px 7px;
      border-radius: 999px;
      border: 1px solid var(--line);
      font-size: 0.6rem;
      color: var(--text-muted);
    }

    .field__input {
      width: 100%;
      height: 48px;
      border-radius: 14px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.055) 0%,
        rgba(255, 255, 255, 0.03) 100%
      );
      color: var(--text);
      padding: 0 15px;
      font-size: 0.94rem;
      outline: none;
      caret-color: var(--accent);
      transition:
        border-color 0.18s var(--out),
        box-shadow 0.18s var(--out),
        background 0.18s var(--out),
        transform 0.18s var(--out);
      box-shadow: 0 1px 0 rgba(255, 255, 255, 0.05) inset;
    }

    .field__input::placeholder {
      color: rgba(255, 255, 255, 0.32);
    }

    .field__input:hover {
      border-color: rgba(255, 255, 255, 0.17);
    }

    .field__input:focus-visible {
      border-color: rgba(143, 216, 255, 0.55);
      background: rgba(255, 255, 255, 0.055);
      box-shadow: 0 0 0 4px var(--accent-ring);
    }

    .dropdown {
      position: relative;
    }

    .dropdown__trigger {
      width: 100%;
      height: 48px;
      border-radius: 14px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.055) 0%,
        rgba(255, 255, 255, 0.03) 100%
      );
      color: var(--text);
      padding: 0 14px 0 15px;
      display: inline-flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      font-size: 0.94rem;
      line-height: 1;
      text-align: left;
      cursor: pointer;
      user-select: none;
      transition:
        border-color 0.18s var(--out),
        box-shadow 0.18s var(--out),
        background 0.18s var(--out),
        transform 0.18s var(--out);
      box-shadow: 0 1px 0 rgba(255, 255, 255, 0.05) inset;
    }

    .dropdown__trigger:hover {
      border-color: rgba(255, 255, 255, 0.17);
    }

    .dropdown__trigger:focus-visible {
      outline: none;
      border-color: rgba(143, 216, 255, 0.55);
      background: rgba(255, 255, 255, 0.055);
      box-shadow: 0 0 0 4px var(--accent-ring);
    }

    .dropdown[data-open="true"] .dropdown__trigger {
      border-color: rgba(143, 216, 255, 0.42);
      box-shadow:
        0 0 0 4px rgba(143, 216, 255, 0.09),
        0 1px 0 rgba(255, 255, 255, 0.05) inset;
    }

    .dropdown__value {
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .dropdown__value[data-placeholder="true"] {
      color: rgba(255, 255, 255, 0.32);
    }

    .dropdown__chevron {
      flex: 0 0 auto;
      color: rgba(255, 255, 255, 0.6);
      transition: transform 0.22s var(--out);
    }

    .dropdown[data-open="true"] .dropdown__chevron {
      transform: rotate(180deg);
    }

    .dropdown__panel {
      position: absolute;
      left: 0;
      right: 0;
      top: calc(100% + 10px);
      padding: 8px;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(9, 10, 14, 0.9);
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      box-shadow:
        0 28px 90px rgba(0, 0, 0, 0.55),
        0 0 0 1px rgba(255, 255, 255, 0.04) inset;
      transform: translateY(-6px);
      opacity: 0;
      pointer-events: none;
      z-index: 20;
      transition:
        opacity 0.16s var(--out),
        transform 0.16s var(--out);
    }

    .dropdown[data-open="true"] .dropdown__panel {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .dropdown__option {
      width: 100%;
      border: none;
      border-radius: 12px;
      padding: 12px 12px;
      background: transparent;
      color: rgba(255, 255, 255, 0.86);
      text-align: left;
      font-size: 0.92rem;
      line-height: 1.3;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      transition:
        background 0.16s var(--out),
        color 0.16s var(--out);
    }

    .dropdown__option::after {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--accent);
      box-shadow: 0 0 0 4px rgba(143, 216, 255, 0.12);
      opacity: 0;
      transform: scale(0.9);
      transition:
        opacity 0.16s var(--out),
        transform 0.16s var(--out);
      flex: 0 0 auto;
    }

    .dropdown__option:hover {
      background: rgba(255, 255, 255, 0.06);
      color: rgba(255, 255, 255, 0.95);
    }

    .dropdown__option:focus-visible {
      outline: none;
      background: rgba(143, 216, 255, 0.1);
    }

    .dropdown__option[aria-selected="true"] {
      background: rgba(255, 255, 255, 0.05);
    }

    .dropdown__option[aria-selected="true"]::after {
      opacity: 1;
      transform: scale(1);
    }

    .field__error {
      min-height: 1em;
      margin: 6px 0 0;
      font-size: 0.72rem;
      color: var(--danger);
    }

    .field[data-invalid="true"] .field__input {
      border-color: rgba(255, 154, 154, 0.55);
      box-shadow: 0 0 0 4px rgba(255, 154, 154, 0.08);
    }

    .field[data-invalid="true"] .dropdown__trigger {
      border-color: rgba(255, 154, 154, 0.55);
      box-shadow: 0 0 0 4px rgba(255, 154, 154, 0.08);
    }

    .btn-submit {
      grid-column: 1 / -1;
      height: 52px;
      margin-top: 2px;
      border: none;
      border-radius: 14px;
      background: linear-gradient(180deg, #79d0ff 0%, #55baf4 100%);
      color: #031019;
      font-size: 0.93rem;
      font-weight: 700;
      letter-spacing: -0.015em;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      cursor: pointer;
      transition:
        transform 0.22s var(--out),
        box-shadow 0.22s var(--out),
        opacity 0.18s var(--out),
        filter 0.18s var(--out);
      box-shadow:
        0 12px 28px rgba(85, 186, 244, 0.16),
        0 0 0 1px rgba(255, 255, 255, 0.1) inset;
    }

    .btn-submit:hover {
      transform: translateY(-1px);
      filter: brightness(1.02);
    }

    .btn-submit:active {
      transform: translateY(0px);
      filter: brightness(0.99);
    }

    .btn-submit:focus-visible {
      outline: none;
      box-shadow:
        0 12px 28px rgba(85, 186, 244, 0.16),
        0 0 0 1px rgba(255, 255, 255, 0.1) inset,
        0 0 0 4px rgba(143, 216, 255, 0.14);
    }

    .btn-submit:disabled {
      opacity: 0.6;
      cursor: wait;
      transform: none;
    }

    .form__legal {
      grid-column: 1 / -1;
      margin: 0;
      text-align: center;
      font-size: 0.73rem;
      color: var(--text-muted);
    }

    .form__status {
      grid-column: 1 / -1;
      padding: 12px 14px;
      border-radius: 14px;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.04);
      color: var(--text-soft);
      font-size: 0.84rem;
      line-height: 1.6;
    }

    .form__status[data-state="success"] {
      border-color: rgba(79, 219, 140, 0.22);
      background: rgba(79, 219, 140, 0.08);
      color: rgba(205, 255, 225, 0.96);
    }

    .form__status[data-state="error"] {
      border-color: rgba(255, 154, 154, 0.22);
      background: rgba(255, 154, 154, 0.08);
      color: rgba(255, 220, 220, 0.96);
    }

    #back-top {
      position: fixed;
      right: var(--back-top-right);
      bottom: var(--back-top-bottom);
      width: var(--back-top-size);
      height: var(--back-top-size);
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      text-decoration: none;
      color: #031019;
      background: var(--accent);
      box-shadow: 0 8px 24px rgba(143, 216, 255, 0.24);
      z-index: 990;
      opacity: 0;
      transform: translateY(8px) scale(0.9);
      transition:
        opacity 0.26s var(--out),
        transform 0.26s var(--spring),
        background 0.18s var(--out);
    }

    #back-top.visible {
      opacity: 1;
      transform: none;
    }

    @media (hover: hover) {
      #back-top:hover {
        background: var(--accent-strong);
        transform: translateY(-2px) scale(1.04);
      }
    }

    @media (max-width: 1100px) {
      .hero__inner {
        grid-template-columns: minmax(0, 1fr) minmax(360px, 430px);
        gap: 28px;
      }

      .hero__title {
        font-size: clamp(2.8rem, 4.5vw, 4rem);
      }
    }

    @media (max-width: 920px) {
      .hero {
        min-height: auto;
      }

      .hero__inner {
        grid-template-columns: 1fr;
        align-items: start;
        justify-content: start;
        padding-top: 92px;
        padding-bottom: 56px;
        gap: 24px;
      }

      .hero__copy {
        max-width: 620px;
      }

      .hero__title {
        max-width: none;
      }

      .form-card {
        max-width: 560px;
      }
    }

    @media (max-width: 640px) {
      .container {
        width: min(100% - 28px, 1180px);
      }

      .hero__image {
        object-position: 74% center;
      }

      .hero__overlay {
        background:
          linear-gradient(
            180deg,
            rgba(2, 5, 12, 0.64) 0%,
            rgba(2, 5, 12, 0.5) 24%,
            rgba(2, 5, 12, 0.7) 100%
          ),
          linear-gradient(
            90deg,
            rgba(2, 5, 12, 0.52) 0%,
            rgba(2, 5, 12, 0.18) 100%
          );
      }

      .hero__inner {
        padding-top: 84px;
        padding-bottom: 42px;
      }

      .hero__title {
        font-size: clamp(2.35rem, 11vw, 3.2rem);
      }

      .hero__subtitle {
        max-width: 28ch;
        font-size: 0.95rem;
      }

      .hero__stats {
        gap: 10px;
      }

      .hero__stat {
        flex: 1 1 calc(50% - 10px);
        min-width: 0;
      }

      .form-card {
        padding: 18px;
        border-radius: 18px;
      }

      .form {
        grid-template-columns: 1fr;
        gap: 12px;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero__copy > * {
        animation: none !important;
        opacity: 1 !important;
        transform: none !important;
      }

      .hero__image {
        animation: none !important;
        transform: scale(1.03) !important;
      }

      .form-card {
        animation: none !important;
        opacity: 1 !important;
        transform: none !important;
      }

      .field__input {
        transition: none !important;
      }

      .dropdown__trigger,
      .dropdown__panel,
      .dropdown__option,
      .dropdown__chevron {
        transition: none !important;
      }

      .btn-submit,
      #back-top {
        transition: none !important;
      }
    }

    @keyframes heroFadeUp {
      from {
        opacity: 0;
        transform: translateY(8px);
      }
      to {
        opacity: 1;
        transform: none;
      }
    }

    @keyframes heroCardIn {
      from {
        opacity: 0;
        transform: translateY(14px) scale(0.986);
      }
      to {
        opacity: 1;
        transform: none;
      }
    }

    @keyframes heroImageIn {
      from {
        transform: scale(1.06);
      }
      to {
        transform: scale(1.03);
      }
    }
  </style>

  <script is:inline>
    (() => {
      const form = document.getElementById("corpQuoteForm");
      const status = document.getElementById("corpQuoteStatus");

      if (
        !(form instanceof HTMLFormElement) ||
        !(status instanceof HTMLElement)
      ) {
        return;
      }

      const nameEl = document.getElementById("corpName");
      const phoneEl = document.getElementById("corpPhone");
      const emailEl = document.getElementById("corpEmail");
      const consumptionEl = document.getElementById("corpConsumption");
      const consumptionTrigger = document.getElementById(
        "corpConsumptionTrigger",
      );
      const consumptionValue = document.getElementById("corpConsumptionValue");
      const consumptionListbox = document.getElementById(
        "corpConsumptionListbox",
      );

      const dropdownRoot = consumptionTrigger?.closest(".dropdown");
      const dropdownOptions = Array.from(
        consumptionListbox?.querySelectorAll("[role='option']") ?? [],
      );
      let dropdownCloseTimer = 0;
      const reduceMotion =
        typeof window !== "undefined" &&
        window.matchMedia?.("(prefers-reduced-motion: reduce)")?.matches;

      const fieldRoot = (el) => el?.closest(".field");
      const errorEl = (el) => document.getElementById(`${el.id}Error`);

      const setInvalid = (el, message) => {
        if (!(el instanceof HTMLElement)) return;
        const root = fieldRoot(el);
        const error = errorEl(el);

        if (root) root.dataset.invalid = "true";
        el.setAttribute("aria-invalid", "true");

        if (error) {
          error.textContent = message || "";
          error.setAttribute("aria-hidden", message ? "false" : "true");
        }
      };

      const clearInvalid = (el) => {
        if (!(el instanceof HTMLElement)) return;
        const root = fieldRoot(el);
        const error = errorEl(el);

        if (root) delete root.dataset.invalid;
        el.removeAttribute("aria-invalid");

        if (error) {
          error.textContent = "";
          error.setAttribute("aria-hidden", "true");
        }
      };

      const validate = () => {
        let firstInvalid = null;

        [nameEl, phoneEl, emailEl, consumptionEl].forEach((el) => {
          if (
            el instanceof HTMLInputElement ||
            el instanceof HTMLSelectElement
          ) {
            clearInvalid(el);
          }
        });

        if (nameEl instanceof HTMLInputElement && !nameEl.value.trim()) {
          setInvalid(nameEl, "Indica tu nombre o empresa.");
          firstInvalid ??= nameEl;
        }

        if (phoneEl instanceof HTMLInputElement) {
          const value = phoneEl.value.trim();

          if (!value) {
            setInvalid(phoneEl, "Indica un teléfono de contacto.");
            firstInvalid ??= phoneEl;
          } else if (!/^[0-9+\s()\-]{8,}$/.test(value)) {
            setInvalid(phoneEl, "Ingresa un teléfono válido.");
            firstInvalid ??= phoneEl;
          }
        }

        if (emailEl instanceof HTMLInputElement) {
          const value = emailEl.value.trim();
          if (value && !emailEl.checkValidity()) {
            setInvalid(emailEl, "Revisa el formato del correo.");
            firstInvalid ??= emailEl;
          }
        }

        if (
          (consumptionEl instanceof HTMLSelectElement ||
            consumptionEl instanceof HTMLInputElement) &&
          !consumptionEl.value
        ) {
          setInvalid(consumptionEl, "Selecciona tu consumo estimado.");
          firstInvalid ??= consumptionTrigger ?? consumptionEl;
        }

        if (firstInvalid instanceof HTMLElement) {
          firstInvalid.focus();
          return false;
        }

        return true;
      };

      [nameEl, phoneEl, emailEl, consumptionEl].forEach((el) => {
        if (
          !(el instanceof HTMLInputElement) &&
          !(el instanceof HTMLSelectElement)
        )
          return;
        el.addEventListener("input", () => clearInvalid(el), { passive: true });
        el.addEventListener("change", () => clearInvalid(el), {
          passive: true,
        });
      });

      const closeDropdown = ({ focusTrigger } = {}) => {
        if (!(dropdownRoot instanceof HTMLElement)) return;
        dropdownRoot.dataset.open = "false";
        if (dropdownCloseTimer) window.clearTimeout(dropdownCloseTimer);
        if (consumptionListbox instanceof HTMLElement) {
          dropdownCloseTimer = window.setTimeout(
            () => {
              if (dropdownRoot.dataset.open === "true") return;
              consumptionListbox.hidden = true;
            },
            reduceMotion ? 0 : 170,
          );
        }
        if (consumptionTrigger instanceof HTMLElement)
          consumptionTrigger.setAttribute("aria-expanded", "false");
        if (focusTrigger && consumptionTrigger instanceof HTMLElement)
          consumptionTrigger.focus();
      };

      const openDropdown = ({ focusSelected } = {}) => {
        if (!(dropdownRoot instanceof HTMLElement)) return;
        if (dropdownCloseTimer) window.clearTimeout(dropdownCloseTimer);
        if (consumptionListbox instanceof HTMLElement)
          consumptionListbox.hidden = false;
        if (consumptionTrigger instanceof HTMLElement)
          consumptionTrigger.setAttribute("aria-expanded", "true");
        window.requestAnimationFrame(() => {
          if (dropdownRoot instanceof HTMLElement) {
            dropdownRoot.dataset.open = "true";
          }
        });

        if (!focusSelected) return;
        const selectedIdx = dropdownOptions.findIndex(
          (opt) => opt.getAttribute("aria-selected") === "true",
        );
        const target =
          dropdownOptions[selectedIdx >= 0 ? selectedIdx : 0] ?? null;
        if (target instanceof HTMLElement) target.focus();
      };

      const setConsumptionValue = (value) => {
        if (!(consumptionEl instanceof HTMLInputElement)) return;

        const option = dropdownOptions.find(
          (opt) => opt instanceof HTMLElement && opt.dataset.value === value,
        );
        const label = option?.textContent?.trim() || "Selecciona una opción";

        dropdownOptions.forEach((opt) => {
          if (!(opt instanceof HTMLElement)) return;
          opt.setAttribute(
            "aria-selected",
            opt.dataset.value === value ? "true" : "false",
          );
        });

        consumptionEl.value = value || "";
        consumptionEl.dispatchEvent(new Event("input", { bubbles: true }));
        consumptionEl.dispatchEvent(new Event("change", { bubbles: true }));

        if (consumptionValue instanceof HTMLElement) {
          consumptionValue.textContent = value
            ? label
            : "Selecciona una opción";
          if (value) {
            consumptionValue.removeAttribute("data-placeholder");
          } else {
            consumptionValue.dataset.placeholder = "true";
          }
        }
      };

      if (
        consumptionEl instanceof HTMLInputElement &&
        consumptionTrigger instanceof HTMLButtonElement &&
        consumptionListbox instanceof HTMLElement &&
        dropdownRoot instanceof HTMLElement &&
        dropdownOptions.length
      ) {
        const syncFromInput = () => setConsumptionValue(consumptionEl.value);
        syncFromInput();

        dropdownOptions.forEach((opt) => {
          if (!(opt instanceof HTMLButtonElement)) return;
          opt.addEventListener(
            "click",
            () => {
              setConsumptionValue(opt.dataset.value || "");
              closeDropdown({ focusTrigger: true });
            },
            { passive: true },
          );

          opt.addEventListener("keydown", (event) => {
            const key = event.key;
            const currentIndex = dropdownOptions.indexOf(opt);

            if (key === "Escape") {
              event.preventDefault();
              closeDropdown({ focusTrigger: true });
              return;
            }

            if (key === "Tab") {
              closeDropdown({ focusTrigger: false });
              return;
            }

            if (key === "ArrowDown" || key === "ArrowUp") {
              event.preventDefault();
              const nextIndex =
                key === "ArrowDown"
                  ? Math.min(dropdownOptions.length - 1, currentIndex + 1)
                  : Math.max(0, currentIndex - 1);
              const next = dropdownOptions[nextIndex];
              if (next instanceof HTMLElement) next.focus();
              return;
            }

            if (key === "Home" || key === "End") {
              event.preventDefault();
              const target =
                key === "Home"
                  ? dropdownOptions[0]
                  : dropdownOptions[dropdownOptions.length - 1];
              if (target instanceof HTMLElement) target.focus();
              return;
            }

            if (key === "Enter" || key === " ") {
              event.preventDefault();
              setConsumptionValue(opt.dataset.value || "");
              closeDropdown({ focusTrigger: true });
            }
          });
        });

        consumptionTrigger.addEventListener("click", () => {
          const isOpen = dropdownRoot.dataset.open === "true";
          if (isOpen) {
            closeDropdown({ focusTrigger: false });
          } else {
            openDropdown({ focusSelected: true });
          }
        });

        consumptionTrigger.addEventListener("keydown", (event) => {
          const key = event.key;
          const isOpen = dropdownRoot.dataset.open === "true";

          if (key === "Escape" && isOpen) {
            event.preventDefault();
            closeDropdown({ focusTrigger: true });
            return;
          }

          if (key === "ArrowDown" || key === "ArrowUp") {
            event.preventDefault();
            openDropdown({ focusSelected: false });
            const selectedIdx = dropdownOptions.findIndex(
              (opt) => opt.getAttribute("aria-selected") === "true",
            );
            const startIdx =
              selectedIdx >= 0
                ? selectedIdx
                : key === "ArrowUp"
                  ? dropdownOptions.length - 1
                  : 0;
            const target = dropdownOptions[startIdx];
            if (target instanceof HTMLElement) target.focus();
            return;
          }

          if (key === "Enter" || key === " ") {
            event.preventDefault();
            if (isOpen) {
              closeDropdown({ focusTrigger: true });
            } else {
              openDropdown({ focusSelected: true });
            }
          }
        });

        document.addEventListener(
          "pointerdown",
          (event) => {
            if (dropdownRoot.dataset.open !== "true") return;
            if (!(event.target instanceof Node)) return;
            if (dropdownRoot.contains(event.target)) return;
            closeDropdown({ focusTrigger: false });
          },
          { passive: true },
        );

        form.addEventListener(
          "reset",
          () => {
            queueMicrotask(() => {
              setConsumptionValue(consumptionEl.value);
              closeDropdown({ focusTrigger: false });
            });
          },
          { passive: true },
        );
      }

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        status.hidden = true;
        status.textContent = "";
        status.dataset.state = "";

        if (!validate()) return;

        const submitBtn = form.querySelector("button[type='submit']");
        if (submitBtn instanceof HTMLButtonElement) submitBtn.disabled = true;

        form.setAttribute("aria-busy", "true");

        try {
          const response = await fetch(form.action, {
            method: "POST",
            body: new FormData(form),
          });

          const payload = await response.json().catch(() => null);

          const message =
            payload?.message ??
            (response.ok
              ? "Gracias. Hemos recibido tu solicitud y un asesor te contactará en breve."
              : "No fue posible enviar tu solicitud. Intenta nuevamente en unos momentos.");

          status.textContent = message;
          status.dataset.state = response.ok ? "success" : "error";
          status.hidden = false;

          if (response.ok) {
            form.reset();
          }
        } catch {
          status.textContent =
            "No fue posible enviar tu solicitud. Intenta nuevamente en unos momentos.";
          status.dataset.state = "error";
          status.hidden = false;
        } finally {
          form.removeAttribute("aria-busy");
          const submitBtnEnd = form.querySelector("button[type='submit']");
          if (submitBtnEnd instanceof HTMLButtonElement)
            submitBtnEnd.disabled = false;
        }
      });

      const backTop = document.getElementById("back-top");

      if (backTop instanceof HTMLElement) {
        const onScroll = () => {
          backTop.classList.toggle("visible", window.scrollY > 300);
        };

        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });
      }
    })();
  </script>
</BaseLayout>
