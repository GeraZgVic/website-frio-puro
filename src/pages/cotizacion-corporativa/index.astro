---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/sections/Header.astro";
import Footer from "../../components/sections/Footer.astro";
import WhatsAppFloat from "../../components/ui/WhatsAppFloat.astro";
import Cursor from "../../components/Cursor.astro";
import SiteScripts from "../../components/SiteScripts.astro";
---

<BaseLayout
  title="Solicitar cotización corporativa | Frío Puro"
  description="Solicitud de cotización corporativa para suministro comercial de alto volumen."
  ogTitle="Solicitar cotización corporativa | Frío Puro"
  ogDescription="Stock permanente y entregas programadas para operación comercial."
>
  <Cursor />
  <Header />

  <script is:inline>
    document.documentElement.classList.add("js");
  </script>

  <main class="page">
    <section id="inicio" class="hero" aria-labelledby="quoteTitle">
      <div class="hero__bg" aria-hidden="true">
        <img
          src="/images/ImaForm.png"
          alt=""
          class="hero-shell__media-image"
          width="1600"
          height="900"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
        <div class="hero-shell__media-overlay" aria-hidden="true"></div>
      </div>
      <div id="formulario-corporativo" class="container hero__inner">
        <div class="hero-shell">
          <section
            class="hero-shell__media"
            aria-label="Presentación comercial"
          >
            <div class="hero__copy">
              <p class="hero__eyebrow">FRÍO PURO · CORPORATIVO</p>

              <div class="hero__title-wrap">
                <span class="hero__kicker">
                  Abasto premium y continuidad operativa
                </span>

                <h1 id="quoteTitle" class="hero__title">
                  <span class="hero__title-line hero__title-line--soft">
                    Suministro de hielo
                  </span>
                  <span class="hero__title-line hero__title-line--accent">
                    para operaciones comerciales
                  </span>
                </h1>
              </div>

              <p class="hero__subtitle">
                Soluciones de suministro para hoteles, restaurantes, eventos y
                operaciones que requieren disponibilidad constante, atención
                ágil y entregas programadas.
              </p>

              <div class="hero__stats" aria-label="Indicadores de confianza">
                <div class="hero__stat">
                  <strong>&lt; 24h</strong>
                  <span>Respuesta comercial</span>
                </div>
                <div class="hero__stat">
                  <strong>Cobertura</strong>
                  <span>Atención en Tabasco</span>
                </div>
              </div>
            </div>
          </section>

          <aside
            class="hero-shell__form"
            role="region"
            aria-label="Formulario de cotización corporativa"
          >
            <div class="form-card">
              <div class="form-card__chrome" aria-hidden="true">
                <span class="form-card__chrome-orb form-card__chrome-orb--a"
                ></span>
                <span class="form-card__chrome-orb form-card__chrome-orb--b"
                ></span>
              </div>

              <div class="form-card__head">
                <p class="form-card__eyebrow">SOLICITUD CORPORATIVA</p>
                <h2 class="form-card__title">
                  Recibe tu cotización de suministro
                </h2>
                <p class="form-card__subtitle">
                  Te compartimos precios, disponibilidad y tiempo de entrega
                  para tu operación.
                </p>
              </div>

              <form
                id="corpQuoteForm"
                class="form"
                method="post"
                action="/api/cotizacion-corporativa"
                novalidate
              >
                <div class="form__honeypot" aria-hidden="true">
                  <label for="companyWebsite">Sitio web</label>
                  <input
                    id="companyWebsite"
                    name="company_website"
                    type="text"
                    tabindex="-1"
                    autocomplete="off"
                  />
                </div>

                <div class="field field--full">
                  <label class="field__label" for="corpName"
                    >Nombre o negocio</label
                  >
                  <input
                    class="field__input"
                    id="corpName"
                    name="name_company"
                    type="text"
                    autocomplete="organization"
                    placeholder="Hotel Vista Mar"
                    required
                    aria-describedby="corpNameError"
                  />
                  <p
                    class="field__error"
                    id="corpNameError"
                    role="alert"
                    aria-hidden="true"
                  >
                  </p>
                </div>

                <div class="field">
                  <label class="field__label" for="corpPhone">
                    Teléfono de contacto
                  </label>
                  <input
                    class="field__input"
                    id="corpPhone"
                    name="phone"
                    type="tel"
                    inputmode="tel"
                    autocomplete="tel"
                    placeholder="993 123 4567"
                    required
                    aria-describedby="corpPhoneError"
                  />
                  <p
                    class="field__error"
                    id="corpPhoneError"
                    role="alert"
                    aria-hidden="true"
                  >
                  </p>
                </div>

                <div class="field">
                  <label class="field__label" for="corpEmail">
                    Correo electrónico <span class="field__badge">opcional</span
                    >
                  </label>
                  <input
                    class="field__input"
                    id="corpEmail"
                    name="email"
                    type="email"
                    autocomplete="email"
                    placeholder="contacto@empresa.com"
                    aria-describedby="corpEmailError"
                  />
                  <p
                    class="field__error"
                    id="corpEmailError"
                    role="alert"
                    aria-hidden="true"
                  >
                  </p>
                </div>

                <div class="field field--full">
                  <label class="field__label" for="corpConsumptionTrigger">
                    ¿Cuánto hielo necesitas?
                  </label>

                  <div class="dropdown" data-open="false">
                    <button
                      class="dropdown__trigger"
                      id="corpConsumptionTrigger"
                      type="button"
                      aria-haspopup="listbox"
                      aria-expanded="false"
                      aria-controls="corpConsumptionListbox"
                      aria-describedby="corpConsumptionError"
                    >
                      <span
                        id="corpConsumptionValue"
                        class="dropdown__value"
                        data-placeholder="true"
                      >
                        Selecciona una opción
                      </span>

                      <svg
                        class="dropdown__chevron"
                        width="16"
                        height="16"
                        viewBox="0 0 16 16"
                        fill="none"
                        aria-hidden="true"
                      >
                        <path
                          d="M4 6L8 10L12 6"
                          stroke="currentColor"
                          stroke-width="1.7"
                          stroke-linecap="round"
                          stroke-linejoin="round"></path>
                      </svg>
                    </button>

                    <input
                      id="corpConsumption"
                      name="consumption"
                      type="hidden"
                      value=""
                      aria-describedby="corpConsumptionError"
                    />

                    <div
                      class="dropdown__panel"
                      id="corpConsumptionListbox"
                      role="listbox"
                      aria-label="Consumo estimado"
                      hidden
                    >
                      <button
                        class="dropdown__option"
                        type="button"
                        role="option"
                        data-value="lt_50"
                        aria-selected="false"
                      >
                        Menos de 50 bolsas / semana
                      </button>
                      <button
                        class="dropdown__option"
                        type="button"
                        role="option"
                        data-value="50_150"
                        aria-selected="false"
                      >
                        50 – 150 bolsas / semana
                      </button>
                      <button
                        class="dropdown__option"
                        type="button"
                        role="option"
                        data-value="gt_150"
                        aria-selected="false"
                      >
                        Más de 150 bolsas / semana
                      </button>
                    </div>
                  </div>

                  <p
                    class="field__error"
                    id="corpConsumptionError"
                    role="alert"
                    aria-hidden="true"
                  >
                  </p>
                </div>

                <button class="btn-submit" type="submit">
                  <span>Solicitar cotización</span>
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 16 16"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path
                      d="M3 8H13M13 8L9 4M13 8L9 12"
                      stroke="currentColor"
                      stroke-width="1.7"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </button>

                <p class="form__legal">
                  Sin compromiso · Te contactamos con información comercial
                  clara
                </p>

                <div
                  id="corpQuoteStatus"
                  class="form__status"
                  role="status"
                  aria-live="polite"
                  hidden
                >
                </div>
              </form>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <Footer />
  </main>

  <WhatsAppFloat />

  <a href="#inicio" id="back-top" aria-label="Volver arriba">
    <svg
      width="14"
      height="14"
      viewBox="0 0 14 14"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M7 11V3M3.5 6.5L7 3L10.5 6.5"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </a>

  <SiteScripts />

  <style>
    :global(:root) {
      --back-top-size: 42px;
      --back-top-right: 28px;
      --back-top-bottom: 28px;

      --bg: #08101c;
      --text: #0b1220;
      --line: rgba(255, 255, 255, 0.12);
      --accent: #41abe2;
      --accent-strong: #2c98d3;
      --accent-soft: #8fd8ff;
      --danger: #ff9a9a;

      --out: cubic-bezier(0.22, 0.61, 0.36, 1);
      --spring: cubic-bezier(0.34, 1.52, 0.64, 1);
    }

    * {
      box-sizing: border-box;
    }

    .page {
      min-height: 100vh;
      background:
        radial-gradient(
          1000px 600px at 16% -10%,
          rgba(65, 171, 226, 0.12) 0%,
          rgba(65, 171, 226, 0.03) 46%,
          transparent 70%
        ),
        radial-gradient(
          1200px 760px at 110% 15%,
          rgba(255, 255, 255, 0.08) 0%,
          rgba(255, 255, 255, 0.02) 40%,
          transparent 70%
        ),
        linear-gradient(180deg, #0a1220 0%, #0c1525 46%, #0a111d 100%);
      color: #fff;
    }

    .container {
      width: min(1280px, calc(100% - 56px));
      margin: 0 auto;
    }

    .hero {
      position: relative;
      min-height: 100svh;
      display: flex;
      align-items: center;
      overflow: hidden;
      isolation: isolate;
      padding: 36px 0 28px;
      --hero-mx: 0px;
      --hero-my: 0px;
      --hero-scroll: 0px;
    }

    .hero__bg {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      overflow: hidden;
    }

    .hero::before {
      display: none;
    }

    .hero__inner {
      position: relative;
      z-index: 2;
      width: 100%;
      padding-top: 104px;
      padding-bottom: 54px;
    }

    #formulario-corporativo {
      scroll-margin-top: 120px;
    }

    .hero-shell {
      position: relative;
      display: grid;
      grid-template-columns: minmax(0, 1.18fr) minmax(390px, 470px);
      min-height: clamp(640px, 82vh, 760px);
      border-radius: 34px;
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.14);
      background:
        linear-gradient(
          135deg,
          rgba(255, 255, 255, 0.08) 0%,
          rgba(255, 255, 255, 0.02) 100%
        ),
        linear-gradient(145deg, rgba(12, 22, 40, 0.62), rgba(8, 16, 30, 0.78));
      backdrop-filter: blur(10px) saturate(1.14);
      -webkit-backdrop-filter: blur(10) saturate(1.14);
      box-shadow:
        0 45px 140px rgba(0, 0, 0, 0.45),
        0 12px 36px rgba(0, 0, 0, 0.28),
        inset 0 1px 0 rgba(255, 255, 255, 0.15),
        inset 0 -1px 0 rgba(255, 255, 255, 0.04);
      isolation: isolate;
    }

    .hero-shell::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.08) 0%,
          rgba(255, 255, 255, 0.02) 18%,
          transparent 36%
        ),
        radial-gradient(
          560px 220px at 18% 0%,
          rgba(255, 255, 255, 0.18) 0%,
          transparent 62%
        ),
        radial-gradient(
          460px 280px at 84% 100%,
          rgba(65, 171, 226, 0.08) 0%,
          transparent 70%
        );
      z-index: 0;
    }

    .hero-shell::after {
      content: "";
      position: absolute;
      top: 18px;
      bottom: 18px;
      right: min(470px, 37.2%);
      width: 1px;
      background: linear-gradient(
        180deg,
        rgba(255, 255, 255, 0) 0%,
        rgba(255, 255, 255, 0.14) 16%,
        rgba(143, 216, 255, 0.22) 50%,
        rgba(255, 255, 255, 0.12) 84%,
        rgba(255, 255, 255, 0) 100%
      );
      box-shadow: 0 0 24px rgba(143, 216, 255, 0.14);
      z-index: 1;
      pointer-events: none;
    }

    .hero-shell__media,
    .hero-shell__form {
      position: relative;
      z-index: 2;
      min-width: 0;
    }

    .hero-shell__media {
      display: flex;
      align-items: flex-start;
      min-height: 100%;
      overflow: visible;
    }

    .hero-shell__media-image-wrap,
    .hero-shell__media-image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .hero-shell__media-image-wrap {
      z-index: 0;
    }

    .hero-shell__media-image {
      object-fit: cover;
      object-position: 62% center;
      z-index: 0;
      filter: brightness(1) contrast(1) saturate(1);
      transform: translate3d(
          calc(var(--hero-mx) * 0.55),
          calc(var(--hero-my) * 0.32 + var(--hero-scroll) * 0.9),
          0
        )
        scale(1.06);
      will-change: transform, filter;
      transition: filter 900ms var(--out);
    }

    .hero-shell__media-overlay {
      display: none;
    }

    .hero__copy {
      position: relative;
      z-index: 3;
      max-width: 700px;
      font-family: "Barlow", sans-serif;
      padding: 6px 0 0;
    }

    .hero__copy :is(p, span, strong) {
      font-family: inherit;
    }

    .hero__eyebrow {
      margin: 0 0 18px;
      font-family: "Barlow Condensed", sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.82);
      text-shadow: 0 8px 20px rgba(0, 0, 0, 0.34);
    }

    .hero__title-wrap {
      display: grid;
      gap: 20px;
    }

    .hero__kicker {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      width: fit-content;
      padding: 7px 13px;
      border-radius: 999px;
      border: 1px solid rgba(143, 216, 255, 0.18);
      background: linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.09),
        rgba(255, 255, 255, 0.03)
      );
      backdrop-filter: blur(12px) saturate(1.08);
      -webkit-backdrop-filter: blur(12px) saturate(1.08);
      color: rgba(248, 251, 255, 0.95);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      box-shadow:
        0 12px 28px rgba(0, 0, 0, 0.12),
        inset 0 1px 0 rgba(255, 255, 255, 0.08);
    }

    .hero__title {
      margin: 0;
      display: grid;
      gap: 12px;
      font-family: "Barlow Condensed", sans-serif;
      line-height: 0.88;
      letter-spacing: -0.04em;
      font-weight: 720;
      text-transform: uppercase;
      max-width: 680px;
      text-wrap: balance;
    }

    .hero__title-line {
      display: block;
    }

    .hero__title-line--soft {
      font-size: clamp(3rem, 5vw, 5.2rem);
      color: #ffffff;
      text-shadow:
        0 18px 38px rgba(0, 0, 0, 0.38),
        0 2px 0 rgba(255, 255, 255, 0.06);
    }

    .hero__title-line--accent {
      font-size: clamp(1.98rem, 3.08vw, 2.82rem);
      color: rgba(248, 251, 255, 0.96);
      letter-spacing: -0.022em;
      font-weight: 600;
      text-shadow:
        0 12px 28px rgba(0, 0, 0, 0.32),
        0 1px 0 rgba(255, 255, 255, 0.04);
    }

    .hero__subtitle {
      margin: 34px 0 0;
      max-width: 43ch;
      font-size: 1.05rem;
      line-height: 1.84;
      color: rgba(245, 248, 252, 0.92);
      text-shadow: 0 10px 26px rgba(0, 0, 0, 0.28);
      text-wrap: balance;
    }

    .hero__stats {
      display: flex;
      gap: 12px;
      margin-top: 38px;
      flex-wrap: wrap;
    }

    .hero__stat {
      min-width: 136px;
      padding: 13px 14px;
      border-radius: 16px;
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.11) 0%,
          rgba(255, 255, 255, 0.03) 100%
        ),
        rgba(255, 255, 255, 0.025);
      border: 1px solid rgba(255, 255, 255, 0.12);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      display: flex;
      flex-direction: column;
      gap: 6px;
      box-shadow:
        0 1px 0 rgba(255, 255, 255, 0.06) inset,
        0 12px 28px rgba(0, 0, 0, 0.14);
    }

    .hero__stat strong {
      display: block;
      font-family: "Barlow Condensed", sans-serif;
      color: #ffffff;
      font-size: 1.66rem;
      line-height: 1;
      letter-spacing: -0.05em;
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }

    .hero__stat span {
      display: block;
      font-size: 0.74rem;
      color: rgba(255, 255, 255, 0.74);
    }

    .hero-shell__form {
      display: flex;
      align-items: stretch;
      min-height: 100%;
      padding: 14px;
      background: linear-gradient(
        180deg,
        rgba(6, 12, 22, 0.28) 0%,
        rgba(6, 12, 22, 0.18) 100%
      );
    }

    .form-card {
      --text: #ffffff;
      --text-soft: rgba(255, 255, 255, 0.8);
      --text-muted: rgba(255, 255, 255, 0.6);
      --line: rgba(255, 255, 255, 0.12);
      --accent: #8fd8ff;
      --accent-strong: #bde9ff;
      --focus: #2fa4ff;
      --danger: #ff9a9a;

      width: 100%;
      position: relative;
      isolation: isolate;
      padding: 30px 28px;
      border-radius: 24px;
      color: var(--text);
      font-family: "Barlow", sans-serif;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background:
        linear-gradient(
          145deg,
          rgba(17, 28, 48, 0.76) 0%,
          rgba(10, 18, 34, 0.84) 100%
        ),
        rgba(9, 16, 28, 0.58);
      backdrop-filter: blur(22px) saturate(1.25);
      -webkit-backdrop-filter: blur(22px) saturate(1.25);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.14),
        inset 0 -1px 0 rgba(255, 255, 255, 0.04),
        0 18px 42px rgba(0, 0, 0, 0.28);
    }

    .form-card :is(p, span, label, input, button, textarea, select) {
      font-family: inherit;
    }

    .form-card::before {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background:
        radial-gradient(
          600px 200px at 20% 0%,
          rgba(255, 255, 255, 0.18),
          transparent 60%
        ),
        radial-gradient(
          400px 220px at 82% 100%,
          rgba(143, 216, 255, 0.08),
          transparent 70%
        );
      opacity: 0.72;
      pointer-events: none;
      z-index: 0;
    }

    .form-card::after {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      background: linear-gradient(
        120deg,
        transparent 20%,
        rgba(255, 255, 255, 0.06),
        transparent 80%
      );
      opacity: 0.42;
      pointer-events: none;
      z-index: 0;
    }

    .form-card__chrome {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      overflow: hidden;
      border-radius: inherit;
    }

    .form-card__chrome-orb {
      position: absolute;
      border-radius: 999px;
      filter: blur(12px);
      opacity: 0.24;
    }

    .form-card__chrome-orb--a {
      width: 180px;
      height: 180px;
      top: -54px;
      right: -36px;
      background: rgba(65, 171, 226, 0.18);
    }

    .form-card__chrome-orb--b {
      width: 120px;
      height: 120px;
      bottom: -32px;
      left: -24px;
      background: rgba(255, 255, 255, 0.07);
    }

    .form-card__head,
    .form-card .form {
      position: relative;
      z-index: 1;
    }

    .form-card__head {
      margin-bottom: 28px;
    }

    .form-card__eyebrow {
      margin: 0 0 10px;
      font-family: "Barlow Condensed", sans-serif;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .form-card__title {
      margin: 0;
      font-family: "Barlow Condensed", sans-serif;
      font-size: clamp(1.82rem, 2.18vw, 2.14rem);
      line-height: 1.02;
      letter-spacing: -0.04em;
      font-weight: 600;
      text-wrap: balance;
      color: #ffffff;
      max-width: 12ch;
    }

    .form-card__subtitle {
      margin: 14px 0 0;
      color: var(--text-soft);
      font-size: 0.94rem;
      line-height: 1.7;
      max-width: 34ch;
    }

    .form {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px 14px;
    }

    .form__honeypot {
      position: absolute;
      left: -9999px;
      width: 1px;
      height: 1px;
      overflow: hidden;
    }

    .field {
      display: flex;
      flex-direction: column;
      position: relative;
      z-index: 0;
    }

    .field[data-dropdown-open="true"] {
      z-index: 100;
    }

    .field--full {
      grid-column: 1 / -1;
    }

    .field__label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 9px;
      font-size: 0.79rem;
      font-weight: 620;
      letter-spacing: 0.015em;
      color: rgba(255, 255, 255, 0.9);
    }

    .field__badge {
      padding: 2px 7px;
      border-radius: 999px;
      border: 1px solid var(--line);
      font-size: 0.6rem;
      color: rgba(255, 255, 255, 0.62);
      background: rgba(10, 16, 28, 0.18);
    }

    .field__input {
      width: 100%;
      height: 52px;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.08),
