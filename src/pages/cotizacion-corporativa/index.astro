    .field__badge {
      padding: 2px 6px;
      border-radius: 999px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      font-size: 0.6rem;
      color: rgba(255, 255, 255, 0.56);
      background: rgba(255, 255, 255, 0.06);
    }

    .field__input {
      width: 100%;
      height: 48px;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.09),
          rgba(255, 255, 255, 0.025)
        ),
        rgba(8, 14, 26, 0.22);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      color: var(--text);
      padding: 0 15px;
      font-size: 0.95rem;
      outline: none;
      caret-color: var(--accent);
      transition:
        border-color 160ms cubic-bezier(0.22, 1, 0.36, 1),
        box-shadow 160ms cubic-bezier(0.22, 1, 0.36, 1),
        background 160ms cubic-bezier(0.22, 1, 0.36, 1),
        transform 160ms cubic-bezier(0.22, 1, 0.36, 1);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.1),
        0 2px 6px rgba(0, 0, 0, 0.16);
    }

    .field__input::placeholder {
      color: rgba(255, 255, 255, 0.56);
    }

    .field__input:hover {
      border-color: rgba(255, 255, 255, 0.18);
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.1) 0%,
          rgba(255, 255, 255, 0.035) 100%
        ),
        rgba(8, 14, 26, 0.24);
    }

    .field__input:focus-visible {
      border-color: rgba(143, 216, 255, 0.46);
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.11),
          rgba(255, 255, 255, 0.045)
        ),
        rgba(8, 14, 26, 0.26);
      box-shadow:
        0 0 0 2px rgba(143, 216, 255, 0.16),
        0 6px 18px rgba(0, 0, 0, 0.24),
        inset 0 1px 0 rgba(255, 255, 255, 0.14);
    }

    .dropdown {
      position: relative;
      z-index: 0;
    }

    .dropdown[data-open="true"] {
      z-index: 60;
    }

    .dropdown__trigger {
      width: 100%;
      height: 48px;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.09),
          rgba(255, 255, 255, 0.025)
        ),
        rgba(8, 14, 26, 0.22);
      color: var(--text);
      padding: 0 13px 0 15px;
      display: inline-flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      font-size: 0.94rem;
      line-height: 1;
      text-align: left;
      cursor: pointer;
      user-select: none;
      transition:
        border-color 150ms cubic-bezier(0.22, 1, 0.36, 1),
        box-shadow 150ms cubic-bezier(0.22, 1, 0.36, 1),
        background 150ms cubic-bezier(0.22, 1, 0.36, 1),
        transform 150ms cubic-bezier(0.22, 1, 0.36, 1);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.1),
        0 2px 6px rgba(0, 0, 0, 0.16);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
    }

    .dropdown__trigger:hover {
      border-color: rgba(255, 255, 255, 0.16);
    }

    .dropdown__trigger:focus-visible {
      outline: none;
      border-color: var(--focus);
      box-shadow:
        0 0 0 2px rgba(143, 216, 255, 0.12),
        0 6px 16px rgba(0, 0, 0, 0.14);
    }

    .dropdown[data-open="true"] .dropdown__trigger {
      border-color: rgba(47, 164, 255, 0.42);
      box-shadow:
        0 0 0 2px rgba(47, 164, 255, 0.16),
        inset 0 1px 0 rgba(255, 255, 255, 0.1),
        0 10px 24px rgba(0, 0, 0, 0.2);
    }

    .dropdown__value {
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .dropdown__value[data-placeholder="true"] {
      color: rgba(255, 255, 255, 0.62);
    }

    .dropdown__chevron {
      flex: 0 0 auto;
      color: rgba(255, 255, 255, 0.6);
      transition: transform 0.22s var(--out);
    }

    .dropdown[data-open="true"] .dropdown__chevron {
      transform: rotate(180deg);
    }

    .dropdown__panel {
      position: absolute;
      left: 0;
      right: 0;
      top: calc(100% + 10px);
      padding: 8px;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background: rgba(10, 16, 28, 0.88);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      box-shadow:
        0 18px 54px rgba(0, 0, 0, 0.44),
        0 6px 14px rgba(0, 0, 0, 0.24),
        0 0 0 1px rgba(255, 255, 255, 0.045) inset;
      transform: translateY(3px);
      opacity: 0;
      pointer-events: none;
      z-index: 80;
      transition:
        opacity 160ms cubic-bezier(0.22, 1, 0.36, 1),
        transform 160ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .dropdown[data-open="true"] .dropdown__panel {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .dropdown__option {
      width: 100%;
      border: none;
      border-radius: 12px;
      padding: 12px 12px;
      background: transparent;
      color: rgba(255, 255, 255, 0.92);
      text-align: left;
      font-size: 0.92rem;
      line-height: 1.3;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      transition:
        background 0.16s var(--out),
        color 0.16s var(--out);
    }

    .dropdown__option::after {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--accent);
      box-shadow: 0 0 0 4px rgba(143, 216, 255, 0.12);
      opacity: 0;
      transform: scale(0.9);
      transition:
        opacity 0.16s var(--out),
        transform 0.16s var(--out);
      flex: 0 0 auto;
    }

    .dropdown__option:hover {
      background: rgba(65, 171, 226, 0.22);
      color: rgba(255, 255, 255, 0.95);
    }

    .dropdown__option:focus-visible {
      outline: none;
      background: rgba(143, 216, 255, 0.1);
    }

    .dropdown__option[aria-selected="true"] {
      background: rgba(65, 171, 226, 0.28);
    }

    .dropdown__option[aria-selected="true"]::after {
      opacity: 1;
      transform: scale(1);
    }

    .field__error {
      min-height: 1em;
      margin: 7px 0 0;
      font-size: 0.72rem;
      color: var(--danger);
      opacity: 1;
      transition: opacity 0.18s var(--out);
    }

    .field__error[aria-hidden="true"] {
      opacity: 0;
    }

    .field[data-invalid="true"] .field__input {
      border-color: rgba(255, 154, 154, 0.42);
      box-shadow:
        0 0 0 1px rgba(255, 154, 154, 0.12) inset,
        0 0 0 2px rgba(255, 154, 154, 0.08);
    }

    .field[data-invalid="true"] .dropdown__trigger {
      border-color: rgba(255, 154, 154, 0.42);
      box-shadow:
        0 0 0 1px rgba(255, 154, 154, 0.12) inset,
        0 0 0 2px rgba(255, 154, 154, 0.08);
    }

    .btn-submit {
      grid-column: 1 / -1;
      height: 54px;
      margin-top: 8px;
      border-radius: 18px;
      border: 1px solid rgba(255, 255, 255, 0.18);
      background: linear-gradient(
        180deg,
        #2f6fea 0%,
        #275fd6 52%,
        #1f56c8 100%
      );
      color: #ffffff;
      font-size: 0.93rem;
      font-weight: 700;
      letter-spacing: -0.012em;
      text-shadow: 0 1px 0 rgba(0, 0, 0, 0.28);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      cursor: pointer;
      position: relative;
      overflow: hidden;
      isolation: isolate;
      transition:
        transform 160ms cubic-bezier(0.22, 1, 0.36, 1),
        box-shadow 160ms cubic-bezier(0.22, 1, 0.36, 1),
        filter 160ms cubic-bezier(0.22, 1, 0.36, 1);
      box-shadow:
        0 6px 14px rgba(0, 0, 0, 0.32),
        0 3px 8px rgba(0, 0, 0, 0.2),
        inset 0 1px 0 rgba(255, 255, 255, 0.12),
        inset 0 -1px 0 rgba(0, 0, 0, 0.26);
    }

    .btn-submit::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(
        120deg,
        rgba(255, 255, 255, 0) 35%,
        rgba(255, 255, 255, 0.08) 50%,
        rgba(255, 255, 255, 0) 65%
      );
      transform: translateX(-60%);
      opacity: 0.08;
      filter: blur(18px);
      pointer-events: none;
      z-index: 0;
    }

    .btn-submit::after {
      content: "";
      position: absolute;
      left: 18px;
      right: 18px;
      top: 8px;
      height: 24px;
      border-radius: 999px;
      background: radial-gradient(
        ellipse at 50% 0%,
        rgba(255, 255, 255, 0.09),
        rgba(255, 255, 255, 0) 72%
      );
      opacity: 0.07;
      filter: blur(16px);
      pointer-events: none;
      z-index: 0;
    }

    .btn-submit__text,
    .btn-submit__glyph {
      position: relative;
      z-index: 1;
    }

    .btn-submit:hover {
      transform: translateY(-0.5px);
      filter: brightness(1.028);
      box-shadow:
        0 8px 18px rgba(0, 0, 0, 0.34),
        0 4px 10px rgba(0, 0, 0, 0.22),
        inset 0 1px 0 rgba(255, 255, 255, 0.12),
        inset 0 -1px 0 rgba(0, 0, 0, 0.3);
    }

    .btn-submit:hover::before {
      transform: translateX(60%);
      transition: transform 900ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .btn-submit:active {
      transform: translateY(0) scale(0.98);
      filter: brightness(0.982);
      box-shadow:
        0 5px 12px rgba(0, 0, 0, 0.31),
        0 2px 6px rgba(0, 0, 0, 0.22),
        inset 0 1px 0 rgba(255, 255, 255, 0.1),
        inset 0 -1px 0 rgba(0, 0, 0, 0.3);
    }

    .btn-submit:focus-visible {
      outline: none;
      box-shadow:
        0 10px 20px rgba(0, 0, 0, 0.14),
        0 14px 28px rgba(47, 164, 255, 0.18),
        0 0 0 1px rgba(255, 255, 255, 0.14) inset,
        0 0 0 3px rgba(176, 229, 255, 0.2);
    }

    .btn-submit:disabled {
      opacity: 0.6;
      cursor: wait;
      transform: none;
    }

    .btn-submit__glyph {
      position: relative;
      width: 18px;
      height: 18px;
      flex: 0 0 auto;
      display: inline-grid;
      place-items: center;
    }

    .btn-submit__spinner {
      position: absolute;
      inset: 0;
      margin: auto;
      width: 16px;
      height: 16px;
      border-radius: 999px;
      opacity: 0;
      transform: scale(0.92);
      transition:
        opacity 0.22s var(--out),
        transform 0.22s var(--out);
    }

    .btn-submit__spinner::before {
      content: "";
      position: absolute;
      inset: 0;
      margin: auto;
      width: 16px;
      height: 16px;
      border-radius: 999px;
      border: 2px solid rgba(3, 16, 25, 0.24);
      border-top-color: rgba(3, 16, 25, 0.92);
      animation: btnSpin 0.85s cubic-bezier(0.55, 0.15, 0.45, 0.85) infinite;
    }

    .btn-submit__text {
      transition: opacity 0.22s var(--out);
    }

    .btn-submit__icon {
      position: absolute;
      inset: 0;
      margin: auto;
      display: block;
      transition:
        opacity 0.22s var(--out),
        transform 0.22s var(--spring);
    }

    .btn-submit:not(:disabled):hover .btn-submit__icon--arrow {
      transform: translateX(2px);
    }

    .btn-submit__icon--success,
    .btn-submit__icon--error {
      opacity: 0;
      transform: scale(0.86);
    }

    .btn-submit[data-state="loading"] .btn-submit__spinner {
      opacity: 1;
      transform: scale(1);
    }

    .btn-submit[data-state="loading"] .btn-submit__icon--arrow {
      opacity: 0;
      transform: translateX(4px) scale(0.96);
    }

    .btn-submit[data-state="success"] {
      box-shadow:
        0 20px 50px rgba(47, 164, 255, 0.25),
        0 18px 46px rgba(79, 219, 140, 0.26),
        inset 0 1px 0 rgba(255, 255, 255, 0.35);
    }

    .btn-submit[data-state="error"] {
      box-shadow:
        0 20px 50px rgba(47, 164, 255, 0.2),
        0 18px 46px rgba(255, 120, 120, 0.18),
        inset 0 1px 0 rgba(255, 255, 255, 0.35);
    }

    .btn-submit[data-state="success"] .btn-submit__icon--arrow,
    .btn-submit[data-state="error"] .btn-submit__icon--arrow,
    .btn-submit[data-state="success"] .btn-submit__spinner,
    .btn-submit[data-state="error"] .btn-submit__spinner {
      opacity: 0;
      transform: translateX(4px) scale(0.96);
    }

    .btn-submit[data-state="success"] .btn-submit__icon--success {
      opacity: 1;
      transform: scale(1);
      color: #18a957;
    }

    .btn-submit[data-state="error"] .btn-submit__icon--error {
      opacity: 1;
      transform: scale(1);
      color: #d33b3b;
    }

    @keyframes btnSpin {
      to {
        transform: rotate(360deg);
      }
    }

    .corpModal {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: grid;
      place-items: center;
      padding: 28px 18px;
      opacity: 0;
      will-change: opacity;
      transition: opacity 320ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .corpModal[data-open="true"] {
      opacity: 1;
    }

    .corpModal__overlay {
      position: absolute;
      inset: 0;
      background: rgba(2, 6, 18, 0.65);
      backdrop-filter: blur(12px);
      opacity: 0;
      will-change: opacity;
      transition: opacity 320ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .corpModal[data-open="true"] .corpModal__overlay {
      opacity: 1;
    }

    .corpModal__panel {
      position: relative;
      width: min(520px, 100%);
      border-radius: 22px;
      background: rgba(20, 28, 40, 0.65);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid rgba(255, 255, 255, 0.18);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.22),
        0 46px 120px rgba(2, 6, 18, 0.65),
        0 22px 60px rgba(2, 6, 18, 0.45);
      padding: 26px 22px 20px;
      color: rgba(255, 255, 255, 0.92);
      will-change: transform, opacity;
      transform: translateY(4px) scale(0.985);
      opacity: 0;
      transition:
        transform 320ms cubic-bezier(0.22, 1, 0.36, 1),
        opacity 320ms cubic-bezier(0.22, 1, 0.36, 1);
    }

    .corpModal__panel::before,
    .corpModal__panel::after {
      display: none !important;
      content: none !important;
    }

    .corpModal[data-open="true"] .corpModal__panel {
      transform: translateY(0) scale(1);
      opacity: 1;
    }

    .corpModal[data-open="false"] {
      transition-duration: 240ms;
    }

    .corpModal[data-open="false"] .corpModal__overlay {
      transition-duration: 240ms;
    }

    .corpModal[data-open="false"] .corpModal__panel {
      transform: translateY(3px) scale(0.992);
      opacity: 0;
      transition-duration: 240ms, 240ms;
    }

    .corpModal__icon {
      width: 60px;
      height: 60px;
      border-radius: 18px;
      display: grid;
      place-items: center;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.14);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.16),
        0 18px 40px rgba(2, 6, 18, 0.28);
      margin-bottom: 14px;
    }

    .corpModal__iconSvg {
      display: none;
      transform: scale(0.92);
      opacity: 0.95;
    }

    .corpModal[data-kind="success"] .corpModal__iconSvg--success,
    .corpModal[data-kind="error"] .corpModal__iconSvg--error {
      display: block;
    }

    .corpModal[data-kind="success"] .corpModal__icon {
      color: rgba(79, 219, 140, 0.95);
      background: rgba(79, 219, 140, 0.1);
      border-color: rgba(79, 219, 140, 0.22);
    }

    .corpModal[data-kind="error"] .corpModal__icon {
      color: rgba(255, 154, 154, 0.95);
      background: rgba(255, 154, 154, 0.1);
      border-color: rgba(255, 154, 154, 0.22);
    }

    .corpModal__title {
      margin: 0;
      font-size: 1.1rem;
      letter-spacing: -0.01em;
      color: #ffffff;
      font-weight: 600;
    }

    .corpModal__message {
      margin: 10px 0 18px;
      color: rgba(255, 255, 255, 0.82);
      line-height: 1.6;
      font-size: 0.92rem;
    }

    .corpModal__btn {
      width: 100%;
      height: 46px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      text-decoration: none;
      background: linear-gradient(
