  <script is:inline>
    (() => {
      const hero = document.getElementById("inicio");
      if (!(hero instanceof HTMLElement)) return;

      const prefersReducedMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)",
      ).matches;

      const canUsePointerDepth = window.matchMedia(
        "(hover: hover) and (pointer: fine)",
      ).matches;

      const isDesktop = window.matchMedia("(min-width: 921px)").matches;
      const isTablet = window.matchMedia(
        "(min-width: 641px) and (max-width: 920px)",
      ).matches;

      const MAX_MOUSE_PX = prefersReducedMotion
        ? 0
        : isDesktop
          ? 8
          : isTablet
            ? 5
            : 0;

      const MAX_SCROLL_PX = prefersReducedMotion
        ? 0
        : isDesktop
          ? 14
          : isTablet
            ? 9
            : 0;

      const clamp = (value, min, max) => Math.max(min, Math.min(max, value));

      let isActive = false;
      let rafId = 0;
      let rectDirty = true;
      let scrollDirty = true;
      let cachedRect = null;

      let mx = 0;
      let my = 0;
      let scroll = 0;

      let targetMX = 0;
      let targetMY = 0;
      let targetScroll = 0;

      const updateRect = () => {
        cachedRect = hero.getBoundingClientRect();
        rectDirty = false;
      };

      const computeScroll = () => {
        if (MAX_SCROLL_PX <= 0) return 0;
        if (rectDirty || !cachedRect) updateRect();
        const rect = cachedRect;
        const height = Math.max(1, rect.height);
        const progress = clamp((-rect.top || 0) / height, 0, 1);
        return progress * MAX_SCROLL_PX;
      };

      const writeVars = () => {
        hero.style.setProperty("--hero-mx", `${mx.toFixed(2)}px`);
        hero.style.setProperty("--hero-my", `${my.toFixed(2)}px`);
        hero.style.setProperty("--hero-scroll", `${scroll.toFixed(2)}px`);
      };

      const scheduleTick = () => {
        if (rafId) return;
        rafId = requestAnimationFrame(tick);
      };

      const tick = () => {
        rafId = 0;

        if (!isActive) return;

        if (scrollDirty) {
          targetScroll = computeScroll();
          scrollDirty = false;
        }

        const LERP = 0.08;
        mx += (targetMX - mx) * LERP;
        my += (targetMY - my) * LERP;
        scroll += (targetScroll - scroll) * 0.11;

        writeVars();

        const needsMore =
          Math.abs(targetMX - mx) > 0.05 ||
          Math.abs(targetMY - my) > 0.05 ||
          Math.abs(targetScroll - scroll) > 0.05;

        if (needsMore) scheduleTick();
      };

      const onScroll = () => {
        if (!isActive) return;
        rectDirty = true;
        scrollDirty = true;
        scheduleTick();
      };

      const onPointerMove = (event) => {
        if (!isActive) return;
        if (!canUsePointerDepth || MAX_MOUSE_PX <= 0) return;
        if (!(event instanceof PointerEvent)) return;

        if (rectDirty || !cachedRect) updateRect();
        const rect = cachedRect;

        const cx = rect.left + rect.width / 2;
        const cy = rect.top + rect.height / 2;
        const rx = (event.clientX - cx) / Math.max(1, rect.width / 2);
        const ry = (event.clientY - cy) / Math.max(1, rect.height / 2);

        targetMX = clamp(rx, -1, 1) * MAX_MOUSE_PX;
        targetMY = clamp(ry, -1, 1) * MAX_MOUSE_PX;
        scheduleTick();
      };

      const onPointerLeave = () => {
        targetMX = 0;
        targetMY = 0;
        scheduleTick();
      };

      const heroObserver =
        "IntersectionObserver" in window
          ? new IntersectionObserver(
              (entries) => {
                const entry = entries[0];
                isActive = Boolean(entry && entry.isIntersecting);
                hero.classList.toggle("hero--active", isActive);

                if (isActive) {
                  rectDirty = true;
                  scrollDirty = true;
                  scheduleTick();
                }
              },
              { root: null, threshold: [0, 0.01], rootMargin: "200px 0px" },
            )
          : null;

      if (heroObserver) heroObserver.observe(hero);
      else {
        isActive = true;
        hero.classList.add("hero--active");
      }

      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onScroll, { passive: true });

      if (canUsePointerDepth && MAX_MOUSE_PX > 0) {
        hero.addEventListener("pointermove", onPointerMove, { passive: true });
        hero.addEventListener("pointerleave", onPointerLeave, {
          passive: true,
        });
      }

      const load = () => {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            hero.classList.add("hero--loaded");
            rectDirty = true;
            scrollDirty = true;
            scheduleTick();
          });
        });
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", load, { once: true });
      } else {
        load();
      }
    })();
  </script>

  <script is:inline>
    (() => {
      const form = document.getElementById("corpQuoteForm");
      const status = document.getElementById("corpQuoteStatus");
      const submitBtn = form?.querySelector("button[type='submit']") ?? null;

      if (
        !(form instanceof HTMLFormElement) ||
        !(status instanceof HTMLElement) ||
        !(submitBtn instanceof HTMLButtonElement)
      ) {
        return;
      }

      const nameEl = document.getElementById("corpName");
      const phoneEl = document.getElementById("corpPhone");
      const emailEl = document.getElementById("corpEmail");
      const recaptchaSiteKey = form?.dataset.recaptchaSiteKey || "";
      const recaptchaAction =
        form?.dataset.recaptchaAction || "corporate_quote_submit";
      const consumptionEl = document.getElementById("corpConsumption");
      const consumptionTrigger = document.getElementById(
        "corpConsumptionTrigger",
      );
      const consumptionValue = document.getElementById("corpConsumptionValue");
      const consumptionListbox = document.getElementById(
        "corpConsumptionListbox",
      );
      const recaptchaTokenEl = form.querySelector(
        "[data-corp-recaptcha-token]",
      );
      const recaptchaError = document.getElementById("corpRecaptchaError");

      const dropdownRoot = consumptionTrigger?.closest(".dropdown");
      const dropdownField = consumptionTrigger?.closest(".field");
      const dropdownOptions = Array.from(
        consumptionListbox?.querySelectorAll("[role='option']") ?? [],
      );

      let dropdownCloseTimer = 0;

      const reduceMotion =
        typeof window !== "undefined" &&
        window.matchMedia?.("(prefers-reduced-motion: reduce)")?.matches;

      const fieldRoot = (el) => el?.closest(".field");
      const errorEl = (el) => document.getElementById(`${el.id}Error`);

      const setInvalid = (el, message) => {
        if (!(el instanceof HTMLElement)) return;
        const root = fieldRoot(el);
        const error = errorEl(el);

        if (root) root.dataset.invalid = "true";
        el.setAttribute("aria-invalid", "true");

        if (error) {
          error.textContent = message || "";
          error.setAttribute("aria-hidden", message ? "false" : "true");
        }
      };

      const clearInvalid = (el) => {
        if (!(el instanceof HTMLElement)) return;
        const root = fieldRoot(el);
        const error = errorEl(el);

        if (root) delete root.dataset.invalid;
        el.removeAttribute("aria-invalid");

        if (error) {
          error.textContent = "";
          error.setAttribute("aria-hidden", "true");
        }
      };

      const setRecaptchaInvalid = (message) => {
        if (!(recaptchaError instanceof HTMLElement)) {
          return;
        }

        recaptchaError.textContent = message || "";
        recaptchaError.setAttribute("aria-hidden", message ? "false" : "true");
      };

      const clearRecaptchaInvalid = () => {
        if (!(recaptchaError instanceof HTMLElement)) {
          return;
        }

        recaptchaError.textContent = "";
        recaptchaError.setAttribute("aria-hidden", "true");
      };

      const validate = () => {
        let firstInvalid = null;

        [nameEl, phoneEl, emailEl, consumptionEl].forEach((el) => {
          if (
            el instanceof HTMLInputElement ||
            el instanceof HTMLSelectElement
          ) {
            clearInvalid(el);
          }
        });
        clearRecaptchaInvalid();

        if (nameEl instanceof HTMLInputElement && !nameEl.value.trim()) {
          setInvalid(nameEl, "Indica tu nombre o empresa.");
          firstInvalid ??= nameEl;
        }

        if (phoneEl instanceof HTMLInputElement) {
          const value = phoneEl.value.trim();

          if (!value) {
            setInvalid(phoneEl, "Indica un teléfono de contacto.");
            firstInvalid ??= phoneEl;
          } else if (!/^[0-9+\s()\-]{8,}$/.test(value)) {
            setInvalid(phoneEl, "Ingresa un teléfono válido.");
            firstInvalid ??= phoneEl;
          }
        }

        if (emailEl instanceof HTMLInputElement) {
          const value = emailEl.value.trim();
          if (value && !emailEl.checkValidity()) {
            setInvalid(emailEl, "Revisa el formato del correo.");
            firstInvalid ??= emailEl;
          }
        }

        if (
          (consumptionEl instanceof HTMLSelectElement ||
            consumptionEl instanceof HTMLInputElement) &&
          !consumptionEl.value
        ) {
          setInvalid(consumptionEl, "Selecciona tu consumo estimado.");
          firstInvalid ??= consumptionTrigger ?? consumptionEl;
        }

        if (firstInvalid instanceof HTMLElement) {
          firstInvalid.focus();
          return false;
        }

        return true;
      };

      [nameEl, phoneEl, emailEl, consumptionEl].forEach((el) => {
        if (
          !(el instanceof HTMLInputElement) &&
          !(el instanceof HTMLSelectElement)
        ) {
          return;
        }

        el.addEventListener("input", () => clearInvalid(el), {
          passive: true,
        });

        el.addEventListener("change", () => clearInvalid(el), {
          passive: true,
        });
      });

      const closeDropdown = ({ focusTrigger } = {}) => {
        if (!(dropdownRoot instanceof HTMLElement)) return;

        dropdownRoot.dataset.open = "false";

        if (dropdownField instanceof HTMLElement) {
          delete dropdownField.dataset.dropdownOpen;
        }

        if (dropdownCloseTimer) window.clearTimeout(dropdownCloseTimer);

        if (consumptionListbox instanceof HTMLElement) {
          dropdownCloseTimer = window.setTimeout(
            () => {
              if (dropdownRoot.dataset.open === "true") return;
              consumptionListbox.hidden = true;
            },
            reduceMotion ? 0 : 170,
          );
        }

        if (consumptionTrigger instanceof HTMLElement) {
          consumptionTrigger.setAttribute("aria-expanded", "false");
        }

        if (focusTrigger && consumptionTrigger instanceof HTMLElement) {
          consumptionTrigger.focus();
        }
      };

      const openDropdown = ({ focusSelected } = {}) => {
        if (!(dropdownRoot instanceof HTMLElement)) return;

        if (dropdownCloseTimer) window.clearTimeout(dropdownCloseTimer);

        if (consumptionListbox instanceof HTMLElement) {
          consumptionListbox.hidden = false;
        }

        if (consumptionTrigger instanceof HTMLElement) {
          consumptionTrigger.setAttribute("aria-expanded", "true");
        }

        if (dropdownField instanceof HTMLElement) {
          dropdownField.dataset.dropdownOpen = "true";
        }

        window.requestAnimationFrame(() => {
          if (dropdownRoot instanceof HTMLElement) {
            dropdownRoot.dataset.open = "true";
          }
        });

        if (!focusSelected) return;

        const selectedIdx = dropdownOptions.findIndex(
          (opt) => opt.getAttribute("aria-selected") === "true",
        );

        const target =
          dropdownOptions[selectedIdx >= 0 ? selectedIdx : 0] ?? null;

        if (target instanceof HTMLElement) {
          target.focus();
        }
      };

      const setConsumptionValue = (value) => {
        if (!(consumptionEl instanceof HTMLInputElement)) return;

        const option = dropdownOptions.find(
          (opt) => opt instanceof HTMLElement && opt.dataset.value === value,
        );

        const label = option?.textContent?.trim() || "Selecciona una opción";

        dropdownOptions.forEach((opt) => {
          if (!(opt instanceof HTMLElement)) return;
          opt.setAttribute(
            "aria-selected",
            opt.dataset.value === value ? "true" : "false",
          );
        });

        consumptionEl.value = value || "";
        consumptionEl.dispatchEvent(new Event("input", { bubbles: true }));
        consumptionEl.dispatchEvent(new Event("change", { bubbles: true }));

        if (consumptionValue instanceof HTMLElement) {
          consumptionValue.textContent = value
            ? label
            : "Selecciona una opción";

          if (value) {
            consumptionValue.removeAttribute("data-placeholder");
          } else {
            consumptionValue.dataset.placeholder = "true";
          }
        }
      };

      if (
        consumptionEl instanceof HTMLInputElement &&
        consumptionTrigger instanceof HTMLButtonElement &&
        consumptionListbox instanceof HTMLElement &&
        dropdownRoot instanceof HTMLElement &&
        dropdownOptions.length
      ) {
        const syncFromInput = () => setConsumptionValue(consumptionEl.value);
        syncFromInput();

        dropdownOptions.forEach((opt) => {
          if (!(opt instanceof HTMLButtonElement)) return;

          opt.addEventListener(
            "click",
            () => {
              setConsumptionValue(opt.dataset.value || "");
              closeDropdown({ focusTrigger: true });
            },
            { passive: true },
          );

          opt.addEventListener("keydown", (event) => {
            const key = event.key;
            const currentIndex = dropdownOptions.indexOf(opt);

            if (key === "Escape") {
              event.preventDefault();
              closeDropdown({ focusTrigger: true });
              return;
            }

            if (key === "Tab") {
              closeDropdown({ focusTrigger: false });
              return;
            }

            if (key === "ArrowDown" || key === "ArrowUp") {
              event.preventDefault();

              const nextIndex =
                key === "ArrowDown"
                  ? (currentIndex + 1) % dropdownOptions.length
                  : (currentIndex - 1 + dropdownOptions.length) %
                    dropdownOptions.length;

              const target = dropdownOptions[nextIndex];
              if (target instanceof HTMLElement) target.focus();
              return;
            }

            if (key === "Enter" || key === " ") {
              event.preventDefault();
              setConsumptionValue(opt.dataset.value || "");
              closeDropdown({ focusTrigger: true });
            }
          });
        });

        consumptionTrigger.addEventListener("click", () => {
          const isOpen = dropdownRoot.dataset.open === "true";

          if (isOpen) {
            closeDropdown({ focusTrigger: false });
          } else {
            openDropdown({ focusSelected: true });
          }
        });

        consumptionTrigger.addEventListener("keydown", (event) => {
          const key = event.key;
          const isOpen = dropdownRoot.dataset.open === "true";

          if (key === "Escape" && isOpen) {
            event.preventDefault();
            closeDropdown({ focusTrigger: true });
            return;
          }

          if (key === "ArrowDown" || key === "ArrowUp") {
            event.preventDefault();
            openDropdown({ focusSelected: false });

            const selectedIdx = dropdownOptions.findIndex(
              (opt) => opt.getAttribute("aria-selected") === "true",
            );

            const startIdx =
              selectedIdx >= 0
                ? selectedIdx
                : key === "ArrowUp"
                  ? dropdownOptions.length - 1
                  : 0;

            const target = dropdownOptions[startIdx];
            if (target instanceof HTMLElement) target.focus();
            return;
          }

          if (key === "Enter" || key === " ") {
            event.preventDefault();

            if (isOpen) {
              closeDropdown({ focusTrigger: true });
            } else {
              openDropdown({ focusSelected: true });
            }
          }
        });

        document.addEventListener(
          "pointerdown",
          (event) => {
            if (dropdownRoot.dataset.open !== "true") return;
            if (!(event.target instanceof Node)) return;
            if (dropdownRoot.contains(event.target)) return;
            closeDropdown({ focusTrigger: false });
          },
          { passive: true },
        );

        form.addEventListener(
          "reset",
          () => {
            queueMicrotask(() => {
              setConsumptionValue(consumptionEl.value);
              closeDropdown({ focusTrigger: false });
            });
          },
          { passive: true },
        );
      }

      let inFlight = false;
      let modalOpen = false;
      let modalHideTimer = 0;
      let lastModalFocus = null;
      const MODAL_EXIT_MS = 240;

      const submitText = submitBtn.querySelector("[data-submit-text]");
      const modalRoot = document.querySelector("[data-corp-result-modal]");
      const modalPanel = modalRoot?.querySelector(".corpModal__panel") ?? null;
      const modalTitle = document.getElementById("corpModalTitle");
      const modalMessage = document.getElementById("corpModalMessage");
      const modalWhatsAppCta =
        modalRoot?.querySelector("[data-corp-whatsapp-cta]") ?? null;
      const whatsappFab = document.getElementById("whatsapp-fab");
      const backTop = document.getElementById("back-top");
      const modalCloseEls = Array.from(
        modalRoot?.querySelectorAll("[data-corp-modal-close]") ?? [],
      );

      const SUBMIT_LABELS = {
        idle: "Solicitar propuesta",
        loading: "Enviando…",
        success: "Enviado",
        error: "Falló",
      };

      const setSubmitState = (nextState) => {
        submitBtn.dataset.state = nextState;
        if (submitText instanceof HTMLElement) {
          submitText.textContent =
            SUBMIT_LABELS[nextState] ?? SUBMIT_LABELS.idle;
        }
      };

      const getWhatsAppHref = () => {
        if (whatsappFab instanceof HTMLAnchorElement && whatsappFab.href) {
          return whatsappFab.href;
        }
        return "https://wa.link/38bbke";
      };

      const ensureFailClosedMessage = () => {
        const existing = form.querySelector(
          "[data-corp-recaptcha-misconfigured]",
        );
        if (existing) return;

        const el = document.createElement("div");
        el.className = "form__status";
        el.dataset.corpRecaptchaMisconfigured = "true";
        el.dataset.state = "error";
        el.setAttribute("role", "status");
        el.setAttribute("aria-live", "polite");

        const title = document.createElement("div");
        title.className = "status__title";
        title.textContent = "Servicio temporalmente no disponible";

        const body = document.createElement("div");
        body.className = "status__body";
        body.textContent =
          "Este formulario no está disponible por el momento. Escríbenos por WhatsApp y te atendemos enseguida.";

        const cta = document.createElement("a");
        cta.className = "status__cta";
        cta.href = getWhatsAppHref();
        cta.target = "_blank";
        cta.rel = "noopener noreferrer";
        cta.innerHTML = "<span>Contactar por WhatsApp</span>";

        el.append(title, body, cta);

        submitBtn.parentElement?.insertBefore(el, submitBtn);
      };

      const showResultModal = (kind, opts) => {
        if (
          !(modalRoot instanceof HTMLElement) ||
          !(modalPanel instanceof HTMLElement) ||
          !(modalTitle instanceof HTMLElement) ||
          !(modalMessage instanceof HTMLElement)
        ) {
          return false;
        }

        lastModalFocus =
          document.activeElement instanceof HTMLElement
            ? document.activeElement
            : null;

        if (modalHideTimer) window.clearTimeout(modalHideTimer);
        modalRoot.dataset.kind = kind;
        modalRoot.hidden = false;
        modalOpen = true;

        const message =
          typeof opts?.message === "string" && opts.message.trim()
            ? opts.message.trim()
            : kind === "success"
              ? "Recibimos tu solicitud correctamente. Nuestro equipo se pondrá en contacto contigo pronto."
              : "Ocurrió un problema al enviar tu solicitud. Intenta nuevamente en un momento.";

        modalTitle.textContent =
          kind === "success" ? "Solicitud enviada" : "No se pudo enviar";
        modalMessage.textContent = message;

        if (modalWhatsAppCta instanceof HTMLAnchorElement) {
          if (kind === "error") {
            modalWhatsAppCta.hidden = false;
            modalWhatsAppCta.href = getWhatsAppHref();
          } else {
            modalWhatsAppCta.hidden = true;
            modalWhatsAppCta.href = "#";
          }
        }

        const acceptBtn =
          modalRoot.querySelector(".corpModal__btn") ??
          modalRoot.querySelector("[data-corp-modal-close]") ??
          null;

        window.requestAnimationFrame(() => {
          modalRoot.dataset.open = "true";
          const target =
            acceptBtn instanceof HTMLElement ? acceptBtn : modalPanel;
          try {
            target.focus({ preventScroll: true });
          } catch {
            // ignore
          }
        });

        return true;
      };

      const getModalFocusables = () => {
        if (!(modalPanel instanceof HTMLElement)) return [];
        const candidates = Array.from(
          modalPanel.querySelectorAll(
            "a[href], button, input, select, textarea, [tabindex]",
          ),
        ).filter((el) => {
          if (!(el instanceof HTMLElement)) return false;
          if (el.hasAttribute("disabled")) return false;
          if (el.getAttribute("tabindex") === "-1") return false;
          if (el.hasAttribute("hidden")) return false;
          if (el.getAttribute("aria-hidden") === "true") return false;
          if (el instanceof HTMLInputElement && el.type === "hidden")
            return false;
          return true;
        });

        return candidates;
      };

      const closeResultModal = ({ resetForm } = {}) => {
        if (!(modalRoot instanceof HTMLElement)) return;

        if (modalHideTimer) window.clearTimeout(modalHideTimer);

        modalRoot.dataset.open = "false";
        modalOpen = false;

        if (resetForm) {
          form.reset();
          closeDropdown({ focusTrigger: false });
          setConsumptionValue("");
          clearRecaptchaInvalid();
          if (recaptchaTokenEl instanceof HTMLInputElement) {
            recaptchaTokenEl.value = "";
          }
          [nameEl, phoneEl, emailEl, consumptionEl].forEach((el) => {
            if (
              el instanceof HTMLInputElement ||
              el instanceof HTMLSelectElement
            ) {
              clearInvalid(el);
            }
          });
        }

        form.removeAttribute("aria-busy");
        submitBtn.disabled = false;
        setSubmitState("idle");

        const restoreTarget = lastModalFocus;
        lastModalFocus = null;

        const firstInput = form.querySelector(
          "input, button, select, textarea",
        );
        const focusTarget =
          restoreTarget instanceof HTMLElement && restoreTarget.isConnected
            ? restoreTarget
            : firstInput instanceof HTMLElement
              ? firstInput
              : null;

        if (focusTarget) {
          try {
            focusTarget.focus({ preventScroll: true });
          } catch {
            // ignore
          }
        }

        if (reduceMotion) {
          modalRoot.hidden = true;
          delete modalRoot.dataset.open;
          delete modalRoot.dataset.kind;
          return;
        }

        modalHideTimer = window.setTimeout(() => {
          modalRoot.hidden = true;
          delete modalRoot.dataset.open;
          delete modalRoot.dataset.kind;
          modalHideTimer = 0;
        }, MODAL_EXIT_MS);
      };

      const closeResultModalFromUi = () =>
        closeResultModal({ resetForm: modalRoot?.dataset.kind === "success" });

      if (modalCloseEls.length) {
        modalCloseEls.forEach((el) => {
          if (!(el instanceof HTMLElement)) return;
          el.addEventListener("click", closeResultModalFromUi, {
            passive: true,
          });
        });
      }

      window.addEventListener("keydown", (event) => {
        if (!modalOpen) return;

        if (event.key === "Tab") {
          const focusables = getModalFocusables();
          if (!(modalPanel instanceof HTMLElement)) return;

          if (!focusables.length) {
            event.preventDefault();
            try {
              modalPanel.focus({ preventScroll: true });
            } catch {
              // ignore
            }
            return;
          }

          const first = focusables[0];
          const last = focusables[focusables.length - 1];
          const active =
            document.activeElement instanceof HTMLElement
              ? document.activeElement
              : null;

          if (!active || !modalPanel.contains(active)) {
            event.preventDefault();
            try {
              first.focus({ preventScroll: true });
            } catch {
              // ignore
            }
            return;
          }

          if (event.shiftKey) {
            if (active === first) {
              event.preventDefault();
              try {
                last.focus({ preventScroll: true });
              } catch {
                // ignore
              }
            }
          } else {
            if (active === last) {
              event.preventDefault();
              try {
                first.focus({ preventScroll: true });
              } catch {
                // ignore
              }
            }
          }

          return;
        }

        if (event.key === "Escape") {
          event.preventDefault();
          closeResultModalFromUi();
        }
      });

      const makeEventId = () => {
        try {
          if (globalThis.crypto && "randomUUID" in globalThis.crypto) {
            // @ts-ignore - runtime feature check
            return globalThis.crypto.randomUUID();
          }
        } catch {
          // ignore
        }
        return `${Date.now()}-${Math.random().toString(16).slice(2)}`;
      };

      const trackEvent = (name, params) => {
        try {
          if (typeof window === "undefined") return;
          if (typeof window.frioPuroTrackEvent !== "function") return;
          window.frioPuroTrackEvent(name, params);
        } catch {
          // ignore
        }
      };

      const syncBackTopFocusability = () => {
        if (!(backTop instanceof HTMLAnchorElement)) return;
        const visible = backTop.classList.contains("visible");
        backTop.tabIndex = visible ? 0 : -1;
        backTop.setAttribute("aria-hidden", visible ? "false" : "true");
      };

      setSubmitState("idle");
      syncBackTopFocusability();
      if (backTop) {
        new MutationObserver(syncBackTopFocusability).observe(backTop, {
          attributes: true,
          attributeFilter: ["class"],
        });
      }

      if (!recaptchaSiteKey) {
        submitBtn.disabled = true;
        ensureFailClosedMessage();
      }

      form.addEventListener("submit", async (event) => {
        event.preventDefault();

        if (inFlight) return;

        if (!recaptchaSiteKey) {
          submitBtn.disabled = true;
          ensureFailClosedMessage();
          return;
        }

        status.hidden = true;
        status.textContent = "";
        status.dataset.state = "";

        if (!validate()) return;

        inFlight = true;
        const eventId = makeEventId();

        setSubmitState("loading");
        submitBtn.disabled = true;
        form.setAttribute("aria-busy", "true");

        if (recaptchaTokenEl instanceof HTMLInputElement) {
          if (!globalThis.grecaptcha || !globalThis.grecaptcha.execute) {
            setRecaptchaInvalid(
              "No fue posible cargar reCAPTCHA. Intenta nuevamente.",
            );
            trackEvent("form_submit_error", {
              event_id: eventId,
              page_path: window.location?.pathname,
              form_id: "corpQuoteForm",
              error_kind: "recaptcha_unavailable",
            });
            setSubmitState("error");
            form.removeAttribute("aria-busy");
            await new Promise((r) => setTimeout(r, 400));
            if (!showResultModal("error")) {
              status.textContent =
                "Ocurrió un problema al enviar tu solicitud. Intenta nuevamente en un momento.";
              status.dataset.state = "error";
              status.hidden = false;
            }
            submitBtn.disabled = false;
            setSubmitState("idle");
            inFlight = false;
            return;
          }

          try {
            const token = await new Promise((resolve, reject) => {
              globalThis.grecaptcha.ready(() => {
                globalThis.grecaptcha
                  .execute(recaptchaSiteKey, { action: recaptchaAction })
                  .then(resolve)
                  .catch(reject);
              });
            });

            recaptchaTokenEl.value = token || "";
          } catch {
            setRecaptchaInvalid(
              "No fue posible validar reCAPTCHA. Intenta nuevamente.",
            );
            trackEvent("form_submit_error", {
              event_id: eventId,
              page_path: window.location?.pathname,
              form_id: "corpQuoteForm",
              error_kind: "recaptcha_execute_failed",
            });
            setSubmitState("error");
            form.removeAttribute("aria-busy");
            await new Promise((r) => setTimeout(r, 400));
            if (!showResultModal("error")) {
              status.textContent =
                "Ocurrió un problema al enviar tu solicitud. Intenta nuevamente en un momento.";
              status.dataset.state = "error";
              status.hidden = false;
            }
            submitBtn.disabled = false;
            setSubmitState("idle");
            inFlight = false;
            return;
          }

          if (!recaptchaTokenEl.value) {
            setRecaptchaInvalid(
              "No fue posible validar reCAPTCHA. Intenta nuevamente.",
            );
            trackEvent("form_submit_error", {
              event_id: eventId,
              page_path: window.location?.pathname,
              form_id: "corpQuoteForm",
              error_kind: "recaptcha_empty_token",
            });
            setSubmitState("error");
            form.removeAttribute("aria-busy");
            await new Promise((r) => setTimeout(r, 400));
            if (!showResultModal("error")) {
              status.textContent =
                "Ocurrió un problema al enviar tu solicitud. Intenta nuevamente en un momento.";
              status.dataset.state = "error";
              status.hidden = false;
            }
            submitBtn.disabled = false;
            setSubmitState("idle");
            inFlight = false;
            return;
          }
        }

        trackEvent("form_submit_attempt", {
          event_id: eventId,
          page_path: window.location?.pathname,
          form_id: "corpQuoteForm",
        });

        try {
          const response = await fetch(form.action, {
            method: "POST",
            body: new FormData(form),
          });

          const payload = await response.json().catch(() => null);
          const success = Boolean(
            response.ok && payload && payload.ok === true,
          );

          const payloadMessage =
            payload && typeof payload.message === "string"
              ? payload.message
              : "";
          const payloadCode =
            payload && typeof payload.code === "string" ? payload.code : "";

          const codeMessage =
            payloadCode === "rate_limited"
              ? "Has enviado muchas solicitudes. Intenta más tarde."
              : payloadCode === "server_busy"
                ? "El sistema está ocupado. Intenta en unos minutos."
                : payloadCode === "smtp_unavailable"
                  ? "No pudimos enviar tu solicitud. Contáctanos por WhatsApp."
                  : payloadCode === "recaptcha_unavailable"
                    ? "No pudimos validar seguridad. Intenta nuevamente."
                    : payloadCode === "service_misconfigured"
                      ? "Servicio temporalmente no disponible."
                      : "";

          const message =
            codeMessage ||
            payloadMessage ||
            (response.ok
              ? "Gracias. Hemos recibido tu solicitud y un asesor te contactará en breve."
              : "No fue posible enviar tu solicitud. Intenta nuevamente en unos momentos.");

          if (success) {
            trackEvent("form_submit_success", {
              event_id: eventId,
              page_path: window.location?.pathname,
              form_id: "corpQuoteForm",
            });
          } else {
            trackEvent("form_submit_error", {
              event_id: eventId,
              page_path: window.location?.pathname,
              form_id: "corpQuoteForm",
              http_status: response.status,
              error_kind: response.ok ? "payload_not_ok" : "http_error",
            });
          }

          status.textContent = message;
          status.dataset.state = success ? "success" : "error";
          status.hidden = true;

          form.removeAttribute("aria-busy");
          if (success) {
            setSubmitState("success");
            await new Promise((r) => setTimeout(r, 400));
            if (!showResultModal("success")) {
              status.hidden = false;
            }
          } else {
            setSubmitState("error");
            await new Promise((r) => setTimeout(r, 400));
            if (!showResultModal("error", { message })) {
              status.hidden = false;
            }
          }
        } catch {
          trackEvent("form_submit_error", {
            event_id: eventId,
            page_path: window.location?.pathname,
            form_id: "corpQuoteForm",
            error_kind: "network_error",
          });
          status.textContent =
            "No fue posible enviar tu solicitud. Intenta nuevamente en unos momentos.";
          status.dataset.state = "error";
          status.hidden = true;

          setSubmitState("error");
          form.removeAttribute("aria-busy");
          await new Promise((r) => setTimeout(r, 400));
          if (!showResultModal("error")) {
            status.hidden = false;
          }
        } finally {
          inFlight = false;
          form.removeAttribute("aria-busy");
          if (!modalOpen) {
            submitBtn.disabled = false;
            setSubmitState("idle");
          }
        }
      });
    })();
  </script>
</BaseLayout>
