    .form-card {
      --surface-border: rgba(255, 255, 255, 0.12);
      --text: #ffffff;
      --text-soft: rgba(255, 255, 255, 0.82);
      --text-muted: rgba(255, 255, 255, 0.62);
      --line: rgba(255, 255, 255, 0.12);
      --accent: #8fd8ff;
      --accent-strong: #bde9ff;
      --accent-ring: rgba(143, 216, 255, 0.18);
      --focus: #2fa4ff;
      --focus-ring: rgba(47, 164, 255, 0.25);
      --danger: #ff9a9a;

      width: 100%;
      position: relative;
      isolation: isolate;
      padding: 36px;
      border-radius: 16px;
      color: var(--text);
      font-family: "Barlow", sans-serif;

      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(10, 16, 28, 0.88);
      backdrop-filter: blur(18px) saturate(1.2);
      -webkit-backdrop-filter: blur(18px) saturate(1.2);

      box-shadow:
        0 30px 80px rgba(0, 0, 0, 0.5),
        0 10px 30px rgba(0, 0, 0, 0.28),
        0 0 0 1px rgba(255, 255, 255, 0.06) inset;
    }

    .form-card :is(p, span, label, input, button, textarea, select) {
      font-family: inherit;
    }

    .form-card::before,
    .form-card::after {
      content: none;
    }

    .form-card__chrome {
      display: none;
    }

    .form-card__chrome-orb {
      position: absolute;
      border-radius: 999px;
      filter: blur(12px);
      opacity: 0.24;
    }

    .form-card__chrome-orb--a {
      width: 180px;
      height: 180px;
      top: -54px;
      right: -36px;
      background: rgba(65, 171, 226, 0.18);
    }

    .form-card__chrome-orb--b {
      width: 120px;
      height: 120px;
      bottom: -32px;
      left: -24px;
      background: rgba(255, 255, 255, 0.07);
    }

    .form-card__head,
    .form-card .form {
      position: relative;
      z-index: 1;
    }

    .form-card__head {
      margin-bottom: 34px;
    }

    .form-card__eyebrow {
      margin: 0 0 10px;
      font-family: "Barlow Condensed", sans-serif;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .form-card__title {
      margin: 0;
      font-family: "Barlow Condensed", sans-serif;
      font-size: clamp(1.82rem, 2.25vw, 2.18rem);
      line-height: 1.04;
      letter-spacing: -0.04em;
      font-weight: 600;
      text-wrap: balance;
      color: #ffffff;
    }

    .form-card__subtitle {
      margin: 15px 0 0;
      color: var(--text-soft);
      font-size: 0.94rem;
      line-height: 1.72;
      max-width: 36ch;
    }

    .form {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px 15px;
    }

    .form__honeypot {
      position: absolute;
      left: -9999px;
      width: 1px;
      height: 1px;
      overflow: hidden;
    }

    .field {
      display: flex;
      flex-direction: column;
      position: relative;
      z-index: 0;
    }

    .field[data-dropdown-open="true"] {
      z-index: 120;
    }

    .field--full {
      grid-column: 1 / -1;
    }

    .field__label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 9px;
      font-size: 0.79rem;
      font-weight: 620;
      letter-spacing: 0.015em;
      color: rgba(255, 255, 255, 0.88);
    }

    .field__badge {
      padding: 2px 7px;
      border-radius: 999px;
      border: 1px solid var(--line);
      font-size: 0.6rem;
      color: rgba(255, 255, 255, 0.62);
      background: rgba(10, 16, 28, 0.18);
    }

    .field__input {
      width: 100%;
      height: 50px;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.08),
          rgba(255, 255, 255, 0.02)
        ),
        rgba(10, 16, 28, 0.18);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      color: var(--text);
      padding: 0 16px;
      font-size: 0.95rem;
      outline: none;
      caret-color: var(--accent);
      transition:
        border-color 0.25s var(--out),
        box-shadow 0.25s var(--out),
        background 0.25s var(--out),
        transform 0.25s var(--out);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.12),
        0 6px 16px rgba(0, 0, 0, 0.25);
    }

    .field__input::placeholder {
      color: rgba(255, 255, 255, 0.42);
    }

    .field__input:hover {
      border-color: rgba(255, 255, 255, 0.18);
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.09) 0%,
          rgba(255, 255, 255, 0.03) 100%
        ),
        rgba(10, 16, 28, 0.2);
    }

    .field__input:focus-visible {
      border-color: rgba(143, 216, 255, 0.6);
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.1),
          rgba(255, 255, 255, 0.04)
        ),
        rgba(10, 16, 28, 0.22);
      box-shadow:
        0 0 0 2px rgba(143, 216, 255, 0.25),
        0 10px 30px rgba(0, 0, 0, 0.35),
        inset 0 1px 0 rgba(255, 255, 255, 0.2);
    }

    .dropdown {
      position: relative;
      z-index: 0;
    }

    .dropdown[data-open="true"] {
      z-index: 60;
    }

    .dropdown__trigger {
      width: 100%;
      height: 50px;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.12);
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.08),
          rgba(255, 255, 255, 0.02)
        ),
        rgba(10, 16, 28, 0.18);
      color: var(--text);
      padding: 0 14px 0 16px;
      display: inline-flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      font-size: 0.94rem;
      line-height: 1;
      text-align: left;
      cursor: pointer;
      user-select: none;
      transition:
        border-color 0.18s var(--out),
        box-shadow 0.18s var(--out),
        background 0.18s var(--out),
        transform 0.18s var(--out);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.12),
        0 6px 16px rgba(0, 0, 0, 0.25);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
    }

    .dropdown__trigger:hover {
      border-color: rgba(255, 255, 255, 0.16);
    }

    .dropdown__trigger:focus-visible {
      outline: none;
      border-color: var(--focus);
      box-shadow:
        0 0 0 2px rgba(143, 216, 255, 0.18),
        0 10px 24px rgba(0, 0, 0, 0.18);
    }

    .dropdown[data-open="true"] .dropdown__trigger {
      border-color: rgba(47, 164, 255, 0.42);
      box-shadow:
        0 0 0 2px rgba(47, 164, 255, 0.16),
        inset 0 1px 0 rgba(255, 255, 255, 0.1),
        0 10px 24px rgba(0, 0, 0, 0.2);
    }

    .dropdown__value {
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .dropdown__value[data-placeholder="true"] {
      color: rgba(255, 255, 255, 0.5);
    }

    .dropdown__chevron {
      flex: 0 0 auto;
      color: rgba(255, 255, 255, 0.6);
      transition: transform 0.22s var(--out);
    }

    .dropdown[data-open="true"] .dropdown__chevron {
      transform: rotate(180deg);
    }

    .dropdown__panel {
      position: absolute;
      left: 0;
      right: 0;
      top: calc(100% + 10px);
      padding: 8px;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(10, 16, 28, 0.88);
      backdrop-filter: blur(18px) saturate(1.2);
      -webkit-backdrop-filter: blur(18px) saturate(1.2);
      box-shadow:
        0 40px 120px rgba(0, 0, 0, 0.7),
        0 10px 40px rgba(0, 0, 0, 0.4),
        0 0 0 1px rgba(255, 255, 255, 0.06) inset;
      transform: translateY(4px);
      opacity: 0;
      pointer-events: none;
      z-index: 80;
      transition:
        opacity 0.18s cubic-bezier(0.22, 0.61, 0.36, 1),
        transform 0.18s cubic-bezier(0.22, 0.61, 0.36, 1);
    }

    .dropdown[data-open="true"] .dropdown__panel {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .dropdown__option {
      width: 100%;
      border: none;
      border-radius: 12px;
      padding: 12px 12px;
      background: transparent;
      color: rgba(255, 255, 255, 0.92);
      text-align: left;
      font-size: 0.92rem;
      line-height: 1.3;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      transition:
        background 0.16s var(--out),
        color 0.16s var(--out);
    }

    .dropdown__option::after {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--accent);
      box-shadow: 0 0 0 4px rgba(143, 216, 255, 0.12);
      opacity: 0;
      transform: scale(0.9);
      transition:
        opacity 0.16s var(--out),
        transform 0.16s var(--out);
      flex: 0 0 auto;
    }

    .dropdown__option:hover {
      background: rgba(65, 171, 226, 0.22);
      color: rgba(255, 255, 255, 0.95);
    }

    .dropdown__option:focus-visible {
      outline: none;
      background: rgba(143, 216, 255, 0.1);
    }

    .dropdown__option[aria-selected="true"] {
      background: rgba(65, 171, 226, 0.28);
    }

    .dropdown__option[aria-selected="true"]::after {
      opacity: 1;
      transform: scale(1);
    }

    .field__error {
      min-height: 1em;
      margin: 7px 0 0;
      font-size: 0.72rem;
      color: var(--danger);
      opacity: 1;
      transition: opacity 0.18s var(--out);
    }

    .field__error[aria-hidden="true"] {
      opacity: 0;
    }

    .field[data-invalid="true"] .field__input {
      border-color: rgba(255, 154, 154, 0.42);
      box-shadow:
        0 0 0 1px rgba(255, 154, 154, 0.12) inset,
        0 0 0 2px rgba(255, 154, 154, 0.08);
    }

    .field[data-invalid="true"] .dropdown__trigger {
      border-color: rgba(255, 154, 154, 0.42);
      box-shadow:
        0 0 0 1px rgba(255, 154, 154, 0.12) inset,
        0 0 0 2px rgba(255, 154, 154, 0.08);
    }

    .btn-submit {
      grid-column: 1 / -1;
      height: 54px;
      margin-top: 10px;
      border-radius: 16px;
      border: none;
      background: linear-gradient(
        135deg,
        #6dd6ff 0%,
        #2fa4ff 60%,
        #1e7fd6 100%
      );
      color: #031019;
      font-size: 0.93rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      cursor: pointer;
      transition:
        transform 0.3s var(--out),
        box-shadow 0.3s var(--out),
        filter 0.3s var(--out);
      box-shadow:
        0 20px 50px rgba(47, 164, 255, 0.35),
        0 10px 25px rgba(47, 164, 255, 0.25),
        inset 0 1px 0 rgba(255, 255, 255, 0.35);
    }

    .btn-submit:hover {
      transform: translateY(-2px) scale(1.01);
      filter: brightness(1.01);
      box-shadow:
        0 30px 80px rgba(47, 164, 255, 0.45),
        0 14px 40px rgba(47, 164, 255, 0.3);
    }

    .btn-submit:active {
      transform: translateY(0);
      box-shadow:
        0 6px 14px rgba(47, 164, 255, 0.14),
        0 2px 8px rgba(47, 164, 255, 0.1);
    }

    .btn-submit:focus-visible {
      outline: none;
      box-shadow:
        0 10px 20px rgba(0, 0, 0, 0.14),
        0 10px 20px rgba(85, 186, 244, 0.14),
        0 0 0 1px rgba(255, 255, 255, 0.1) inset,
        0 0 0 2px rgba(143, 216, 255, 0.16);
    }

    .btn-submit:disabled {
      opacity: 0.6;
      cursor: wait;
      transform: none;
    }

    .btn-submit__glyph {
      position: relative;
      width: 18px;
      height: 18px;
      flex: 0 0 auto;
      display: inline-grid;
      place-items: center;
    }

    .btn-submit__spinner {
      position: absolute;
      inset: 0;
      margin: auto;
      width: 16px;
      height: 16px;
      border-radius: 999px;
      opacity: 0;
      transform: scale(0.92);
      transition:
        opacity 0.22s var(--out),
        transform 0.22s var(--out);
    }

    .btn-submit__spinner::before {
      content: "";
      position: absolute;
      inset: 0;
      margin: auto;
      width: 16px;
      height: 16px;
      border-radius: 999px;
      border: 2px solid rgba(3, 16, 25, 0.24);
      border-top-color: rgba(3, 16, 25, 0.92);
      animation: btnSpin 0.85s cubic-bezier(.55,.15,.45,.85) infinite;
    }

    .btn-submit__text {
      transition: opacity 0.22s var(--out);
    }

    .btn-submit__icon {
      position: absolute;
      inset: 0;
      margin: auto;
      display: block;
      transition:
        opacity 0.22s var(--out),
        transform 0.22s var(--spring);
    }

    .btn-submit__icon--success,
    .btn-submit__icon--error {
      opacity: 0;
      transform: scale(0.86);
    }

    .btn-submit[data-state="loading"] .btn-submit__spinner {
      opacity: 1;
      transform: scale(1);
    }

    .btn-submit[data-state="loading"] .btn-submit__icon--arrow {
      opacity: 0;
      transform: translateX(4px) scale(0.96);
    }

    .btn-submit[data-state="success"] {
      box-shadow:
        0 20px 50px rgba(47, 164, 255, 0.25),
        0 18px 46px rgba(79, 219, 140, 0.26),
        inset 0 1px 0 rgba(255, 255, 255, 0.35);
    }

    .btn-submit[data-state="error"] {
      box-shadow:
        0 20px 50px rgba(47, 164, 255, 0.2),
        0 18px 46px rgba(255, 120, 120, 0.18),
        inset 0 1px 0 rgba(255, 255, 255, 0.35);
    }

    .btn-submit[data-state="success"] .btn-submit__icon--arrow,
    .btn-submit[data-state="error"] .btn-submit__icon--arrow,
    .btn-submit[data-state="success"] .btn-submit__spinner,
    .btn-submit[data-state="error"] .btn-submit__spinner {
      opacity: 0;
      transform: translateX(4px) scale(0.96);
    }

    .btn-submit[data-state="success"] .btn-submit__icon--success {
      opacity: 1;
      transform: scale(1);
      color: #18a957;
    }

    .btn-submit[data-state="error"] .btn-submit__icon--error {
      opacity: 1;
      transform: scale(1);
      color: #d33b3b;
    }

    @keyframes btnSpin {
      to {
        transform: rotate(360deg);
      }
    }

    .corpModal {
      position: fixed;
      inset: 0;
      z-index: 9999;
      display: grid;
      place-items: center;
      padding: 28px 18px;
    }

    .corpModal__overlay {
      position: absolute;
      inset: 0;
      background: rgba(2, 6, 18, 0.46);
      backdrop-filter: blur(10px);
    }

    .corpModal__panel {
      position: relative;
      width: min(520px, 100%);
      border-radius: 22px;
      border: 1px solid rgba(255, 255, 255, 0.16);
      background: linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.14),
        rgba(255, 255, 255, 0.08)
      );
      box-shadow:
        0 46px 120px rgba(2, 6, 18, 0.55),
        0 22px 60px rgba(2, 6, 18, 0.35);
      padding: 22px 20px 18px;
      color: rgba(255, 255, 255, 0.92);
      transform: translateY(10px) scale(0.98);
      opacity: 0;
      transition:
        transform 0.28s var(--spring),
        opacity 0.22s var(--out);
    }

    .corpModal[data-open="true"] .corpModal__panel {
      transform: none;
      opacity: 1;
    }

    .corpModal__icon {
      width: 60px;
      height: 60px;
      border-radius: 18px;
      display: grid;
      place-items: center;
      background: rgba(255, 255, 255, 0.08);
      border: 1px solid rgba(255, 255, 255, 0.14);
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.16),
        0 18px 40px rgba(2, 6, 18, 0.28);
      margin-bottom: 14px;
    }

    .corpModal__iconSvg {
      display: none;
      transform: scale(0.92);
      opacity: 0.95;
    }

    .corpModal[data-kind="success"] .corpModal__iconSvg--success,
    .corpModal[data-kind="error"] .corpModal__iconSvg--error {
      display: block;
    }

    .corpModal[data-kind="success"] .corpModal__icon {
      color: rgba(79, 219, 140, 0.95);
      background: rgba(79, 219, 140, 0.1);
      border-color: rgba(79, 219, 140, 0.22);
    }

    .corpModal[data-kind="error"] .corpModal__icon {
      color: rgba(255, 154, 154, 0.95);
      background: rgba(255, 154, 154, 0.1);
      border-color: rgba(255, 154, 154, 0.22);
    }

    .corpModal__title {
      margin: 0;
      font-size: 1.1rem;
      letter-spacing: -0.01em;
    }

    .corpModal__message {
      margin: 10px 0 18px;
      color: rgba(255, 255, 255, 0.78);
      line-height: 1.6;
      font-size: 0.92rem;
    }

    .corpModal__btn {
      width: 100%;
      height: 46px;
      border-radius: 14px;
      border: 1px solid rgba(255, 255, 255, 0.16);
      background: rgba(255, 255, 255, 0.1);
      color: rgba(255, 255, 255, 0.92);
      font-weight: 700;
      letter-spacing: -0.01em;
      cursor: pointer;
      transition:
        transform 0.22s var(--out),
        background 0.22s var(--out),
        border-color 0.22s var(--out);
    }

    .corpModal__btn:hover {
      transform: translateY(-1px);
      background: rgba(255, 255, 255, 0.14);
      border-color: rgba(255, 255, 255, 0.24);
    }

    .corpModal__btn:active {
      transform: translateY(0);
    }

    .corpModal__btn:focus-visible {
      outline: none;
      box-shadow: 0 0 0 4px rgba(143, 216, 255, 0.16);
    }

    @media (prefers-reduced-motion: reduce) {
      .btn-submit__spinner::before {
        animation: none;
      }

      .corpModal__panel {
        transition: none;
      }
    }

    .form__legal {
      grid-column: 1 / -1;
      margin: 2px 0 0;
      text-align: center;
      font-size: 0.74rem;
      color: rgba(255, 255, 255, 0.62);
      line-height: 1.5;
    }

    .form__status {
      grid-column: 1 / -1;
      padding: 12px 14px;
      border-radius: 14px;
      border: 1px solid var(--line);
      background: rgba(255, 255, 255, 0.04);
      color: var(--text-soft);
      font-size: 0.84rem;
      line-height: 1.6;
    }

    .form__status[data-state="success"] {
      border-color: rgba(79, 219, 140, 0.22);
      background: rgba(79, 219, 140, 0.08);
      color: rgba(205, 255, 225, 0.96);
