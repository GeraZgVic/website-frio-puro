---
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/sections/Header.astro";
import Footer from "../../components/sections/Footer.astro";
import WhatsAppFloat from "../../components/ui/WhatsAppFloat.astro";
import Cursor from "../../components/Cursor.astro";
import SiteScripts from "../../components/SiteScripts.astro";
import formHeroImage from "../../assets/forms/ImaForm.png";
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY;
const recaptchaAction = "corporate_quote_submit";
---

<BaseLayout
  title="Solicitar cotización corporativa | Frío Puro"
  description="Solicitud de cotización corporativa para suministro comercial de alto volumen."
  ogTitle="Solicitar cotización corporativa | Frío Puro"
  ogDescription="Stock permanente y entregas programadas para operación comercial."
>
  <Cursor />
  <Header />
  {recaptchaSiteKey && (
    <script src={`https://www.google.com/recaptcha/api.js?render=${recaptchaSiteKey}`} async defer></script>
  )}
  <script is:inline>
    document.documentElement.classList.add("js");
  </script>

  <main class="page">
    <section id="inicio" class="hero" aria-labelledby="quoteTitle">
      <div class="hero__bg" aria-hidden="true">
        <Image
          src={formHeroImage}
          alt=""
          class="hero__image"
          widths={[960, 1280, 1600, 1920, 2400]}
          sizes="100vw"
          format="webp"
          quality={92}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
        <div class="hero__focus-gradient"></div>
      </div>

      <div id="formulario-corporativo" class="container hero__inner">
        <div class="hero__copy">
          <p class="hero__eyebrow">FRÍO PURO · CORPORATIVO</p>

          <div class="hero__title-wrap">
            <span class="hero__kicker">
              Abasto premium y continuidad operativa
            </span>

            <h1 id="quoteTitle" class="hero__title">
              <span class="hero__title-line hero__title-line--soft">
                Suministro de hielo
              </span>
              <span class="hero__title-line hero__title-line--accent">
                para operaciones comerciales
              </span>
            </h1>
          </div>

          <p class="hero__subtitle">
            Soluciones de suministro para hoteles, restaurantes, eventos y
            operaciones que requieren disponibilidad constante, atención ágil y
            entregas programadas.
          </p>

          <div class="hero__stats" aria-label="Indicadores de confianza">
            <div class="hero__stat">
              <strong>&lt; 24h</strong>
              <span>Respuesta comercial</span>
            </div>
            <div class="hero__stat">
              <strong>Cobertura</strong>
              <span>Atención en Tabasco</span>
            </div>
          </div>
        </div>

        <aside
          class="form-card"
          role="region"
          aria-label="Formulario de cotización corporativa"
        >
          <div class="form-card__chrome" aria-hidden="true">
            <span class="form-card__chrome-orb form-card__chrome-orb--a"></span>
            <span class="form-card__chrome-orb form-card__chrome-orb--b"></span>
          </div>

          <div class="form-card__head">
            <p class="form-card__eyebrow">SOLICITUD CORPORATIVA</p>
            <h2 class="form-card__title">Recibe tu cotización de suministro</h2>
            <p class="form-card__subtitle">
              Te compartimos precios, disponibilidad y tiempo de entrega para tu
              operación.
            </p>
          </div>

          <form
            id="corpQuoteForm"
            class="form"
            method="post"
            action="/api/cotizacion-corporativa"
            novalidate
            data-recaptcha-site-key={recaptchaSiteKey ?? undefined}
            data-recaptcha-action={recaptchaAction}
          >
            <div class="form__honeypot" aria-hidden="true">
              <label for="companyWebsite">Sitio web</label>
              <input
                id="companyWebsite"
                name="company_website"
                type="text"
                tabindex="-1"
                autocomplete="off"
              />
            </div>

            <div class="field field--full">
              <label class="field__label" for="corpName">Nombre o negocio</label
              >
              <input
                class="field__input"
                id="corpName"
                name="name_company"
                type="text"
                autocomplete="organization"
                placeholder="Hotel Vista Mar"
                required
                aria-describedby="corpNameError"
              />
              <p
                class="field__error"
                id="corpNameError"
                role="alert"
                aria-hidden="true"
              >
              </p>
            </div>

            <div class="field">
              <label class="field__label" for="corpPhone">
                Teléfono de contacto
              </label>
              <input
                class="field__input"
                id="corpPhone"
                name="phone"
                type="tel"
                inputmode="tel"
                autocomplete="tel"
                placeholder="993 123 4567"
                required
                aria-describedby="corpPhoneError"
              />
              <p
                class="field__error"
                id="corpPhoneError"
                role="alert"
                aria-hidden="true"
              >
              </p>
            </div>

            <div class="field">
              <label class="field__label" for="corpEmail">
                Correo electrónico <span class="field__badge">opcional</span>
              </label>
              <input
                class="field__input"
                id="corpEmail"
                name="email"
                type="email"
                autocomplete="email"
                placeholder="contacto@empresa.com"
                aria-describedby="corpEmailError"
              />
              <p
                class="field__error"
                id="corpEmailError"
                role="alert"
                aria-hidden="true"
              >
              </p>
            </div>

            <div class="field field--full">
              <label class="field__label" for="corpConsumptionTrigger">
                ¿Cuánto hielo necesitas?
              </label>

              <div class="dropdown" data-open="false">
                <button
                  class="dropdown__trigger"
                  id="corpConsumptionTrigger"
                  type="button"
                  aria-haspopup="listbox"
                  aria-expanded="false"
                  aria-controls="corpConsumptionListbox"
                  aria-describedby="corpConsumptionError"
                >
                  <span
                    id="corpConsumptionValue"
                    class="dropdown__value"
                    data-placeholder="true"
                  >
                    Selecciona una opción
                  </span>

                  <svg
                    class="dropdown__chevron"
                    width="16"
                    height="16"
                    viewBox="0 0 16 16"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path
                      d="M4 6L8 10L12 6"
                      stroke="currentColor"
                      stroke-width="1.7"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </button>

                <input
                  id="corpConsumption"
                  name="consumption"
                  type="hidden"
                  value=""
                  aria-describedby="corpConsumptionError"
                />

                <div
                  class="dropdown__panel"
                  id="corpConsumptionListbox"
                  role="listbox"
                  aria-label="Consumo estimado"
                  hidden
                >
                  <button
                    class="dropdown__option"
                    type="button"
                    role="option"
                    data-value="lt_50"
                    aria-selected="false"
                  >
                    Menos de 50 bolsas / semana
                  </button>
                  <button
                    class="dropdown__option"
                    type="button"
                    role="option"
                    data-value="50_150"
                    aria-selected="false"
                  >
                    50 – 150 bolsas / semana
                  </button>
                  <button
                    class="dropdown__option"
                    type="button"
                    role="option"
                    data-value="gt_150"
                    aria-selected="false"
                  >
                    Más de 150 bolsas / semana
                  </button>
                </div>
              </div>

              <p
                class="field__error"
                id="corpConsumptionError"
                role="alert"
                aria-hidden="true"
              >
              </p>
            </div>

            {recaptchaSiteKey && (
              <div class="field field--full">
                <input type="hidden" name="g-recaptcha-response" value="" data-corp-recaptcha-token />
                <p class="field__error" id="corpRecaptchaError" role="alert" aria-hidden="true">
                </p>
              </div>
            )}

            <button class="btn-submit" type="submit" data-state="idle">
              <span class="btn-submit__text" data-submit-text>Solicitar propuesta</span>

              <span class="btn-submit__glyph" aria-hidden="true">
                <span class="btn-submit__spinner"></span>

                <svg
                  class="btn-submit__icon btn-submit__icon--arrow"
                  width="16"
                  height="16"
                  viewBox="0 0 16 16"
                  fill="none"
                >
                  <path
                    d="M3 8H13M13 8L9 4M13 8L9 12"
                    stroke="currentColor"
                    stroke-width="1.7"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>

                <svg
                  class="btn-submit__icon btn-submit__icon--success"
                  width="18"
                  height="18"
                  viewBox="0 0 18 18"
                  fill="none"
                >
                  <path
                    d="M4 9.4L7.3 12.6L14 5.8"
                    stroke="currentColor"
                    stroke-width="2.1"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>

                <svg
                  class="btn-submit__icon btn-submit__icon--error"
                  width="18"
                  height="18"
                  viewBox="0 0 18 18"
                  fill="none"
                >
                  <path
                    d="M5.4 5.4L12.6 12.6M12.6 5.4L5.4 12.6"
                    stroke="currentColor"
                    stroke-width="2.1"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </span>
            </button>

            <p class="form__legal">
              Sin compromiso · Te contactamos con información comercial clara
            </p>

            <div
              id="corpQuoteStatus"
              class="form__status"
              role="status"
              aria-live="polite"
              hidden
            >
            </div>
          </form>

          <div class="corpModal" data-corp-result-modal hidden>
            <div class="corpModal__overlay" data-corp-modal-close></div>
            <div
              class="corpModal__panel"
              role="dialog"
              aria-modal="true"
              aria-labelledby="corpModalTitle"
              aria-describedby="corpModalMessage"
              tabindex="-1"
            >
              <div class="corpModal__icon" aria-hidden="true">
                <svg
                  class="corpModal__iconSvg corpModal__iconSvg--success"
                  width="44"
                  height="44"
                  viewBox="0 0 44 44"
                  fill="none"
                >
                  <circle
                    cx="22"
                    cy="22"
                    r="18"
                    stroke="currentColor"
                    stroke-width="2"
                    opacity="0.5"></circle>
                  <path
                    d="M14.5 22.6L19.6 27.6L30 17.2"
                    stroke="currentColor"
                    stroke-width="2.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>

                <svg
                  class="corpModal__iconSvg corpModal__iconSvg--error"
                  width="44"
                  height="44"
                  viewBox="0 0 44 44"
                  fill="none"
                >
                  <circle
                    cx="22"
                    cy="22"
                    r="18"
                    stroke="currentColor"
                    stroke-width="2"
                    opacity="0.5"></circle>
                  <path
                    d="M16 16L28 28M28 16L16 28"
                    stroke="currentColor"
                    stroke-width="2.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </div>

              <h3 class="corpModal__title" id="corpModalTitle">Solicitud enviada</h3>
              <p class="corpModal__message" id="corpModalMessage">
                Recibimos tu solicitud correctamente. Nuestro equipo se pondrá en contacto contigo pronto.
              </p>

              <button type="button" class="corpModal__btn" data-corp-modal-close>
                Aceptar
              </button>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <Footer />
  </main>

  <WhatsAppFloat />

  <a href="#inicio" id="back-top" aria-label="Volver arriba">
    <svg
      width="14"
      height="14"
      viewBox="0 0 14 14"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M7 11V3M3.5 6.5L7 3L10.5 6.5"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </a>

  <SiteScripts />

  <style>
    :global(:root) {
      --back-top-size: 42px;
      --back-top-right: 28px;
      --back-top-bottom: 28px;

      --bg: #f3f6fb;
      --surface: rgba(255, 255, 255, 0.74);
      --surface-strong: rgba(255, 255, 255, 0.88);
      --surface-border: rgba(12, 18, 38, 0.14);
      --text: #0b1220;
      --text-soft: rgba(11, 18, 32, 0.74);
      --text-muted: rgba(11, 18, 32, 0.54);
      --line: rgba(11, 18, 32, 0.12);
      --accent: #41abe2;
      --accent-strong: #2c98d3;
      --accent-ring: rgba(65, 171, 226, 0.14);
      --danger: #c93838;

      --out: cubic-bezier(0.22, 0.61, 0.36, 1);
      --spring: cubic-bezier(0.34, 1.52, 0.64, 1);
    }

    * {
      box-sizing: border-box;
    }

    .page {
      min-height: 100vh;
      background:
        radial-gradient(
          1000px 600px at 16% -10%,
          rgba(65, 171, 226, 0.12) 0%,
          rgba(65, 171, 226, 0.03) 46%,
          transparent 70%
        ),
        radial-gradient(
          1200px 760px at 110% 15%,
          rgba(255, 255, 255, 0.72) 0%,
          rgba(255, 255, 255, 0.14) 40%,
          transparent 70%
        ),
        linear-gradient(180deg, #f6f9ff 0%, var(--bg) 42%, #eef3fa 100%);
      color: var(--text);
    }

    .container {
      width: min(1220px, calc(100% - 56px));
      margin: 0 auto;
    }

    .hero {
      position: relative;
      min-height: 100svh;
      display: flex;
      align-items: center;
      overflow: hidden;
      isolation: isolate;
      background: linear-gradient(180deg, #f7f9fc 0%, #eef3f9 100%);
      --hero-mx: 0px;
      --hero-my: 0px;
      --hero-scroll: 0px;
    }

    .hero__bg,
    .hero__image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .hero__bg {
      pointer-events: none;
      z-index: 0;
    }

    .hero__bg::before,
    .hero__bg::after {
      content: "";
      position: absolute;
      inset: -10%;
      pointer-events: none;
      opacity: 0.18;
      background-size: 180% 180%;
      filter: blur(18px) saturate(0.95);
      transform: translate3d(
          calc(var(--hero-mx) * 0.7),
          calc(var(--hero-my) * 0.55 + var(--hero-scroll) * 0.55),
          0
        )
        scale(1.02);
      will-change: transform, opacity, background-position;
    }

    .hero__bg::before {
      background-image:
        radial-gradient(
          700px 420px at 18% 34%,
          rgba(255, 255, 255, 0.16) 0%,
          rgba(255, 255, 255, 0.06) 38%,
          transparent 62%
        ),
        radial-gradient(
          900px 520px at 58% 42%,
          rgba(65, 171, 226, 0.16) 0%,
          rgba(65, 171, 226, 0.05) 44%,
          transparent 68%
        );
      animation: smokeDriftA 26s ease-in-out infinite;
      z-index: 1;
    }

    .hero__bg::after {
      opacity: 0.14;
      background-image:
        radial-gradient(
          820px 540px at 72% 28%,
          rgba(255, 255, 255, 0.12) 0%,
          rgba(255, 255, 255, 0.045) 40%,
          transparent 66%
        ),
        radial-gradient(
          900px 620px at 38% 70%,
          rgba(65, 171, 226, 0.12) 0%,
          rgba(65, 171, 226, 0.04) 48%,
          transparent 70%
        );
      animation: smokeDriftB 34s ease-in-out infinite;
      z-index: 1;
    }

    .hero__focus-gradient {
      position: absolute;
      inset: 0;
      z-index: 2;
      pointer-events: none;
      background:
        linear-gradient(
          90deg,
          rgba(3, 8, 18, 0) 0%,
          rgba(4, 10, 20, 0) 18%,
          rgba(5, 12, 24, 0) 34%,
          rgba(6, 14, 28, 0) 52%,
          rgba(6, 14, 28, 0) 66%,
          rgba(6, 14, 28, 0) 78%,
          rgba(6, 14, 28, 0) 100%
        ),
        linear-gradient(
          90deg,
          rgba(2, 7, 16, 0) 0%,
          rgba(4, 10, 20, 0) 46%,
          rgba(6, 14, 28, 0) 68%,
          rgba(6, 14, 28, 0) 82%,
          rgba(6, 14, 28, 0) 100%
        ),
        radial-gradient(
          760px 560px at 18% 48%,
          rgba(4, 10, 20, 0) 0%,
          rgba(5, 12, 22, 0) 40%,
          rgba(5, 12, 22, 0) 66%,
          transparent 84%
        ),
        radial-gradient(
          780px 520px at 82% 50%,
          rgba(32, 96, 145, 0) 0%,
          rgba(18, 42, 72, 0) 32%,
          rgba(5, 12, 22, 0) 62%,
          transparent 78%
        ),
        linear-gradient(
          180deg,
          rgba(7, 6, 20, 0) 0%,
          rgba(6, 10, 20, 0) 18%,
          rgba(6, 10, 20, 0) 80%,
          rgba(6, 10, 20, 0.44) 100%
        );
      mix-blend-mode: normal;
    }

    .hero:not(.hero--active) .hero__bg::before,
    .hero:not(.hero--active) .hero__bg::after {
      animation-play-state: paused;
    }

    .hero__image {
      object-fit: cover;
      object-position: 72% center;
      filter: brightness(0.6) contrast(1.08) saturate(0.9);
      transform: translate3d(
          calc(var(--hero-mx) * 0.55),
          calc(var(--hero-my) * 0.35 + var(--hero-scroll) * 0.85),
          0
        )
        scale(1.06);
      will-change: transform, filter;
      transition: filter 900ms var(--out);
      z-index: 0;
    }

    .hero__inner {
      position: relative;
      z-index: 3;
      width: 100%;
      display: grid;
      grid-template-columns: minmax(0, 1.12fr) minmax(400px, 470px);
      align-items: center;
      gap: clamp(40px, 5.8vw, 102px);
      padding-top: 108px;
      padding-bottom: 68px;
    }

    #formulario-corporativo {
      scroll-margin-top: 120px;
    }

    .hero__copy {
      position: relative;
      max-width: 640px;
      z-index: 2;
      font-family: "Barlow", sans-serif;
      padding: 14px 0 26px;
    }

    .hero__copy :is(p, span, strong) {
      font-family: inherit;
    }

    .hero__copy::before {
      content: "";
      position: absolute;
      inset: -56px -84px -76px -54px;
      z-index: -1;
      pointer-events: none;
      border-radius: 56px;
      opacity: 0.9;
      -webkit-mask-image: radial-gradient(
        160% 130% at 18% 52%,
        rgba(0, 0, 0, 1) 0%,
        rgba(0, 0, 0, 1) 50%,
        rgba(0, 0, 0, 0.7) 66%,
        rgba(0, 0, 0, 0) 92%
      );
      mask-image: radial-gradient(
        160% 130% at 18% 52%,
        rgba(0, 0, 0, 1) 0%,
        rgba(0, 0, 0, 1) 50%,
        rgba(0, 0, 0, 0.7) 66%,
        rgba(0, 0, 0, 0) 92%
      );
      -webkit-mask-repeat: no-repeat;
      mask-repeat: no-repeat;
      -webkit-mask-size: 100% 100%;
      mask-size: 100% 100%;
      -webkit-mask-position: center;
      mask-position: center;
      background:
        radial-gradient(
          820px 520px at 18% 52%,
          rgba(4, 10, 20, 0.34) 0%,
          rgba(5, 12, 22, 0.18) 48%,
          rgba(5, 12, 22, 0.08) 66%,
          transparent 86%
        ),
        linear-gradient(
          90deg,
          rgba(4, 10, 20, 0.24) 0%,
          rgba(5, 12, 22, 0.14) 58%,
          transparent 84%
        ),
        radial-gradient(
          620px 300px at 24% 46%,
          rgba(5, 12, 22, 0.22) 0%,
          rgba(5, 12, 22, 0.12) 46%,
          rgba(5, 12, 22, 0.05) 68%,
          transparent 86%
        ),
        radial-gradient(
          360px 200px at 24% 20%,
          rgba(143, 216, 255, 0.09) 0%,
          rgba(143, 216, 255, 0.018) 56%,
          transparent 82%
        );
      filter: blur(3.2px);
    }

    .hero__copy > * {
      position: relative;
      z-index: 1;
    }

    .hero__eyebrow {
      margin: 0 0 18px;
      font-family: "Barlow Condensed", sans-serif;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.82);
      text-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
    }

    .hero__title-wrap {
      display: grid;
      gap: 20px;
    }

    .hero__kicker {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      width: fit-content;
      padding: 7px 13px;
      border-radius: 999px;
      border: 1px solid rgba(143, 216, 255, 0.18);
      background: linear-gradient(
        135deg,
        rgba(255, 255, 255, 0.085),
        rgba(255, 255, 255, 0.03)
      );
      backdrop-filter: blur(12px) saturate(1.08);
      -webkit-backdrop-filter: blur(12px) saturate(1.08);
      color: rgba(248, 251, 255, 0.94);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      box-shadow:
        0 12px 28px rgba(0, 0, 0, 0.12),
        inset 0 1px 0 rgba(255, 255, 255, 0.08);
    }

    .hero__title {
      margin: 0;
      display: grid;
      gap: 12px;
      font-family: "Barlow Condensed", sans-serif;
      line-height: 0.88;
      letter-spacing: -0.04em;
      font-weight: 720;
      max-width: 640px;
      text-wrap: balance;
      text-transform: uppercase;
    }

    .hero__title-line {
      display: block;
    }

    .hero__title-line--soft {
      font-size: clamp(3.18rem, 5.15vw, 5.12rem);
      color: #ffffff;
      text-shadow:
        0 18px 38px rgba(0, 0, 0, 0.32),
        0 2px 0 rgba(255, 255, 255, 0.06);
    }

    .hero__title-line--accent {
      font-size: clamp(2.06rem, 3.18vw, 2.86rem);
      color: rgba(248, 251, 255, 0.96);
      letter-spacing: -0.022em;
      font-weight: 600;
      text-shadow:
        0 12px 28px rgba(0, 0, 0, 0.28),
        0 1px 0 rgba(255, 255, 255, 0.04);
      filter: none;
    }

    .hero__subtitle {
      margin: 38px 0 0;
      max-width: 43ch;
      font-size: 1.06rem;
      line-height: 1.86;
      color: rgba(245, 248, 252, 0.92);
      text-shadow: 0 10px 26px rgba(0, 0, 0, 0.28);
      text-wrap: balance;
    }

    .hero__stats {
      display: flex;
      gap: 12px;
      margin-top: 42px;
      flex-wrap: wrap;
    }

    .hero__stat {
      min-width: 122px;
      padding: 12px 14px;
      border-radius: 15px;
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.09) 0%,
          rgba(255, 255, 255, 0.028) 100%
        ),
        rgba(255, 255, 255, 0.024);
      border: 1px solid rgba(255, 255, 255, 0.12);
