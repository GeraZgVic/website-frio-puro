    #back-top {
      position: fixed;
      right: var(--back-top-right);
      bottom: var(--back-top-bottom);
      width: var(--back-top-size);
      height: var(--back-top-size);
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      text-decoration: none;
      color: #ffffff;
      background: linear-gradient(
        180deg,
        rgba(65, 171, 226, 0.98),
        rgba(44, 152, 211, 0.98)
      );
      box-shadow: 0 10px 26px rgba(15, 23, 42, 0.16);
      z-index: 990;
      opacity: 0;
      transform: translateY(8px) scale(0.9);
      transition:
        opacity 0.26s var(--out),
        transform 0.26s var(--spring),
        background 0.18s var(--out);
    }

    #back-top.visible {
      opacity: 1;
      transform: none;
    }

    @media (hover: hover) {
      #back-top:hover {
        background: linear-gradient(
          180deg,
          rgba(65, 171, 226, 1),
          rgba(44, 152, 211, 1)
        );
        transform: translateY(-2px) scale(1.04);
      }
    }

    @media (max-width: 1100px) {
      .hero__inner {
        grid-template-columns: minmax(0, 1.06fr) minmax(370px, 444px);
        gap: 36px;
      }

      .hero__title-line--soft {
        font-size: clamp(2.88rem, 4.55vw, 4.18rem);
      }

      .hero__title-line--accent {
        font-size: clamp(1.94rem, 3vw, 2.56rem);
      }

      .hero__focus-gradient {
        background:
          linear-gradient(
            90deg,
            rgba(3, 8, 18, 0.7) 0%,
            rgba(5, 12, 25, 0.62) 26%,
            rgba(7, 15, 30, 0.46) 52%,
            rgba(7, 15, 30, 0.34) 74%,
