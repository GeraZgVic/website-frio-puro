---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/sections/Header.astro";
import Footer from "../../components/sections/Footer.astro";
import WhatsAppFloat from "../../components/ui/WhatsAppFloat.astro";
import Cursor from "../../components/Cursor.astro";
import SiteScripts from "../../components/SiteScripts.astro";
---

<BaseLayout
  title="Solicitar cotización corporativa | Frío Puro"
  description="Solicitud de cotización corporativa para suministro comercial de alto volumen."
  ogTitle="Solicitar cotización corporativa | Frío Puro"
  ogDescription="Stock permanente y entregas programadas para operación comercial."
>
  <Cursor />
  <Header />
  <script is:inline>
    document.documentElement.classList.add("js");
  </script>

  <main class="page">
    <section id="inicio" class="hero" aria-labelledby="quoteTitle">
      <div class="hero__bg" aria-hidden="true">
        <img
          src="/images/ImaForm.png"
          alt=""
          class="hero__image"
          width="1600"
          height="900"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </div>

      <div class="hero__overlay" aria-hidden="true"></div>

      <div id="formulario-corporativo" class="container hero__inner">
        <div class="hero__copy">
          <p class="hero__eyebrow">FRÍO PURO · CORPORATIVO</p>

          <h1 id="quoteTitle" class="hero__title">
            Suministro de hielo<br />
            para operación comercial
          </h1>

          <p class="hero__subtitle">
            Entregas programadas, stock constante y atención directa para
            negocios que no pueden detener su operación.
          </p>

          <div class="hero__stats" aria-label="Indicadores de confianza">
            <div class="hero__stat">
              <strong>+120</strong>
              <span>negocios activos</span>
            </div>
            <div class="hero__stat">
              <strong>&lt;24h</strong>
              <span>respuesta</span>
            </div>
            <div class="hero__stat">
              <strong>MX</strong>
              <span>cobertura</span>
            </div>
          </div>
        </div>

        <aside
          class="form-card"
          role="region"
          aria-label="Formulario de cotización corporativa"
        >
          <div class="form-card__head">
            <p class="form-card__eyebrow">SOLICITUD CORPORATIVA</p>
            <h2 class="form-card__title">Solicita tu propuesta</h2>
            <p class="form-card__subtitle">Respuesta en menos de 24 horas.</p>
          </div>

          <form
            id="corpQuoteForm"
            class="form"
            method="post"
            action="/api/cotizacion-corporativa"
            novalidate
          >
            <div class="form__honeypot" aria-hidden="true">
              <label for="companyWebsite">Sitio web</label>
              <input
                id="companyWebsite"
                name="company_website"
                type="text"
                tabindex="-1"
                autocomplete="off"
              />
            </div>

            <div class="field field--full">
              <label class="field__label" for="corpName">Nombre o empresa</label
              >
              <input
                class="field__input"
                id="corpName"
                name="name_company"
                type="text"
                autocomplete="organization"
                placeholder="Hotel Vista Mar"
                required
                aria-describedby="corpNameError"
              />
              <p
                class="field__error"
                id="corpNameError"
                role="alert"
                aria-hidden="true"
              >
              </p>
            </div>

            <div class="field">
              <label class="field__label" for="corpPhone">Teléfono</label>
              <input
                class="field__input"
                id="corpPhone"
                name="phone"
                type="tel"
                inputmode="tel"
                autocomplete="tel"
                placeholder="993 123 4567"
                required
                aria-describedby="corpPhoneError"
              />
              <p
                class="field__error"
                id="corpPhoneError"
                role="alert"
                aria-hidden="true"
              >
              </p>
            </div>

            <div class="field">
              <label class="field__label" for="corpEmail">
                Correo <span class="field__badge">opcional</span>
              </label>
              <input
                class="field__input"
                id="corpEmail"
                name="email"
                type="email"
                autocomplete="email"
                placeholder="contacto@empresa.com"
                aria-describedby="corpEmailError"
              />
              <p
                class="field__error"
                id="corpEmailError"
                role="alert"
                aria-hidden="true"
              >
              </p>
            </div>

            <div class="field field--full">
              <label class="field__label" for="corpConsumptionTrigger"
                >Consumo estimado</label
              >
              <div class="dropdown" data-open="false">
                <button
                  class="dropdown__trigger"
                  id="corpConsumptionTrigger"
                  type="button"
                  aria-haspopup="listbox"
                  aria-expanded="false"
                  aria-controls="corpConsumptionListbox"
                  aria-describedby="corpConsumptionError"
                >
                  <span
                    id="corpConsumptionValue"
                    class="dropdown__value"
                    data-placeholder="true">Selecciona una opción</span
                  >
                  <svg
                    class="dropdown__chevron"
                    width="16"
                    height="16"
                    viewBox="0 0 16 16"
                    fill="none"
                    aria-hidden="true"
                  >
                    <path
                      d="M4 6L8 10L12 6"
                      stroke="currentColor"
                      stroke-width="1.7"
                      stroke-linecap="round"
                      stroke-linejoin="round"></path>
                  </svg>
                </button>

                <input
                  id="corpConsumption"
                  name="consumption"
                  type="hidden"
                  value=""
                  aria-describedby="corpConsumptionError"
                />

                <div
                  class="dropdown__panel"
                  id="corpConsumptionListbox"
                  role="listbox"
                  aria-label="Consumo estimado"
                  hidden
                >
                  <button
                    class="dropdown__option"
                    type="button"
                    role="option"
                    data-value="lt_50"
                    aria-selected="false"
                  >
                    Menos de 50 bolsas / semana
                  </button>
                  <button
                    class="dropdown__option"
                    type="button"
                    role="option"
                    data-value="50_150"
                    aria-selected="false"
                  >
                    50 – 150 bolsas / semana
                  </button>
                  <button
                    class="dropdown__option"
                    type="button"
                    role="option"
                    data-value="gt_150"
                    aria-selected="false"
                  >
                    Más de 150 bolsas / semana
                  </button>
                </div>
              </div>
              <p
                class="field__error"
                id="corpConsumptionError"
                role="alert"
                aria-hidden="true"
              >
              </p>
            </div>

            <button class="btn-submit" type="submit">
              <span>Solicitar propuesta</span>
              <svg
                width="16"
                height="16"
                viewBox="0 0 16 16"
                fill="none"
                aria-hidden="true"
              >
                <path
                  d="M3 8H13M13 8L9 4M13 8L9 12"
                  stroke="currentColor"
                  stroke-width="1.7"
                  stroke-linecap="round"
                  stroke-linejoin="round"></path>
              </svg>
            </button>

            <p class="form__legal">
              Sin compromiso · Atención comercial directa
            </p>

            <div
              id="corpQuoteStatus"
              class="form__status"
              role="status"
              aria-live="polite"
              hidden
            >
            </div>
          </form>
        </aside>
      </div>
    </section>
    <Footer />
  </main>

  <WhatsAppFloat />

  <a href="#inicio" id="back-top" aria-label="Volver arriba">
    <svg
      width="14"
      height="14"
      viewBox="0 0 14 14"
      fill="none"
      aria-hidden="true"
    >
      <path
        d="M7 11V3M3.5 6.5L7 3L10.5 6.5"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </a>

  <SiteScripts />

  <style>
    :global(:root) {
      --back-top-size: 42px;
      --back-top-right: 28px;
      --back-top-bottom: 28px;

      /* Light premium palette (airy + refined, not flat white) */
      --bg: #f3f6fb;
      --surface: rgba(255, 255, 255, 0.74);
      --surface-strong: rgba(255, 255, 255, 0.88);
      --surface-border: rgba(12, 18, 38, 0.14);
      --text: #0b1220;
      --text-soft: rgba(11, 18, 32, 0.74);
      --text-muted: rgba(11, 18, 32, 0.54);
      --line: rgba(11, 18, 32, 0.12);
      --accent: #41abe2;
      --accent-strong: #2c98d3;
      --accent-ring: rgba(65, 171, 226, 0.14);
      --danger: #c93838;

      --out: cubic-bezier(0.22, 0.61, 0.36, 1);
      --spring: cubic-bezier(0.34, 1.52, 0.64, 1);
    }

    * {
      box-sizing: border-box;
    }

    .page {
      min-height: 100vh;
      background:
        radial-gradient(
          1000px 600px at 16% -10%,
          rgba(65, 171, 226, 0.12) 0%,
          rgba(65, 171, 226, 0.03) 46%,
          transparent 70%
        ),
        radial-gradient(
          1200px 760px at 110% 15%,
          rgba(255, 255, 255, 0.72) 0%,
          rgba(255, 255, 255, 0.14) 40%,
          transparent 70%
        ),
        linear-gradient(180deg, #f6f9ff 0%, var(--bg) 42%, #eef3fa 100%);
      color: var(--text);
    }

    .container {
      width: min(1180px, calc(100% - 48px));
      margin: 0 auto;
    }

    .hero {
      position: relative;
      min-height: 100svh;
      display: flex;
      align-items: center;
      overflow: hidden;
      isolation: isolate;
      background: linear-gradient(180deg, #f7f9fc 0%, #eef3f9 100%);
      --hero-mx: 0px;
      --hero-my: 0px;
      --hero-scroll: 0px;
    }

    .hero__bg,
    .hero__image {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }

    .hero__bg {
      pointer-events: none;
      z-index: 0;
    }

    .hero__bg::before,
    .hero__bg::after {
      content: "";
      position: absolute;
      inset: -10%;
      pointer-events: none;
      opacity: 0.18;
      background-size: 180% 180%;
      filter: blur(18px) saturate(0.95);
      transform: translate3d(
          calc(var(--hero-mx) * 0.7),
          calc(var(--hero-my) * 0.55 + var(--hero-scroll) * 0.55),
          0
        )
        scale(1.02);
      will-change: transform, opacity, background-position;
    }

    .hero__bg::before {
      background-image:
        radial-gradient(
          700px 420px at 18% 34%,
          rgba(255, 255, 255, 0.16) 0%,
          rgba(255, 255, 255, 0.06) 38%,
          transparent 62%
        ),
        radial-gradient(
          900px 520px at 58% 42%,
          rgba(65, 171, 226, 0.16) 0%,
          rgba(65, 171, 226, 0.05) 44%,
          transparent 68%
        );
      animation: smokeDriftA 26s ease-in-out infinite;
    }

    .hero__bg::after {
      opacity: 0.14;
      background-image:
        radial-gradient(
          820px 540px at 72% 28%,
          rgba(255, 255, 255, 0.12) 0%,
          rgba(255, 255, 255, 0.045) 40%,
          transparent 66%
        ),
        radial-gradient(
          900px 620px at 38% 70%,
          rgba(65, 171, 226, 0.12) 0%,
          rgba(65, 171, 226, 0.04) 48%,
          transparent 70%
        );
      animation: smokeDriftB 34s ease-in-out infinite;
    }

    .hero:not(.hero--active) .hero__bg::before,
    .hero:not(.hero--active) .hero__bg::after {
      animation-play-state: paused;
    }

    .hero__image {
      object-fit: cover;
      object-position: 72% center;
      filter: brightness(0.7) contrast(1.05) saturate(0.9);
      transform: translate3d(
          calc(var(--hero-mx) * 0.55),
          calc(var(--hero-my) * 0.35 + var(--hero-scroll) * 0.85),
          0
        )
        scale(1.06);
      will-change: transform, filter;
      transition: filter 900ms var(--out);
    }

    .hero__overlay {
      position: absolute;
      inset: 0;
      z-index: 1;
      background: linear-gradient(
        90deg,
        rgba(0, 0, 0, 0.75) 0%,
        rgba(0, 0, 0, 0.55) 40%,
        rgba(0, 0, 0, 0.25) 70%,
        transparent 100%
      );
      opacity: 0.92;
      transition: opacity 700ms var(--out);
    }

    .hero__inner {
      position: relative;
      z-index: 2;
      width: 100%;
      display: grid;
      grid-template-columns: minmax(0, 640px) minmax(380px, 460px);
      justify-content: space-between;
      align-items: center;
      gap: clamp(28px, 4vw, 68px);
      padding-top: 92px;
      padding-bottom: 54px;
    }

    #formulario-corporativo {
      scroll-margin-top: 120px;
    }

    .hero__copy {
      position: relative;
      max-width: 610px;
    }

    .hero__copy::before {
      display: none;
    }

    .hero__eyebrow {
      margin: 0 0 18px;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, 0.6);
    }

    .hero__title {
      margin: 0;
      color: #ffffff;
      font-size: clamp(3rem, 5vw, 4.45rem);
      line-height: 1.08;
      letter-spacing: -0.02em;
      font-weight: 680;
      max-width: 620px;
      text-wrap: balance;
    }

    .hero__subtitle {
      margin: 22px 0 0;
      max-width: 40ch;
      font-size: 1.02rem;
      line-height: 1.72;
      color: rgba(255, 255, 255, 0.82);
    }

    .hero__stats {
      display: flex;
      gap: 12px;
      margin-top: 30px;
      flex-wrap: wrap;
    }

    .hero__stat {
      min-width: 112px;
      padding: 12px 14px;
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      display: flex;
      flex-direction: column;
      gap: 6px;
    }

    .hero__stat strong {
      display: block;
      color: #ffffff;
      font-size: 1.5rem;
      line-height: 1;
      letter-spacing: -0.05em;
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }

    .hero__stat span {
      display: block;
      font-size: 0.72rem;
      color: rgba(255, 255, 255, 0.6);
    }

    /* Form theme rollback (scoped variables so hero stays light) */
    .form-card {
      --surface-border: rgba(255, 255, 255, 0.12);
      --text: #ffffff;
      --text-soft: rgba(255, 255, 255, 0.78);
      --text-muted: rgba(255, 255, 255, 0.58);
      --line: rgba(255, 255, 255, 0.12);
      --accent: #8fd8ff;
      --accent-strong: #bde9ff;
      --accent-ring: rgba(143, 216, 255, 0.18);
      --focus: #2fa4ff;
      --focus-ring: rgba(47, 164, 255, 0.25);
      --danger: #ff9a9a;

      color: var(--text);
    }

    .form-card {
      width: 100%;
      padding: 26px;
      border-radius: 22px;
      border: 1px solid rgba(255, 255, 255, 0.08);
      background: rgba(20, 30, 50, 0.55);
      box-shadow:
        0 20px 60px rgba(0, 0, 0, 0.5),
        inset 0 1px 0 rgba(255, 255, 255, 0.05);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
    }

    .form-card__head {
      margin-bottom: 18px;
    }

    .form-card__eyebrow {
      margin: 0 0 8px;
      font-size: 0.66rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
    }

    .form-card__title {
      margin: 0;
      font-size: clamp(1.7rem, 2.2vw, 2.15rem);
      line-height: 1.04;
      letter-spacing: -0.045em;
      font-weight: 660;
    }

    .form-card__subtitle {
      margin: 8px 0 0;
      color: var(--text-soft);
      font-size: 0.92rem;
      line-height: 1.55;
    }

    .form {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
    }

    .form__honeypot {
      position: absolute;
      left: -9999px;
      width: 1px;
      height: 1px;
      overflow: hidden;
    }

    .field {
      display: flex;
      flex-direction: column;
      position: relative;
      z-index: 0;
    }

    .field[data-dropdown-open="true"] {
      z-index: 120;
    }

    .field--full {
      grid-column: 1 / -1;
    }

    .field__label {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 8px;
      font-size: 0.78rem;
      font-weight: 620;
      letter-spacing: 0.01em;
      color: rgba(255, 255, 255, 0.84);
    }

    .field__badge {
      padding: 2px 7px;
      border-radius: 999px;
      border: 1px solid var(--line);
      font-size: 0.6rem;
      color: rgba(255, 255, 255, 0.62);
      background: rgba(10, 16, 28, 0.18);
    }

    .field__input {
      width: 100%;
      height: 48px;
      border-radius: 14px;
      border: 1px solid rgba(255, 255, 255, 0.14);
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.06) 0%,
          rgba(255, 255, 255, 0.025) 100%
        ),
        rgba(10, 16, 28, 0.26);
      color: var(--text);
      padding: 0 15px;
      font-size: 0.94rem;
      outline: none;
      caret-color: var(--accent);
      transition:
        border-color 0.18s var(--out),
        box-shadow 0.18s var(--out),
        background 0.18s var(--out),
        transform 0.18s var(--out);
      box-shadow: 0 1px 0 rgba(255, 255, 255, 0.06) inset;
    }

    .field__input::placeholder {
      color: rgba(255, 255, 255, 0.42);
    }

    .field__input:hover {
      border-color: rgba(255, 255, 255, 0.22);
    }

    .field__input:focus-visible {
      border-color: var(--focus);
      box-shadow: 0 0 0 2px var(--focus-ring);
    }

    .dropdown {
      position: relative;
      z-index: 0;
    }

    .dropdown[data-open="true"] {
      z-index: 60;
    }

    .dropdown__trigger {
      width: 100%;
      height: 48px;
      border-radius: 14px;
      border: 1px solid rgba(255, 255, 255, 0.14);
      background:
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.06) 0%,
          rgba(255, 255, 255, 0.025) 100%
        ),
        rgba(10, 16, 28, 0.26);
      color: var(--text);
      padding: 0 14px 0 15px;
      display: inline-flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      font-size: 0.94rem;
      line-height: 1;
      text-align: left;
      cursor: pointer;
      user-select: none;
      transition:
        border-color 0.18s var(--out),
        box-shadow 0.18s var(--out),
        background 0.18s var(--out),
        transform 0.18s var(--out);
      box-shadow: 0 1px 0 rgba(255, 255, 255, 0.05) inset;
    }

    .dropdown__trigger:hover {
      border-color: rgba(255, 255, 255, 0.22);
    }

    .dropdown__trigger:focus-visible {
      outline: none;
      border-color: var(--focus);
      box-shadow: 0 0 0 2px var(--focus-ring);
    }

    .dropdown[data-open="true"] .dropdown__trigger {
      border-color: rgba(47, 164, 255, 0.42);
      box-shadow:
        0 0 0 2px rgba(47, 164, 255, 0.18),
        0 1px 0 rgba(255, 255, 255, 0.05) inset;
    }

    .dropdown__value {
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    .dropdown__value[data-placeholder="true"] {
      color: rgba(255, 255, 255, 0.5);
    }

    .dropdown__chevron {
      flex: 0 0 auto;
      color: rgba(255, 255, 255, 0.6);
      transition: transform 0.22s var(--out);
    }

    .dropdown[data-open="true"] .dropdown__chevron {
      transform: rotate(180deg);
    }

    .dropdown__panel {
      position: absolute;
      left: 0;
      right: 0;
      top: calc(100% + 10px);
      padding: 8px;
      border-radius: 16px;
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(10, 16, 28, 0.88);
      backdrop-filter: blur(18px) saturate(1.2);
      -webkit-backdrop-filter: blur(18px) saturate(1.2);
      box-shadow:
        0 40px 120px rgba(0, 0, 0, 0.7),
        0 10px 40px rgba(0, 0, 0, 0.4),
        0 0 0 1px rgba(255, 255, 255, 0.06) inset;
      transform: translateY(4px);
      opacity: 0;
      pointer-events: none;
      z-index: 80;
      transition:
        opacity 0.18s cubic-bezier(0.22, 0.61, 0.36, 1),
        transform 0.18s cubic-bezier(0.22, 0.61, 0.36, 1);
    }

    .dropdown[data-open="true"] .dropdown__panel {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }

    .dropdown__option {
      width: 100%;
      border: none;
      border-radius: 12px;
      padding: 12px 12px;
      background: transparent;
      color: rgba(255, 255, 255, 0.92);
      text-align: left;
      font-size: 0.92rem;
      line-height: 1.3;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      transition:
        background 0.16s var(--out),
        color 0.16s var(--out);
    }

    .dropdown__option::after {
      content: "";
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: var(--accent);
      box-shadow: 0 0 0 4px rgba(143, 216, 255, 0.12);
      opacity: 0;
      transform: scale(0.9);
      transition:
        opacity 0.16s var(--out),
        transform 0.16s var(--out);
      flex: 0 0 auto;
    }

    .dropdown__option:hover {
      background: rgba(65, 171, 226, 0.22);
      color: rgba(255, 255, 255, 0.95);
    }

    .dropdown__option:focus-visible {
      outline: none;
      background: rgba(143, 216, 255, 0.1);
    }

    .dropdown__option[aria-selected="true"] {
      background: rgba(65, 171, 226, 0.28);
    }

    .dropdown__option[aria-selected="true"]::after {
      opacity: 1;
      transform: scale(1);
    }

    .field__error {
      min-height: 1em;
      margin: 6px 0 0;
      font-size: 0.72rem;
      color: var(--danger);
    }

    .field[data-invalid="true"] .field__input {
      border-color: rgba(255, 154, 154, 0.55);
      box-shadow: 0 0 0 4px rgba(255, 154, 154, 0.08);
    }

    .field[data-invalid="true"] .dropdown__trigger {
      border-color: rgba(255, 154, 154, 0.55);
