---
export interface Props {
	as?: "h1" | "h2" | "h3";
	className?: string;
}

const { as: rawAs = "h2", className = "" } = Astro.props;

const sizes = {
	h1: "text-4xl sm:text-5xl lg:text-6xl",
	h2: "text-3xl sm:text-4xl lg:text-5xl",
	h3: "text-2xl sm:text-3xl lg:text-4xl"
};

const as = (rawAs in sizes ? rawAs : "h2") as keyof typeof sizes;
const Tag = as;
const classes = `${sizes[as]} text-[var(--color-text-strong)] ${className}`;
---

<Tag class={classes}>
	<slot />
</Tag>
