---
import { buildWhatsAppUrl, commercialContent } from "../../config/commercial";
---

<div class="mobile-menu" id="mobileMenu" aria-hidden="true">
  <a href="#inicio" class="mobile-link">Inicio</a>
  <a href="#nosotros" class="mobile-link">Nosotros</a>
  <a href="#productos" class="mobile-link">Productos</a>
  <a href="#cobertura" class="mobile-link">Cobertura</a>
  <a href="#contacto" class="mobile-link">Contacto</a>
</div>

<header id="navbar">
  <div class="max-w-xs">
    <a href="#inicio" class="header-logo-link">
      <img class="w-auto h-16" src="/images/FrioPuroLogo.png" alt="Frío Puro" />
    </a>
  </div>

  <nav>
    <ul>
      <li><a href="#inicio" class="nav-link">Inicio</a></li>
      <li><a href="#nosotros" class="nav-link">Nosotros</a></li>
      <li><a href="#productos" class="nav-link">Productos</a></li>
      <li><a href="#cobertura" class="nav-link">Puntos de Venta</a></li>
      <li><a href="#contacto" class="nav-link">Contacto</a></li>
    </ul>
  </nav>

  <a
    href={buildWhatsAppUrl()}
    target="_blank"
    rel="noopener noreferrer"
    class="btn-whatsapp"
  >
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
      ></path>
    </svg>
    {commercialContent.ctas.header}
  </a>

  <button
    class="hamburger"
    id="hamburger"
    type="button"
    aria-controls="mobileMenu"
    aria-expanded="false"
    aria-label="Abrir menú"
  >
    <span></span><span></span><span></span>
  </button>
</header>

<style>
  #navbar,
  .mobile-menu {
    box-sizing: border-box;
  }

  #navbar {
    position: fixed;
    top: 10px;
    left: 50%;
    right: auto;
    transform: translateX(-50%);
    z-index: 1000;
    width: min(1200px, calc(100% - 24px));
    padding: 1px 13px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    min-height: 70px;
    background: linear-gradient(
      180deg,
      rgba(50, 59, 129, 0.1) 0%,
      rgba(26, 31, 78, 0.06) 100%
    );
    border: 1px solid rgba(157, 212, 242, 0.08);
    border-radius: 999px;
    box-shadow: 0 6px 18px rgba(9, 12, 40, 0.08);
    backdrop-filter: blur(3px) saturate(104%);
    -webkit-backdrop-filter: blur(3px) saturate(104%);
    overflow: hidden;
    isolation: isolate;
    will-change: transform, box-shadow;
    transition:
      background 0.4s ease,
      backdrop-filter 0.4s ease,
      padding 0.4s ease,
      box-shadow 0.4s ease,
      border-color 0.4s ease,
      transform 0.4s ease;
  }

  #navbar::before,
  #navbar::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition:
      opacity 0.5s ease,
      transform 0.6s ease;
    z-index: 0;
  }

  #navbar::before {
    background: linear-gradient(
      120deg,
      rgba(255, 255, 255, 0.08),
      rgba(255, 255, 255, 0) 40%,
      rgba(65, 171, 226, 0.05) 70%,
      rgba(255, 255, 255, 0) 100%
    );
    opacity: 0;
    transform: translateY(-16%);
  }

  #navbar::after {
    background:
      radial-gradient(
        140% 110% at 50% -20%,
        rgba(255, 255, 255, 0.08),
        rgba(255, 255, 255, 0) 62%
      ),
      radial-gradient(
        120% 90% at 85% 10%,
        rgba(65, 171, 226, 0.05),
        rgba(255, 255, 255, 0) 65%
      );
    opacity: 0;
  }

  #navbar > * {
    position: relative;
    z-index: 1;
  }

  #navbar.scrolled {
    background: linear-gradient(
      180deg,
      rgba(50, 59, 129, 0.68) 0%,
      rgba(26, 31, 78, 0.82) 100%
    );
    backdrop-filter: blur(14px) saturate(125%);
    -webkit-backdrop-filter: blur(14px) saturate(125%);
    border-color: rgba(157, 212, 242, 0.22);
    box-shadow:
      0 18px 44px rgba(9, 12, 40, 0.3),
      0 1px 0 rgba(255, 255, 255, 0.07) inset;
  }

  #navbar.scrolled::before,
  #navbar.scrolled::after {
    opacity: 1;
    transform: translateY(0);
  }

  .header-logo-link {
    display: inline-flex;
    align-items: center;
    line-height: 0;
    flex-shrink: 0;
  }

  .header-logo-link img {
    width: auto;
    height: 3.5rem;
  }

  nav ul {
    list-style: none;
    display: flex;
    gap: clamp(18px, 3vw, 36px);
    align-items: center;
    flex-wrap: nowrap;
  }

  nav ul li a {
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-family: "Barlow", sans-serif;
    font-weight: 600;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    position: relative;
    transition: color var(--transition);
  }

  nav ul li a::after {
    content: "";
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-accent);
    transition: width 0.3s ease;
  }

  nav ul li a:hover {
    color: var(--color-white);
  }

  nav ul li a:hover::after {
    width: 100%;
  }

  nav ul li a.active {
    color: var(--color-accent);
  }

  nav ul li a.active::after {
    width: 100%;
  }

  .btn-whatsapp {
    background: var(--color-accent);
    color: var(--color-white);
    padding: 9px 20px;
    border-radius: 50px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    font-family: "Barlow", sans-serif;
    font-weight: 600;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
    transition: all var(--transition);
    box-shadow: 0 2px 10px rgba(65, 171, 226, 0.26);
  }

  .btn-whatsapp:hover {
    background: #25d366;
    box-shadow: 0 6px 25px rgba(37, 211, 102, 0.5);
    transform: translateY(-2px);
  }

  .btn-whatsapp svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 5px;
    background: none;
    border: none;
  }

  .hamburger span {
    display: block;
    width: 25px;
    height: 2px;
    background: var(--color-white);
    transition: all 0.35s ease;
    border-radius: 2px;
  }

  .hamburger.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger.open span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .hamburger.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(26, 31, 78, 0.98);
    z-index: 999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(18px, 4vw, 34px);
    opacity: 0;
    transform: translateY(-8px);
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.35s ease,
      transform 0.35s ease,
      visibility 0.35s ease;
  }

  .mobile-menu.open {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  .mobile-menu a {
    color: var(--color-white);
    text-decoration: none;
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(1.9rem, 7vw, 2.6rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: clamp(2px, 0.8vw, 3px);
    transition: color var(--transition);
  }

  .mobile-menu a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    #navbar {
      top: 8px;
      width: calc(100% - 16px);
      padding-left: clamp(12px, 3.2vw, 18px);
      padding-right: clamp(12px, 3.2vw, 18px);
      min-height: 64px;
      gap: 10px;
      background: linear-gradient(
        180deg,
        rgba(50, 59, 129, 0.08) 0%,
        rgba(26, 31, 78, 0.05) 100%
      );
      border-color: rgba(157, 212, 242, 0.07);
      box-shadow: 0 5px 14px rgba(9, 12, 40, 0.07);
      backdrop-filter: blur(2px) saturate(103%);
      -webkit-backdrop-filter: blur(2px) saturate(103%);
    }

    #navbar.scrolled {
      backdrop-filter: blur(10px) saturate(112%);
      -webkit-backdrop-filter: blur(10px) saturate(112%);
    }

    #navbar.scrolled::before,
    #navbar.scrolled::after {
      opacity: 0.6;
    }

    nav ul,
    .btn-whatsapp {
      display: none;
    }

    .hamburger {
      display: flex;
    }
  }

  @media (max-width: 360px) {
    #navbar {
      padding-left: 10px;
      padding-right: 10px;
      min-height: 70px;
    }

    .header-logo-link img {
      height: 2.3rem;
    }

    .hamburger span {
      width: 24px;
    }

    .mobile-menu a {
      font-size: 1.8rem;
      letter-spacing: 2px;
    }
  }
</style>
