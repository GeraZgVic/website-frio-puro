---
import { commercialContent } from "../../config/commercial";
---

<div
  class="mobile-menu"
  id="mobileMenu"
  aria-hidden="true"
  role="navigation"
  aria-label="Navegación móvil"
>
  <a href="#inicio" class="mobile-link">Inicio</a>
  <a href="#clientes" class="mobile-link">Clientes</a>
  <a href="#productos" class="mobile-link">Productos</a>
  <a href="#proceso" class="mobile-link">Proceso de producción</a>
  <a href="#contacto" class="mobile-link">Contacto</a>
</div>

<header id="navbar">
  <div class="max-w-xs">
    <a href="#inicio" class="header-logo-link">
      <img class="w-auto h-16" src="/images/FrioPuroLogo.png" alt="Frío Puro" />
    </a>
  </div>

  <nav aria-label="Navegación principal" class="nav-desktop">
    <ul class="nav-list" data-nav-list>
      <li><a href="#inicio" class="nav-link">Inicio</a></li>
      <li><a href="#clientes" class="nav-link">Clientes</a></li>
      <li><a href="#productos" class="nav-link">Productos</a></li>
      <li><a href="#proceso" class="nav-link">Proceso de producción</a></li>
      <li><a href="#contacto" class="nav-link">Contacto</a></li>
    </ul>
    <span class="nav-indicator" data-nav-indicator aria-hidden="true"></span>
  </nav>

  <a
    href="/cotizacion-corporativa"
    class="btn-whatsapp"
  >
    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M9 2a2 2 0 0 0-2 2H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-1a2 2 0 0 0-2-2H9zm0 2h6v2H9V4zm1 7h8v2h-8v-2zm0 4h8v2h-8v-2z"
      ></path>
    </svg>
    {commercialContent.ctas.header}
  </a>

  <button
    class="hamburger"
    id="hamburger"
    type="button"
    aria-controls="mobileMenu"
    aria-expanded="false"
    aria-label="Abrir menú"
  >
    <span></span><span></span><span></span>
  </button>
</header>

<style>
  #navbar,
  .mobile-menu {
    box-sizing: border-box;
  }

  #navbar {
    --nav-scroll: 0;
    --nav-solid-boost: 0;
    --nav-elevate: 0;
    --nav-mode-blend: 0;
    --nav-text-blend: 0;

    --nav-ink: rgba(255, 255, 255, 0.92);
    --nav-link: rgba(255, 255, 255, 0.85);

    --nav-border-rgb: 150 202 232;
    --nav-bg-top-rgb: 44 54 118;
    --nav-bg-bottom-rgb: 22 28 70;
    --nav-shadow-rgb: 8 11 34;
    --nav-glow-rgb: 65 171 226;

    --nav-cta-bg: var(--color-accent);
    --nav-cta-ink: var(--color-white);
    --nav-cta-border: rgba(255, 255, 255, 0.08);
    --nav-cta-shadow-alpha: 0.22;

    position: fixed;
    top: 10px;
    left: 50%;
    right: auto;
    transform: translateX(-50%);
    z-index: 1000;
    width: min(1200px, calc(100% - 24px));
    padding: 1px 13px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    min-height: 70px;
    background: linear-gradient(
      180deg,
      rgb(var(--nav-bg-top-rgb) /
            calc(0.1 + var(--nav-solid-boost) + var(--nav-scroll) * 0.58)) 0%,
      rgb(var(--nav-bg-bottom-rgb) /
            calc(0.06 + var(--nav-solid-boost) + var(--nav-scroll) * 0.76))
        100%
    );
    border: 1px solid
      rgb(var(--nav-border-rgb) / calc(0.08 + var(--nav-scroll) * 0.14));
    border-radius: 999px;
    box-shadow:
      0 6px 18px
        rgb(
          var(--nav-shadow-rgb) /
            calc(0.08 + var(--nav-scroll) * 0.16 + var(--nav-elevate) * 0.1)
        ),
      0 1px 0
        rgb(255 255 255 / calc(0.06 + var(--nav-scroll) * 0.1)) inset;
    backdrop-filter: blur(calc(3px + var(--nav-scroll) * 11px))
      saturate(calc(104% + var(--nav-scroll) * 46%));
    -webkit-backdrop-filter: blur(calc(3px + var(--nav-scroll) * 11px))
      saturate(calc(104% + var(--nav-scroll) * 46%));
    overflow: hidden;
    isolation: isolate;
    will-change: transform;
    transition:
      background 0.65s cubic-bezier(0.22, 1, 0.36, 1),
      backdrop-filter 0.65s cubic-bezier(0.22, 1, 0.36, 1),
      -webkit-backdrop-filter 0.65s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.55s cubic-bezier(0.22, 1, 0.36, 1);
  }

  #navbar.nav--glass {
    --nav-solid-boost: 0;
  }

  #navbar.nav--solid {
    --nav-solid-boost: 0.12;
  }

  #navbar.nav--elevated {
    --nav-elevate: 1;
  }

  #navbar[data-nav-mode="light"] {
    --nav-ink: rgba(18, 26, 56, 0.92);
    --nav-link: rgba(18, 26, 56, 0.72);

    --nav-border-rgb: 18 26 56;
    --nav-bg-top-rgb: 252 253 255;
    --nav-bg-bottom-rgb: 242 247 255;
    --nav-shadow-rgb: 8 14 34;

    --nav-cta-border: rgba(18, 26, 56, 0.1);
    --nav-cta-shadow-alpha: 0.16;
  }

  @supports (background: color-mix(in srgb, white, black)) {
    #navbar {
      --nav-ink-dark: rgba(255, 255, 255, 0.92);
      --nav-ink-light: rgba(18, 26, 56, 0.92);
      --nav-link-dark: rgba(255, 255, 255, 0.85);
      --nav-link-light: rgba(18, 26, 56, 0.72);

      --nav-border-dark: rgb(150 202 232);
      --nav-border-light: rgb(18 26 56);

      --nav-bg-top-dark: rgb(44 54 118);
      --nav-bg-top-light: rgb(252 253 255);
      --nav-bg-bottom-dark: rgb(22 28 70);
      --nav-bg-bottom-light: rgb(242 247 255);

      --nav-shadow-dark: rgb(8 11 34);
      --nav-shadow-light: rgb(8 14 34);

      --nav-ink: color-mix(
        in srgb,
        var(--nav-ink-dark) calc((1 - var(--nav-text-blend)) * 100%),
        var(--nav-ink-light) calc(var(--nav-text-blend) * 100%)
      );

      --nav-link: color-mix(
        in srgb,
        var(--nav-link-dark) calc((1 - var(--nav-text-blend)) * 100%),
        var(--nav-link-light) calc(var(--nav-text-blend) * 100%)
      );

      --nav-border-solid: color-mix(
        in srgb,
        var(--nav-border-dark) calc((1 - var(--nav-mode-blend)) * 100%),
        var(--nav-border-light) calc(var(--nav-mode-blend) * 100%)
      );

      --nav-bg-top-solid: color-mix(
        in srgb,
        var(--nav-bg-top-dark) calc((1 - var(--nav-mode-blend)) * 100%),
        var(--nav-bg-top-light) calc(var(--nav-mode-blend) * 100%)
      );

      --nav-bg-bottom-solid: color-mix(
        in srgb,
        var(--nav-bg-bottom-dark) calc((1 - var(--nav-mode-blend)) * 100%),
        var(--nav-bg-bottom-light) calc(var(--nav-mode-blend) * 100%)
      );

      --nav-shadow-solid: color-mix(
        in srgb,
        var(--nav-shadow-dark) calc((1 - var(--nav-mode-blend)) * 100%),
        var(--nav-shadow-light) calc(var(--nav-mode-blend) * 100%)
      );

      --nav-tone-dampen: calc(1 - var(--nav-mode-blend) * 0.12);
      --nav-bg-top-alpha: calc(
        (0.105 + var(--nav-solid-boost) + var(--nav-scroll) * 0.54) * var(--nav-tone-dampen)
      );
      --nav-bg-bottom-alpha: calc(
        (0.07 + var(--nav-solid-boost) + var(--nav-scroll) * 0.7) * var(--nav-tone-dampen)
      );
      --nav-border-alpha: calc((0.075 + var(--nav-scroll) * 0.12) * var(--nav-tone-dampen));
      --nav-shadow-alpha: calc(
        (0.075 + var(--nav-scroll) * 0.14 + var(--nav-elevate) * 0.09) *
          (1 - var(--nav-mode-blend) * 0.18)
      );
      --nav-inset-alpha: calc((0.06 + var(--nav-scroll) * 0.085) * var(--nav-tone-dampen));

      --nav-cta-shadow-alpha: calc(0.2 - var(--nav-mode-blend) * 0.05);
      --nav-cta-border: color-mix(
        in srgb,
        rgba(255 255 255 / 0.08) calc((1 - var(--nav-mode-blend)) * 100%),
        rgba(18 26 56 / 0.1) calc(var(--nav-mode-blend) * 100%)
      );

      background: linear-gradient(
        180deg,
        color-mix(
          in srgb,
          var(--nav-bg-top-solid) calc(var(--nav-bg-top-alpha) * 100%),
          transparent
        )
          0%,
        color-mix(
          in srgb,
          var(--nav-bg-bottom-solid) calc(var(--nav-bg-bottom-alpha) * 100%),
          transparent
        )
          100%
      );

      border-color: color-mix(
        in srgb,
        var(--nav-border-solid) calc(var(--nav-border-alpha) * 100%),
        transparent
      );

      box-shadow:
        0 6px 18px
          color-mix(
            in srgb,
            var(--nav-shadow-solid) calc(var(--nav-shadow-alpha) * 100%),
            transparent
          ),
        0 1px 0
          color-mix(
            in srgb,
            rgb(255 255 255) calc(var(--nav-inset-alpha) * 100%),
            transparent
          )
          inset;
    }
  }

  #navbar::before,
  #navbar::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition:
      opacity 0.5s ease,
      transform 0.6s ease;
    z-index: 0;
  }

  #navbar::before {
    background: linear-gradient(
      120deg,
      rgba(255, 255, 255, 0.08),
      rgba(255, 255, 255, 0) 40%,
      rgba(65, 171, 226, 0.05) 70%,
      rgba(255, 255, 255, 0) 100%
    );
    opacity: calc(
      (0.06 + var(--nav-scroll) * 0.58 + var(--nav-elevate) * 0.08) *
        (1 - var(--nav-mode-blend) * 0.42)
    );
    transform: translateY(calc(-16% + var(--nav-scroll) * 16%));
  }

  #navbar::after {
    background:
      radial-gradient(
        140% 110% at 50% -20%,
        rgba(255, 255, 255, 0.08),
        rgba(255, 255, 255, 0) 62%
      ),
      radial-gradient(
        120% 90% at 85% 10%,
        rgba(65, 171, 226, 0.05),
        rgba(255, 255, 255, 0) 65%
      );
    opacity: calc(
      (0.04 + var(--nav-scroll) * 0.44 + var(--nav-elevate) * 0.06) *
        (1 - var(--nav-mode-blend) * 0.38)
    );
  }

  #navbar > * {
    position: relative;
    z-index: 1;
  }

  #navbar.scrolled {
    --nav-solid-boost: 0.15;
  }

  .header-logo-link {
    display: inline-flex;
    align-items: center;
    line-height: 0;
    flex-shrink: 0;
  }

  .header-logo-link img {
    width: auto;
    height: 3.5rem;
  }

  .nav-desktop {
    position: relative;
  }

  .nav-list {
    list-style: none;
    display: flex;
    gap: clamp(18px, 3vw, 36px);
    align-items: center;
    flex-wrap: nowrap;
    position: relative;
    padding-bottom: 4px;
  }

  nav ul li a {
    color: var(--nav-link);
    text-decoration: none;
    font-family: "Barlow", sans-serif;
    font-weight: 600;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    position: relative;
    transition:
      color 0.08s cubic-bezier(0.22, 1, 0.36, 1),
      opacity 0.14s ease;
  }

  nav ul li a:hover {
    color: var(--nav-ink);
  }

  nav ul li a.active {
    color: var(--color-accent);
  }

  .nav-indicator {
    position: absolute;
    left: 0;
    bottom: -1px;
    width: 0;
    height: calc(2px + var(--nav-scroll) * 0.6px);
    border-radius: 999px;
    opacity: 0;
    pointer-events: none;
    background: linear-gradient(
      90deg,
      rgba(157, 212, 242, 0.12) 0%,
      rgba(157, 212, 242, 0.96) 50%,
      rgba(157, 212, 242, 0.12) 100%
    );
    transform: translateX(0);
    transform-origin: center;
    transition:
      transform 0.48s cubic-bezier(0.16, 1, 0.3, 1),
      width 0.48s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.22s ease;
    will-change: transform, width, opacity;
    filter: drop-shadow(
      0 10px 18px rgb(var(--nav-glow-rgb) / calc(0.12 + var(--nav-scroll) * 0.14))
    );
  }

  .nav-indicator.is-visible {
    opacity: 1;
  }

  .btn-whatsapp {
    background: var(--nav-cta-bg);
    color: var(--nav-cta-ink);
    padding: 9px 20px;
    border-radius: 50px;
    border: 1px solid var(--nav-cta-border);
    font-family: "Barlow", sans-serif;
    font-weight: 600;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 8px;
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease,
      background 0.22s ease,
      border-color 0.22s ease;
    box-shadow:
      0 10px 22px
        rgb(var(--nav-glow-rgb) /
            calc(var(--nav-cta-shadow-alpha) + var(--nav-scroll) * 0.08)),
      0 1px 0 rgb(255 255 255 / 0.12) inset;
  }

  .btn-whatsapp:hover {
    background: #25d366;
    border-color: rgba(37, 211, 102, 0.5);
    box-shadow:
      0 18px 36px rgba(37, 211, 102, 0.42),
      0 1px 0 rgba(255, 255, 255, 0.18) inset;
    transform: translateY(-2px) scale(1.01);
  }

  .btn-whatsapp:active {
    transform: translateY(0) scale(0.99);
  }

  .btn-whatsapp:focus-visible {
    outline: none;
    box-shadow:
      0 0 0 4px rgba(157, 212, 242, 0.32),
      0 10px 22px
        rgb(var(--nav-glow-rgb) /
            calc(var(--nav-cta-shadow-alpha) + var(--nav-scroll) * 0.08));
  }

  .btn-whatsapp svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    padding: 5px;
    background: none;
    border: none;
  }

  .hamburger span {
    display: block;
    width: 25px;
    height: 2px;
    background-color: var(--nav-ink);
    transition:
      transform 0.35s ease,
      opacity 0.35s ease,
      background-color 0.08s cubic-bezier(0.22, 1, 0.36, 1);
    border-radius: 2px;
  }

  .hamburger.open span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .hamburger.open span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  .hamburger.open span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(26, 31, 78, 0.98);
    z-index: 999;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: clamp(18px, 4vw, 34px);
    opacity: 0;
    transform: translateY(-8px);
    visibility: hidden;
    pointer-events: none;
    transition:
      opacity 0.35s ease,
      transform 0.35s ease,
      visibility 0.35s ease;
  }

  .mobile-menu.open {
    visibility: visible;
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  .mobile-menu a {
    color: var(--color-white);
    text-decoration: none;
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(1.9rem, 7vw, 2.6rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: clamp(2px, 0.8vw, 3px);
    transition: color var(--transition);
  }

  .mobile-menu a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    #navbar {
      top: 8px;
      width: calc(100% - 16px);
      padding-left: clamp(12px, 3.2vw, 18px);
      padding-right: clamp(12px, 3.2vw, 18px);
      min-height: 64px;
      gap: 10px;
      padding-top: 2px;
      padding-bottom: 2px;
    }

    #navbar.scrolled {
      --nav-solid-boost: 0.16;
    }

    nav ul,
    .nav-indicator,
    .btn-whatsapp {
      display: none;
    }

    .hamburger {
      display: flex;
    }
  }

  @media (max-width: 360px) {
    #navbar {
      padding-left: 10px;
      padding-right: 10px;
      min-height: 70px;
    }

    .header-logo-link img {
      height: 2.3rem;
    }

    .hamburger span {
      width: 24px;
    }

    .mobile-menu a {
      font-size: 1.8rem;
      letter-spacing: 2px;
    }
  }
</style>

<script is:inline>
  (() => {
    const navList = document.querySelector("[data-nav-list]");
    const indicator = document.querySelector("[data-nav-indicator]");
    const navLinks = Array.from(document.querySelectorAll(".nav-link"));

    if (!navList || !indicator || navLinks.length === 0) return;

    const desktopQuery = window.matchMedia("(min-width: 769px)");
    let hoveredLink = null;
    let rafId = 0;

    const applyIndicator = (link) => {
      if (!desktopQuery.matches || !link) {
        indicator.classList.remove("is-visible");
        return;
      }

      const listRect = navList.getBoundingClientRect();
      const linkRect = link.getBoundingClientRect();

      if (!listRect.width || !linkRect.width) {
        indicator.classList.remove("is-visible");
        return;
      }

      const inset = Math.min(10, linkRect.width * 0.16);
      const width = Math.max(linkRect.width - inset * 2, 22);
      const offset =
        linkRect.left - listRect.left + (linkRect.width - width) / 2;

      indicator.style.width = `${width}px`;
      indicator.style.transform = `translateX(${offset}px)`;
      indicator.classList.add("is-visible");
    };

    const getActiveLink = () =>
      navLinks.find((link) => link.classList.contains("active")) ?? null;

    const syncIndicator = () => {
      applyIndicator(hoveredLink ?? getActiveLink());
    };

    const queueSync = () => {
      if (rafId) return;
      rafId = window.requestAnimationFrame(() => {
        rafId = 0;
        syncIndicator();
      });
    };

    navLinks.forEach((link) => {
      link.addEventListener("pointerenter", () => {
        hoveredLink = link;
        queueSync();
      });

      link.addEventListener("pointerleave", () => {
        hoveredLink = null;
        queueSync();
      });

      link.addEventListener("focus", () => {
        hoveredLink = link;
        queueSync();
      });

      link.addEventListener("blur", () => {
        hoveredLink = null;
        queueSync();
      });
    });

    const activeObserver = new MutationObserver(() => {
      queueSync();
    });

    navLinks.forEach((link) => {
      activeObserver.observe(link, {
        attributes: true,
        attributeFilter: ["class"],
      });
    });

    const handleViewportChange = () => {
      hoveredLink = null;
      queueSync();
    };

    if (typeof desktopQuery.addEventListener === "function") {
      desktopQuery.addEventListener("change", handleViewportChange);
    } else if (typeof desktopQuery.addListener === "function") {
      desktopQuery.addListener(handleViewportChange);
    }

    window.addEventListener("resize", queueSync, { passive: true });
    window.addEventListener("hashchange", queueSync, { passive: true });
    window.addEventListener("load", queueSync, { once: true });

    if ("fonts" in document && "ready" in document.fonts) {
      document.fonts.ready.then(() => {
        queueSync();
      });
    }

    queueSync();
  })();
</script>
