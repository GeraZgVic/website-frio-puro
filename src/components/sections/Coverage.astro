<script is:inline>
  const LEAFLET_CSS_ID = "leaflet-css-cdn";
  const LEAFLET_SCRIPT_ID = "leaflet-script-cdn";

  const ensureLeafletCss = () => {
    if (document.getElementById(LEAFLET_CSS_ID)) return;

    const link = document.createElement("link");
    link.id = LEAFLET_CSS_ID;
    link.rel = "stylesheet";
    link.href = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.css";
    document.head.appendChild(link);
  };

  const ensureLeafletScript = () => {
    if (window.L) return Promise.resolve(window.L);
    if (window.__leafletLoadingPromise) return window.__leafletLoadingPromise;

    window.__leafletLoadingPromise = new Promise((resolve, reject) => {
      const existing = document.getElementById(LEAFLET_SCRIPT_ID);

      if (existing) {
        existing.addEventListener("load", () => resolve(window.L));
        existing.addEventListener("error", () =>
          reject(new Error("No se pudo cargar Leaflet")),
        );
        return;
      }

      const script = document.createElement("script");
      script.id = LEAFLET_SCRIPT_ID;
      script.src = "https://unpkg.com/leaflet@1.9.4/dist/leaflet.js";
      script.async = true;

      script.onload = () => resolve(window.L);
      script.onerror = () => reject(new Error("No se pudo cargar Leaflet"));

      document.head.appendChild(script);
    });

    return window.__leafletLoadingPromise;
  };

  const initCoverageMap = async () => {
    const mapElement = document.getElementById("villahermosa-map");
    if (!mapElement) return;
    if (mapElement.dataset.initialized === "true") return;

    ensureLeafletCss();
    const L = await ensureLeafletScript();
    if (!L) return;

    mapElement.dataset.initialized = "true";

    const center = [17.9895, -92.9475];

    const map = L.map(mapElement, {
      zoomControl: false,
      scrollWheelZoom: false,
      dragging: false,
      doubleClickZoom: false,
      boxZoom: false,
      keyboard: false,
      attributionControl: true,
    }).setView(center, 12);

    L.tileLayer("https://tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    }).addTo(map);

    const markerIcon = L.divIcon({
      className: "map-marker-wrap",
      html: '<span class="map-marker-core"></span>',
      iconSize: [20, 20],
      iconAnchor: [10, 10],
    });

    L.marker(center, { icon: markerIcon }).addTo(map);

    const coverageZones = [
      { coords: [17.995, -92.96], radius: 1600 },
      { coords: [18.001, -92.925], radius: 1450 },
      { coords: [17.973, -92.952], radius: 1550 },
      { coords: [17.982, -92.987], radius: 1350 },
      { coords: [17.9895, -92.9475], radius: 1900 },
    ];

    coverageZones.forEach((zone, index) => {
      L.circle(zone.coords, {
        radius: zone.radius,
        color: "rgba(120,224,255,0.58)",
        weight: 1.2,
        fillColor:
          index === 4 ? "rgba(65,171,226,0.20)" : "rgba(65,171,226,0.12)",
        fillOpacity: 1,
      }).addTo(map);
    });

    const routePrimary = [
      [17.995, -92.96],
      [17.9895, -92.9475],
      [17.982, -92.937],
      [17.973, -92.952],
    ];

    const routeSecondary = [
      [18.001, -92.925],
      [17.9895, -92.9475],
      [17.982, -92.987],
    ];

    L.polyline(routePrimary, {
      color: "rgba(126,224,255,0.86)",
      weight: 2,
      opacity: 0.88,
      dashArray: "7 10",
      lineCap: "round",
      lineJoin: "round",
    }).addTo(map);

    L.polyline(routeSecondary, {
      color: "rgba(126,224,255,0.48)",
      weight: 1.6,
      opacity: 0.7,
      dashArray: "5 10",
      lineCap: "round",
      lineJoin: "round",
    }).addTo(map);
  };

  document.addEventListener("astro:page-load", () => {
    void initCoverageMap();
  });

  document.addEventListener("DOMContentLoaded", () => {
    void initCoverageMap();
  });
</script>
