---
import Section from "../ui/Section.astro";
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
---

<Section className="bg-[var(--color-bg-soft)]">
	<Container>
		<div class="grid items-center gap-10 lg:grid-cols-2">
			<div class="relative">
				<div class="aspect-[4/3] w-full overflow-hidden rounded-3xl border border-[var(--color-primary)]/10 bg-[var(--color-white)] shadow-[var(--shadow-sm)]">
					<div class="flex h-full items-center justify-center">
						<div class="rounded-2xl border border-[var(--color-primary)]/15 bg-[var(--color-bg-soft)] px-6 py-3 text-sm font-semibold tracking-wide text-[var(--color-text-strong)]/80">
							Mapa de cobertura
						</div>
					</div>
				</div>
			</div>
			<div>
				<Heading as="h2" className="text-[var(--color-text)]">
					Cobertura operativa
				</Heading>
				<p class="mt-4 text-sm text-[var(--color-text)]/75">
					Atendemos zonas clave con entregas coordinadas y rutas estables.
				</p>
				<ul class="mt-6 space-y-3 text-sm sm:text-base">
					<li class="flex items-center gap-3">
						<span class="flex h-6 w-6 items-center justify-center rounded-full bg-[var(--color-accent-soft)] text-[var(--color-primary)]">●</span>
						<span>Centro</span>
					</li>
					<li class="flex items-center gap-3">
						<span class="flex h-6 w-6 items-center justify-center rounded-full bg-[var(--color-accent-soft)] text-[var(--color-primary)]">●</span>
						<span>Zona norte</span>
					</li>
					<li class="flex items-center gap-3">
						<span class="flex h-6 w-6 items-center justify-center rounded-full bg-[var(--color-accent-soft)] text-[var(--color-primary)]">●</span>
						<span>Zona sur</span>
					</li>
					<li class="flex items-center gap-3">
						<span class="flex h-6 w-6 items-center justify-center rounded-full bg-[var(--color-accent-soft)] text-[var(--color-primary)]">●</span>
						<span>Restaurantes y comercios locales</span>
					</li>
					<li class="flex items-center gap-3">
						<span class="flex h-6 w-6 items-center justify-center rounded-full bg-[var(--color-accent-soft)] text-[var(--color-primary)]">●</span>
						<span>Cobertura bajo coordinación</span>
					</li>
				</ul>
			</div>
		</div>
	</Container>
</Section>
