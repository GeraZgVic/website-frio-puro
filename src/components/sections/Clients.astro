---
/* Clientes Section — Rediseño clean profile-card style */
---

<section id="clientes" class="clients-section">
  <div class="clients-ambient clients-ambient-1" aria-hidden="true"></div>
  <div class="clients-ambient clients-ambient-2" aria-hidden="true"></div>
  <div class="clients-noise" aria-hidden="true"></div>
  <div class="clients-grid-overlay" aria-hidden="true"></div>

  <div class="container clients-container">
    <div class="clients-header fade-in">
      <div class="clients-header-main">
        <h2
          class="section-title clients-title"
          style="color: var(--color-primary);"
        >
          Soluciones de suministro<br />
          para cada sector
        </h2>

        <p class="section-subtitle clients-subtitle">
          Garantía de stock permanente y planes de entrega de alto volumen para
          el sector comercial.
        </p>
      </div>
    </div>

    <div class="clients-grid">
      <article class="client-card fade-in fade-in-delay-1">
        <div class="client-card-media">
          <div class="client-card-badge">Sector comercial</div>
          <img
            src="/images/Clients/restaurantes.png"
            alt="Restaurantes"
            loading="lazy"
          />
        </div>

        <div class="client-card-body">
          <div class="client-card-head">
            <h3>RESTAURANTES</h3>
            <p>
              Abasto confiable para cocina, barra y operación diaria con
              suministro continuo.
            </p>
          </div>

          <div class="client-card-footer">
            <div class="client-card-stats" aria-hidden="true">
              <span class="client-stat">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M16 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                  <circle cx="10" cy="7" r="4"></circle>
                  <path d="M20 8v6"></path>
                  <path d="M23 11h-6"></path>
                </svg>
                24/7
              </span>
              <span class="client-stat">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="3" y="3" width="18" height="18" rx="4"></rect>
                  <path d="M7 12h10"></path>
                  <path d="M12 7v10"></path>
                </svg>
                Stock
              </span>
            </div>

            <a href="/cotizacion-corporativa/#formulario-corporativo" class="client-card-cta"> Cotizar + </a>
          </div>
        </div>
      </article>

      <article class="client-card fade-in fade-in-delay-2">
        <div class="client-card-media">
          <div class="client-card-badge">Alta demanda</div>
          <img
            src="/images/Clients/bares-entretenimiento.png"
            alt="Bares y entretenimiento"
            loading="lazy"
          />
        </div>

        <div class="client-card-body">
          <div class="client-card-head">
            <h3>BARES Y ENTRETENIMIENTO</h3>
            <p>
              Suministro programado para alta demanda nocturna y operación
              continua de barra.
            </p>
          </div>

          <div class="client-card-footer">
            <div class="client-card-stats" aria-hidden="true">
              <span class="client-stat">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 6v6l4 2"></path>
                  <circle cx="12" cy="12" r="9"></circle>
                </svg>
                Nocturno
              </span>
              <span class="client-stat">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M4 17l6-6 4 4 6-8"></path>
                  <path d="M14 7h6v6"></path>
                </svg>
                Alto flujo
              </span>
            </div>

            <a href="/cotizacion-corporativa/#formulario-corporativo" class="client-card-cta"> Cotizar + </a>
          </div>
        </div>
      </article>

      <article class="client-card fade-in fade-in-delay-3">
        <div class="client-card-media">
          <div class="client-card-badge">Operación especial</div>
          <img src="/images/Clients/eventos.png" alt="Eventos" loading="lazy" />
        </div>

        <div class="client-card-body">
          <div class="client-card-head">
            <h3>EVENTOS</h3>
            <p>
              Entregas masivas con logística de descarga y cobertura para
              operaciones de volumen.
            </p>
          </div>

          <div class="client-card-footer">
            <div class="client-card-stats" aria-hidden="true">
              <span class="client-stat">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M3 12h18"></path>
                  <path d="M7 8l-4 4 4 4"></path>
                  <path d="M17 8l4 4-4 4"></path>
                </svg>
                Masivo
              </span>
              <span class="client-stat">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="3" y="5" width="18" height="14" rx="3"></rect>
                  <path d="M7 9h10"></path>
                  <path d="M7 13h6"></path>
                </svg>
                Logística
              </span>
            </div>

            <a href="/cotizacion-corporativa/#formulario-corporativo" class="client-card-cta"> Cotizar + </a>
          </div>
        </div>
      </article>

      <article class="client-card fade-in fade-in-delay-4">
        <div class="client-card-media">
          <div class="client-card-badge">Reposición</div>
          <img
            src="/images/Clients/puntos-venta-autoservicio.png"
            alt="Puntos de venta y autoservicio"
            loading="lazy"
          />
        </div>

        <div class="client-card-body">
          <div class="client-card-head">
            <h3>PUNTOS DE VENTA Y AUTOSERVICIO</h3>
            <p>
              Reposición programada y stock constante para operación comercial y
              autoservicio.
            </p>
          </div>

          <div class="client-card-footer">
            <div class="client-card-stats" aria-hidden="true">
              <span class="client-stat">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M3 12h18"></path>
                  <path d="M12 3v18"></path>
                </svg>
                Ruta
              </span>
              <span class="client-stat">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="12" cy="12" r="8"></circle>
                  <path d="M12 8v4l3 3"></path>
                </svg>
                Constante
              </span>
            </div>

            <a href="/cotizacion-corporativa/#formulario-corporativo" class="client-card-cta"> Cotizar + </a>
          </div>
        </div>
      </article>

      <article class="client-card fade-in fade-in-delay-5">
        <div class="client-card-media">
          <div class="client-card-badge">Hospitalidad</div>
          <img src="/images/Clients/hoteles.png" alt="Hoteles" loading="lazy" />
        </div>

        <div class="client-card-body">
          <div class="client-card-head">
            <h3>HOTELES</h3>
            <p>
              Suministro para room service, banquetes y operación institucional
              con entregas seguras.
            </p>
          </div>

          <div class="client-card-footer">
            <div class="client-card-stats" aria-hidden="true">
              <span class="client-stat">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M4 19V8a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v11"></path>
                  <path d="M2 19h20"></path>
                  <path d="M7 10h.01"></path>
                  <path d="M12 10h.01"></path>
                  <path d="M17 10h.01"></path>
                </svg>
                Banquetes
              </span>
              <span class="client-stat">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M3 10h18"></path>
                  <path d="M6 6h12v12H6z"></path>
                </svg>
                Room service
              </span>
            </div>

            <a href="/cotizacion-corporativa/#formulario-corporativo" class="client-card-cta"> Cotizar + </a>
          </div>
        </div>
      </article>

      <article class="client-card fade-in fade-in-delay-6">
        <div class="client-card-media">
          <div class="client-card-badge">Conservación</div>
          <img
            src="/images/Clients/pescaderias.png"
            alt="Pescaderías"
            loading="lazy"
          />
        </div>

        <div class="client-card-body">
          <div class="client-card-head">
            <h3>PESCADERÍAS</h3>
            <p>
              Suministro industrial para conservación, manejo de producto y
              operación continua.
            </p>
          </div>

          <div class="client-card-footer">
            <div class="client-card-stats" aria-hidden="true">
              <span class="client-stat">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 3v18"></path>
                  <path d="M8 7h8"></path>
                  <path d="M8 17h8"></path>
                </svg>
                Frío
              </span>
              <span class="client-stat">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="3" y="4" width="18" height="16" rx="3"></rect>
                  <path d="M7 8h10"></path>
                  <path d="M7 12h10"></path>
                </svg>
                Industrial
              </span>
            </div>

            <a href="/cotizacion-corporativa/#formulario-corporativo" class="client-card-cta"> Cotizar + </a>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .clients-section {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: clamp(84px, 9vw, 124px) 0;
    background:
      radial-gradient(
        circle at 10% 18%,
        rgba(65, 171, 226, 0.1) 0%,
        transparent 28%
      ),
      radial-gradient(
        circle at 88% 84%,
        rgba(50, 59, 129, 0.06) 0%,
        transparent 24%
      ),
      linear-gradient(180deg, #eef6fb 0%, #f7fbfe 40%, #ffffff 100%);
  }

  .clients-ambient,
  .clients-noise,
  .clients-grid-overlay {
    pointer-events: none;
    position: absolute;
  }

  .clients-ambient {
    border-radius: 999px;
    filter: blur(88px);
    z-index: 0;
  }

  .clients-ambient-1 {
    top: -120px;
    left: -140px;
    width: 340px;
    height: 340px;
    background: rgba(65, 171, 226, 0.08);
  }

  .clients-ambient-2 {
    right: -140px;
    bottom: -140px;
    width: 360px;
    height: 360px;
    background: rgba(50, 59, 129, 0.05);
  }

  .clients-noise {
    inset: 0;
    z-index: 0;
    opacity: 0.02;
    background-image:
      radial-gradient(circle at 20% 20%, #ffffff 0.6px, transparent 0.8px),
      radial-gradient(circle at 80% 30%, #ffffff 0.6px, transparent 0.8px),
      radial-gradient(circle at 50% 75%, #ffffff 0.6px, transparent 0.8px);
    background-size:
      24px 24px,
      30px 30px,
      22px 22px;
  }

  .clients-grid-overlay {
    inset: 0;
    z-index: 0;
    opacity: 0.08;
    background-image:
      linear-gradient(rgba(65, 171, 226, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(65, 171, 226, 0.04) 1px, transparent 1px);
    background-size: 120px 120px;
    mask-image: radial-gradient(circle at center, black 40%, transparent 88%);
    -webkit-mask-image: radial-gradient(
      circle at center,
      black 40%,
      transparent 88%
    );
  }

  .clients-container {
    position: relative;
    z-index: 2;
  }

  .clients-header {
    display: grid;
    justify-items: center;
    text-align: center;
    margin-bottom: 48px;
  }

  .clients-header-main {
    max-width: 780px;
    text-align: center;
  }

  .clients-title {
    margin-bottom: 14px;
    font-size: clamp(2.8rem, 5vw, 5rem);
    line-height: 0.94;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .clients-subtitle {
    max-width: 560px;
    margin: 0 auto;
    font-size: 1rem;
    line-height: 1.82;
    color: rgba(18, 26, 60, 0.8);
  }

  .clients-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 26px;
    align-items: stretch;
  }

  .client-card {
    position: relative;
    min-height: 100%;
    border-radius: 34px;
    background: rgba(255, 255, 255, 0.84);
    border: 1px solid rgba(255, 255, 255, 0.94);
    box-shadow:
      0 24px 54px rgba(42, 55, 102, 0.1),
      0 8px 18px rgba(65, 171, 226, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.96);
    overflow: hidden;
    transform-origin: center;
    transition:
      transform 0.34s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.34s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.3s ease;
  }

  .client-card::after {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: linear-gradient(
      120deg,
      rgba(255, 255, 255, 0.24) 0%,
      rgba(255, 255, 255, 0.08) 18%,
      transparent 42%
    );
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .client-card:hover {
    transform: translateY(-8px);
    border-color: rgba(255, 255, 255, 1);
    box-shadow:
      0 30px 72px rgba(42, 55, 102, 0.13),
      0 10px 24px rgba(65, 171, 226, 0.07),
      inset 0 1px 0 rgba(255, 255, 255, 1);
  }

  .client-card:hover::after {
    opacity: 1;
  }

  .client-card-media {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 0.9;
    overflow: hidden;
    border-radius: 34px 34px 0 0;
    background: #dfe8f2;
  }

  .client-card-media::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(8, 16, 38, 0.08) 0%,
      rgba(8, 16, 38, 0) 24%,
      rgba(12, 20, 48, 0.18) 100%
    );
  }

  .client-card-media::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.025) 0%,
      rgba(0, 0, 0, 0.045) 100%
    );
    pointer-events: none;
  }

  .client-card-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    filter: saturate(1.05) contrast(1.04);
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.35s ease;
  }

  .client-card:hover .client-card-media img {
    transform: scale(1.04);
    filter: saturate(1.08) contrast(1.05);
  }

  .client-card-body {
    position: relative;
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 16px 18px 16px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.92) 0%,
      #ffffff 100%
    );
  }

  .client-card-body::before {
    content: "";
    position: absolute;
    top: 0;
    left: 18px;
    right: 18px;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(24, 40, 86, 0.02) 0%,
      rgba(24, 40, 86, 0.08) 50%,
      rgba(24, 40, 86, 0.02) 100%
    );
  }

  .client-card-head {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .client-card-badge {
    position: absolute;
    top: 18px;
    left: 18px;
    z-index: 4;
    display: inline-flex;
    align-items: center;
    min-height: 32px;
    max-width: calc(100% - 36px);
    padding: 0 13px;
    border-radius: 999px;
    background: linear-gradient(
      180deg,
      rgba(26, 38, 76, 0.62) 0%,
      rgba(20, 31, 66, 0.54) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.22);
    color: rgba(255, 255, 255, 0.98);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    backdrop-filter: blur(12px) saturate(1.1);
    -webkit-backdrop-filter: blur(12px) saturate(1.1);
    box-shadow:
      0 10px 24px rgba(8, 16, 38, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      inset 0 -1px 0 rgba(0, 0, 0, 0.12);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.28);
  }

  .client-card-head h3 {
    margin: 0;
    font-family: "Barlow Condensed", sans-serif;
    font-weight: 700;
    font-size: 1.4rem;
    line-height: 0.96;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: #182856;
    text-wrap: balance;
  }

  .client-card-head h3::after {
    content: "";
    display: block;
    width: 24px;
    height: 2px;
    margin-top: 7px;
    border-radius: 999px;
    background: rgba(65, 171, 226, 0.62);
  }

  .client-card-head p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.52;
    color: rgba(18, 26, 60, 0.7);
  }

  .client-card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: auto;
    padding-top: 14px;
  }

  .client-card-stats {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    flex-wrap: wrap;
  }

  .client-stat {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 28px;
    padding: 0 9px;
    border-radius: 999px;
    background: rgba(18, 26, 60, 0.04);
    border: 1px solid rgba(18, 26, 60, 0.07);
    color: rgba(18, 26, 60, 0.6);
    font-size: 0.72rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .client-stat svg {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }

  .client-card-cta {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    padding: 0 18px;
    border-radius: 999px;
    overflow: hidden;
    background: linear-gradient(180deg, #ffffff 0%, #f3f6fb 100%);
    border: 1px solid rgba(18, 26, 60, 0.08);
    color: #182856;
    font-size: 0.84rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    white-space: nowrap;
    text-decoration: none;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 8px 16px rgba(42, 55, 102, 0.06);
    transition:
      transform 0.22s ease,
      box-shadow 0.22s ease,
      background 0.22s ease;
  }

  .client-card-cta::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      120deg,
      transparent 0%,
      rgba(255, 255, 255, 0.56) 50%,
      transparent 100%
    );
    transform: translateX(-130%);
    transition: transform 0.55s ease;
    pointer-events: none;
  }

  .client-card-cta:hover {
    transform: translateY(-1px);
    background: linear-gradient(180deg, #ffffff 0%, #eef4fb 100%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 12px 18px rgba(42, 55, 102, 0.08);
  }

  .client-card-cta:hover::after {
    transform: translateX(130%);
  }

  @media (max-width: 1200px) {
    .clients-grid {
      gap: 20px;
    }

    .client-card-head h3 {
      font-size: 1.22rem;
    }

    .client-card-head p {
      font-size: 0.86rem;
    }

    .client-card-cta {
      min-height: 46px;
      padding: 0 16px;
      font-size: 0.8rem;
    }
  }

  @media (max-width: 1024px) {
    .clients-header {
      margin-bottom: 40px;
    }

    .clients-title {
      font-size: clamp(2.6rem, 7vw, 4.4rem);
    }

    .clients-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      padding: 0 12px;
    }
  }

  @media (max-width: 768px) {
    .clients-section {
      padding: clamp(72px, 11vw, 92px) 0;
    }

    .clients-container {
      padding-inline: clamp(14px, 4.5vw, 22px);
    }

    .clients-header {
      margin-bottom: 30px;
    }

    .clients-header-main {
      max-width: 100%;
    }

    .clients-title {
      font-size: clamp(2.25rem, 11vw, 3.4rem);
      line-height: 0.96;
      letter-spacing: -0.035em;
      text-wrap: balance;
    }

    .clients-subtitle {
      max-width: 100%;
      font-size: 0.96rem;
      line-height: 1.72;
    }

    .clients-grid {
      grid-template-columns: 1fr;
      gap: 16px;
      padding: 0;
    }

    .client-card {
      width: min(100%, 560px);
      margin-inline: auto;
      border-radius: 28px;
      transform: none !important;
    }

    .client-card::after {
      display: none;
    }

    .client-card-media {
