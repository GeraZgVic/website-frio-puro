---
/* Clientes Section — Clients B2B Premium / Cleaner Apple Style */
---

<!-- CLIENTES -->
<section id="clientes" class="clients-section">
  <div class="clients-ambient clients-ambient-1" aria-hidden="true"></div>
  <div class="clients-ambient clients-ambient-2" aria-hidden="true"></div>
  <div class="clients-noise" aria-hidden="true"></div>
  <div class="clients-grid-overlay" aria-hidden="true"></div>

  <div class="container clients-container">
    <div class="clients-header fade-in">
      <div class="clients-header-main">
        <h2
          class="section-title clients-title"
          style="color: var(--color-primary);"
        >
          Soluciones de suministro<br />
          para cada sector
        </h2>

        <p class="section-subtitle clients-subtitle">
          Pureza garantizada y planes de abasto diseñados para tu negocio.
        </p>
      </div>
    </div>

    <div class="clients-grid">
      <article class="client-card fade-in fade-in-delay-1">
        <div class="client-card-inner">
          <div class="client-card-top">
            <div class="client-icon-wrap" aria-hidden="true">
              <span class="card-icon">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="4" y="4" width="16" height="16" rx="3"></rect>
                  <path d="M8 8h8M8 12h8M8 16h5"></path>
                </svg>
              </span>
            </div>
          </div>

          <h3>Restaurantes</h3>
          <p>
            Hielo ideal para bebidas, conservación de alimentos y presentaciones
            gourmet con entregas puntuales y operación constante.
          </p>

          <div class="client-card-footer">
            <a class="client-card-cta" href="#contacto">
              Solicitar plan de abasto
            </a>
          </div>
        </div>
      </article>

      <article class="client-card fade-in fade-in-delay-2">
        <div class="client-card-inner">
          <div class="client-card-top">
            <div class="client-icon-wrap" aria-hidden="true">
              <span class="card-icon">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M4 4h16l-6 7v5l-4 4v-9L4 4z"></path>
                </svg>
              </span>
            </div>
          </div>

          <h3>Bares & Cantinas</h3>
          <p>
            Cubos perfectos para cócteles y tragos con suministro confiable y
            entregas adaptadas al ritmo operativo nocturno.
          </p>

          <div class="client-card-footer">
            <a class="client-card-cta" href="#contacto">
              Cotizar suministro nocturno
            </a>
          </div>
        </div>
      </article>

      <article class="client-card fade-in fade-in-delay-3">
        <div class="client-card-inner">
          <div class="client-card-top">
            <div class="client-icon-wrap" aria-hidden="true">
              <span class="card-icon">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M4 20l7-16 4 9 5-2-6 9H4z"></path>
                </svg>
              </span>
            </div>
          </div>

          <h3>Eventos</h3>
          <p>
            Soluciones para bodas, fiestas corporativas y celebraciones con
            atención por volumen, logística ágil y respuesta rápida.
          </p>

          <div class="client-card-footer">
            <a class="client-card-cta" href="#contacto">
              Cotizar volumen para evento
            </a>
          </div>
        </div>
      </article>

      <article class="client-card fade-in fade-in-delay-4">
        <div class="client-card-inner">
          <div class="client-card-top">
            <div class="client-icon-wrap" aria-hidden="true">
              <span class="card-icon">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M3 10h18l-1.5 10h-15L3 10z"></path>
                  <path d="M5 10l2-6h10l2 6"></path>
                  <path d="M9 20v-6h6v6"></path>
                </svg>
              </span>
            </div>
          </div>

          <h3>Tiendas & Minisupers</h3>
          <p>
            Abastecimiento regular y confiable para puntos de venta que
            requieren continuidad operativa y reposición constante.
          </p>

          <div class="client-card-footer">
            <a class="client-card-cta" href="#contacto">
              Solicitar reposición programada
            </a>
          </div>
        </div>
      </article>

      <article class="client-card fade-in fade-in-delay-5">
        <div class="client-card-inner">
          <div class="client-card-top">
            <div class="client-icon-wrap" aria-hidden="true">
              <span class="card-icon">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M4 20V6h16v14"></path>
                  <path d="M8 10h2M8 14h2M14 10h2M14 14h2"></path>
                  <path d="M9 20v-4h6v4"></path>
                </svg>
              </span>
            </div>
          </div>

          <h3>Hoteles</h3>
          <p>
            Suministro continuo para room service, restaurantes, bares y eventos
            dentro de sus instalaciones con servicio de alto estándar.
          </p>

          <div class="client-card-footer">
            <a class="client-card-cta" href="#contacto">
              Solicitar abasto para hotelería
            </a>
          </div>
        </div>
      </article>

      <article class="client-card fade-in fade-in-delay-6">
        <div class="client-card-inner">
          <div class="client-card-top">
            <div class="client-icon-wrap" aria-hidden="true">
              <span class="card-icon">
                <svg
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M3 12s3-5 9-5 9 5 9 5-3 5-9 5-9-5-9-5z"></path>
                  <circle cx="14" cy="12" r="1.2"></circle>
                </svg>
              </span>
            </div>
          </div>

          <h3>Pescaderías</h3>
          <p>
            Hielo en alto volumen para conservación eficiente de mariscos y
            productos frescos durante toda la jornada.
          </p>

          <div class="client-card-footer">
            <a class="client-card-cta" href="#contacto">
              Cotizar hielo para conservación
            </a>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  .clients-section {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: clamp(84px, 9vw, 124px) 0;
    background:
      radial-gradient(
        circle at 10% 18%,
        rgba(65, 171, 226, 0.1) 0%,
        transparent 28%
      ),
      radial-gradient(
        circle at 88% 84%,
        rgba(50, 59, 129, 0.06) 0%,
        transparent 24%
      ),
      linear-gradient(180deg, #eef6fb 0%, #f7fbfe 40%, #ffffff 100%);
  }

  .clients-ambient,
  .clients-noise,
  .clients-grid-overlay {
    pointer-events: none;
    position: absolute;
  }

  .clients-ambient {
    border-radius: 999px;
    filter: blur(88px);
    z-index: 0;
  }

  .clients-ambient-1 {
    top: -120px;
    left: -140px;
    width: 340px;
    height: 340px;
    background: rgba(65, 171, 226, 0.08);
  }

  .clients-ambient-2 {
    right: -140px;
    bottom: -140px;
    width: 360px;
    height: 360px;
    background: rgba(50, 59, 129, 0.05);
  }

  .clients-noise {
    inset: 0;
    z-index: 0;
    opacity: 0.02;
    background-image:
      radial-gradient(circle at 20% 20%, #ffffff 0.6px, transparent 0.8px),
      radial-gradient(circle at 80% 30%, #ffffff 0.6px, transparent 0.8px),
      radial-gradient(circle at 50% 75%, #ffffff 0.6px, transparent 0.8px);
    background-size:
      24px 24px,
      30px 30px,
      22px 22px;
  }

  .clients-grid-overlay {
    inset: 0;
    z-index: 0;
    opacity: 0.08;
    background-image:
      linear-gradient(rgba(65, 171, 226, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(65, 171, 226, 0.04) 1px, transparent 1px);
    background-size: 120px 120px;
    mask-image: radial-gradient(circle at center, black 40%, transparent 88%);
    -webkit-mask-image: radial-gradient(
      circle at center,
      black 40%,
      transparent 88%
    );
  }

  .clients-container {
    position: relative;
    z-index: 2;
  }

  .clients-header {
    display: grid;
    justify-items: center;
    text-align: center;
    margin-bottom: 48px;
  }

  .clients-header-main {
    max-width: 780px;
    text-align: center;
  }

  .clients-title {
    margin-bottom: 14px;
    font-size: clamp(2.8rem, 5vw, 5rem);
    line-height: 0.94;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .clients-subtitle {
    max-width: 560px;
    margin: 0 auto;
    font-size: 1rem;
    line-height: 1.82;
    color: rgba(18, 26, 60, 0.8);
  }

  .clients-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 22px;
    align-items: stretch;
  }

  .client-card {
    position: relative;
    min-height: 320px;
    border-radius: 28px;
    overflow: hidden;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.84) 0%,
      rgba(247, 252, 255, 0.76) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.88);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.94),
      0 18px 42px rgba(50, 59, 129, 0.08),
      0 6px 16px rgba(65, 171, 226, 0.04);
    backdrop-filter: blur(14px) saturate(1.18);
    -webkit-backdrop-filter: blur(14px) saturate(1.18);
    transition:
      transform 0.28s ease,
      box-shadow 0.28s ease,
      border-color 0.28s ease;
  }

  .client-card:hover {
    transform: translateY(-6px);
    border-color: rgba(255, 255, 255, 0.96);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 24px 54px rgba(50, 59, 129, 0.1),
      0 10px 22px rgba(65, 171, 226, 0.05);
  }

  .client-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 22px;
    right: 22px;
    height: 3px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      var(--color-primary) 0%,
      var(--color-accent) 60%,
      rgba(157, 212, 242, 0.95) 100%
    );
    transform: scaleX(0.34);
    transform-origin: left;
    transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 0 10px rgba(65, 171, 226, 0.22);
  }

  .client-card:hover::before {
    transform: scaleX(1);
  }

  .client-card-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 30px 26px 24px;
  }

  .client-card-top {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    margin-bottom: 18px;
  }

  .client-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 68px;
    height: 68px;
    border-radius: 20px;
    flex-shrink: 0;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.92) 0%,
      rgba(231, 246, 254, 0.76) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.92);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 8px 22px rgba(65, 171, 226, 0.08),
      0 2px 8px rgba(50, 59, 129, 0.04);
    transition:
      transform 0.24s ease,
      box-shadow 0.24s ease;
  }

  .client-card:hover .client-icon-wrap {
    transform: translateY(-2px) scale(1.03);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 12px 26px rgba(65, 171, 226, 0.1),
      0 4px 10px rgba(50, 59, 129, 0.05);
  }

  .card-icon {
    display: block;
    color: #1c2b52;
    width: 30px;
    height: 30px;
    line-height: 1;
  }

  .card-icon svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .client-card h3 {
    margin: 0;
    font-family: "Barlow Condensed", sans-serif;
    font-weight: 700;
    font-size: 1.42rem;
    line-height: 1;
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .client-card p {
    margin-top: 14px;
    max-width: 32ch;
    font-size: 0.95rem;
    line-height: 1.72;
    color: rgba(20, 28, 60, 0.8);
  }

  .client-card-footer {
    display: flex;
    align-items: center;
    margin-top: auto;
    padding-top: 20px;
  }

  .client-card-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 46px;
    padding: 0 16px;
    border-radius: 999px;
    border: 1.5px solid rgba(28, 43, 82, 0.18);
    background: rgba(255, 255, 255, 0.84);
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.22px;
    color: rgba(28, 43, 82, 0.9);
    text-decoration: none;
    text-align: center;
    transition:
      color 0.22s ease,
      border-color 0.22s ease,
      transform 0.22s ease,
      background 0.22s ease,
      box-shadow 0.22s ease;
  }

  .client-card:hover .client-card-cta {
    color: rgba(28, 43, 82, 1);
    border-color: rgba(28, 43, 82, 0.32);
    background: #ffffff;
    box-shadow: 0 10px 20px rgba(50, 59, 129, 0.06);
  }

  @media (max-width: 1200px) {
    .clients-grid {
      gap: 20px;
    }

    .client-card-inner {
      padding: 28px 22px 22px;
    }
  }

  @media (max-width: 1024px) {
    .clients-header {
      margin-bottom: 40px;
    }

    .clients-title {
      font-size: clamp(2.6rem, 7vw, 4.4rem);
    }

    .clients-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      padding: 0 12px;
    }
  }

  @media (max-width: 768px) {
    .clients-section {
      padding: clamp(72px, 11vw, 92px) 0;
    }

    .clients-container {
      padding-inline: clamp(14px, 4.5vw, 22px);
    }

    .clients-header {
      margin-bottom: 30px;
    }

    .clients-header-main {
      max-width: 100%;
    }

    .clients-title {
      font-size: clamp(2.25rem, 11vw, 3.4rem);
      line-height: 0.96;
      letter-spacing: -0.035em;
      text-wrap: balance;
    }

    .clients-subtitle {
      max-width: 100%;
      font-size: 0.96rem;
      line-height: 1.72;
    }

    .clients-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .client-card {
      width: min(100%, 560px);
      min-height: unset;
      margin-inline: auto;
      border-radius: 24px;
      transform: none !important;
    }

    .client-card::before {
      left: 16px;
      right: 16px;
      transform: scaleX(0.26);
    }

    .client-card-inner {
      padding: 22px 18px 20px;
    }

    .client-card-top {
      margin-bottom: 16px;
    }

    .client-icon-wrap {
      width: 60px;
      height: 60px;
      border-radius: 18px;
    }

    .card-icon {
      width: 24px;
      height: 24px;
    }

    .client-card h3 {
      font-size: 1.18rem;
      letter-spacing: 0.3px;
    }

    .client-card p {
      max-width: 100%;
      margin-top: 12px;
      font-size: 0.9rem;
      line-height: 1.64;
    }

    .client-card-footer {
      padding-top: 16px;
    }

    .client-card-cta {
      min-height: 44px;
      padding: 0 14px;
      font-size: 0.76rem;
    }
  }

  @media (max-width: 480px) {
    .clients-container {
      padding-inline: 16px;
    }

    .clients-title {
      font-size: clamp(2.1rem, 12vw, 3rem);
      letter-spacing: -0.03em;
    }

    .clients-grid {
      gap: 14px;
    }

    .client-card {
      width: min(100%, 430px);
      border-radius: 22px;
    }

    .client-card-inner {
      padding: 20px 16px 18px;
    }

    .client-icon-wrap {
      width: 56px;
      height: 56px;
      border-radius: 16px;
    }

    .card-icon {
      width: 22px;
      height: 22px;
    }

    .client-card h3 {
      font-size: 1.12rem;
    }

    .client-card p {
      font-size: 0.88rem;
      line-height: 1.6;
    }

    .client-card-cta {
      min-height: 42px;
      font-size: 0.74rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .client-card,
    .client-icon-wrap {
      transition: none !important;
    }
  }
</style>

<script is:inline>
  (() => {
    const cards = document.querySelectorAll(".client-card");
    if (!cards.length) return;

    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const canHover = window.matchMedia(
      "(hover: hover) and (pointer: fine)",
    ).matches;

    if ("IntersectionObserver" in window) {
      const revealObserver = new IntersectionObserver(
        (entries, observer) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          });
        },
        { threshold: 0.12 },
      );

      cards.forEach((card) => revealObserver.observe(card));
    } else {
      cards.forEach((card) => card.classList.add("is-visible"));
    }

    if (!reducedMotion && canHover) {
      cards.forEach((card) => {
        card.addEventListener("pointerenter", () => {
          card.style.willChange = "transform";
        });

        card.addEventListener("pointerleave", () => {
          card.style.willChange = "auto";
        });
      });
    }
  })();
</script>
