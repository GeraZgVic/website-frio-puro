---
import { commercialContent } from "../../config/commercial";
---

<!-- BENEFICIOS -->
<section id="beneficios">
  <div class="bg-orb bg-orb-1"></div>
  <div class="bg-orb bg-orb-2"></div>
  <div class="bg-grid"></div>
  <div class="bg-noise"></div>

  <div class="container">
    <div class="beneficios-grid">
      <!-- Col izquierda -->
      <div class="counters-col">
        <div class="section-header fade-in">
          <p class="section-label">
            <span class="label-pip"></span>
            ¿Por qué elegirnos?
          </p>

          <h2 class="section-title">
            <span>Números que</span>
            <span>hablan</span>
            <span class="title-gradient">por sí solos</span>
          </h2>

          <p class="section-copy">
            Calidad constante, atención continua y una operación diseñada para
            que tu negocio nunca se quede sin hielo.
          </p>
        </div>

        <div class="counters-grid">
          <article
            class="counter-card counter-card--accent fade-in fade-in-delay-3"
          >
            <div class="card-glow card-glow--accent"></div>
            <div class="card-reflection"></div>

            <div class="counter-top">
              <div class="counter-icon-wrap" aria-hidden="true">
                <span class="counter-icon">⚡</span>
              </div>
            </div>

            <div class="counter-value counter-value--sm">
              <span class="counter-inline-text">
                {commercialContent.badges.operation247}
              </span>
            </div>

            <p class="counter-label">Atención continua</p>
          </article>

          <article class="counter-card fade-in fade-in-delay-4">
            <div class="card-glow"></div>
            <div class="card-reflection"></div>

            <div class="counter-top">
              <div class="counter-icon-wrap" aria-hidden="true">
                <span class="counter-icon">💧</span>
              </div>
            </div>

            <div class="counter-value">
              <span class="counter-num" data-target="100">0</span>
              <span class="suffix">%</span>
            </div>

            <p class="counter-label">Hielo purificado</p>
          </article>
        </div>
      </div>

      <!-- Col derecha -->
      <div class="benefits-col">
        <ul class="benefits-list fade-in fade-in-delay-1">
          <li class="benefit-item">
            <div class="check-wrap" aria-hidden="true">
              <span class="check">✓</span>
              <div class="check-ring"></div>
            </div>

            <span class="benefit-text">
              <strong>Entrega coordinada en farica o domicilio.</strong>
              Flexibilidad total para adaptarnos a la necesidad de cada negocio. <br
              /> *Aplica restricciones
            </span>
          </li>

          <li class="benefit-item">
            <div class="check-wrap" aria-hidden="true">
              <span class="check">✓</span>
              <div class="check-ring"></div>
            </div>

            <span class="benefit-text">
              <strong>Entrega segura</strong>
              Red de distribución optimizada para Villahermosa, Tabasco y municipios
              aledaños.
            </span>
          </li>
        </ul>

        <div class="production-photo fade-in fade-in-delay-3">
          <img
            src="/gallery/Fabrica01.jpg"
            alt="Planta de producción de hielo Hielo Express"
            class="photo-img"
            loading="lazy"
          />

          <div class="photo-overlay"></div>
          <div class="photo-reflection"></div>

          <div class="photo-chip">
            <svg
              width="11"
              height="11"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            Certificado COFEPRIS
          </div>

          <div class="photo-badge">
            <span class="badge-dot"></span>
            Producción activa 24/7
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #beneficios {
    --benefit-bg-top: #fbfdff;
    --benefit-bg-mid: #f3f7fb;
    --benefit-bg-bottom: #edf3f9;
    --benefit-panel: rgba(255, 255, 255, 0.76);
    --benefit-border: rgba(255, 255, 255, 0.9);
    --benefit-shadow-lg: 0 28px 70px rgba(22, 44, 87, 0.1);
    --benefit-shadow-md: 0 16px 36px rgba(24, 46, 92, 0.07);
    --benefit-text: #4e617f;
    --benefit-text-strong: #24477a;
    --benefit-line: rgba(65, 171, 226, 0.08);
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: 108px 0;
    background:
      radial-gradient(
        circle at 12% 14%,
        rgba(125, 211, 252, 0.14) 0%,
        transparent 30%
      ),
      radial-gradient(
        circle at 88% 84%,
        rgba(65, 171, 226, 0.08) 0%,
        transparent 30%
      ),
      radial-gradient(
        circle at 50% 20%,
        rgba(255, 255, 255, 0.6) 0%,
        transparent 42%
      ),
      linear-gradient(
        180deg,
        var(--benefit-bg-top) 0%,
        var(--benefit-bg-mid) 52%,
        var(--benefit-bg-bottom) 100%
      );
  }

  #beneficios .container {
    position: relative;
    z-index: 2;
  }

  .bg-orb,
  .bg-grid,
  .bg-noise {
    position: absolute;
    pointer-events: none;
  }

  .bg-orb {
    border-radius: 999px;
    filter: blur(92px);
    opacity: 0.62;
  }

  .bg-orb-1 {
    width: 500px;
    height: 500px;
    top: -180px;
    left: -170px;
    background: radial-gradient(
      circle,
      rgba(65, 171, 226, 0.16) 0%,
      transparent 68%
    );
    animation: orbFloatA 18s ease-in-out infinite alternate;
  }

  .bg-orb-2 {
    width: 400px;
    height: 400px;
    right: -130px;
    bottom: -110px;
    background: radial-gradient(
      circle,
      rgba(50, 59, 129, 0.08) 0%,
      transparent 68%
    );
    animation: orbFloatB 20s ease-in-out infinite alternate;
  }

  .bg-grid {
    inset: 0;
    z-index: 0;
    opacity: 0.08;
    background-image:
      linear-gradient(rgba(105, 138, 190, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(105, 138, 190, 0.05) 1px, transparent 1px);
    background-size: 34px 34px;
    -webkit-mask-image: radial-gradient(
      circle at center,
      #000 36%,
      transparent 100%
    );
    mask-image: radial-gradient(circle at center, #000 36%, transparent 100%);
  }

  .bg-noise {
    inset: 0;
    z-index: 1;
    opacity: 0.01;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 220px;
  }

  @keyframes orbFloatA {
    from {
      transform: translate3d(0, 0, 0) scale(1);
    }
    to {
      transform: translate3d(36px, 48px, 0) scale(1.04);
    }
  }

  @keyframes orbFloatB {
    from {
      transform: translate3d(0, 0, 0) scale(1);
    }
    to {
      transform: translate3d(-28px, -38px, 0) scale(1.05);
    }
  }

  .beneficios-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.98fr) minmax(0, 1.02fr);
    gap: 36px;
    align-items: start;
  }

  .counters-col,
  .benefits-col {
    min-width: 0;
  }

  .counters-col {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
  }

  .benefits-col {
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding-top: 26px;
  }

  .section-header {
    max-width: 520px;
    margin-bottom: 22px;
    padding-top: 4px;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 16px;
    padding: 8px 15px;
    width: fit-content;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.88);
    background: rgba(255, 255, 255, 0.64);
    box-shadow:
      0 10px 24px rgba(31, 66, 135, 0.045),
      inset 0 1px 0 rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(16px) saturate(1.15);
    -webkit-backdrop-filter: blur(16px) saturate(1.15);
    font-family: "Barlow", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .label-pip {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    background: linear-gradient(180deg, #9de2ff 0%, var(--color-accent) 100%);
    box-shadow:
      0 0 0 6px rgba(65, 171, 226, 0.08),
      0 0 14px rgba(65, 171, 226, 0.2);
  }

  .section-title {
    display: flex;
    flex-direction: column;
    margin: 0;
    max-width: 420px;
    font-family: "Barlow Condensed", sans-serif;
    font-weight: 800;
    font-size: clamp(2.5rem, 4vw, 3.9rem);
    line-height: 0.9;
    letter-spacing: -0.06em;
    text-transform: uppercase;
    color: var(--color-primary);
    text-wrap: balance;
    text-shadow:
      0 12px 26px rgba(20, 44, 86, 0.08),
      0 2px 6px rgba(20, 44, 86, 0.06);
  }

  .section-title span {
    display: block;
  }

  .title-gradient {
    background: linear-gradient(
      135deg,
      #2d5e9a 0%,
      var(--color-accent) 54%,
      #8ddcff 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .section-copy {
    margin: 14px 0 0;
    max-width: 40ch;
    font-family: "Barlow", sans-serif;
    font-size: 0.95rem;
    line-height: 1.65;
    letter-spacing: -0.01em;
    color: #536886;
  }

  .counters-grid {
    margin-top: 6px;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
  }

  .counter-card {
    position: relative;
    overflow: hidden;
    min-height: 120px;
    padding: 16px 16px 14px;
    border-radius: 22px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.9) 0%,
      rgba(255, 255, 255, 0.72) 100%
    );
    border: 1px solid var(--benefit-border);
    box-shadow:
      0 24px 58px rgba(24, 46, 92, 0.1),
      0 10px 22px rgba(24, 46, 92, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(18px) saturate(1.14);
    -webkit-backdrop-filter: blur(18px) saturate(1.14);
    transition:
      transform 0.38s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.38s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.28s ease;
  }

  .counter-card::after {
    content: "";
    position: absolute;
    inset: 1px;
    border-radius: inherit;
    pointer-events: none;
    border: 1px solid rgba(255, 255, 255, 0.34);
    opacity: 0.92;
  }

  .counter-card::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      circle at 20% 15%,
      rgba(255, 255, 255, 0.6),
      transparent 55%
    );
    opacity: 0.55;
    pointer-events: none;
  }

  .counter-card:hover {
    transform: translateY(-6px);
    box-shadow:
      0 32px 74px rgba(24, 46, 92, 0.14),
      0 14px 28px rgba(65, 171, 226, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 1);
    border-color: rgba(255, 255, 255, 0.96);
  }

  .counter-card--accent {
    background:
      radial-gradient(
        circle at top right,
        rgba(125, 211, 252, 0.12) 0%,
        transparent 40%
      ),
      linear-gradient(
        180deg,
        rgba(241, 250, 255, 0.92) 0%,
        rgba(255, 255, 255, 0.74) 100%
      );
  }

  .card-glow {
    position: absolute;
    top: -28px;
    right: -28px;
    width: 92px;
    height: 92px;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(65, 171, 226, 0.16) 0%,
      transparent 74%
    );
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.35s ease;
  }

  .counter-card:hover .card-glow {
    opacity: 1;
  }

  .card-glow--accent {
    background: radial-gradient(
      circle,
      rgba(65, 171, 226, 0.22) 0%,
      transparent 72%
    );
  }

  .card-reflection {
    position: absolute;
    inset: 0 0 auto 0;
    height: 52%;
    border-radius: 22px 22px 56% 0 / 22px 22px 16px 0;
    background: linear-gradient(
      160deg,
      rgba(255, 255, 255, 0.58) 0%,
      rgba(255, 255, 255, 0.15) 36%,
      transparent 64%
    );
    pointer-events: none;
  }

  .counter-top,
  .counter-value,
  .counter-label {
    position: relative;
    z-index: 2;
  }

  .counter-top {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    margin-bottom: 14px;
  }

  .counter-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 12px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.92) 0%,
      rgba(255, 255, 255, 0.58) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.84);
    box-shadow:
      0 10px 20px rgba(40, 66, 118, 0.07),
      inset 0 1px 0 rgba(255, 255, 255, 0.96);
  }

  .counter-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.95rem;
    line-height: 1;
  }

  .counter-value {
    display: flex;
    align-items: baseline;
    justify-content: flex-start;
    gap: 3px;
    font-family: "Barlow Condensed", sans-serif;
    font-weight: 800;
    font-size: 2.2rem;
    line-height: 0.9;
    letter-spacing: -0.05em;
    color: var(--color-primary);
  }

  .counter-value--sm {
    font-size: 1.68rem;
    line-height: 0.96;
    letter-spacing: -0.07em;
  }

  .counter-inline-text {
    font-family: "Barlow Condensed", sans-serif;
    font-weight: 800;
  }

  .counter-value .suffix {
    font-size: 0.96rem;
    color: var(--color-accent);
  }

  .counter-label {
    margin: 10px 0 0;
    font-family: "Barlow", sans-serif;
    font-size: 0.58rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: #8192b0;
  }

  .benefits-list {
    list-style: none;
    margin: 0;
    padding: 12px 14px;
    border-radius: 28px;
    background: var(--benefit-panel);
    border: 1px solid var(--benefit-border);
    box-shadow:
      var(--benefit-shadow-md),
      inset 0 1px 0 rgba(255, 255, 255, 0.94);
    backdrop-filter: blur(18px) saturate(1.16);
    -webkit-backdrop-filter: blur(18px) saturate(1.16);
  }

  .benefit-item {
    display: grid;
    grid-template-columns: 26px minmax(0, 1fr);
    align-items: start;
    column-gap: 12px;
    padding: 16px 8px;
    border-bottom: 1px solid var(--benefit-line);
    border-radius: 16px;
    color: var(--benefit-text);
    font-family: "Barlow", sans-serif;
    font-size: 0.94rem;
    line-height: 1.6;
    transition:
      background 0.28s ease,
      transform 0.28s ease,
      padding-left 0.28s ease;
  }

  .benefit-item:last-child {
    border-bottom: none;
  }

  .benefit-item:hover {
    background: rgba(255, 255, 255, 0.42);
    padding-left: 12px;
    transform: translateX(2px);
  }

  .check-wrap {
    position: relative;
    width: 26px;
    height: 26px;
    margin-top: 1px;
    flex-shrink: 0;
  }

  .check {
    position: relative;
    z-index: 1;
    width: 26px;
    height: 26px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: linear-gradient(180deg, #66ceff 0%, #2f95d4 100%);
    color: #fff;
    font-size: 0.58rem;
    font-weight: 800;
    box-shadow:
      0 10px 22px rgba(65, 171, 226, 0.22),
      inset 0 1px 0 rgba(255, 255, 255, 0.38);
  }

  .check-ring {
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid rgba(65, 171, 226, 0.15);
    opacity: 0;
    transform: scale(0.95);
    transition:
      opacity 0.3s ease,
      transform 0.3s ease;
  }

  .benefit-item:hover .check-ring {
    opacity: 1;
    transform: scale(1);
  }

  .benefit-text {
    display: block;
    min-width: 0;
  }

  .benefit-text strong {
    display: block;
    margin: 0 0 4px;
    color: var(--benefit-text-strong);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .production-photo {
    position: relative;
    width: 100%;
    height: 300px;
    overflow: hidden;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.32);
    border: 1px solid rgba(255, 255, 255, 0.82);
    box-shadow:
      0 32px 80px rgba(24, 46, 92, 0.18),
      0 14px 28px rgba(24, 46, 92, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.78);
    transition:
      transform 0.44s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.44s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .production-photo::after {
    content: "";
    position: absolute;
    inset: 1px;
    border-radius: inherit;
    border: 1px solid rgba(255, 255, 255, 0.24);
    pointer-events: none;
    z-index: 3;
  }

  .production-photo:hover {
    transform: translateY(-5px) scale(1.004);
  }

  .photo-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .production-photo:hover .photo-img {
    transform: scale(1.04);
  }

  .photo-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background:
      linear-gradient(
        180deg,
        rgba(18, 32, 70, 0.05) 0%,
        rgba(18, 32, 70, 0) 34%
      ),
      linear-gradient(
        180deg,
        rgba(10, 21, 47, 0) 42%,
        rgba(8, 18, 46, 0.62) 100%
      );
  }

  .photo-reflection {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 43%;
    z-index: 2;
    border-radius: 28px 28px 58% 0 / 28px 28px 18px 0;
    background: linear-gradient(
      160deg,
      rgba(255, 255, 255, 0.18) 0%,
      rgba(255, 255, 255, 0.05) 34%,
      transparent 62%
    );
  }

  .photo-chip,
  .photo-badge {
    position: absolute;
    z-index: 4;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    max-width: calc(100% - 24px);
    border-radius: 999px;
    font-family: "Barlow", sans-serif;
    backdrop-filter: blur(14px) saturate(1.15);
    -webkit-backdrop-filter: blur(14px) saturate(1.15);
  }

  .photo-chip {
    top: 12px;
    left: 12px;
    padding: 6px 10px;
    background: rgba(255, 255, 255, 0.16);
    border: 1px solid rgba(255, 255, 255, 0.26);
    color: rgba(255, 255, 255, 0.98);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .photo-chip svg {
    color: #4ade80;
    flex-shrink: 0;
  }

  .photo-badge {
    right: 12px;
    bottom: 12px;
    padding: 7px 10px;
    background: rgba(12, 24, 58, 0.56);
    border: 1px solid rgba(255, 255, 255, 0.18);
    color: rgba(255, 255, 255, 0.96);
    font-size: 0.6rem;
    font-weight: 600;
  }

  .badge-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    background: #4ade80;
    box-shadow: 0 0 10px rgba(74, 222, 128, 0.56);
  }

  @media (max-width: 1024px) {
    #beneficios {
      padding: 94px 0;
    }

    .beneficios-grid {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .section-header {
      max-width: 100%;
      margin-bottom: 20px;
      padding-top: 0;
      text-align: center;
    }

    .section-label {
      margin-left: auto;
      margin-right: auto;
    }

    .section-title {
      max-width: 100%;
      font-size: clamp(2.3rem, 6vw, 3.35rem);
    }

    .section-copy {
      max-width: 58ch;
      margin-left: auto;
      margin-right: auto;
    }

    .benefits-col {
      padding-top: 0;
      gap: 16px;
    }

    .production-photo {
      height: 330px;
    }
  }

  @media (max-width: 768px) {
    #beneficios {
      padding: 80px 0;
    }

    .beneficios-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .section-title {
      font-size: clamp(2rem, 10vw, 2.9rem);
      line-height: 0.92;
    }

    .section-copy {
      font-size: 0.91rem;
      line-height: 1.56;
    }

    .counters-grid {
      grid-template-columns: 1fr;
    }

    .counter-card {
      min-height: 118px;
      padding: 15px 14px 13px;
      border-radius: 20px;
    }

    .card-reflection {
