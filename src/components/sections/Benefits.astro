---
import { commercialContent } from "../../config/commercial";
---

<section id="beneficios">
  <div class="bg-aurora" aria-hidden="true"></div>
  <div class="bg-mesh" aria-hidden="true"></div>

  <div class="wrap">
    <div class="col-left">
      <div class="eyebrow reveal" style="--d: 0s">
        <span class="eyebrow__orb" aria-hidden="true"></span>
        <span>¿Por qué elegirnos?</span>
      </div>

      <h2 class="title reveal" style="--d: .06s">
        <span>Nuestra oferta</span>
        <span>se caracteriza por</span>
        <span class="title__accent">calidad y cantidad</span>
      </h2>

      <p class="copy reveal" style="--d: .11s">
        Calidad constante, atención continua y una operación diseñada para que
        tu negocio nunca se quede sin hielo.
      </p>

      <article class="hero-kpi reveal" style="--d: .16s" data-tilt>
        <div class="hero-kpi__top">
          <span class="hero-kpi__chip">OPERACIÓN Y CALIDAD</span>

          <div class="hero-kpi__icon" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path
                d="M12 3c3.2 4.2 5 7 5 9.3A5 5 0 1 1 7 12.3C7 10 8.8 7.2 12 3z"
              ></path>
            </svg>
          </div>
        </div>

        <div class="hero-kpi__numbers">
          <div class="hero-kpi__metric">
            <strong>{commercialContent.badges.operation247}</strong>
            <span>Atención continua</span>
          </div>

          <div class="hero-kpi__divider" aria-hidden="true"></div>

          <div class="hero-kpi__metric">
            <strong>
              <span class="hero-kpi__counter" data-target="100">0</span><span
                class="hero-kpi__suffix">%</span
              >
            </strong>
            <span>Hielo purificado</span>
          </div>
        </div>

        <span class="hero-kpi__bar" aria-hidden="true">
          <span class="hero-kpi__fill"></span>
        </span>
      </article>

      <ul class="blist reveal" style="--d: .22s">
        <li class="blist__item">
          <div class="blist__icon-wrap" aria-hidden="true">
            <span class="blist__check">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </span>
          </div>

          <div class="blist__body">
            <strong>Entrega coordinada en fábrica o domicilio.</strong>
            Flexibilidad para adaptarnos a la necesidad operativa de cada negocio.
            <em>*Aplican restricciones</em>
          </div>
        </li>

        <li class="blist__item">
          <div class="blist__icon-wrap" aria-hidden="true">
            <span class="blist__check">
              <svg
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </span>
          </div>

          <div class="blist__body">
            <strong>Entrega segura.</strong>
            Red de distribución optimizada para Villahermosa, Tabasco y municipios
            aledaños.
          </div>
        </li>
      </ul>
    </div>

    <div class="col-right">
      <div class="vcard-wrap reveal" style="--d: .09s">
        <div class="vcard" data-tilt-video>
          <video
            class="vcard__video"
            autoplay
            muted
            loop
            playsinline
            webkit-playsinline
            preload="metadata"
            aria-label="Video de planta de producción de hielo"
          >
            <source
              src="/gallery/videoOptimizado.mp4"
              type="video/mp4"
              media="(max-width: 1024px)"
            />
            <source
              src="/gallery/video.mp4"
              type="video/mp4"
              media="(min-width: 1025px)"
            />
          </video>

          <div class="vcard__overlay" aria-hidden="true"></div>

          <div class="vcard__info">
            <div class="vcard__caption">
              <strong>Proceso y operación continua</strong>
              <span>Infraestructura preparada para suministro comercial.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #beneficios {
    --cp: #0f2748;
    --cp2: #183960;
    --ca: #41abe2;
    --ca2: #7dd3fc;
    --ca3: #1f6f9f;
    --ct: #59718d;
    --cth: #173256;
    --r: 24px;
    --rp: 999px;

    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: clamp(88px, 9vw, 124px) 0;
    background:
      radial-gradient(
        ellipse 58% 46% at 6% 10%,
        rgba(125, 211, 252, 0.13) 0%,
        transparent 46%
      ),
      radial-gradient(
        ellipse 40% 30% at 96% 90%,
        rgba(65, 171, 226, 0.06) 0%,
        transparent 42%
      ),
      linear-gradient(180deg, #f8fbff 0%, #eff5fa 56%, #eaf1f7 100%);
  }

  .bg-aurora,
  .bg-mesh {
    pointer-events: none;
  }

  .bg-aurora {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .bg-aurora::before,
  .bg-aurora::after {
    content: "";
    position: absolute;
    border-radius: 50%;
    filter: blur(110px);
    will-change: transform;
  }

  .bg-aurora::before {
    width: 620px;
    height: 380px;
    top: -160px;
    left: -160px;
    background: radial-gradient(
      ellipse,
      rgba(65, 171, 226, 0.12) 0%,
      transparent 76%
    );
    animation: auroraA 24s ease-in-out infinite alternate;
  }

  .bg-aurora::after {
    width: 420px;
    height: 320px;
    right: -120px;
    bottom: -100px;
    background: radial-gradient(
      ellipse,
      rgba(30, 111, 160, 0.07) 0%,
      transparent 76%
    );
    animation: auroraB 28s ease-in-out infinite alternate-reverse;
  }

  @keyframes auroraA {
    0% {
      transform: translate(0, 0) scale(1);
    }
    100% {
      transform: translate(40px, 24px) scale(1.08);
    }
  }

  @keyframes auroraB {
    0% {
      transform: translate(0, 0) scale(1);
    }
    100% {
      transform: translate(-30px, -24px) scale(1.08);
    }
  }

  .bg-mesh {
    position: absolute;
    inset: 0;
    z-index: 1;
    opacity: 0.015;
    background-image:
      linear-gradient(rgba(100, 140, 200, 0.12) 1px, transparent 1px),
      linear-gradient(90deg, rgba(100, 140, 200, 0.12) 1px, transparent 1px);
    background-size: 72px 72px;
    -webkit-mask-image: radial-gradient(
      ellipse 75% 65% at center,
      #000 12%,
      transparent 100%
    );
    mask-image: radial-gradient(
      ellipse 75% 65% at center,
      #000 12%,
      transparent 100%
    );
  }

  .wrap {
    position: relative;
    z-index: 10;
    max-width: 1200px;
    margin-inline: auto;
    padding-inline: clamp(20px, 4vw, 56px);
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 390px);
    gap: clamp(26px, 2.8vw, 40px);
    align-items: center;
  }

  .col-left {
    display: flex;
    flex-direction: column;
    min-width: 0;
    padding-top: 4px;
  }

  .col-right {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-width: 0;
  }

  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    width: fit-content;
    margin-bottom: 20px;
    padding: 8px 14px;
    border-radius: var(--rp);
    border: 1px solid rgba(255, 255, 255, 0.9);
    background: rgba(255, 255, 255, 0.74);
    box-shadow:
      0 8px 24px rgba(19, 49, 98, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    font-family: "Barlow", sans-serif;
    font-size: 0.68rem;
    font-weight: 800;
    letter-spacing: 0.17em;
    text-transform: uppercase;
    color: var(--ca3);
  }

  .eyebrow__orb {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex-shrink: 0;
    background: linear-gradient(180deg, var(--ca2), var(--ca));
    animation: orbPulse 2.8s ease-in-out infinite;
  }

  @keyframes orbPulse {
    0%,
    100% {
      box-shadow: 0 0 0 3px rgba(65, 171, 226, 0.14);
    }
    50% {
      box-shadow: 0 0 0 6px rgba(65, 171, 226, 0.05);
    }
  }

  .title {
    display: flex;
    flex-direction: column;
    margin: 0 0 18px;
    font-family: "Barlow Condensed", sans-serif;
    font-weight: 800;
    font-size: clamp(2.8rem, 4.6vw, 4.5rem);
    line-height: 0.9;
    text-transform: uppercase;
    color: var(--cp);
    letter-spacing: -0.03em;
  }

  .title span {
    display: block;
  }

  .title__accent {
    background: linear-gradient(
      180deg,
      rgba(18, 54, 95, 1) 0%,
      rgba(65, 171, 226, 0.92) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .copy {
    max-width: 44ch;
    margin: 0 0 28px;
    font-family: "Barlow", sans-serif;
    font-size: 1rem;
    line-height: 1.72;
    letter-spacing: -0.01em;
    color: var(--ct);
  }

  .hero-kpi {
    position: relative;
    overflow: hidden;
    margin-bottom: 18px;
    padding: 20px 20px 22px;
    border-radius: calc(var(--r) + 2px);
    background:
      radial-gradient(
        circle at 88% 12%,
        rgba(125, 211, 252, 0.16) 0%,
        transparent 44%
      ),
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.88) 0%,
        rgba(248, 252, 255, 0.8) 100%
      );
    border: 1px solid rgba(255, 255, 255, 0.92);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 18px 44px rgba(18, 38, 80, 0.08),
      0 6px 18px rgba(18, 38, 80, 0.04);
    backdrop-filter: blur(16px) saturate(1.08);
    -webkit-backdrop-filter: blur(16px) saturate(1.08);
    transition:
      transform 0.34s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.34s ease;
    transform-style: preserve-3d;
    will-change: transform;
  }

  .hero-kpi:hover {
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 24px 52px rgba(18, 38, 80, 0.1),
      0 10px 24px rgba(18, 38, 80, 0.05);
  }

  .hero-kpi__top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 18px;
  }

  .hero-kpi__chip {
    padding: 6px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.62);
    border: 1px solid rgba(15, 39, 72, 0.07);
    font-family: "Barlow", sans-serif;
    font-size: 0.56rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(36, 71, 122, 0.62);
    white-space: nowrap;
  }

  .hero-kpi__icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 14px;
    display: grid;
    place-items: center;
    background: rgba(255, 255, 255, 0.76);
    border: 1px solid rgba(15, 39, 72, 0.06);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.92),
      0 8px 16px rgba(40, 66, 118, 0.05);
  }

  .hero-kpi__icon svg {
    width: 19px;
    height: 19px;
    color: var(--ca3);
  }

  .hero-kpi__numbers {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 16px;
  }

  .hero-kpi__metric {
    display: grid;
    gap: 6px;
  }

  .hero-kpi__metric strong {
    display: flex;
    align-items: baseline;
    gap: 2px;
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(2.2rem, 4vw, 3.1rem);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.06em;
    color: var(--cp);
  }

  .hero-kpi__metric span {
    font-family: "Barlow", sans-serif;
    font-size: 0.66rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: #8193b1;
  }

  .hero-kpi__suffix {
    font-size: 1rem;
    font-weight: 700;
    color: var(--ca);
    letter-spacing: -0.02em;
  }

  .hero-kpi__divider {
    width: 1px;
    height: 54px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(15, 39, 72, 0.1) 20%,
      rgba(15, 39, 72, 0.1) 80%,
      transparent 100%
    );
  }

  .hero-kpi__bar {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 2px;
    overflow: hidden;
    background: rgba(65, 171, 226, 0.05);
    border-radius: 0 0 calc(var(--r) + 2px) calc(var(--r) + 2px);
  }

  .hero-kpi__fill {
    display: block;
    width: 0;
    height: 100%;
    background: linear-gradient(90deg, var(--ca3), var(--ca), var(--ca2));
    transition: width 1.6s cubic-bezier(0.22, 1, 0.36, 1) 0.25s;
  }

  .hero-kpi.in .hero-kpi__fill {
    width: 100%;
  }

  .blist {
    list-style: none;
    margin: 0;
    padding: 10px 12px;
    border-radius: var(--r);
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.92);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 14px 34px rgba(22, 44, 87, 0.06);
    backdrop-filter: blur(16px) saturate(1.08);
    -webkit-backdrop-filter: blur(16px) saturate(1.08);
  }

  .blist__item {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr);
    align-items: start;
    column-gap: 12px;
    padding: 14px 8px;
    border-radius: 14px;
    border-bottom: 1px solid rgba(15, 39, 72, 0.06);
    font-family: "Barlow", sans-serif;
    font-size: 0.92rem;
    line-height: 1.62;
    color: var(--ct);
    transition:
      background 0.24s ease,
      transform 0.24s ease,
      opacity 0.45s ease;
    will-change: transform;
  }

  .blist__item:last-child {
    border-bottom: none;
  }

  .blist__item:hover {
    background: rgba(255, 255, 255, 0.5);
    transform: translateX(2px);
  }

  .blist__icon-wrap {
    width: 34px;
    height: 34px;
    margin-top: 2px;
    flex-shrink: 0;
  }

  .blist__check {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: linear-gradient(180deg, #7ad4f8 0%, #2f95d4 100%);
    color: #fff;
    box-shadow:
      0 6px 16px rgba(65, 171, 226, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.32);
  }

  .blist__check svg {
    width: 14px;
    height: 14px;
  }

  .blist__body {
    min-width: 0;
  }

  .blist__body strong {
    display: block;
    margin-bottom: 3px;
    color: var(--cth);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    line-height: 1.24;
  }

  .blist__body em {
    display: block;
    margin-top: 4px;
    font-size: 0.72rem;
    font-style: italic;
    color: #93a7c4;
  }

  .vcard-wrap {
    width: 100%;
    display: flex;
    justify-content: center;
    padding-top: clamp(8px, 2vw, 16px);
  }

  .vcard {
    position: relative;
    width: min(100%, 390px);
    aspect-ratio: 9 / 16;
    overflow: hidden;
    border-radius: 32px;
    background: #091221;
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 34px 84px rgba(8, 18, 48, 0.28),
      0 14px 34px rgba(20, 42, 85, 0.14);
    transition:
      transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.5s ease;
    transform-style: preserve-3d;
    will-change: transform;
  }

  .vcard:hover {
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      0 40px 92px rgba(8, 18, 48, 0.3),
      0 18px 42px rgba(20, 42, 85, 0.16);
  }

  .vcard__video {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .vcard__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      180deg,
      rgba(6, 14, 40, 0.12) 0%,
      rgba(6, 14, 40, 0.03) 24%,
      rgba(6, 14, 40, 0.08) 62%,
      rgba(6, 14, 40, 0.56) 100%
    );
  }

  .vcard__info {
    position: absolute;
    inset: 0;
    z-index: 3;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 16px;
  }

  .vcard__caption {
    display: grid;
    gap: 4px;
    max-width: 255px;
    padding: 14px 14px 15px;
    border-radius: 18px;
    background: rgba(7, 18, 36, 0.42);
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .vcard__caption strong {
    color: rgba(255, 255, 255, 0.98);
    font-family: "Barlow", sans-serif;
    font-size: 0.84rem;
    font-weight: 700;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }

  .vcard__caption span {
    color: rgba(226, 239, 248, 0.78);
    font-family: "Barlow", sans-serif;
    font-size: 0.72rem;
    line-height: 1.45;
  }

  .reveal {
    opacity: 0;
    transform: translateY(22px);
    transition:
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1) var(--d, 0s),
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1) var(--d, 0s);
  }

  .reveal.in {
    opacity: 1;
    transform: translateY(0);
  }

  .vcard-wrap.reveal {
    transform: translateY(28px) scale(0.98);
  }

  .vcard-wrap.reveal.in {
    transform: translateY(0) scale(1);
  }

  @media (max-width: 1020px) {
    .wrap {
      grid-template-columns: 1fr;
      gap: 34px;
      align-items: start;
    }

    .col-right {
      align-items: center;
    }

    .vcard-wrap {
      padding-top: 0;
    }

    .vcard {
      width: min(100%, 420px);
    }
  }

  @media (max-width: 640px) {
    #beneficios {
      padding: 72px 0;
    }

    .wrap {
      padding-inline: 16px;
      gap: 26px;
    }

    .title {
      font-size: clamp(2.3rem, 13vw, 3.15rem);
      line-height: 0.94;
    }

    .copy {
      font-size: 0.95rem;
      line-height: 1.68;
      max-width: 100%;
    }

    .hero-kpi {
      padding: 18px 16px 20px;
    }

    .hero-kpi__numbers {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .hero-kpi__divider {
      width: 100%;
      height: 1px;
      background: linear-gradient(
        90deg,
        transparent 0%,
        rgba(15, 39, 72, 0.1) 20%,
        rgba(15, 39, 72, 0.1) 80%,
        transparent 100%
      );
    }
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation: none !important;
      transition: none !important;
      scroll-behavior: auto !important;
    }

    .reveal,
    .reveal.in,
    .vcard-wrap.reveal,
    .vcard-wrap.reveal.in {
      opacity: 1 !important;
      transform: none !important;
    }

    .hero-kpi__fill {
      width: 100% !important;
    }

    .blist__item {
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>

<script is:inline>
  (() => {
    const section = document.getElementById("beneficios");
    if (!section) return;

    const reduceMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const noHover = window.matchMedia("(hover: none)").matches;

    const observers = [];
    const cleanups = [];

    const createObserver = (callback, options) => {
      const observer = new IntersectionObserver(callback, options);
      observers.push(observer);
      return observer;
    };

    const rafThrottle = (fn) => {
      let rafId = 0;
      let lastArgs = null;

      return (...args) => {
        lastArgs = args;
        if (rafId) return;
        rafId = requestAnimationFrame(() => {
          rafId = 0;
          fn(...lastArgs);
        });
      };
    };

    {
      const revealEls = section.querySelectorAll(".reveal");

      if (reduceMotion) {
        revealEls.forEach((el) => el.classList.add("in"));
      } else {
        const io = createObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add("in");
              observer.unobserve(entry.target);
            });
          },
          { threshold: 0.12 },
        );

        revealEls.forEach((el) => io.observe(el));
      }
    }

    {
      const counters = section.querySelectorAll(
        ".hero-kpi__counter[data-target]",
      );

      if (reduceMotion) {
        counters.forEach((el) => {
          const target = Number(el.dataset.target || 0);
          el.textContent = String(target);
        });
      } else {
        const easeOut = (t) => 1 - Math.pow(1 - t, 4);

        const io = createObserver(
          (entries, observer) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;

              const el = entry.target;
              const target = Number(el.dataset.target || 0);
              const start = performance.now();
              const duration = 1800;

              const tick = (now) => {
                const p = Math.min((now - start) / duration, 1);
                el.textContent = String(Math.round(easeOut(p) * target));
                if (p < 1) {
                  requestAnimationFrame(tick);
                } else {
                  el.textContent = String(target);
                }
              };

              requestAnimationFrame(tick);
              observer.unobserve(el);
            });
          },
          { threshold: 0.5 },
        );

        counters.forEach((el) => io.observe(el));
      }
    }

    {
      const kpi = section.querySelector(".hero-kpi");

      if (kpi) {
        if (reduceMotion) {
          kpi.classList.add("in");
        } else {
          const io = createObserver(
            (entries, observer) => {
              entries.forEach((entry) => {
                if (!entry.isIntersecting) return;
                entry.target.classList.add("in");
                observer.unobserve(entry.target);
              });
            },
            { threshold: 0.35 },
          );

          io.observe(kpi);
        }
      }
    }

    {
      const list = section.querySelector(".blist");
      const items = section.querySelectorAll(".blist__item");

      if (reduceMotion) {
        items.forEach((item) => {
          item.style.opacity = "1";
          item.style.transform = "none";
        });
      } else if (list && items.length) {
        const io = createObserver(
          (entries, observer) => {
            const first = entries[0];
            if (!first?.isIntersecting) return;

            items.forEach((item, i) => {
              item.style.opacity = "0";
              item.style.transform = "translateX(14px)";

              setTimeout(
                () => {
                  item.style.opacity = "1";
                  item.style.transform = "translateX(0)";
                },
                i * 110 + 60,
              );
            });

            observer.unobserve(list);
          },
          { threshold: 0.25 },
        );

        io.observe(list);
      }
    }

    const setupTilt = (element, options = {}) => {
      if (!element || reduceMotion || noHover) return;

      const {
        rotate = 3.2,
        scale = 1.014,
        lift = -4,
        perspective = 820,
        media = null,
      } = options;

      let currentX = 0;
      let currentY = 0;
      let targetX = 0;
      let targetY = 0;
      let active = false;
      let rafId = 0;

      const animate = () => {
        currentX += (targetX - currentX) * 0.12;
        currentY += (targetY - currentY) * 0.12;

        element.style.transform = `translateY(${lift}px) perspective(${perspective}px) rotateX(${-currentY * rotate}deg) rotateY(${currentX * rotate}deg) scale(${scale})`;

        if (media) {
          media.style.transform = `scale(1.03) translate(${currentX * 4}px, ${currentY * 3}px)`;
        }

        if (
          active ||
          Math.abs(targetX - currentX) > 0.01 ||
          Math.abs(targetY - currentY) > 0.01
        ) {
          rafId = requestAnimationFrame(animate);
        } else {
          rafId = 0;
        }
      };

      const onMove = rafThrottle((event) => {
        const rect = element.getBoundingClientRect();
        targetX =
          (event.clientX - rect.left - rect.width / 2) / (rect.width / 2);
        targetY =
          (event.clientY - rect.top - rect.height / 2) / (rect.height / 2);

        if (!rafId) {
          active = true;
          rafId = requestAnimationFrame(animate);
        }
      });

      const onLeave = () => {
        active = false;
        targetX = 0;
        targetY = 0;

        element.style.transition = "transform .6s cubic-bezier(.22,1,.36,1)";
        if (media) {
          media.style.transition = "transform .6s cubic-bezier(.22,1,.36,1)";
        }

        if (!rafId) {
          rafId = requestAnimationFrame(animate);
        }

        window.setTimeout(() => {
          element.style.transition = "";
          if (media) media.style.transition = "";
        }, 650);
      };

      element.addEventListener("mousemove", onMove, { passive: true });
      element.addEventListener("mouseleave", onLeave);

      cleanups.push(() => {
        element.removeEventListener("mousemove", onMove);
        element.removeEventListener("mouseleave", onLeave);
        if (rafId) cancelAnimationFrame(rafId);
      });
    };

    const heroKpi = section.querySelector("[data-tilt]");
    if (heroKpi) {
      setupTilt(heroKpi, {
        rotate: 3.5,
        scale: 1.016,
        lift: -4,
        perspective: 760,
      });
    }

    const vcard = section.querySelector("[data-tilt-video]");
    const vcardVideo = vcard?.querySelector(".vcard__video");
    if (vcard) {
      setupTilt(vcard, {
        rotate: 2.5,
        scale: 1.01,
        lift: -6,
        perspective: 900,
        media: vcardVideo,
      });
    }

    {
      const video = section.querySelector(".vcard__video");

      if (video) {
        const enableInline = () => {
          video.setAttribute("playsinline", "");
          video.setAttribute("webkit-playsinline", "");
          video.playsInline = true;
        };

        const ensureMuted = () => {
          video.muted = true;
          video.defaultMuted = true;
          video.setAttribute("muted", "");
        };

        const attemptPlay = () => {
          enableInline();
          ensureMuted();
          video.loop = true;

          const playPromise = video.play();
          if (playPromise && typeof playPromise.catch === "function") {
            playPromise.catch(() => {
              // Autoplay can be blocked; we'll retry on visibility/user interaction.
            });
          }
        };

        const onCanPlay = () => {
          attemptPlay();
        };

        if (video.readyState >= 2) {
          attemptPlay();
        } else {
          video.addEventListener("canplay", onCanPlay, { once: true });
        }

        const io = createObserver(
          (entries, observer) => {
            const entry = entries[0];
            if (!entry?.isIntersecting) return;
            attemptPlay();
            observer.unobserve(entry.target);
          },
          { threshold: 0.35 },
        );

        io.observe(video);

        const onVisible = () => {
          if (document.visibilityState === "visible") {
            attemptPlay();
          }
        };

        const onUser = () => {
          attemptPlay();
        };

        document.addEventListener("visibilitychange", onVisible);
        window.addEventListener("pageshow", onUser);
        window.addEventListener("touchstart", onUser, { passive: true });
        window.addEventListener("pointerdown", onUser, { passive: true });

        cleanups.push(() => {
          video.removeEventListener("canplay", onCanPlay);
          document.removeEventListener("visibilitychange", onVisible);
          window.removeEventListener("pageshow", onUser);
          window.removeEventListener("touchstart", onUser);
          window.removeEventListener("pointerdown", onUser);
        });
      }
    }

    cleanups.push(() => {
      observers.forEach((observer) => observer.disconnect());
    });

    window.addEventListener(
      "pagehide",
      () => {
        cleanups.forEach((fn) => fn());
      },
      { once: true },
    );
  })();
</script>
