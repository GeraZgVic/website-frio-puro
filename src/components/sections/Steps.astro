  }

  @keyframes connectorFlow {
    0% {
      left: -35%;
    }
    100% {
      left: 130%;
    }
  }

  @keyframes btnShift {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  @media (max-width: 980px) {
    .steps-stage {
      grid-template-columns: 1fr;
      gap: 16px;
      max-width: 390px;
    }

    .stage-panel {
      inset: -12px;
      border-radius: 26px;
    }

    .step-connector {
      min-height: 28px;
    }

    .connector-line {
      width: 1px;
      height: 28px;
      background: linear-gradient(
