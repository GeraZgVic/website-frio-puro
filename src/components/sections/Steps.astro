---
import { buildWhatsAppUrl, commercialContent } from "../../config/commercial";
---

<!-- COMO PEDIR -->
<section id="como-pedir">
  <div class="steps-ambient steps-ambient-1"></div>
  <div class="steps-ambient steps-ambient-2"></div>
  <div class="steps-grid" aria-hidden="true"></div>

  <div class="container">
    <div class="steps-header fade-in">
      <p class="section-label">
        <span class="label-dot"></span>
        Proceso comercial
      </p>

      <h2 class="section-title">SOLICITA TU PLAN DE ABASTO</h2>

      <p class="section-subtitle">
        Un proceso claro para definir volumen, logística y entregas programadas
        para tu operación.
      </p>
    </div>

    <div class="steps-stage fade-in fade-in-delay-1">
      <div class="stage-panel"></div>

      <article class="step-card" data-step="1">
        <div class="step-shell">
          <div class="step-body">
            <div class="step-body-glow"></div>
            <div class="step-body-sheen"></div>

            <div class="step-meta">Paso 1</div>

            <div class="step-top">
              <div class="step-badge-wrap">
                <span class="step-badge-ring"></span>
                <span class="step-badge">1</span>
              </div>

              <div class="step-icon-orb" aria-hidden="true">
                <svg
                  class="step-icon-svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="7" y="2.5" width="10" height="19" rx="2"></rect>
                  <line x1="10" y1="5.5" x2="14" y2="5.5"></line>
                  <line x1="11" y1="18.5" x2="13" y2="18.5"></line>
                </svg>
              </div>
            </div>

            <h3>SOLICITUD DE SUMINISTRO</h3>
            <p>
              Envía tus requerimientos de volumen y ubicación a través de
              nuestro formulario.
            </p>
          </div>
        </div>
      </article>

      <div class="step-connector" aria-hidden="true">
        <span class="connector-line"></span>
        <span class="connector-core"></span>
      </div>

      <article class="step-card" data-step="2">
        <div class="step-shell">
          <div class="step-body">
            <div class="step-body-glow"></div>
            <div class="step-body-sheen"></div>

            <div class="step-meta">Paso 2</div>

            <div class="step-top">
              <div class="step-badge-wrap">
                <span class="step-badge-ring"></span>
                <span class="step-badge">2</span>
              </div>

              <div class="step-icon-orb" aria-hidden="true">
                <svg
                  class="step-icon-svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M8 6h11"></path>
                  <path d="M8 12h11"></path>
                  <path d="M8 18h11"></path>
                  <path d="M3.5 6h.01"></path>
                  <path d="M3.5 12h.01"></path>
                  <path d="M3.5 18h.01"></path>
                </svg>
              </div>
            </div>

            <h3>PROPUESTA LOGÍSTICA PERSONALIZADA</h3>
            <p>
              Analizamos tu consumo semanal para diseñar una oferta con precios
              de mayoreo y rutas de entrega optimizadas.
            </p>
          </div>
        </div>
      </article>

      <div class="step-connector" aria-hidden="true">
        <span class="connector-line"></span>
        <span class="connector-core"></span>
      </div>

      <article class="step-card" data-step="3">
        <div class="step-shell">
          <div class="step-body">
            <div class="step-body-glow"></div>
            <div class="step-body-sheen"></div>

            <div class="step-meta">Paso 3</div>

            <div class="step-top">
              <div class="step-badge-wrap">
                <span class="step-badge-ring"></span>
                <span class="step-badge">3</span>
              </div>

              <div class="step-icon-orb" aria-hidden="true">
                <svg
                  class="step-icon-svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.8"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="2.5" y="7.5" width="13" height="9" rx="2"></rect>
                  <path d="M15.5 10h2.4l2.6 2.7v3.8h-2.2"></path>
                  <circle cx="7" cy="18" r="1.7"></circle>
                  <circle cx="18" cy="18" r="1.7"></circle>
                </svg>
              </div>
            </div>

            <h3>SUMINISTRO PROGRAMADO</h3>
            <p>
              Activamos tu cronograma de entregas y recibes tu stock
              puntualmente.
            </p>
          </div>
        </div>
      </article>
    </div>

    <p class="steps-note fade-in fade-in-delay-2">
      Servicio de entrega a domicilio exclusivo para pedidos mayores a xxxx
      unidades/kg/tons. Ventas individuales disponibles únicamente en sucursal.
    </p>

    <div class="cta-center fade-in fade-in-delay-2">
      <a
        href={buildWhatsAppUrl(
          commercialContent.whatsappMessages.generalInquiry,
        )}
        class="btn-liquid"
        id="cta-btn"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="btn-layer btn-layer-bg"></span>
        <span class="btn-layer btn-layer-border"></span>

        <span class="btn-content">
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
            ></path>
          </svg>
          SOLICITAR PLAN DE ENTREGAS
        </span>
      </a>
    </div>
  </div>
</section>

<style>
  #como-pedir {
    --bg-1: #0b1e31;
    --bg-2: #10273d;
    --bg-3: #14314b;
    --ink: rgba(255, 255, 255, 0.98);
    --text-soft: rgba(220, 233, 243, 0.68);
    --blue: #41abe2;
    --blue-2: #8bdcff;

    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: 116px 0;
    background:
      radial-gradient(
        circle at 50% 0%,
        rgba(139, 220, 255, 0.08),
        transparent 26%
      ),
      radial-gradient(
        circle at 12% 18%,
        rgba(134, 219, 255, 0.04),
        transparent 24%
      ),
      radial-gradient(
        circle at 88% 80%,
        rgba(90, 180, 240, 0.04),
        transparent 28%
      ),
      linear-gradient(180deg, var(--bg-1) 0%, var(--bg-2) 46%, var(--bg-3) 100%);
  }

  #como-pedir::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.025) 0%, transparent 18%),
      radial-gradient(circle at 50% 40%, rgba(0, 0, 0, 0.14), transparent 58%);
  }

  .steps-ambient,
  .steps-grid {
    position: absolute;
    z-index: 0;
    pointer-events: none;
  }

  .steps-ambient {
    border-radius: 999px;
    filter: blur(110px);
    opacity: 0.8;
    transform: translateZ(0);
  }

  .steps-ambient-1 {
    width: 38rem;
    height: 38rem;
    right: -12rem;
    top: -13rem;
    background: radial-gradient(
      circle,
      rgba(145, 225, 255, 0.11) 0%,
      transparent 72%
    );
    animation: ambientFloatOne 18s ease-in-out infinite alternate;
  }

  .steps-ambient-2 {
    width: 28rem;
    height: 28rem;
    left: -8rem;
    bottom: -8rem;
    background: radial-gradient(
      circle,
      rgba(65, 171, 226, 0.1) 0%,
      transparent 72%
    );
    animation: ambientFloatTwo 20s ease-in-out infinite alternate;
  }

  .steps-grid {
    inset: 0;
    opacity: 0.07;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: radial-gradient(circle at 50% 42%, black, transparent 80%);
    -webkit-mask-image: radial-gradient(
      circle at 50% 42%,
      black,
      transparent 80%
    );
  }

  #como-pedir .container {
    position: relative;
    z-index: 1;
  }

  .steps-header {
    max-width: 820px;
    margin: 0 auto 56px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .steps-header::after,
  .section-title::after {
    display: none !important;
  }

  .section-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    margin: 0 0 20px;
    padding: 8px 16px;
    border-radius: 999px;
    font-family: "Barlow", sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: rgba(214, 240, 252, 0.96);
    background: rgba(82, 173, 225, 0.08);
    border: 1px solid rgba(134, 219, 255, 0.16);
    box-shadow:
      0 12px 28px rgba(0, 0, 0, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }

  .label-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--blue-2);
    box-shadow: 0 0 10px rgba(134, 219, 255, 0.55);
    animation: pulseDot 2.2s ease-in-out infinite;
  }

  .section-title {
    margin: 0 0 14px;
    font-family: "Barlow Condensed", sans-serif;
    font-weight: 800;
    font-size: clamp(2.6rem, 5vw, 4.1rem);
    line-height: 0.92;
    letter-spacing: -0.03em;
    color: var(--ink);
    text-wrap: balance;
    text-transform: uppercase;
    text-shadow:
      0 18px 44px rgba(0, 0, 0, 0.28),
      0 2px 8px rgba(0, 0, 0, 0.18);
  }

  .section-subtitle {
    max-width: 620px;
    margin: 0;
    font-family: "Barlow", sans-serif;
    font-size: 0.98rem;
    line-height: 1.68;
    color: rgba(233, 244, 252, 0.74);
    text-wrap: balance;
  }

  .steps-note {
    max-width: 820px;
    margin: 18px auto 0;
    padding: 0 18px;
    text-align: center;
    font-size: 0.92rem;
    line-height: 1.6;
    color: rgba(233, 244, 252, 0.62);
  }

  .steps-stage {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) 56px minmax(0, 1fr) 56px minmax(
        0,
        1fr
      );
    align-items: center;
    max-width: 1120px;
    margin: 0 auto;
  }

  .stage-panel {
    position: absolute;
    inset: -14px;
    border-radius: 28px;
    pointer-events: none;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.026),
        rgba(255, 255, 255, 0.012)
      ),
      rgba(8, 22, 34, 0.14);
    border: 1px solid rgba(255, 255, 255, 0.045);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.035),
      0 24px 60px rgba(0, 0, 0, 0.1);
    transform: translateZ(0);
  }

  .step-card {
    position: relative;
  }

  .step-shell {
    position: relative;
    min-height: 270px;
    border-radius: 24px;
    overflow: hidden;
    transform: translate3d(0, 0, 0);
    transform-style: preserve-3d;
    will-change: transform;
    transition:
      transform 0.32s ease,
      box-shadow 0.32s ease,
      border-color 0.32s ease;
    box-shadow:
      0 16px 42px rgba(0, 0, 0, 0.18),
      0 8px 18px rgba(65, 171, 226, 0.04);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .step-card:hover .step-shell {
    transform: translate3d(0, -6px, 0);
    box-shadow:
      0 24px 54px rgba(0, 0, 0, 0.24),
      0 10px 24px rgba(65, 171, 226, 0.06);
  }

  .step-body {
    position: relative;
    z-index: 2;
    min-height: 270px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px 22px;
    text-align: center;
    border-radius: 24px;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.065) 0%,
        rgba(255, 255, 255, 0.02) 100%
      ),
      linear-gradient(
        180deg,
        rgba(15, 42, 65, 0.88) 0%,
        rgba(11, 31, 49, 0.9) 100%
      );
    border: 1px solid rgba(255, 255, 255, 0.075);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      inset 0 -1px 0 rgba(255, 255, 255, 0.02);
    transform: translateZ(0);
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .step-body-glow,
  .step-body-sheen {
    position: absolute;
    pointer-events: none;
    inset: 0;
    border-radius: inherit;
  }

  .step-body-glow {
    background:
      radial-gradient(
        circle at 50% 0%,
        rgba(110, 205, 255, 0.08),
        transparent 42%
      ),
      radial-gradient(
        circle at 50% 100%,
        rgba(40, 128, 196, 0.05),
        transparent 48%
      );
    opacity: 1;
  }

  .step-body-sheen {
    inset: 1px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.055) 0%,
      rgba(255, 255, 255, 0.012) 16%,
      transparent 42%
    );
    opacity: 1;
  }

  .step-meta,
  .step-top,
  .step-body h3,
  .step-body p {
    position: relative;
    z-index: 2;
  }

  .step-meta {
    margin-bottom: 10px;
    font-family: "Barlow", sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    color: rgba(194, 232, 249, 0.58);
  }

  .step-top {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    margin-bottom: 14px;
  }

  .step-badge-wrap,
  .step-icon-orb {
    width: 56px;
    height: 56px;
  }

  .step-badge-wrap {
    position: relative;
    display: grid;
    place-items: center;
    flex: 0 0 auto;
  }

  .step-badge-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 1px solid rgba(134, 219, 255, 0.22);
    animation: ringPulse 3s ease-in-out infinite;
  }

  .step-badge {
    position: relative;
    z-index: 1;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1.24rem;
    font-weight: 800;
    color: #fff;
    background: linear-gradient(135deg, #57c7fb 0%, #2e95d6 58%, #1a638f 100%);
    box-shadow:
      0 10px 24px rgba(65, 171, 226, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      inset 0 -2px 5px rgba(0, 0, 0, 0.16);
    transition:
      transform 0.28s ease,
      box-shadow 0.28s ease;
    transform: translateZ(0);
  }

  .step-card:hover .step-badge {
    transform: scale(1.04);
  }

  .step-icon-orb {
    position: relative;
    display: grid;
    place-items: center;
    border-radius: 50%;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.12),
        rgba(255, 255, 255, 0.035)
      ),
      rgba(12, 39, 59, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.09);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.08),
      0 10px 22px rgba(0, 0, 0, 0.1);
    overflow: hidden;
    flex: 0 0 auto;
    transform: translateZ(0);
  }

  .step-icon-orb::before {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at 30% 25%,
      rgba(255, 255, 255, 0.14),
      transparent 42%
    );
    pointer-events: none;
  }

  .step-icon-svg {
    position: relative;
    z-index: 1;
    width: 22px;
    height: 22px;
    color: rgba(238, 248, 255, 0.96);
  }

  .step-body h3 {
    margin: 0 0 8px;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1.12rem;
    line-height: 1;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.985);
  }

  .step-body p {
    max-width: 240px;
    margin: 0;
    font-family: "Barlow", sans-serif;
    font-size: 0.9rem;
    line-height: 1.62;
    color: var(--text-soft);
  }

  .step-connector {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 270px;
  }

  .connector-line {
    position: relative;
    display: block;
    width: 38px;
    height: 1px;
    border-radius: 999px;
    overflow: hidden;
    background: linear-gradient(
      90deg,
      rgba(134, 219, 255, 0.04) 0%,
      rgba(134, 219, 255, 0.3) 50%,
      rgba(134, 219, 255, 0.04) 100%
    );
    transform: translateZ(0);
  }

  .connector-line::after {
    content: "";
    position: absolute;
    top: 0;
    left: -35%;
    width: 35%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(235, 249, 255, 0.8),
      transparent
    );
    animation: connectorFlow 2.3s ease-in-out infinite;
  }

  .connector-core {
    position: absolute;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(134, 219, 255, 0.82);
    box-shadow: 0 0 14px rgba(134, 219, 255, 0.45);
    animation: pulseSoft 2.2s ease-in-out infinite;
    transform: translateZ(0);
  }

  .cta-center {
    margin-top: 52px;
    text-align: center;
  }

  .btn-liquid {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-radius: 999px;
    padding: 1px;
    text-decoration: none;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      filter 0.3s ease;
    box-shadow:
      0 18px 42px rgba(24, 108, 168, 0.24),
      0 0 0 1px rgba(255, 255, 255, 0.05);
    transform: translateZ(0);
  }

  .btn-liquid:hover,
  .btn-liquid:focus-visible {
    transform: translateY(-3px);
    box-shadow:
      0 24px 56px rgba(24, 108, 168, 0.3),
      0 0 0 1px rgba(255, 255, 255, 0.08);
    filter: saturate(1.03);
    outline: none;
  }

  .btn-layer {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    pointer-events: none;
  }

  .btn-layer-bg {
    background: linear-gradient(135deg, #49b6eb 0%, #2b87c8 50%, #65caf8 100%);
    background-size: 220% 100%;
    animation: btnShift 5.4s ease-in-out infinite;
  }

  .btn-layer-border {
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.22),
      inset 0 -1px 0 rgba(0, 0, 0, 0.14),
      0 0 0 1px rgba(255, 255, 255, 0.12);
  }

  .btn-content {
    position: relative;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 18px 38px;
    font-family: "Barlow", sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #fff;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.16);
  }

  @keyframes ambientFloatOne {
    from {
      transform: translate3d(0, 0, 0) scale(1);
    }
    to {
      transform: translate3d(-24px, 32px, 0) scale(1.06);
    }
  }

  @keyframes ambientFloatTwo {
    from {
      transform: translate3d(0, 0, 0) scale(1);
    }
    to {
      transform: translate3d(22px, -28px, 0) scale(1.08);
    }
  }

  @keyframes pulseDot {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.62;
      transform: scale(1.16);
    }
  }

  @keyframes ringPulse {
    0%,
    100% {
      opacity: 0.34;
      transform: scale(1);
    }
    50% {
      opacity: 0.68;
