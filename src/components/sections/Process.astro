---
const processFlow = [
  {
    step: "01",
    group: "Tratamiento",
    title: "Agua cruda",
    text: "Recepción y análisis inicial.",
    detail:
      "Punto de entrada del proceso, donde se verifica la calidad del agua antes de avanzar a las siguientes etapas.",
    image: "/images/process/agua-cruda.png",
    alt: "Tanque de agua cruda para recepción y análisis inicial",
  },
  {
    step: "02",
    group: "Filtración",
    title: "Filtros",
    text: "Remoción de partículas.",
    detail:
      "Sistema de filtrado diseñado para reducir sedimentos e impurezas visibles, estabilizando el flujo de tratamiento.",
    image: "/images/process/filtros.png",
    alt: "Sistema de filtros para remoción de partículas",
  },
  {
    step: "03",
    group: "Purificación",
    title: "Ósmosis inversa",
    text: "Alta pureza.",
    detail:
      "Etapa clave de purificación que mejora la calidad del agua para garantizar consistencia en la producción.",
    image: "/images/process/osmosis-inversa.png",
    alt: "Sistema de ósmosis inversa para purificación",
  },
  {
    step: "04",
    group: "Resultado",
    title: "Agua tratada",
    text: "Lista para producción.",
    detail:
      "Agua acondicionada y lista para ingresar al proceso de fabricación, bajo parámetros controlados.",
    image: "/images/process/agua-tratada.png",
    alt: "Agua tratada lista para producción",
  },
  {
    step: "05",
    group: "Producción",
    title: "Máquina de hielo",
    text: "Producción continua.",
    detail:
      "Sistema principal de fabricación, donde se transforma el agua tratada en hielo con operación continua.",
    image: "/images/process/maquina-hielo.png",
    alt: "Máquina de hielo en operación",
  },
  {
    step: "06",
    group: "Transferencia",
    title: "Dispensador",
    text: "Salida controlada.",
    detail:
      "Etapa de transferencia que canaliza el producto con control de flujo hacia el siguiente punto del proceso.",
    image: "/images/process/dispensador-hielo.png",
    alt: "Dispensador de hielo para salida controlada",
  },
  {
    step: "07",
    group: "Empaque",
    title: "Hielo en bolsa",
    text: "Sellado seguro.",
    detail:
      "Proceso de embolsado y sellado diseñado para conservar limpieza, presentación y seguridad del producto.",
    image: "/images/process/hielo-bolsa.png",
    alt: "Hielo en bolsa con sellado seguro",
  },
  {
    step: "08",
    group: "Conservación",
    title: "Cámara fría",
    text: "Control térmico.",
    detail:
      "Área de resguardo refrigerado para mantener la integridad del producto antes de su despacho.",
    image: "/images/process/camara-fria.png",
    alt: "Cámara fría para control térmico",
  },
  {
    step: "09",
    group: "Distribución",
    title: "Logística",
    text: "Entrega continua.",
    detail:
      "Fase final orientada a asegurar disponibilidad, continuidad operativa y entrega eficiente al cliente.",
    image: "/images/process/logistica.png",
    alt: "Logística de distribución y entrega continua",
  },
];
---

<section class="process-section" id="proceso">
  <div class="process-ambient process-ambient-1" aria-hidden="true"></div>
  <div class="process-ambient process-ambient-2" aria-hidden="true"></div>
  <div class="process-noise" aria-hidden="true"></div>
  <div class="process-grid-overlay" aria-hidden="true"></div>

  <div class="container process-container">
    <div class="process-header fade-in">
      <p class="section-label process-label">
        <span class="process-dot" aria-hidden="true"></span>
        Producción
      </p>

      <h2 class="section-title process-title">Proceso de producción</h2>

      <p class="section-subtitle process-subtitle">
        Un flujo continuo, controlado y trazable desde el tratamiento del agua
        hasta la distribución final.
      </p>
    </div>

    <div class="process-timeline" data-process-timeline>
      <div class="process-line" aria-hidden="true">
        <span class="process-line-track"></span>
        <span class="process-line-glow"></span>
        <span class="process-line-progress" data-process-progress></span>
      </div>

      <ol class="process-steps" aria-label="Etapas del proceso de producción">
        {
          processFlow.map((item, index) => (
            <li class="process-item" data-step-index={index}>
              <div class="process-pin" aria-hidden="true">
                <span class="process-pin-ring" />
                <span class="process-pin-core" />
                <span class="process-pin-dot" />
                <span class="process-pin-step">Paso {item.step}</span>
              </div>

              <div class="process-connector" aria-hidden="true">
                <span class="process-connector-line" />
              </div>

              <article class="process-card process-card-main">
                <div class="process-card-inner">
                  <div class="process-card-top">
                    <span class="process-group">{item.group}</span>
                    <span class="process-step-badge">Paso {item.step}</span>
                  </div>

                  <div class="process-media">
                    <img
                      src={item.image}
                      alt={item.alt}
                      loading={index < 2 ? "eager" : "lazy"}
                      decoding="async"
                    />
                  </div>

                  <div class="process-card-content">
                    <h3 class="process-card-title">{item.title}</h3>
                    <p class="process-card-text">{item.text}</p>
                  </div>
                </div>
              </article>

              <aside
                class="process-detail-card"
                aria-label={`Descripción de ${item.title}`}
              >
                <div class="process-detail-card-inner">
                  <div class="process-detail-top">
                    <span class="process-detail-label">Detalle técnico</span>
                    <span class="process-detail-step">Paso {item.step}</span>
                  </div>

                  <div class="process-detail-main">
                    <span class="process-detail-kicker">{item.group}</span>
                    <h4 class="process-detail-title">{item.title}</h4>
                    <p class="process-detail-text">{item.detail}</p>
                  </div>

                  <div class="process-detail-accent" aria-hidden="true">
                    <span class="process-detail-accent-line" />
                    <span class="process-detail-accent-dot" />
                  </div>
                </div>
              </aside>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  .process-section {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: clamp(74px, 8vw, 106px) 0;
    background:
      radial-gradient(
        ellipse 64% 46% at 8% 12%,
        rgba(157, 212, 242, 0.12) 0%,
        transparent 52%
      ),
      radial-gradient(
        ellipse 46% 50% at 92% 88%,
        rgba(65, 171, 226, 0.06) 0%,
        transparent 50%
      ),
      linear-gradient(180deg, #f9fcff 0%, #eef5fb 52%, #ffffff 100%);
  }

  .process-ambient,
  .process-noise,
  .process-grid-overlay {
    position: absolute;
    pointer-events: none;
  }

  .process-ambient {
    border-radius: 999px;
    filter: blur(78px);
    opacity: 0.66;
    z-index: 0;
  }

  .process-ambient-1 {
    top: -140px;
    left: -140px;
    width: 400px;
    height: 400px;
    background: rgba(157, 212, 242, 0.13);
  }

  .process-ambient-2 {
    right: -120px;
    bottom: -140px;
    width: 350px;
    height: 350px;
    background: rgba(65, 171, 226, 0.08);
  }

  .process-noise {
    inset: 0;
    z-index: 1;
    opacity: 0.01;
    background-image:
      radial-gradient(
        circle at 20% 20%,
        rgba(16, 33, 73, 0.08) 0.7px,
        transparent 0.8px
      ),
      radial-gradient(
        circle at 80% 40%,
        rgba(16, 33, 73, 0.08) 0.7px,
        transparent 0.8px
      );
    background-size:
      28px 28px,
      34px 34px;
  }

  .process-grid-overlay {
    inset: 0;
    z-index: 1;
    opacity: 0.045;
    background-image:
      linear-gradient(rgba(65, 171, 226, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(65, 171, 226, 0.05) 1px, transparent 1px);
    background-size: 120px 120px;
    mask-image: radial-gradient(circle at center, black 35%, transparent 86%);
  }

  .process-container {
    position: relative;
    z-index: 2;
  }

  .process-header {
    max-width: 760px;
    margin: 0 auto 46px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .process-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 16px;
    padding: 7px 13px;
    border-radius: 999px;
    border: 1px solid rgba(65, 171, 226, 0.2);
    background: rgba(255, 255, 255, 0.78);
    box-shadow:
      0 10px 26px rgba(24, 48, 88, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary);
    backdrop-filter: blur(12px);
  }

  .process-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: linear-gradient(180deg, #8fdcff, #41abe2);
    box-shadow: 0 0 0 4px rgba(65, 171, 226, 0.12);
  }

  .process-title {
    margin: 0 0 12px;
    line-height: 0.96;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    text-wrap: balance;
    color: var(--color-primary);
  }

  .process-subtitle {
    max-width: 620px;
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.64;
    color: rgba(16, 33, 73, 0.74);
    text-wrap: balance;
  }

  .process-timeline {
    --progress: 0;
    --line-x: 50%;
    position: relative;
    padding: 8px 0 6px;
  }

  .process-line {
    position: absolute;
    left: var(--line-x);
    top: 0;
    bottom: 0;
    width: 10px;
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 0;
  }

  .process-line-track,
  .process-line-glow,
  .process-line-progress {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    border-radius: 999px;
  }

  .process-line-track {
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
      180deg,
      rgba(16, 33, 73, 0.04) 0%,
      rgba(65, 171, 226, 0.16) 48%,
      rgba(16, 33, 73, 0.04) 100%
    );
  }

  .process-line-glow {
    top: 0;
    bottom: 0;
    width: 10px;
    background: linear-gradient(
      180deg,
      rgba(157, 212, 242, 0.02) 0%,
      rgba(65, 171, 226, 0.08) 50%,
      rgba(157, 212, 242, 0.02) 100%
    );
    filter: blur(5px);
    opacity: 0.9;
  }

  .process-line-progress {
    top: 0;
    width: 2px;
    height: calc(100% * var(--progress));
    background: linear-gradient(
      180deg,
      rgba(65, 171, 226, 0.34) 0%,
      rgba(65, 171, 226, 0.8) 58%,
      rgba(50, 59, 129, 0.92) 100%
    );
    box-shadow:
      0 0 0 1px rgba(65, 171, 226, 0.08),
      0 0 18px rgba(65, 171, 226, 0.09);
    transition: height 0.72s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .process-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 26px;
  }

  .process-item {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    column-gap: 60px;
    align-items: start;
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 0.55s ease,
      transform 0.55s ease;
  }

  .process-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .process-card-main,
  .process-detail-card {
    width: 100%;
    max-width: 500px;
    align-self: start;
    margin-top: 0;
  }

  .process-item:nth-child(odd) .process-card-main {
    grid-column: 1 / 2;
    grid-row: 1;
    justify-self: end;
  }

  .process-item:nth-child(odd) .process-detail-card {
    grid-column: 2 / 3;
    grid-row: 1;
    justify-self: start;
  }

  .process-item:nth-child(even) .process-detail-card {
    grid-column: 1 / 2;
    grid-row: 1;
    justify-self: end;
  }

  .process-item:nth-child(even) .process-card-main {
    grid-column: 2 / 3;
    grid-row: 1;
    justify-self: start;
  }

  .process-item:nth-child(odd) .process-card-main,
  .process-item:nth-child(odd) .process-detail-card,
  .process-item:nth-child(even) .process-card-main,
  .process-item:nth-child(even) .process-detail-card {
    align-self: start;
  }

  .process-item > .process-card-main,
  .process-item > .process-detail-card {
    transform: translateY(0);
  }

  .process-pin {
    position: absolute;
    left: var(--line-x);
    top: 32px;
    transform: translateX(-50%);
    z-index: 3;
    display: grid;
    justify-items: center;
    gap: 5px;
  }

  .process-pin-ring {
    position: absolute;
    top: -6px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(65, 171, 226, 0.06);
    border: 1px solid rgba(65, 171, 226, 0.14);
    backdrop-filter: blur(8px);
    transition:
      transform 0.35s ease,
      opacity 0.35s ease;
  }

  .process-pin-core {
    position: absolute;
    top: 1px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.92);
    border: 1px solid rgba(65, 171, 226, 0.22);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.95),
      0 8px 14px rgba(27, 47, 94, 0.08);
  }

  .process-pin-dot {
    position: relative;
    width: 8px;
    height: 8px;
    margin-top: 4px;
    border-radius: 50%;
    background: linear-gradient(
      180deg,
      rgba(65, 171, 226, 0.94),
      rgba(50, 59, 129, 0.94)
    );
    box-shadow:
      0 0 0 4px rgba(65, 171, 226, 0.12),
      0 10px 16px rgba(27, 47, 94, 0.12);
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease;
  }

  .process-item.is-visible .process-pin-ring {
    transform: scale(1.08);
    opacity: 1;
  }

  .process-item.is-visible .process-pin-dot {
    transform: scale(1.06);
    box-shadow:
      0 0 0 5px rgba(65, 171, 226, 0.14),
      0 10px 18px rgba(27, 47, 94, 0.13);
  }

  .process-pin-step {
    position: relative;
    margin-top: 9px;
    padding: 3px 9px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.93);
    border: 1px solid rgba(65, 171, 226, 0.2);
    color: rgba(16, 33, 73, 0.82);
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    box-shadow: 0 5px 12px rgba(11, 32, 51, 0.05);
    backdrop-filter: blur(10px);
    white-space: nowrap;
  }

  .process-connector {
    position: absolute;
    top: 39px;
    left: 50%;
    width: 44px;
    height: 14px;
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 1;
  }

  .process-item:nth-child(odd) .process-connector {
    margin-left: 24px;
  }

  .process-item:nth-child(even) .process-connector {
    margin-left: -24px;
  }

  .process-connector-line {
    position: absolute;
    top: 6px;
    left: 0;
    right: 0;
    height: 1px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      rgba(65, 171, 226, 0) 0%,
      rgba(65, 171, 226, 0.18) 30%,
      rgba(65, 171, 226, 0.42) 100%
    );
    opacity: 0.88;
  }

  .process-item:nth-child(even) .process-connector-line {
    background: linear-gradient(
      90deg,
      rgba(65, 171, 226, 0.42) 0%,
      rgba(65, 171, 226, 0.18) 70%,
      rgba(65, 171, 226, 0) 100%
    );
  }

  .process-connector-line::before {
    content: "";
    position: absolute;
    inset: -1px 0;
    background-image: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.55) 50%,
      transparent 100%
    );
    background-size: 120px 100%;
    background-repeat: repeat-x;
    opacity: 0.55;
    animation: processFlowLine 4.6s linear infinite;
    mix-blend-mode: screen;
  }

  .process-item:nth-child(even) .process-connector-line::before {
    animation-direction: reverse;
  }

  .process-connector-line::after {
    content: "";
    position: absolute;
    top: 50%;
    right: 0;
    width: 7px;
    height: 7px;
    border-top: 1.5px solid rgba(65, 171, 226, 0.4);
    border-right: 1.5px solid rgba(65, 171, 226, 0.4);
    transform: translateY(-50%) rotate(45deg);
  }

  .process-item:nth-child(even) .process-connector-line::after {
    right: auto;
    left: 0;
    border-top: 0;
    border-right: 0;
    border-left: 1.5px solid rgba(65, 171, 226, 0.4);
    border-bottom: 1.5px solid rgba(65, 171, 226, 0.4);
    transform: translateY(-50%) rotate(45deg);
  }

  .process-card-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 14px;
    border-radius: 22px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.94) 0%,
      rgba(248, 252, 255, 0.9) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.94);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.96),
      0 16px 34px rgba(27, 47, 94, 0.075),
      0 6px 14px rgba(27, 47, 94, 0.03);
    backdrop-filter: blur(14px) saturate(1.05);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease;
  }

  .process-card-inner::before {
    content: "";
    position: absolute;
    top: 0;
    left: 14px;
    right: 14px;
    height: 3px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      rgba(50, 59, 129, 0.34),
      rgba(65, 171, 226, 0.8),
      rgba(157, 212, 242, 0.74)
    );
    opacity: 0.55;
    transform: scaleX(0.42);
    transform-origin: left;
    transition:
      transform 0.35s ease,
      opacity 0.35s ease;
  }

  .process-card-inner::after {
    content: "";
    position: absolute;
    inset: 1px;
    border-radius: inherit;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.18),
      rgba(255, 255, 255, 0) 42%
    );
    opacity: 0.75;
  }

  .process-item.is-visible .process-card-inner::before {
    transform: scaleX(1);
  }

  .process-card-inner:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 255, 255, 0.98);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 20px 42px rgba(27, 47, 94, 0.09),
      0 8px 18px rgba(27, 47, 94, 0.05);
  }

  .process-card-top,
  .process-card-content {
    position: relative;
    z-index: 2;
  }

  .process-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .process-group {
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.17em;
    text-transform: uppercase;
    color: rgba(16, 33, 73, 0.52);
  }

  .process-step-badge {
    display: none;
    align-items: center;
    justify-content: center;
    padding: 3px 9px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(65, 171, 226, 0.2);
    color: rgba(16, 33, 73, 0.82);
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    box-shadow: 0 5px 12px rgba(11, 32, 51, 0.05);
    backdrop-filter: blur(10px);
    white-space: nowrap;
  }

  .process-media {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 8.6;
    border-radius: 15px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(255, 255, 255, 0.92);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.74),
      0 10px 22px rgba(27, 47, 94, 0.065);
  }

  .process-media::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        circle at 18% 14%,
        rgba(255, 255, 255, 0.22),
        transparent 28%
      ),
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.02) 0%,
        rgba(16, 33, 73, 0.12) 100%
      );
    z-index: 1;
    pointer-events: none;
  }

  .process-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transition:
      transform 0.5s ease,
      filter 0.5s ease;
  }

  .process-card-inner:hover .process-media img {
    transform: scale(1.024);
    filter: saturate(1.03);
  }

  .process-card-content {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex: 1 1 auto;
    justify-content: flex-start;
  }

  .process-card-title {
    margin: 0;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1.02rem;
    line-height: 1.03;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .process-card-text {
    margin: 0;
    font-size: 0.84rem;
    line-height: 1.5;
    color: rgba(16, 33, 73, 0.7);
  }

  .process-detail-card {
    position: relative;
  }

