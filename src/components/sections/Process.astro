---
import "swiper/css";
import "swiper/css/navigation";

const processFlow = [
  {
    step: "01",
    group: "Tratamiento",
    title: "Agua cruda",
    text: "Recepción y análisis inicial.",
    image: "/images/process/agua-cruda.png",
    alt: "Tanque de agua cruda para recepción y análisis inicial",
  },
  {
    step: "02",
    group: "Filtración",
    title: "Filtros",
    text: "Remoción de partículas.",
    image: "/images/process/filtros.png",
    alt: "Sistema de filtros para remoción de partículas",
  },
  {
    step: "03",
    group: "Purificación",
    title: "Ósmosis inversa",
    text: "Alta pureza.",
    image: "/images/process/osmosis-inversa.png",
    alt: "Sistema de ósmosis inversa para purificación",
  },
  {
    step: "04",
    group: "Resultado",
    title: "Agua tratada",
    text: "Lista para producción.",
    image: "/images/process/agua-tratada.png",
    alt: "Agua tratada lista para producción",
  },
  {
    step: "05",
    group: "Producción",
    title: "Máquina de hielo",
    text: "Producción continua.",
    image: "/images/process/maquina-hielo.png",
    alt: "Máquina de hielo en operación",
  },
  {
    step: "06",
    group: "Transferencia",
    title: "Dispensador",
    text: "Salida controlada.",
    image: "/images/process/dispensador-hielo.png",
    alt: "Dispensador de hielo para salida controlada",
  },
  {
    step: "07",
    group: "Empaque",
    title: "Hielo en bolsa",
    text: "Sellado seguro.",
    image: "/images/process/hielo-bolsa.png",
    alt: "Hielo en bolsa con sellado seguro",
  },
  {
    step: "08",
    group: "Conservación",
    title: "Cámara fría",
    text: "Control térmico.",
    image: "/images/process/camara-fria.png",
    alt: "Cámara fría para control térmico",
  },
  {
    step: "09",
    group: "Distribución",
    title: "Logística",
    text: "Entrega continua.",
    image: "/images/process/logistica.png",
    alt: "Logística de distribución y entrega continua",
  },
];
---

<section class="process-section">
  <div class="container">
    <h2 class="process-title">Proceso de producción</h2>

    <div class="swiper process-swiper" data-process-swiper>
      <div class="swiper-wrapper">
        {
          processFlow.map((item) => (
            <div class="swiper-slide process-slide">
              <div class="card">
                <div class="badge">{item.step}</div>
                <div class="group">{item.group}</div>
                <div class="media">
                  <img src={item.image} alt={item.alt} loading="lazy" />
                </div>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </div>
            </div>
          ))
        }
      </div>

      <button class="process-nav process-nav--prev" type="button" aria-label="Anterior">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 5l-7 7 7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
      <button class="process-nav process-nav--next" type="button" aria-label="Siguiente">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M9 5l7 7-7 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  .process-section {
    padding: 80px 0;
    text-align: center;
  }

  .process-title {
    font-size: 3rem;
    margin-bottom: 40px;
  }

  .process-swiper {
    position: relative;
    overflow: visible;
    padding: 10px 0 20px;
  }

  .process-swiper .swiper-wrapper {
    align-items: stretch;
  }

  .process-slide {
    width: 300px;
    opacity: 0.45;
    transform: scale(0.86);
    transition: transform 0.6s ease, opacity 0.6s ease, filter 0.6s ease;
    filter: saturate(0.9);
    padding: 8px 6px;
  }

  .process-swiper .swiper-slide-active {
    opacity: 1;
    transform: scale(1);
    filter: saturate(1.05);
  }

  .process-swiper .swiper-slide-prev,
  .process-swiper .swiper-slide-next {
    opacity: 0.7;
    transform: scale(0.93);
    filter: saturate(1);
  }

  .card {
    padding: 30px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(10px);
    box-shadow: 0 18px 40px rgba(11, 32, 51, 0.1);
    transition: box-shadow 0.4s ease, transform 0.4s ease;
  }

  .badge {
    letter-spacing: 0.2em;
    text-transform: uppercase;
    font-size: 0.8rem;
    margin-bottom: 10px;
  }

  .group {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: rgba(11, 32, 51, 0.55);
    margin-bottom: 12px;
  }

  .media {
    position: relative;
    margin: 16px auto 20px;
    width: 100%;
    max-width: 230px;
    aspect-ratio: 5 / 4;
    border-radius: 18px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.7);
    border: 1px solid rgba(255, 255, 255, 0.6);
    box-shadow: inset 0 0 0 1px rgba(11, 32, 51, 0.04);
  }

  .media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(11, 32, 51, 0) 35%, rgba(11, 32, 51, 0.18) 100%);
    pointer-events: none;
  }

  .media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .process-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 42px;
    height: 42px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.85);
    box-shadow: 0 12px 24px rgba(11, 32, 51, 0.12);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(11, 32, 51, 0.8);
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease, opacity 0.25s ease;
    z-index: 2;
  }

  .process-nav svg {
    width: 18px;
    height: 18px;
  }

  .process-nav--prev {
    left: -6px;
  }

  .process-nav--next {
    right: -6px;
  }

  .process-nav:hover {
    transform: translateY(calc(-50% - 1px));
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 16px 28px rgba(11, 32, 51, 0.16);
  }

  .process-nav:active {
    transform: translateY(-50%);
    box-shadow: 0 10px 20px rgba(11, 32, 51, 0.12);
  }

  .process-nav[disabled],
  .process-nav.swiper-button-disabled {
    opacity: 0.35;
    pointer-events: none;
  }

  .process-swiper .swiper-slide-active .card {
    box-shadow: 0 22px 48px rgba(11, 32, 51, 0.18);
  }

  @media (max-width: 720px) {
    .process-title {
      font-size: 2.2rem;
    }

    .process-slide {
      width: 250px;
    }

    .card {
      padding: 24px;
    }

    .media {
      max-width: 210px;
    }

    .process-nav {
      width: 36px;
      height: 36px;
      top: auto;
      bottom: -8px;
      transform: translateY(0);
    }

    .process-nav--prev {
      left: 6px;
    }

    .process-nav--next {
      right: 6px;
    }

    .process-nav:hover {
      transform: translateY(-1px);
    }

    .process-nav:active {
      transform: translateY(0);
    }
  }
</style>

<script>
  import Swiper from "swiper";
  import { Navigation, Keyboard, Mousewheel, Autoplay } from "swiper/modules";

  const init = () => {
    const el = document.querySelector("[data-process-swiper]");
    if (!el || el.dataset.ready) return;

    new Swiper(el, {
      modules: [Navigation, Keyboard, Mousewheel, Autoplay],
      loop: true,
      centeredSlides: true,
      speed: 900,
      slidesPerView: "auto",
      spaceBetween: 12,
      watchSlidesProgress: true,
      autoplay: {
        delay: 3500,
        disableOnInteraction: false,
        pauseOnMouseEnter: true,
      },
      navigation: {
        nextEl: el.querySelector(".process-nav--next"),
        prevEl: el.querySelector(".process-nav--prev"),
      },
      keyboard: true,
      mousewheel: true,
    });

    el.dataset.ready = "true";
  };

  init();
</script>
