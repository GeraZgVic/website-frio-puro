---
const processFlow = [
  {
    step: "01",
    group: "Tratamiento",
    title: "Agua cruda",
    text: "Recepción y análisis inicial.",
    detail:
      "Punto de entrada del proceso, donde se verifica la calidad del agua antes de avanzar a las siguientes etapas.",
    image: "/images/process/agua-cruda.png",
    alt: "Tanque de agua cruda para recepción y análisis inicial",
  },
  {
    step: "02",
    group: "Filtración",
    title: "Filtros",
    text: "Remoción de partículas.",
    detail:
      "Sistema de filtrado diseñado para reducir sedimentos e impurezas visibles, estabilizando el flujo de tratamiento.",
    image: "/images/process/filtros.png",
    alt: "Sistema de filtros para remoción de partículas",
  },
  {
    step: "03",
    group: "Purificación",
    title: "Ósmosis inversa",
    text: "Alta pureza.",
    detail:
      "Etapa clave de purificación que mejora la calidad del agua para garantizar consistencia en la producción.",
    image: "/images/process/osmosis-inversa.png",
    alt: "Sistema de ósmosis inversa para purificación",
  },
  {
    step: "04",
    group: "Resultado",
    title: "Agua tratada",
    text: "Lista para producción.",
    detail:
      "Agua acondicionada y lista para ingresar al proceso de fabricación, bajo parámetros controlados.",
    image: "/images/process/agua-tratada.png",
    alt: "Agua tratada lista para producción",
  },
  {
    step: "05",
    group: "Producción",
    title: "Máquina de hielo",
    text: "Producción continua.",
    detail:
      "Sistema principal de fabricación, donde se transforma el agua tratada en hielo con operación continua.",
    image: "/images/process/maquina-hielo.png",
    alt: "Máquina de hielo en operación",
  },
  {
    step: "06",
    group: "Transferencia",
    title: "Dispensador",
    text: "Salida controlada.",
    detail:
      "Etapa de transferencia que canaliza el producto con control de flujo hacia el siguiente punto del proceso.",
    image: "/images/process/dispensador-hielo.png",
    alt: "Dispensador de hielo para salida controlada",
  },
  {
    step: "07",
    group: "Empaque",
    title: "Hielo en bolsa",
    text: "Sellado seguro.",
    detail:
      "Proceso de embolsado y sellado diseñado para conservar limpieza, presentación y seguridad del producto.",
    image: "/images/process/hielo-bolsa.png",
    alt: "Hielo en bolsa con sellado seguro",
  },
  {
    step: "08",
    group: "Conservación",
    title: "Cámara fría",
    text: "Control térmico.",
    detail:
      "Área de resguardo refrigerado para mantener la integridad del producto antes de su despacho.",
    image: "/images/process/camara-fria.png",
    alt: "Cámara fría para control térmico",
  },
  {
    step: "09",
    group: "Distribución",
    title: "Logística",
    text: "Entrega continua.",
    detail:
      "Fase final orientada a asegurar disponibilidad, continuidad operativa y entrega eficiente al cliente.",
    image: "/images/process/logistica.png",
    alt: "Logística de distribución y entrega continua",
  },
];
---

<section class="process-section" id="proceso">
  <div class="process-ambient process-ambient-1" aria-hidden="true"></div>
  <div class="process-ambient process-ambient-2" aria-hidden="true"></div>
  <div class="process-ambient process-ambient-3" aria-hidden="true"></div>
  <div class="process-noise" aria-hidden="true"></div>
  <div class="process-grid-overlay" aria-hidden="true"></div>

  <div class="container process-container">
    <div class="process-header fade-in">
      <p class="section-label process-label">
        <span class="process-dot" aria-hidden="true"></span>
        Producción
      </p>

      <h2 class="section-title process-title">Proceso de producción</h2>

      <p class="section-subtitle process-subtitle">
        Un flujo continuo, controlado y trazable desde el tratamiento del agua
        hasta la distribución final.
      </p>
    </div>

    <div class="process-timeline" data-process-timeline>
      <div class="process-line" aria-hidden="true">
        <span class="process-line-track"></span>
        <span class="process-line-glow"></span>
        <span class="process-line-progress" data-process-progress></span>
      </div>

      <ol class="process-steps" aria-label="Etapas del proceso de producción">
        {
          processFlow.map((item, index) => (
            <li class="process-item" data-step-index={index}>
              <div class="process-pin" aria-hidden="true">
                <span class="process-pin-ring" />
                <span class="process-pin-ring process-pin-ring--outer" />
                <span class="process-pin-core" />
                <span class="process-pin-dot" />
                <span class="process-pin-step">Paso {item.step}</span>
              </div>

              <div class="process-connector" aria-hidden="true">
                <span class="process-connector-line" />
              </div>

              <article class="process-card process-card-main">
                <div class="process-card-inner">
                  <div class="process-card-top">
                    <span class="process-group">{item.group}</span>
                    <span class="process-step-badge">Paso {item.step}</span>
                  </div>

                  <div class="process-media">
                    <div class="process-media-shimmer" aria-hidden="true" />
                    <img
                      src={item.image}
                      alt={item.alt}
                      loading="lazy"
                      decoding="async"
                    />
                  </div>

                  <div class="process-card-content">
                    <h3 class="process-card-title">{item.title}</h3>
                    <p class="process-card-text">{item.text}</p>
                  </div>
                </div>
              </article>

              <aside
                class="process-detail-card"
                aria-label={`Descripción de ${item.title}`}
              >
                <div class="process-detail-card-inner">
                  <div class="process-detail-top">
                    <span class="process-detail-label">Detalle técnico</span>
                    <span class="process-detail-step">Paso {item.step}</span>
                  </div>

                  <div class="process-detail-main">
                    <span class="process-detail-kicker">{item.group}</span>
                    <h4 class="process-detail-title">{item.title}</h4>
                    <p class="process-detail-text">{item.detail}</p>
                  </div>

                  <div class="process-detail-accent" aria-hidden="true">
                    <span class="process-detail-accent-line" />
                    <span class="process-detail-accent-dot" />
                  </div>
                </div>
              </aside>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>

<style>
  /* ─── Custom Properties ─────────────────────────────────────── */
  .process-section {
    --clr-primary: var(--color-primary, #102149);
    --clr-accent: #41abe2;
    --clr-accent-light: #9dd4f2;
    --clr-accent-deep: #323b81;
    --clr-surface: rgba(255, 255, 255, 0.94);
    --clr-text-muted: rgba(16, 33, 73, 0.62);
    --clr-text-faint: rgba(16, 33, 73, 0.44);
    --clr-border: rgba(255, 255, 255, 0.94);
    --clr-border-accent: rgba(65, 171, 226, 0.22);
    --shadow-card:
      inset 0 1px 0 rgba(255, 255, 255, 0.96),
      0 18px 38px rgba(27, 47, 94, 0.08), 0 6px 14px rgba(27, 47, 94, 0.04);
    --shadow-card-hover:
      inset 0 1px 0 rgba(255, 255, 255, 1), 0 24px 48px rgba(27, 47, 94, 0.11),
      0 10px 22px rgba(27, 47, 94, 0.06);
    --radius-card: 22px;
    --radius-media: 15px;
    --timing-smooth: cubic-bezier(0.22, 1, 0.36, 1);
    --timing-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  /* ─── Section Base ──────────────────────────────────────────── */
  .process-section {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: clamp(74px, 8vw, 106px) 0;
    background:
      radial-gradient(
        ellipse 64% 46% at 8% 12%,
        rgba(157, 212, 242, 0.13) 0%,
        transparent 52%
      ),
      radial-gradient(
        ellipse 46% 50% at 92% 88%,
        rgba(65, 171, 226, 0.07) 0%,
        transparent 50%
      ),
      linear-gradient(180deg, #f9fcff 0%, #eef5fb 52%, #ffffff 100%);
  }

  /* ─── Ambient / Decorative Layers ──────────────────────────── */
  .process-ambient,
  .process-noise,
  .process-grid-overlay {
    position: absolute;
    pointer-events: none;
    will-change: transform; /* Promote to composited layer */
  }

  .process-ambient {
    border-radius: 999px;
    filter: blur(80px);
    z-index: 0;
  }

  .process-ambient-1 {
    top: -160px;
    left: -160px;
    width: 440px;
    height: 440px;
    background: rgba(157, 212, 242, 0.14);
    opacity: 0.7;
    animation: ambientDrift1 18s ease-in-out infinite alternate;
  }

  .process-ambient-2 {
    right: -130px;
    bottom: -160px;
    width: 380px;
    height: 380px;
    background: rgba(65, 171, 226, 0.09);
    opacity: 0.7;
    animation: ambientDrift2 22s ease-in-out infinite alternate;
  }

  /* NEW: subtle center ambient for depth */
  .process-ambient-3 {
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 600px;
    height: 300px;
    background: radial-gradient(
      ellipse,
      rgba(65, 171, 226, 0.04) 0%,
      transparent 70%
    );
    opacity: 1;
    filter: blur(40px);
  }

  @keyframes ambientDrift1 {
    from {
      transform: translate(0, 0) scale(1);
    }
    to {
      transform: translate(24px, 18px) scale(1.06);
    }
  }

  @keyframes ambientDrift2 {
    from {
      transform: translate(0, 0) scale(1);
    }
    to {
      transform: translate(-20px, -14px) scale(1.04);
    }
  }

  .process-noise {
    inset: 0;
    z-index: 1;
    opacity: 0.018;
    background-image:
      radial-gradient(
        circle at 20% 20%,
        rgba(16, 33, 73, 0.09) 0.7px,
        transparent 0.8px
      ),
      radial-gradient(
        circle at 80% 40%,
        rgba(16, 33, 73, 0.09) 0.7px,
        transparent 0.8px
      );
    background-size:
      28px 28px,
      34px 34px;
  }

  .process-grid-overlay {
    inset: 0;
    z-index: 1;
    opacity: 0.04;
    background-image:
      linear-gradient(rgba(65, 171, 226, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(65, 171, 226, 0.05) 1px, transparent 1px);
    background-size: 120px 120px;
    mask-image: radial-gradient(circle at center, black 35%, transparent 86%);
  }

  /* ─── Layout ────────────────────────────────────────────────── */
  .process-container {
    position: relative;
    z-index: 2;
  }

  /* ─── Header ────────────────────────────────────────────────── */
  .process-header {
    max-width: 760px;
    margin: 0 auto 52px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0; /* Controlled per-child */
  }

  .process-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 18px;
    padding: 7px 14px;
    border-radius: 999px;
    border: 1px solid rgba(65, 171, 226, 0.22);
    background: rgba(255, 255, 255, 0.82);
    box-shadow:
      0 10px 28px rgba(24, 48, 88, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--clr-primary);
    backdrop-filter: blur(12px);
    transition:
      box-shadow 0.3s ease,
      border-color 0.3s ease;
  }

  .process-label:hover {
    border-color: rgba(65, 171, 226, 0.34);
    box-shadow:
      0 12px 32px rgba(24, 48, 88, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.95);
  }

  /* Animated dot pulse */
  .process-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: linear-gradient(180deg, #8fdcff, #41abe2);
    box-shadow: 0 0 0 4px rgba(65, 171, 226, 0.12);
    animation: dotPulse 2.8s ease-in-out infinite;
  }

  @keyframes dotPulse {
    0%,
    100% {
      box-shadow: 0 0 0 4px rgba(65, 171, 226, 0.12);
    }
    50% {
      box-shadow: 0 0 0 6px rgba(65, 171, 226, 0.18);
    }
  }

  .process-title {
    margin: 0 0 14px;
    line-height: 0.96;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    text-wrap: balance;
    color: var(--clr-primary);
  }

  .process-subtitle {
    max-width: 580px;
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.68;
    color: var(--clr-text-muted);
    text-wrap: balance;
  }

  /* ─── Timeline Shell ────────────────────────────────────────── */
  .process-timeline {
    --progress: 0;
    --line-x: 50%;
    position: relative;
    padding: 8px 12px;
  }

  /* ─── Vertical Line ─────────────────────────────────────────── */
  .process-line {
    position: absolute;
    left: var(--line-x);
    top: 0;
    bottom: 0;
    width: 10px;
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 0;
  }

  .process-line-track,
  .process-line-glow,
  .process-line-progress {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    border-radius: 999px;
  }

  .process-line-track {
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(
      180deg,
      rgba(16, 33, 73, 0.04) 0%,
      rgba(65, 171, 226, 0.18) 48%,
      rgba(16, 33, 73, 0.04) 100%
    );
  }

  .process-line-glow {
    top: 0;
    bottom: 0;
    width: 12px;
    background: linear-gradient(
      180deg,
      rgba(157, 212, 242, 0.02) 0%,
      rgba(65, 171, 226, 0.09) 50%,
      rgba(157, 212, 242, 0.02) 100%
    );
    filter: blur(6px);
    opacity: 0.85;
  }

  .process-line-progress {
    top: 0;
    width: 2px;
    height: calc(100% * var(--progress));
    background: linear-gradient(
      180deg,
      rgba(65, 171, 226, 0.36) 0%,
      rgba(65, 171, 226, 0.84) 52%,
      rgba(50, 59, 129, 0.94) 100%
    );
    box-shadow:
      0 0 0 1px rgba(65, 171, 226, 0.1),
      0 0 22px rgba(65, 171, 226, 0.12);
    transition: height 0.85s var(--timing-smooth);
    will-change: height;
  }

  /* ─── Steps List ────────────────────────────────────────────── */
  .process-steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 28px;
  }

  /* ─── Individual Step Item ──────────────────────────────────── */
  .process-item {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    column-gap: 64px;
    align-items: start;
    opacity: 0;
    transform: translateY(22px);
    transition:
      opacity 0.62s var(--timing-smooth),
      transform 0.62s var(--timing-smooth);
    will-change: opacity, transform;
  }

  /* Stagger delay per item for cascade feel */
  .process-item:nth-child(1) {
    transition-delay: 0ms;
  }
  .process-item:nth-child(2) {
    transition-delay: 40ms;
  }
  .process-item:nth-child(3) {
    transition-delay: 80ms;
  }
  .process-item:nth-child(4) {
    transition-delay: 120ms;
  }
  .process-item:nth-child(5) {
    transition-delay: 160ms;
  }
  .process-item:nth-child(6) {
    transition-delay: 200ms;
  }
  .process-item:nth-child(7) {
    transition-delay: 240ms;
  }
  .process-item:nth-child(8) {
    transition-delay: 280ms;
  }
  .process-item:nth-child(9) {
    transition-delay: 320ms;
  }

  .process-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ─── Card Sizing & Placement ───────────────────────────────── */
  .process-card-main,
  .process-detail-card {
    width: 100%;
    max-width: 500px;
    align-self: start;
  }

  /* Odd: main card left, detail right */
  .process-item:nth-child(odd) .process-card-main {
    grid-column: 1 / 2;
    grid-row: 1;
    justify-self: end;
  }
  .process-item:nth-child(odd) .process-detail-card {
    grid-column: 2 / 3;
    grid-row: 1;
    justify-self: start;
  }

  /* Even: detail left, main card right */
  .process-item:nth-child(even) .process-detail-card {
    grid-column: 1 / 2;
    grid-row: 1;
    justify-self: end;
  }
  .process-item:nth-child(even) .process-card-main {
    grid-column: 2 / 3;
    grid-row: 1;
    justify-self: start;
  }

  /* ─── Pin ───────────────────────────────────────────────────── */
  .process-pin {
    position: absolute;
    left: var(--line-x);
    top: 32px;
    transform: translateX(-50%);
    z-index: 3;
    display: grid;
    justify-items: center;
    gap: 5px;
  }

  .process-pin-ring {
    position: absolute;
    top: -6px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: rgba(65, 171, 226, 0.06);
    border: 1px solid rgba(65, 171, 226, 0.14);
    backdrop-filter: blur(8px);
    transition:
      transform 0.45s var(--timing-bounce),
      opacity 0.45s ease;
    will-change: transform;
  }

  /* NEW: outer ping ring for active state */
  .process-pin-ring--outer {
    width: 34px;
    height: 34px;
    top: -11px;
    background: transparent;
    border-color: rgba(65, 171, 226, 0.07);
    opacity: 0;
    transition:
      transform 0.6s var(--timing-smooth),
      opacity 0.6s ease;
  }

  .process-pin-core {
    position: absolute;
    top: 1px;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(65, 171, 226, 0.24);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.95),
      0 8px 16px rgba(27, 47, 94, 0.09);
    transition: transform 0.35s var(--timing-bounce);
  }

  .process-pin-dot {
    position: relative;
    width: 8px;
    height: 8px;
    margin-top: 4px;
    border-radius: 50%;
    background: linear-gradient(
      180deg,
      rgba(65, 171, 226, 0.96),
      rgba(50, 59, 129, 0.96)
    );
    box-shadow:
      0 0 0 4px rgba(65, 171, 226, 0.12),
      0 10px 18px rgba(27, 47, 94, 0.13);
    transition:
      transform 0.45s var(--timing-bounce),
      box-shadow 0.45s ease;
    will-change: transform;
  }

  /* Visible state – pin animations */
  .process-item.is-visible .process-pin-ring {
    transform: scale(1.1);
  }
  .process-item.is-visible .process-pin-ring--outer {
    transform: scale(1.12);
    opacity: 1;
  }
  .process-item.is-visible .process-pin-dot {
    transform: scale(1.1);
    box-shadow:
      0 0 0 6px rgba(65, 171, 226, 0.15),
      0 10px 20px rgba(27, 47, 94, 0.14);
  }

  .process-pin-step {
    position: relative;
    margin-top: 10px;
    padding: 3px 9px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(65, 171, 226, 0.2);
    color: rgba(16, 33, 73, 0.82);
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    box-shadow: 0 5px 14px rgba(11, 32, 51, 0.06);
    backdrop-filter: blur(10px);
    white-space: nowrap;
  }

  /* ─── Connector ─────────────────────────────────────────────── */
  .process-connector {
    position: absolute;
    top: 39px;
    left: 50%;
    width: 44px;
    height: 14px;
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 1;
  }

  .process-item:nth-child(odd) .process-connector {
    margin-left: 24px;
  }
  .process-item:nth-child(even) .process-connector {
    margin-left: -24px;
  }

  .process-connector-line {
    position: absolute;
    top: 6px;
    left: 0;
    right: 0;
    height: 1px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      rgba(65, 171, 226, 0) 0%,
      rgba(65, 171, 226, 0.2) 30%,
      rgba(65, 171, 226, 0.46) 100%
    );
    opacity: 0.9;
  }

  .process-item:nth-child(even) .process-connector-line {
    background: linear-gradient(
      90deg,
      rgba(65, 171, 226, 0.46) 0%,
      rgba(65, 171, 226, 0.2) 70%,
      rgba(65, 171, 226, 0) 100%
    );
  }

  /* Flow shimmer animation on connector */
  .process-connector-line::before {
    content: "";
    position: absolute;
    inset: -1px 0;
    background-image: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.6) 50%,
      transparent 100%
    );
    background-size: 120px 100%;
    background-repeat: repeat-x;
    opacity: 0.5;
    animation: processFlowLine 4.6s linear infinite;
    mix-blend-mode: screen;
  }

  .process-item:nth-child(even) .process-connector-line::before {
    animation-direction: reverse;
  }

  /* Arrow tip */
  .process-connector-line::after {
    content: "";
    position: absolute;
    top: 50%;
    right: 0;
    width: 6px;
    height: 6px;
    border-top: 1.5px solid rgba(65, 171, 226, 0.44);
    border-right: 1.5px solid rgba(65, 171, 226, 0.44);
    transform: translateY(-50%) rotate(45deg);
  }

  .process-item:nth-child(even) .process-connector-line::after {
    right: auto;
    left: 0;
    border-top: 0;
    border-right: 0;
    border-left: 1.5px solid rgba(65, 171, 226, 0.44);
    border-bottom: 1.5px solid rgba(65, 171, 226, 0.44);
    transform: translateY(-50%) rotate(45deg);
  }

  /* ─── Main Card ─────────────────────────────────────────────── */
  .process-card-inner {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 13px;
    padding: 15px;
