<script is:inline>
  (() => {
    "use strict";

    const timeline = document.querySelector("[data-process-timeline]");
    if (!timeline) return;

    const items = Array.from(timeline.querySelectorAll(".process-item"));
    const progressEl = timeline.querySelector("[data-process-progress]");
    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    // ── Progress bar (CSS custom property approach) ───────────────
    const setProgress = (activeIndex) => {
      if (!progressEl || items.length === 0) return;
      const ratio = Math.min(activeIndex / Math.max(items.length - 1, 1), 1);
      timeline.style.setProperty("--progress", ratio.toFixed(4));
    };

    // ── Fast-path: reduced motion or no IntersectionObserver ──────
    if (reducedMotion || !("IntersectionObserver" in window)) {
      items.forEach((item) => item.classList.add("is-visible"));
      setProgress(items.length - 1);
      return;
    }

    // ── Mark images as loaded so shimmer fades ────────────────────
    items.forEach((item) => {
      const img = item.querySelector(".process-media img");
      if (!img) return;
      const markLoaded = () => img.classList.add("is-loaded");
      if (img.complete) {
        markLoaded();
      } else {
        img.addEventListener("load", markLoaded, { once: true });
      }
    });

    // ── IntersectionObserver for step visibility + progress ───────
    let lastActiveIndex = 0;
    const visibilityRatios = new Map();

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const ratio = entry.isIntersecting ? entry.intersectionRatio : 0;
          visibilityRatios.set(entry.target, ratio);
          entry.target.classList.toggle("is-visible", ratio > 0.14);
        }

        // Pick the most-visible item as "active" for the progress line
        let bestIndex = lastActiveIndex;
        let bestRatio = -1;

        items.forEach((item, i) => {
          const r = visibilityRatios.get(item) ?? 0;
          if (r > bestRatio) {
            bestRatio = r;
            bestIndex = i;
          }
        });

        if (bestIndex !== lastActiveIndex) {
          lastActiveIndex = bestIndex;
          setProgress(lastActiveIndex);
        }
      },
      {
        threshold: [0, 0.14, 0.28, 0.46, 0.64],
        rootMargin: "0px 0px -14% 0px",
      },
    );

    items.forEach((item) => observer.observe(item));
    setProgress(0);
  })();
</script>
