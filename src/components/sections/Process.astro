---
import "swiper/css";
import "swiper/css/navigation";

const processFlow = [
  {
    step: "01",
    group: "Tratamiento",
    title: "Agua cruda",
    text: "Recepción y análisis inicial.",
    image: "/images/process/agua-cruda.png",
    alt: "Tanque de agua cruda para recepción y análisis inicial",
  },
  {
    step: "02",
    group: "Filtración",
    title: "Filtros",
    text: "Remoción de partículas.",
    image: "/images/process/filtros.png",
    alt: "Sistema de filtros para remoción de partículas",
  },
  {
    step: "03",
    group: "Purificación",
    title: "Ósmosis inversa",
    text: "Alta pureza.",
    image: "/images/process/osmosis-inversa.png",
    alt: "Sistema de ósmosis inversa para purificación",
  },
  {
    step: "04",
    group: "Resultado",
    title: "Agua tratada",
    text: "Lista para producción.",
    image: "/images/process/agua-tratada.png",
    alt: "Agua tratada lista para producción",
  },
  {
    step: "05",
    group: "Producción",
    title: "Máquina de hielo",
    text: "Producción continua.",
    image: "/images/process/maquina-hielo.png",
    alt: "Máquina de hielo en operación",
  },
  {
    step: "06",
    group: "Transferencia",
    title: "Dispensador",
    text: "Salida controlada.",
    image: "/images/process/dispensador-hielo.png",
    alt: "Dispensador de hielo para salida controlada",
  },
  {
    step: "07",
    group: "Empaque",
    title: "Hielo en bolsa",
    text: "Sellado seguro.",
    image: "/images/process/hielo-bolsa.png",
    alt: "Hielo en bolsa con sellado seguro",
  },
  {
    step: "08",
    group: "Conservación",
    title: "Cámara fría",
    text: "Control térmico.",
    image: "/images/process/camara-fria.png",
    alt: "Cámara fría para control térmico",
  },
  {
    step: "09",
    group: "Distribución",
    title: "Logística",
    text: "Entrega continua.",
    image: "/images/process/logistica.png",
    alt: "Logística de distribución y entrega continua",
  },
];
---

<section class="process-section" id="proceso">
  <div class="process-ambient process-ambient-1" aria-hidden="true"></div>
  <div class="process-ambient process-ambient-2" aria-hidden="true"></div>
  <div class="process-noise" aria-hidden="true"></div>
  <div class="process-grid-overlay" aria-hidden="true"></div>

  <div class="container process-container">
    <div class="process-header fade-in">
      <p class="section-label process-label">
        <span class="process-dot" aria-hidden="true"></span>
        Producción
      </p>
      <h2 class="section-title process-title">Proceso de producción</h2>
      <p class="section-subtitle process-subtitle">
        Un flujo continuo, controlado y trazable desde el tratamiento del agua
        hasta la distribución final.
      </p>
    </div>

    <div class="process-track">
      <div class="process-line" aria-hidden="true">
        <span class="process-line-track"></span>
        <span class="process-line-progress" data-process-progress></span>
      </div>

      <div class="swiper process-swiper" data-process-swiper>
        <div class="swiper-wrapper">
          {
            processFlow.map((item, index) => (
              <div class="swiper-slide process-slide" data-step-index={index}>
                <article class="process-card">
                  <div class="process-pin" aria-hidden="true">
                    <span class="process-pin-dot"></span>
                    <span class="process-pin-step">Paso {item.step}</span>
                  </div>

                  <div class="process-card-inner">
                    <div class="process-card-top">
                      <span class="process-group">{item.group}</span>
                    </div>

                    <div class="process-media">
                      <img src={item.image} alt={item.alt} loading="lazy" />
                    </div>

                    <h3 class="process-card-title">{item.title}</h3>
                    <p class="process-card-text">{item.text}</p>
                  </div>
                </article>
              </div>
            ))
          }
        </div>

        <button
          class="process-nav process-nav--prev"
          type="button"
          aria-label="Anterior"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M15 5l-7 7 7 7"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>

        <button
          class="process-nav process-nav--next"
          type="button"
          aria-label="Siguiente"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M9 5l7 7-7 7"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .process-section {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding: clamp(84px, 9vw, 122px) 0;
    background:
      radial-gradient(
        ellipse 64% 46% at 8% 12%,
        rgba(157, 212, 242, 0.12) 0%,
        transparent 52%
      ),
      radial-gradient(
        ellipse 46% 50% at 92% 88%,
        rgba(65, 171, 226, 0.06) 0%,
        transparent 50%
      ),
      linear-gradient(180deg, #f9fcff 0%, #eef5fb 52%, #ffffff 100%);
  }

  .process-ambient,
  .process-noise,
  .process-grid-overlay {
    position: absolute;
    pointer-events: none;
  }

  .process-ambient {
    border-radius: 999px;
    filter: blur(80px);
    opacity: 0.72;
    z-index: 0;
  }

  .process-ambient-1 {
    top: -140px;
    left: -140px;
    width: 420px;
    height: 420px;
    background: rgba(157, 212, 242, 0.14);
  }

  .process-ambient-2 {
    right: -130px;
    bottom: -150px;
    width: 380px;
    height: 380px;
    background: rgba(65, 171, 226, 0.08);
  }

  .process-noise {
    inset: 0;
    z-index: 1;
    opacity: 0.01;
    background-image:
      radial-gradient(
        circle at 20% 20%,
        rgba(16, 33, 73, 0.08) 0.7px,
        transparent 0.8px
      ),
      radial-gradient(
        circle at 80% 40%,
        rgba(16, 33, 73, 0.08) 0.7px,
        transparent 0.8px
      );
    background-size:
      28px 28px,
      34px 34px;
  }

  .process-grid-overlay {
    inset: 0;
    z-index: 1;
    opacity: 0.05;
    background-image:
      linear-gradient(rgba(65, 171, 226, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(65, 171, 226, 0.05) 1px, transparent 1px);
    background-size: 120px 120px;
    mask-image: radial-gradient(circle at center, black 35%, transparent 86%);
  }

  .process-container {
    position: relative;
    z-index: 2;
  }

  .process-header {
    max-width: 780px;
    margin: 0 auto 48px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .process-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 18px;
    padding: 8px 14px;
    border-radius: 999px;
    border: 1px solid rgba(65, 171, 226, 0.2);
    background: rgba(255, 255, 255, 0.78);
    box-shadow:
      0 10px 26px rgba(24, 48, 88, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.9);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-primary);
    backdrop-filter: blur(12px);
  }

  .process-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: linear-gradient(180deg, #8fdcff, #41abe2);
    box-shadow: 0 0 0 4px rgba(65, 171, 226, 0.12);
  }

  .process-title {
    margin: 0 0 14px;
    line-height: 0.96;
    letter-spacing: -0.04em;
    text-transform: uppercase;
    text-wrap: balance;
    color: var(--color-primary);
  }

  .process-subtitle {
    max-width: 620px;
    margin: 0;
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(16, 33, 73, 0.74);
  }

  .process-track {
    position: relative;
    padding: 16px 0 6px;
  }

  .process-line {
    --progress: 0;
    --line-gap: 7%;
    position: absolute;
    left: 0;
    right: 0;
    top: 20px;
    height: 10px;
    pointer-events: none;
    z-index: 0;
  }

  .process-line-track,
  .process-line-progress {
    position: absolute;
    top: 50%;
    left: var(--line-gap);
    right: var(--line-gap);
    height: 2px;
    transform: translateY(-50%);
    border-radius: 999px;
  }

  .process-line-track {
    background: linear-gradient(
      90deg,
      rgba(16, 33, 73, 0.03) 0%,
      rgba(65, 171, 226, 0.14) 50%,
      rgba(16, 33, 73, 0.03) 100%
    );
  }

  .process-line-progress {
    right: auto;
    width: calc((100% - (var(--line-gap) * 2)) * var(--progress));
    background: linear-gradient(
      90deg,
      rgba(65, 171, 226, 0.22) 0%,
      rgba(65, 171, 226, 0.55) 60%,
      rgba(50, 59, 129, 0.8) 100%
    );
    box-shadow: 0 0 0 1px rgba(65, 171, 226, 0.08);
    transition: width 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .process-line-progress::after {
    content: "";
    position: absolute;
    right: -1px;
    top: 50%;
    width: 28px;
    height: 8px;
    transform: translateY(-50%);
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(65, 171, 226, 0.28) 45%,
      rgba(65, 171, 226, 0.6) 100%
    );
    filter: blur(5px);
    opacity: 0.45;
  }

  .process-swiper {
    position: relative;
    overflow: visible;
    padding: 34px 0 14px;
    z-index: 1;
  }

  .process-swiper .swiper-wrapper {
    align-items: stretch;
  }

  .process-slide {
    width: 260px;
    min-height: 360px;
    padding: 0 8px;
    opacity: 0.55;
    transform: scale(0.96);
    transition:
      transform 0.5s ease,
      opacity 0.5s ease,
      filter 0.5s ease;
    filter: saturate(0.96);
  }

  .process-swiper .swiper-slide-active {
    opacity: 1;
    transform: scale(1);
    filter: saturate(1.02);
  }

  .process-swiper .swiper-slide-prev,
  .process-swiper .swiper-slide-next {
    opacity: 0.75;
    transform: scale(0.98);
  }

  .process-card {
    position: relative;
    height: 100%;
    padding-top: 48px;
  }

  .process-pin {
    position: absolute;
    left: 50%;
    top: 20px;
    transform: translate(-50%, -50%);
    z-index: 2;
    display: grid;
    justify-items: center;
    gap: 5px;
  }

  .process-pin-dot {
    width: 11px;
    height: 11px;
    border-radius: 999px;
    background: linear-gradient(
      180deg,
      rgba(65, 171, 226, 0.85),
      rgba(50, 59, 129, 0.9)
    );
    box-shadow:
      0 0 0 3px rgba(65, 171, 226, 0.12),
      0 8px 14px rgba(27, 47, 94, 0.1);
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .process-pin-step {
    padding: 5px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid rgba(65, 171, 226, 0.2);
    color: rgba(16, 33, 73, 0.82);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    box-shadow: 0 6px 14px rgba(11, 32, 51, 0.05);
    backdrop-filter: blur(10px);
    white-space: nowrap;
  }

  .process-card-inner {
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 16px 16px 18px;
    border-radius: 22px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.92) 0%,
      rgba(248, 252, 255, 0.86) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.9);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.95),
      0 16px 34px rgba(27, 47, 94, 0.08),
      0 5px 12px rgba(27, 47, 94, 0.04);
    backdrop-filter: blur(14px) saturate(1.08);
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease,
      border-color 0.3s ease;
  }

  .process-card-inner::before {
    content: "";
    position: absolute;
    top: 0;
    left: 18px;
    right: 18px;
    height: 3px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      rgba(50, 59, 129, 0.35),
      rgba(65, 171, 226, 0.75),
      rgba(157, 212, 242, 0.75)
    );
    opacity: 0.5;
    transform: scaleX(0.4);
    transform-origin: left;
    transition: transform 0.32s ease;
  }

  .process-card:hover .process-card-inner {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.98);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 20px 46px rgba(27, 47, 94, 0.12),
      0 8px 18px rgba(27, 47, 94, 0.06);
  }

  .process-card:hover .process-card-inner::before {
    transform: scaleX(1);
  }

  .process-swiper .swiper-slide-active .process-pin-dot {
    transform: scale(1.06);
    box-shadow:
      0 0 0 4px rgba(65, 171, 226, 0.18),
      0 10px 20px rgba(27, 47, 94, 0.14);
  }

  .process-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
    margin-bottom: 12px;
  }

  .process-group {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(16, 33, 73, 0.52);
  }

  .process-media {
    position: relative;
    width: 100%;
    aspect-ratio: 5 / 3.3;
    border-radius: 14px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.9);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.7),
      0 10px 20px rgba(27, 47, 94, 0.07);
    margin-bottom: 12px;
  }

  .process-media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.04) 0%,
      rgba(16, 33, 73, 0.12) 100%
    );
    pointer-events: none;
  }

  .process-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .process-card-title {
    margin: 0 0 6px;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1.05rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .process-card-text {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.56;
    color: rgba(16, 33, 73, 0.7);
  }

  .process-nav {
    position: absolute;
    top: 22px;
    transform: translateY(-50%);
    width: 34px;
    height: 34px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.78);
    background: rgba(255, 255, 255, 0.92);
    color: var(--color-primary);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 16px rgba(11, 32, 51, 0.08);
    backdrop-filter: blur(10px);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease,
      background 0.25s ease,
      opacity 0.25s ease;
    z-index: 4;
  }

  .process-nav svg {
    width: 14px;
    height: 14px;
  }

  .process-nav--prev {
    left: -4px;
  }

  .process-nav--next {
    right: -4px;
  }

  .process-nav:hover {
    transform: translateY(calc(-50% - 1px));
    background: rgba(255, 255, 255, 0.98);
    box-shadow: 0 10px 22px rgba(11, 32, 51, 0.12);
  }

  .process-nav:active {
    transform: translateY(-50%);
  }

  .process-nav[disabled],
  .process-nav.swiper-button-disabled {
    opacity: 0.35;
    pointer-events: none;
  }

  @media (max-width: 1024px) {
    .process-header {
      margin-bottom: 40px;
    }

    .process-slide {
      width: 248px;
      min-height: 350px;
    }
  }

  @media (max-width: 720px) {
    .process-section {
      padding: 72px 0;
    }

    .process-header {
      margin-bottom: 32px;
    }

    .process-title {
      font-size: clamp(2.15rem, 10vw, 3rem);
    }

    .process-subtitle {
      max-width: 100%;
      font-size: 0.95rem;
      line-height: 1.62;
    }

    .process-track {
      padding-top: 20px;
    }

    .process-line {
      top: 16px;
    }

    .process-line-track,
    .process-line-progress {
      left: 10%;
      right: 10%;
    }

    .process-swiper {
      padding: 36px 0 54px;
    }

    .process-slide {
      width: 226px;
      min-height: 332px;
      padding: 0 6px;
      opacity: 0.62;
      transform: scale(0.96);
    }

    .process-card {
      padding-top: 44px;
    }

    .process-pin {
      top: 16px;
    }

    .process-card-inner {
      border-radius: 20px;
      padding: 14px 14px 16px;
    }

    .process-media {
      border-radius: 12px;
      margin-bottom: 10px;
    }

    .process-card-title {
      font-size: 0.98rem;
    }

    .process-card-text {
      font-size: 0.86rem;
    }

    .process-nav {
      top: auto;
      bottom: 0;
      transform: translateY(0);
      width: 32px;
      height: 32px;
    }

    .process-nav--prev {
      left: calc(50% - 44px);
    }

    .process-nav--next {
      right: calc(50% - 44px);
    }

    .process-nav:hover {
      transform: translateY(-1px);
    }

    .process-nav:active {
      transform: translateY(0);
    }
  }

  @media (max-width: 480px) {
    .process-label {
      width: 100%;
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .process-card-inner,
    .process-card-inner::before,
    .process-nav,
    .process-slide {
      transition: none !important;
    }
  }
</style>

<script>
  import Swiper from "swiper";
  import { Navigation, Keyboard, Mousewheel, Autoplay } from "swiper/modules";

  const init = () => {
    const el = document.querySelector("[data-process-swiper]");
    if (!el || el.dataset.ready) return;

    const track = el.closest(".process-track");
    const progressEl = track?.querySelector("[data-process-progress]") ?? null;
    const slides = () => [...el.querySelectorAll(".process-slide")];

    const setVisualState = (swiper) => {
      if (!progressEl) return;

      const realIndex = swiper.realIndex ?? 0;
      const total =
        [...new Set(slides().map((slide) => slide.dataset.stepIndex))].filter(
          Boolean,
        ).length ||
        slides().length ||
        1;

      const ratio = total <= 1 ? 1 : realIndex / (total - 1);

    progressEl.style.setProperty("--progress", `${ratio}`);
    };

    const swiper = new Swiper(el, {
      modules: [Navigation, Keyboard, Mousewheel, Autoplay],
      loop: true,
      initialSlide: 0,
      centeredSlides: true,
      speed: 700,
      slidesPerView: "auto",
      spaceBetween: 6,
      watchSlidesProgress: true,
      autoplay: {
        delay: 3600,
        disableOnInteraction: false,
        pauseOnMouseEnter: true,
      },
      navigation: {
        nextEl: el.querySelector(".process-nav--next"),
        prevEl: el.querySelector(".process-nav--prev"),
      },
      keyboard: {
        enabled: true,
      },
      mousewheel: {
        forceToAxis: true,
      },
      breakpoints: {
        0: {
          spaceBetween: 4,
        },
        721: {
          spaceBetween: 8,
        },
      },
      on: {
        init(swiperInstance) {
          setVisualState(swiperInstance);
        },
        slideChange(swiperInstance) {
          setVisualState(swiperInstance);
        },
        autoplay(swiperInstance) {
          setVisualState(swiperInstance);
        },
      },
    });

    setVisualState(swiper);
    el.dataset.ready = "true";
  };

  init();
</script>
