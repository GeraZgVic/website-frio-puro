---
import { buildWhatsAppUrl, commercialContent } from "../../config/commercial";
---

<section id="inicio" class="hero-section">
  <div id="hero">
    <canvas id="hero-particles-canvas" aria-hidden="true"></canvas>

    <div class="hero-bg-glow hero-bg-glow-1"></div>
    <div class="hero-bg-glow hero-bg-glow-2"></div>

    <div class="hero-content">
      <div class="hero-left">
        <div class="hero-badge fade-in">
          <span class="hero-badge-dot"></span>
          #1 en Villahermosa, Tabasco
        </div>

        <h1 class="hero-title fade-in fade-in-delay-1">
          <span class="hero-title-top">
            <span class="hero-title-ice">HIELO</span>
            <span class="hero-title-ice">PREMIUM</span>
          </span>
          <span class="hero-title-bottom">PARA TU NEGOCIO</span>
        </h1>

        <p class="hero-subtitle fade-in fade-in-delay-2">
          Distribuimos hielo de máxima calidad con entrega rápida y puntual.
          Ideal para restaurantes, bares, hoteles y eventos en todo
          Villahermosa, Tabasco.
        </p>

        <ul class="hero-checks" aria-label="Beneficios principales">
          <li>
            <span class="check-icon">✓</span>
            <span>Coordinamos el tiempo de entrega</span>
          </li>
          <li>
            <span class="check-icon">✓</span>
            <span>Hielo 100% purificado y certificado</span>
          </li>
          <li>
            <span class="check-icon">✓</span>
            <span>{commercialContent.badges.service247}</span>
          </li>
        </ul>

        <div class="hero-buttons fade-in fade-in-delay-3">
          <a
            href={buildWhatsAppUrl()}
            class="btn-primary hero-cta-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            {commercialContent.ctas.heroPrimary}
          </a>

          <a href="#productos" class="btn-outline hero-cta-secondary">
            Ver producto
          </a>
        </div>
      </div>

      <div class="hero-visual fade-in fade-in-delay-2">
        <div class="hero-visual-shell">
          <div class="hero-visual-aura"></div>
          <div class="hero-visual-ring hero-visual-ring-1"></div>
          <div class="hero-visual-ring hero-visual-ring-2"></div>

          <div class="hero-media-card">
            <div class="hero-media-shine"></div>
            <div class="hero-media-noise"></div>

            <div class="hero-media-frame">
              <picture>
                <source
                  type="image/webp"
                  srcset="/images/Hero-512.webp 512w, /images/Hero-768.webp 768w, /images/Hero-1024.webp 1024w"
                  sizes="(min-width: 1025px) 520px, 1px"
                />
                <img
                  src="/images/Hero.png"
                  alt="Hielo premium para negocio"
                  class="hero-image"
                  width="1024"
                  height="1080"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                />
              </picture>
            </div>

            <div class="hero-floating-card hero-floating-card-top">
              <span class="floating-label">Calidad</span>
              <strong>Premium</strong>
            </div>

            <div class="hero-floating-card hero-floating-card-bottom">
              <span class="floating-label">Cobertura</span>
              <strong>Entrega rápida</strong>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding: 0;
  }

  #hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 140px 60px 90px;
    isolation: isolate;
    background:
      radial-gradient(
        circle at 18% 22%,
        rgba(65, 171, 226, 0.22) 0%,
        transparent 32%
      ),
      radial-gradient(
        circle at 82% 30%,
        rgba(157, 212, 242, 0.12) 0%,
        transparent 24%
      ),
      linear-gradient(
        135deg,
        #171d48 0%,
        #232b68 32%,
        #2a4d8f 62%,
        #41abe2 100%
      );
  }

  #hero-particles-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .hero-bg-glow {
    position: absolute;
    border-radius: 999px;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }

  .hero-bg-glow-1 {
    top: 8%;
    left: -4%;
    width: 340px;
    height: 340px;
    background: rgba(65, 171, 226, 0.18);
  }

  .hero-bg-glow-2 {
    right: -4%;
    bottom: 5%;
    width: 420px;
    height: 420px;
    background: rgba(157, 212, 242, 0.12);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(420px, 0.98fr);
    gap: 64px;
    align-items: center;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
  }

  .hero-left {
    position: relative;
    z-index: 2;
    max-width: 640px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 42px;
    padding: 10px 18px;
    margin-bottom: 28px;
    border-radius: 999px;
    border: 1px solid rgba(157, 212, 242, 0.28);
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.12),
      rgba(255, 255, 255, 0.06)
    );
    backdrop-filter: blur(12px);
    color: var(--color-pale);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    box-shadow: 0 12px 40px rgba(5, 15, 50, 0.22);
  }

  .hero-badge-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 6px rgba(65, 171, 226, 0.14);
    flex-shrink: 0;
  }

  .hero-title {
    margin-bottom: 24px;
    font-family: "Barlow Condensed", sans-serif;
    text-transform: uppercase;
    width: 100%;
    max-width: 760px;
    line-height: 0.9;
  }

  .hero-title-top {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 18px;
    margin-bottom: 10px;
  }

  .hero-title-bottom {
    display: block;
    font-size: clamp(3.2rem, 6.2vw, 5.6rem);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -1.6px;
    color: var(--color-white);
    text-shadow: 0 10px 40px rgba(10, 16, 48, 0.28);
  }

  .hero-title-ice {
    display: inline-block;
    position: relative;
    width: fit-content;
    font-size: clamp(4.3rem, 8vw, 7.2rem);
    font-weight: 800;
    line-height: 0.88;
    letter-spacing: -1.9px;
    color: transparent;
    -webkit-text-stroke: 1.4px rgba(255, 255, 255, 0.3);
    background-image:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.96) 0%,
        rgba(228, 245, 255, 0.78) 16%,
        rgba(151, 220, 255, 0.28) 36%,
        rgba(255, 255, 255, 0.92) 52%,
        rgba(177, 230, 255, 0.34) 68%,
        rgba(255, 255, 255, 0.18) 100%
      ),
      linear-gradient(
        115deg,
        rgba(255, 255, 255, 0) 18%,
        rgba(255, 255, 255, 0.06) 28%,
        rgba(255, 255, 255, 0.95) 46%,
        rgba(255, 255, 255, 0.18) 58%,
        rgba(255, 255, 255, 0) 72%
      );
    background-size:
      100% 100%,
      260% 100%;
    background-position:
      0 0,
      -180% 50%;
    background-repeat: no-repeat;
    -webkit-background-clip: text;
    background-clip: text;
    text-shadow: none;
    filter: drop-shadow(0 0 10px rgba(255, 255, 255, 0.08))
      drop-shadow(0 0 22px rgba(65, 171, 226, 0.14));
    will-change: background-position, filter;
    animation: heroIceSweep 3.2s cubic-bezier(0.4, 0, 0.2, 1) infinite;
  }

  .hero-subtitle {
    max-width: 560px;
    margin-bottom: 34px;
    font-size: 1.1rem;
    line-height: 1.8;
    color: rgba(224, 239, 248, 0.88);
  }

  .hero-checks {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 40px;
  }

  .hero-checks li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: rgba(255, 255, 255, 0.92);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.55;
    opacity: 0;
    transform: translateX(-20px);
    transition: all 0.5s ease;
  }

  .hero-checks li.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .check-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    margin-top: 1px;
    border-radius: 999px;
    flex-shrink: 0;
    background: linear-gradient(135deg, #41abe2, #7ad3ff);
    color: var(--color-white);
    font-size: 0.75rem;
    box-shadow:
      0 8px 20px rgba(65, 171, 226, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.28);
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
  }

  .hero-cta-primary,
  .hero-cta-secondary {
    min-width: 220px;
    text-align: center;
  }

  .hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 620px;
  }

  .hero-visual-shell {
    position: relative;
    width: min(100%, 620px);
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-visual-aura {
    position: absolute;
    width: 76%;
    height: 76%;
    border-radius: 999px;
    background: radial-gradient(
      circle,
      rgba(65, 171, 226, 0.32) 0%,
      rgba(65, 171, 226, 0.1) 40%,
      transparent 72%
    );
    filter: blur(14px);
    animation: heroAuraPulse 4.5s ease-in-out infinite;
    pointer-events: none;
  }

  .hero-visual-ring {
    position: absolute;
    border-radius: 999px;
    border: 1px solid rgba(157, 212, 242, 0.14);
    pointer-events: none;
  }

  .hero-visual-ring-1 {
    inset: 8%;
    animation: heroSpin 20s linear infinite;
  }

  .hero-visual-ring-2 {
    inset: 15%;
    border-style: dashed;
    animation: heroSpinReverse 28s linear infinite;
  }

  .hero-media-card {
    position: relative;
    width: min(100%, 520px);
    aspect-ratio: 1 / 1;
    border-radius: 38px;
    padding: 20px;
    overflow: visible;
    background: linear-gradient(
      145deg,
      rgba(255, 255, 255, 0.18),
      rgba(255, 255, 255, 0.05)
    );
    border: 1px solid rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(16px);
    box-shadow:
      0 30px 80px rgba(5, 15, 50, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.16);
    animation: heroFloatCard 5.2s ease-in-out infinite;
  }

  .hero-media-shine {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.16) 0%,
      rgba(255, 255, 255, 0.04) 30%,
      transparent 58%
    );
  }

  .hero-media-noise {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    opacity: 0.06;
    pointer-events: none;
    background-image:
      radial-gradient(circle at 20% 20%, #ffffff 0.6px, transparent 0.7px),
      radial-gradient(circle at 80% 30%, #ffffff 0.6px, transparent 0.7px),
      radial-gradient(circle at 50% 75%, #ffffff 0.6px, transparent 0.7px);
    background-size:
      26px 26px,
      34px 34px,
      22px 22px;
  }

  .hero-media-frame {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    border-radius: 28px;
    overflow: hidden;
    background:
      radial-gradient(
        circle at 50% 40%,
        rgba(255, 255, 255, 0.2),
        transparent 55%
      ),
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.08),
        rgba(255, 255, 255, 0.02)
      );
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.12);
  }

  .hero-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    transform: scale(1.03);
    filter: drop-shadow(0 22px 50px rgba(65, 171, 226, 0.18))
      drop-shadow(0 10px 20px rgba(10, 20, 55, 0.18));
  }

  .hero-floating-card {
    position: absolute;
    z-index: 3;
    min-width: 150px;
    padding: 14px 16px;
    border-radius: 18px;
    background: rgba(9, 21, 58, 0.55);
    border: 1px solid rgba(157, 212, 242, 0.18);
    backdrop-filter: blur(12px);
    box-shadow: 0 16px 32px rgba(4, 10, 35, 0.22);
  }

  .hero-floating-card strong {
    display: block;
    color: var(--color-white);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.2px;
  }

  .floating-label {
    display: inline-block;
    margin-bottom: 4px;
    color: rgba(157, 212, 242, 0.88);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.2px;
  }

  .hero-floating-card-top {
    top: 24px;
    left: -26px;
    animation: heroFloatTag 4.2s ease-in-out infinite;
  }

  .hero-floating-card-bottom {
    right: -24px;
    bottom: 28px;
    animation: heroFloatTag 4.8s ease-in-out infinite 0.4s;
  }

  @keyframes heroIceSweep {
    0% {
      background-position:
        0 0,
        -180% 50%;
      filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.06))
        drop-shadow(0 0 18px rgba(65, 171, 226, 0.12));
    }

    45% {
      background-position:
        0 0,
        140% 50%;
      filter: drop-shadow(0 0 16px rgba(255, 255, 255, 0.14))
        drop-shadow(0 0 34px rgba(65, 171, 226, 0.22));
    }

    100% {
      background-position:
        0 0,
        140% 50%;
      filter: drop-shadow(0 0 8px rgba(255, 255, 255, 0.06))
        drop-shadow(0 0 18px rgba(65, 171, 226, 0.12));
    }
  }

  @keyframes heroFloatCard {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-14px);
    }
  }

  @keyframes heroFloatTag {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-8px);
    }
  }

  @keyframes heroAuraPulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.9;
    }
    50% {
      transform: scale(1.08);
      opacity: 0.62;
    }
  }

  @keyframes heroSpin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes heroSpinReverse {
    from {
      transform: rotate(360deg);
    }
    to {
      transform: rotate(0deg);
    }
  }

  @media (max-width: 1200px) {
    #hero {
      padding: 132px 40px 84px;
    }

    .hero-content {
      grid-template-columns: minmax(0, 1fr) minmax(360px, 0.92fr);
      gap: 48px;
    }

    .hero-title-bottom {
      font-size: clamp(2.9rem, 5.6vw, 4.9rem);
    }

    .hero-title-ice {
      font-size: clamp(3.9rem, 7.2vw, 6.3rem);
    }

    .hero-visual {
      min-height: 560px;
    }

    .hero-media-card {
      width: min(100%, 470px);
    }
  }

  @media (max-width: 1024px) {
    #hero {
      min-height: auto;
      padding: 126px 32px 72px;
    }

    .hero-content {
      grid-template-columns: 1fr;
      gap: 34px;
    }

    .hero-left {
      max-width: 100%;
      text-align: center;
    }

    .hero-subtitle {
      max-width: 680px;
    }

    .hero-visual {
      min-height: auto;
      justify-content: center;
    }

    .hero-visual-shell {
      display: none;
    }

    .hero-title {
      text-align: center;
      margin-left: auto;
      margin-right: auto;
      max-width: 100%;
    }

    .hero-title-top {
      justify-content: center;
      gap: 14px;
      margin-bottom: 8px;
    }

    .hero-title-bottom {
      font-size: clamp(2.8rem, 6.4vw, 4.6rem);
    }

    .hero-title-ice {
      font-size: clamp(3.9rem, 8.5vw, 6rem);
      -webkit-text-stroke: 1.2px rgba(255, 255, 255, 0.3);
    }
  }

  @media (min-width: 1025px) {
    .hero-title br {
      display: none;
    }
  }

  @media (max-width: 768px) {
    #hero {
      padding: 118px 24px 64px;
    }

    .hero-badge {
      font-size: 0.72rem;
      letter-spacing: 1.4px;
      padding: 9px 14px;
      margin-bottom: 22px;
    }

    .hero-title-top {
      gap: 10px;
      margin-bottom: 6px;
    }

    .hero-title-bottom {
      font-size: clamp(2.5rem, 8vw, 3.8rem);
      letter-spacing: -1.2px;
    }

    .hero-title-ice {
      font-size: clamp(3.4rem, 11vw, 5rem);
      -webkit-text-stroke: 1px rgba(255, 255, 255, 0.28);
      background-size:
        100% 100%,
        300% 100%;
      animation-duration: 3s;
    }

    .hero-subtitle {
      font-size: 1rem;
      line-height: 1.75;
      margin-bottom: 28px;
    }

    .hero-checks {
      gap: 12px;
      margin-bottom: 30px;
    }

    .hero-checks li {
      font-size: 0.96rem;
    }

    .hero-buttons {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-cta-primary,
    .hero-cta-secondary {
      width: 100%;
      min-width: 0;
    }

    .hero-visual {
      display: none;
    }

    .hero-visual-shell {
      width: min(100%, 430px);
    }

    .hero-media-card {
      width: 100%;
      padding: 14px;
      border-radius: 28px;
    }

    .hero-media-frame {
      border-radius: 20px;
    }

    .hero-floating-card {
      min-width: 128px;
      padding: 11px 13px;
      border-radius: 14px;
    }

    .hero-floating-card strong {
      font-size: 0.9rem;
    }

    .hero-floating-card-top {
      top: 10px;
      left: -8px;
    }

    .hero-floating-card-bottom {
      right: -8px;
      bottom: 14px;
    }
  }

  @media (max-width: 480px) {
    #hero {
      padding: 112px 18px 56px;
    }

    .hero-badge {
      width: 100%;
      justify-content: center;
    }

    .hero-title-top {
      gap: 8px;
    }

    .hero-title-bottom {
      font-size: clamp(2.15rem, 8.8vw, 3rem);
      letter-spacing: -1px;
    }

    .hero-title-ice {
      font-size: clamp(2.9rem, 11.8vw, 4rem);
      -webkit-text-stroke: 0.9px rgba(255, 255, 255, 0.28);
    }

    .hero-checks li {
      gap: 10px;
      font-size: 0.92rem;
    }

    .check-icon {
      width: 22px;
      height: 22px;
      font-size: 0.7rem;
    }

    .hero-visual-shell {
      width: 100%;
    }

    .hero-floating-card {
      min-width: 116px;
      padding: 10px 12px;
    }

    .floating-label {
      font-size: 0.66rem;
    }

    .hero-floating-card strong {
      font-size: 0.84rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title-ice,
    .hero-visual-aura,
    .hero-visual-ring-1,
    .hero-visual-ring-2,
    .hero-media-card,
    .hero-floating-card-top,
    .hero-floating-card-bottom {
      animation: none;
    }
  }
</style>
