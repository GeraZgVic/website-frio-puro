---
import { buildWhatsAppUrl, commercialContent } from "../../config/commercial";
---

<section id="inicio" class="hero-section">
  <div id="hero">
    <canvas id="hero-particles-canvas" aria-hidden="true"></canvas>

    <div class="hero-bg-glow hero-bg-glow-1"></div>
    <div class="hero-bg-glow hero-bg-glow-2"></div>

    <div class="hero-content">
      <div class="hero-left">
        <div class="hero-badge fade-in">
          <span class="hero-badge-dot"></span>
          Suministro B2B en Villahermosa
        </div>

        <h1 class="hero-title fade-in fade-in-delay-1">
          <span class="hero-title-top">
            <span class="hero-title-ice">HIELO PREMIUM</span>
          </span>
          <span class="hero-title-bottom">PARA OPERACIÓN COMERCIAL</span>
        </h1>

        <p class="hero-subtitle fade-in fade-in-delay-2">
          Suministro garantizado de hielo purificado con stock permanente para
          tu negocio en Villahermosa.
        </p>

        <ul class="hero-checks" aria-label="Beneficios principales">
          <li>
            <span class="check-icon">✓</span>
            <span>Stock permanente para pedidos recurrentes</span>
          </li>
          <li>
            <span class="check-icon">✓</span>
            <span>Hielo purificado con presentación uniforme</span>
          </li>
          <li>
            <span class="check-icon">✓</span>
            <span>Entrega coordinada por rutas comerciales</span>
          </li>
        </ul>

        <div class="hero-buttons fade-in fade-in-delay-3">
          <a
            href={buildWhatsAppUrl()}
            class="btn-primary hero-cta-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            {commercialContent.ctas.heroPrimary}
          </a>

          <a href="#productos" class="btn-outline hero-cta-secondary">
            Ver producto
          </a>
        </div>
      </div>

      <div class="hero-visual fade-in fade-in-delay-2">
        <div class="hero-visual-shell">
          <div class="hero-visual-aura"></div>
          <div class="hero-visual-orbit hero-visual-orbit-1"></div>
          <div class="hero-visual-orbit hero-visual-orbit-2"></div>

          <div class="hero-media-card">
            <div class="hero-media-card-bg"></div>
            <div class="hero-media-shine"></div>
            <div class="hero-media-overlay-top"></div>
            <div class="hero-media-edge-highlight"></div>
            <div class="hero-media-bottom-glow"></div>

            <div class="hero-media-frame">
              <div class="hero-media-inner-bg"></div>
              <div class="hero-media-vignette"></div>

              <picture>
                <source
                  type="image/webp"
                  srcset="/images/Hero-512.webp 512w, /images/Hero-768.webp 768w, /images/Hero-1024.webp 1024w"
                  sizes="(min-width: 1025px) 540px, 1px"
                />
                <img
                  src="/images/Hero.png"
                  alt="Hielo premium para negocio"
                  class="hero-image"
                  width="1024"
                  height="1080"
                  loading="eager"
                  decoding="async"
                  fetchpriority="high"
                />
              </picture>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding: 0;
  }

  #hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 140px 60px 90px;
    isolation: isolate;
    background:
      radial-gradient(
        circle at 18% 22%,
        rgba(65, 171, 226, 0.22) 0%,
        transparent 32%
      ),
      radial-gradient(
        circle at 82% 30%,
        rgba(157, 212, 242, 0.12) 0%,
        transparent 24%
      ),
      linear-gradient(
        135deg,
        #171d48 0%,
        #232b68 32%,
        #2a4d8f 62%,
        #41abe2 100%
      );
  }

  #hero-particles-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .hero-bg-glow {
    position: absolute;
    border-radius: 999px;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }

  .hero-bg-glow-1 {
    top: 8%;
    left: -4%;
    width: 340px;
    height: 340px;
    background: rgba(65, 171, 226, 0.18);
  }

  .hero-bg-glow-2 {
    right: -4%;
    bottom: 5%;
    width: 420px;
    height: 420px;
    background: rgba(157, 212, 242, 0.12);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(420px, 0.98fr);
    gap: 64px;
    align-items: center;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
  }

  .hero-left {
    position: relative;
    z-index: 2;
    max-width: 640px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 42px;
    padding: 10px 18px;
    margin-bottom: 28px;
    border-radius: 999px;
    border: 1px solid rgba(157, 212, 242, 0.28);
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.12),
      rgba(255, 255, 255, 0.06)
    );
    backdrop-filter: blur(12px);
    color: var(--color-pale);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    box-shadow: 0 12px 40px rgba(5, 15, 50, 0.22);
  }

  .hero-badge-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 6px rgba(65, 171, 226, 0.14);
    flex-shrink: 0;
  }

  .hero-title {
    margin-bottom: 24px;
    font-family: "Barlow Condensed", sans-serif;
    text-transform: uppercase;
    width: 100%;
    max-width: 760px;
    line-height: 0.9;
  }

  .hero-title-top {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 18px;
    margin-bottom: 10px;
  }

  .hero-title-bottom {
    display: block;
    font-size: clamp(3.2rem, 6.2vw, 5.6rem);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -1.6px;
    color: var(--color-white);
    text-shadow: 0 10px 40px rgba(10, 16, 48, 0.28);
  }

  .hero-title-ice {
    display: inline-block;
    position: relative;
    width: fit-content;
    font-size: clamp(4.3rem, 8vw, 7.2rem);
    font-weight: 800;
    line-height: 0.88;
    letter-spacing: -1.9px;
    color: #f6f9ff;
    text-shadow: 0 10px 26px rgba(9, 16, 40, 0.35);
  }

  .hero-subtitle {
    max-width: 560px;
    margin-bottom: 34px;
    font-size: 1.1rem;
    line-height: 1.8;
    color: rgba(224, 239, 248, 0.88);
  }

  .hero-checks {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 40px;
  }

  .hero-checks li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: rgba(255, 255, 255, 0.92);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.55;
    opacity: 0;
    transform: translateX(-20px);
    transition: all 0.5s ease;
  }

  .hero-checks li.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .check-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    margin-top: 1px;
    border-radius: 999px;
    flex-shrink: 0;
    background: linear-gradient(135deg, #41abe2, #7ad3ff);
    color: var(--color-white);
    font-size: 0.75rem;
    box-shadow:
      0 8px 20px rgba(65, 171, 226, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.28);
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
  }

  .hero-cta-primary,
  .hero-cta-secondary {
    min-width: 220px;
    text-align: center;
  }

  .hero-cta-primary {
    background: linear-gradient(180deg, #8ddcff 0%, #4fb5ef 100%);
    border: 1px solid rgba(255, 255, 255, 0.28);
    box-shadow:
      0 18px 40px rgba(5, 15, 50, 0.35),
      0 6px 16px rgba(79, 181, 239, 0.45);
    font-weight: 700;
  }

  .hero-cta-secondary {
    border: 2px solid rgba(255, 255, 255, 0.72);
    color: var(--color-white);
    font-weight: 700;
    background: transparent;
    box-shadow: 0 10px 26px rgba(5, 15, 50, 0.2);
  }

  .hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 640px;
  }

  .hero-visual-shell {
    position: relative;
    width: min(100%, 640px);
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hero-visual-aura {
    position: absolute;
    inset: 10%;
    border-radius: 999px;
    background: radial-gradient(
      circle,
      rgba(65, 171, 226, 0.2) 0%,
      rgba(65, 171, 226, 0.08) 42%,
      rgba(65, 171, 226, 0.02) 62%,
      transparent 76%
    );
    filter: blur(26px);
    animation: heroAuraPulse 5.8s ease-in-out infinite;
    pointer-events: none;
  }

  .hero-visual-orbit {
    position: absolute;
    border-radius: 999px;
    pointer-events: none;
  }

  .hero-visual-orbit-1 {
    inset: 7%;
    border: 1px solid rgba(157, 212, 242, 0.1);
    opacity: 0.46;
    animation: heroSpin 30s linear infinite;
  }

  .hero-visual-orbit-2 {
    inset: 14%;
    border: 1px dashed rgba(157, 212, 242, 0.08);
    opacity: 0.28;
    animation: heroSpinReverse 38s linear infinite;
  }

  .hero-media-card {
    position: relative;
    width: min(100%, 548px);
    aspect-ratio: 1 / 1;
    border-radius: 44px;
    padding: 16px;
    overflow: visible;
    isolation: isolate;
    animation: heroFloatCard 6.1s ease-in-out infinite;
  }

  .hero-media-card-bg {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      145deg,
      rgba(255, 255, 255, 0.14) 0%,
      rgba(255, 255, 255, 0.06) 38%,
      rgba(255, 255, 255, 0.025) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(18px);
    box-shadow:
      0 34px 80px rgba(5, 15, 50, 0.34),
      0 10px 30px rgba(65, 171, 226, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.14);
    z-index: 0;
  }

  .hero-media-shine {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.13) 0%,
      rgba(255, 255, 255, 0.045) 24%,
      rgba(255, 255, 255, 0.015) 44%,
      transparent 64%
    );
    z-index: 2;
  }

  .hero-media-overlay-top {
    position: absolute;
    left: 16px;
    right: 16px;
    top: 16px;
    height: 78px;
    border-radius: 28px 28px 18px 18px;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.1) 0%,
      rgba(255, 255, 255, 0.04) 46%,
      transparent 100%
    );
    opacity: 0.7;
    z-index: 2;
  }

  .hero-media-edge-highlight {
    position: absolute;
    inset: 1px;
    border-radius: 43px;
    pointer-events: none;
    border: 1px solid rgba(255, 255, 255, 0.065);
    mask-image: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 1),
      rgba(0, 0, 0, 0.65) 38%,
      rgba(0, 0, 0, 0.16) 100%
    );
    z-index: 3;
  }

  .hero-media-bottom-glow {
    position: absolute;
    left: 11%;
    right: 11%;
    bottom: -14px;
    height: 92px;
    border-radius: 999px;
    background: radial-gradient(
      ellipse at center,
      rgba(65, 171, 226, 0.18) 0%,
      rgba(65, 171, 226, 0.06) 44%,
      transparent 74%
    );
    filter: blur(20px);
    pointer-events: none;
    z-index: 0;
  }

  .hero-media-frame {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    border-radius: 32px;
    overflow: hidden;
    background:
      radial-gradient(
        circle at 50% 16%,
        rgba(65, 171, 226, 0.12) 0%,
        transparent 36%
      ),
      linear-gradient(
        180deg,
        rgba(8, 20, 48, 0.98) 0%,
        rgba(7, 19, 44, 0.96) 100%
      );
    border: 1px solid rgba(255, 255, 255, 0.095);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      inset 0 -34px 64px rgba(6, 16, 40, 0.24);
  }

  .hero-media-inner-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(
        circle at 50% 10%,
        rgba(255, 255, 255, 0.08) 0%,
        transparent 22%
      ),
      radial-gradient(
        circle at 50% 92%,
        rgba(65, 171, 226, 0.1) 0%,
        transparent 28%
      );
    z-index: 1;
  }

  .hero-media-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(
        180deg,
        rgba(4, 10, 26, 0.04) 0%,
        rgba(4, 10, 26, 0) 24%,
        rgba(4, 10, 26, 0) 68%,
        rgba(4, 10, 26, 0.12) 100%
      ),
      linear-gradient(
        90deg,
        rgba(4, 10, 26, 0.08) 0%,
        rgba(4, 10, 26, 0) 14%,
        rgba(4, 10, 26, 0) 86%,
        rgba(4, 10, 26, 0.08) 100%
      );
    z-index: 2;
  }

  .hero-image {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.035);
    filter: saturate(1.03) contrast(1.03) brightness(1.01)
      drop-shadow(0 18px 42px rgba(65, 171, 226, 0.1))
      drop-shadow(0 12px 20px rgba(10, 20, 55, 0.2));
  }

  @keyframes heroFloatCard {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-14px);
    }
  }

  @keyframes heroAuraPulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.9;
    }
    50% {
      transform: scale(1.08);
      opacity: 0.62;
    }
  }

  @keyframes heroSpin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @keyframes heroSpinReverse {
    from {
      transform: rotate(360deg);
    }
    to {
      transform: rotate(0deg);
    }
  }

  @media (max-width: 1200px) {
    #hero {
      padding: 132px 40px 84px;
    }

    .hero-content {
      grid-template-columns: minmax(0, 1fr) minmax(360px, 0.92fr);
      gap: 48px;
    }

    .hero-title-bottom {
      font-size: clamp(2.9rem, 5.6vw, 4.9rem);
    }

    .hero-title-ice {
      font-size: clamp(3.9rem, 7.2vw, 6.3rem);
    }

    .hero-visual {
      min-height: 580px;
    }

    .hero-visual-shell {
      width: min(100%, 580px);
    }

    .hero-media-card {
      width: min(100%, 500px);
    }
  }

  @media (max-width: 1024px) {
    #hero {
      min-height: auto;
      padding: 126px 32px 72px;
    }

    .hero-content {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .hero-left {
      max-width: 100%;
      text-align: center;
    }

    .hero-subtitle {
      max-width: 680px;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-checks {
      max-width: 720px;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-checks li {
      justify-content: flex-start;
      text-align: left;
    }

    .hero-buttons {
      justify-content: center;
    }

    .hero-visual {
      display: none;
    }

    .hero-title {
      text-align: center;
      margin-left: auto;
      margin-right: auto;
      max-width: 100%;
    }

    .hero-title-top {
      justify-content: center;
      gap: 14px;
      margin-bottom: 8px;
    }

    .hero-title-bottom {
      font-size: clamp(2.8rem, 6.4vw, 4.6rem);
    }

    .hero-title-ice {
      font-size: clamp(3.9rem, 8.5vw, 6rem);
    }
  }

  @media (min-width: 1025px) {
    .hero-title br {
      display: none;
    }
  }

  @media (max-width: 768px) {
    #hero {
      padding: 118px 24px 64px;
    }

    .hero-badge {
      font-size: 0.72rem;
      letter-spacing: 1.4px;
      padding: 9px 14px;
      margin-bottom: 22px;
    }

    .hero-title-top {
      gap: 10px;
      margin-bottom: 6px;
    }

    .hero-title-bottom {
      font-size: clamp(2.5rem, 8vw, 3.8rem);
      letter-spacing: -1.2px;
    }

    .hero-title-ice {
      font-size: clamp(3.4rem, 11vw, 5rem);
    }

    .hero-subtitle {
      font-size: 1rem;
      line-height: 1.75;
      margin-bottom: 28px;
    }

    .hero-checks {
      gap: 12px;
      margin-bottom: 30px;
    }

    .hero-checks li {
      font-size: 0.96rem;
    }

    .hero-buttons {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-cta-primary,
    .hero-cta-secondary {
      width: 100%;
      min-width: 0;
    }
  }

  @media (max-width: 480px) {
    #hero {
      padding: 112px 18px 56px;
    }

    .hero-badge {
      width: 100%;
      justify-content: center;
    }

    .hero-title-top {
      gap: 8px;
    }

    .hero-title-bottom {
      font-size: clamp(2.15rem, 8.8vw, 3rem);
      letter-spacing: -1px;
    }

    .hero-title-ice {
      font-size: clamp(2.9rem, 11.8vw, 4rem);
    }

    .hero-checks li {
      gap: 10px;
      font-size: 0.92rem;
    }

    .check-icon {
      width: 22px;
      height: 22px;
      font-size: 0.7rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-title-ice,
    .hero-visual-aura,
    .hero-visual-orbit-1,
    .hero-visual-orbit-2,
    .hero-media-card {
      animation: none;
    }
  }
</style>
