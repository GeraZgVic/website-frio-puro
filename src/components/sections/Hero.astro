---
import { buildWhatsAppUrl, commercialContent } from "../../config/commercial";
---

<section id="inicio" class="hero-section">
  <div id="hero">
    <canvas id="hero-particles-canvas" aria-hidden="true"></canvas>

    <div class="hero-bg-glow hero-bg-glow-1"></div>
    <div class="hero-bg-glow hero-bg-glow-2"></div>

    <!-- Imagen integrada en la zona visual del hero antiguo -->
    <div class="hero-visual-bg fade-in fade-in-delay-2" aria-hidden="true">
      <picture class="hero-picture">
        <img
          src="/images/Hero4.png"
          alt=""
          class="hero-image"
          width="1024"
          height="1080"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </picture>

      <div class="hero-vignette"></div>
      <div class="hero-image-overlay"></div>

      <div class="hero-chip">
        <span class="hero-chip-dot"></span>
        Stock disponible
      </div>

      <div class="hero-pill hero-pill-1">
        <svg
          viewBox="0 0 16 16"
          fill="none"
          class="hero-pill-icon"
          aria-hidden="true"
        >
          <path
            d="M8 1v2M8 13v2M1 8h2M13 8h2M3.05 3.05l1.41 1.41M11.54 11.54l1.41 1.41M3.05 12.95l1.41-1.41M11.54 4.46l1.41-1.41"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"></path>
          <circle cx="8" cy="8" r="2.5" stroke="currentColor" stroke-width="1.4"
          ></circle>
        </svg>
        Hielo purificado
      </div>

      <div class="hero-pill hero-pill-2">
        <svg
          viewBox="0 0 16 16"
          fill="none"
          class="hero-pill-icon"
          aria-hidden="true"
        >
          <path
            d="M1.5 8a6.5 6.5 0 1 1 13 0 6.5 6.5 0 0 1-13 0Z"
            stroke="currentColor"
            stroke-width="1.4"></path>
          <path
            d="M8 5v3.5l2.5 1.5"
            stroke="currentColor"
            stroke-width="1.4"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        Entrega coordinada
      </div>
    </div>

    <div class="hero-content">
      <div class="hero-left">
        <div class="hero-badge fade-in">
          <span class="hero-badge-dot"></span>
          Suministro B2B en Villahermosa
        </div>

        <h1 class="hero-title fade-in fade-in-delay-1">
          <span class="hero-title-top">
            <span class="hero-title-ice">HIELO PREMIUM</span>
          </span>
          <span class="hero-title-bottom">PARA OPERACIÓN COMERCIAL</span>
        </h1>

        <p class="hero-subtitle fade-in fade-in-delay-2">
          Suministro garantizado de hielo purificado con stock permanente para
          tu negocio en Villahermosa.
        </p>

        <ul class="hero-checks" aria-label="Beneficios principales">
          <li>
            <span class="check-icon">✓</span>
            <span>Stock permanente para pedidos recurrentes</span>
          </li>
          <li>
            <span class="check-icon">✓</span>
            <span>Hielo purificado con presentación uniforme</span>
          </li>
          <li>
            <span class="check-icon">✓</span>
            <span>Entrega coordinada por rutas comerciales</span>
          </li>
        </ul>

        <div class="hero-buttons fade-in fade-in-delay-3">
          <a
            href={buildWhatsAppUrl()}
            class="btn-primary hero-cta-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            {commercialContent.ctas.heroPrimary}
          </a>

          <a href="#productos" class="btn-outline hero-cta-secondary">
            Ver producto
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding: 0;
  }

  #hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 140px 60px 90px;
    isolation: isolate;
    background:
      radial-gradient(
        circle at 18% 22%,
        rgba(65, 171, 226, 0.22) 0%,
        transparent 32%
      ),
      radial-gradient(
        circle at 82% 30%,
        rgba(157, 212, 242, 0.12) 0%,
        transparent 24%
      ),
      linear-gradient(
        135deg,
        #171d48 0%,
        #232b68 32%,
        #2a4d8f 62%,
        #41abe2 100%
      );
  }

  #hero-particles-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .hero-bg-glow {
    position: absolute;
    border-radius: 999px;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }

  .hero-bg-glow-1 {
    top: 8%;
    left: -4%;
    width: 340px;
    height: 340px;
    background: rgba(65, 171, 226, 0.18);
  }

  .hero-bg-glow-2 {
    right: -4%;
    bottom: 5%;
    width: 420px;
    height: 420px;
    background: rgba(157, 212, 242, 0.12);
  }

  /* ===== Imagen integrada ===== */
  .hero-visual-bg {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 50.8%;
    z-index: 2;
    overflow: hidden;
  }

  .hero-picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 18%;
    filter: saturate(0.95) contrast(1.04) brightness(0.9);
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background:
      linear-gradient(
        to right,
        rgba(23, 29, 72, 1) 0%,
        rgba(23, 29, 72, 0.92) 7%,
        rgba(23, 29, 72, 0.68) 16%,
        rgba(23, 29, 72, 0.34) 28%,
        transparent 44%
      ),
      linear-gradient(to top, rgba(8, 16, 40, 0.34) 0%, transparent 26%),
      linear-gradient(to bottom, rgba(8, 16, 40, 0.16) 0%, transparent 18%);
  }

  .hero-image-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background:
      radial-gradient(
        circle at 54% 42%,
        rgba(65, 171, 226, 0.08) 0%,
        transparent 34%
      ),
      radial-gradient(
        circle at 78% 72%,
        rgba(255, 255, 255, 0.05) 0%,
        transparent 24%
      );
  }

  .hero-chip {
    position: absolute;
    top: 34px;
    left: 55%;
    transform: translateX(-50%);
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 8px 14px;
    border-radius: 999px;
    background: rgba(8, 16, 40, 0.68);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    box-shadow:
      0 8px 24px rgba(0, 0, 0, 0.3),
      0 1px 0 rgba(255, 255, 255, 0.05) inset;
    font-family: -apple-system, "Helvetica Neue", sans-serif;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.3px;
    color: rgba(223, 240, 250, 0.92);
    z-index: 10;
    white-space: nowrap;
  }

  .hero-chip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #22dd6e;
    flex-shrink: 0;
    animation: heroPulseDotGreen 2.2s ease-out infinite;
  }

  .hero-pill {
    position: absolute;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 14px;
    border-radius: 999px;
    background: rgba(8, 16, 40, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(18px) saturate(1.3);
    -webkit-backdrop-filter: blur(18px) saturate(1.3);
    box-shadow:
      0 10px 28px rgba(0, 0, 0, 0.3),
      0 1px 0 rgba(255, 255, 255, 0.05) inset;
    font-family: -apple-system, "Helvetica Neue", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.25px;
    color: rgba(212, 233, 248, 0.9);
    z-index: 10;
    pointer-events: none;
  }

  .hero-pill-icon {
    width: 13px;
    height: 13px;
    color: #9dd4f2;
    flex-shrink: 0;
  }

  .hero-pill-1 {
    left: 9%;
    bottom: 20%;
    animation: pillFloat 5s ease-in-out infinite;
  }

  .hero-pill-2 {
    right: 2.4%;
    bottom: 7.2%;
    animation: pillFloat 6.2s ease-in-out infinite reverse;
  }

  .hero-content {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
  }

  .hero-left {
    position: relative;
    z-index: 2;
    width: 50.8%;
    max-width: 640px;
    padding-right: 32px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 42px;
    padding: 10px 18px;
    margin-bottom: 28px;
    border-radius: 999px;
    border: 1px solid rgba(157, 212, 242, 0.28);
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.12),
      rgba(255, 255, 255, 0.06)
    );
    backdrop-filter: blur(12px);
    color: var(--color-pale);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 1.8px;
    text-transform: uppercase;
    box-shadow: 0 12px 40px rgba(5, 15, 50, 0.22);
  }

  .hero-badge-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 6px rgba(65, 171, 226, 0.14);
    flex-shrink: 0;
  }

  .hero-title {
    margin-bottom: 24px;
    font-family: "Barlow Condensed", sans-serif;
    text-transform: uppercase;
    width: 100%;
    max-width: 760px;
    line-height: 0.9;
  }

  .hero-title-top {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 18px;
    margin-bottom: 10px;
  }

  .hero-title-bottom {
    display: block;
    font-size: clamp(3.2rem, 6.2vw, 5.6rem);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -1.6px;
    color: var(--color-white);
    text-shadow: 0 10px 40px rgba(10, 16, 48, 0.28);
  }

  .hero-title-ice {
    display: inline-block;
    position: relative;
    width: fit-content;
    font-size: clamp(4.3rem, 8vw, 7.2rem);
    font-weight: 800;
    line-height: 0.88;
    letter-spacing: -1.9px;
    color: #f6f9ff;
    text-shadow: 0 10px 26px rgba(9, 16, 40, 0.35);
  }

  .hero-subtitle {
    max-width: 560px;
    margin-bottom: 34px;
    font-size: 1.1rem;
    line-height: 1.8;
    color: rgba(224, 239, 248, 0.88);
  }

  .hero-checks {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-bottom: 40px;
    padding: 0;
  }

  .hero-checks li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: rgba(255, 255, 255, 0.92);
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.55;
    opacity: 0;
    transform: translateX(-20px);
    transition: all 0.5s ease;
  }

  .hero-checks li.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .check-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    margin-top: 1px;
    border-radius: 999px;
    flex-shrink: 0;
    background: linear-gradient(135deg, #41abe2, #7ad3ff);
    color: var(--color-white);
    font-size: 0.75rem;
    box-shadow:
      0 8px 20px rgba(65, 171, 226, 0.35),
      inset 0 1px 0 rgba(255, 255, 255, 0.28);
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
  }

  .hero-cta-primary,
  .hero-cta-secondary {
    min-width: 220px;
    text-align: center;
  }

  .hero-cta-primary {
    background: linear-gradient(180deg, #8ddcff 0%, #4fb5ef 100%);
    border: 1px solid rgba(255, 255, 255, 0.28);
    box-shadow:
      0 18px 40px rgba(5, 15, 50, 0.35),
      0 6px 16px rgba(79, 181, 239, 0.45);
    font-weight: 700;
  }

  .hero-cta-secondary {
    border: 2px solid rgba(255, 255, 255, 0.72);
    color: var(--color-white);
    font-weight: 700;
    background: transparent;
    box-shadow: 0 10px 26px rgba(5, 15, 50, 0.2);
  }

  .fade-in {
    opacity: 0;
    transform: translateY(18px);
    animation: revealUp 0.6s ease forwards;
  }

  .fade-in-delay-1 {
    animation-delay: 0.15s;
  }

  .fade-in-delay-2 {
    animation-delay: 0.28s;
  }

  .fade-in-delay-3 {
    animation-delay: 0.42s;
  }

  @keyframes revealUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes pillFloat {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-6px);
    }
  }

  @keyframes heroPulseDotGreen {
    0% {
      box-shadow: 0 0 0 0 rgba(34, 221, 110, 0.45);
    }
    70% {
      box-shadow: 0 0 0 7px rgba(34, 221, 110, 0);
    }
    100% {
      box-shadow: 0 0 0 0 rgba(34, 221, 110, 0);
    }
  }

  @media (max-width: 1200px) {
    #hero {
      padding: 132px 40px 84px;
    }

    .hero-left {
      width: 53%;
    }

    .hero-visual-bg {
      left: 53%;
    }

    .hero-title-bottom {
      font-size: clamp(2.9rem, 5.6vw, 4.9rem);
    }

    .hero-title-ice {
      font-size: clamp(3.9rem, 7.2vw, 6.3rem);
    }

    .hero-pill-1 {
      left: 6%;
      bottom: 18%;
    }

    .hero-pill-2 {
      right: 2%;
      bottom: 6%;
    }
  }

  @media (max-width: 1024px) {
    #hero {
      min-height: auto;
      padding: 126px 32px 72px;
      display: flex;
      flex-direction: column;
    }

    .hero-content {
      width: 100%;
      order: 0;
      max-width: 100%;
    }

    .hero-left {
      width: 100%;
      max-width: 100%;
      text-align: center;
      padding-right: 0;
    }

    .hero-subtitle {
      max-width: 680px;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-checks {
      max-width: 720px;
      margin-left: auto;
      margin-right: auto;
      flex-direction: row;
    }

    .hero-checks li {
      justify-content: flex-start;
      text-align: left;
    }

    .hero-buttons {
      justify-content: center;
    }

    .hero-title {
      text-align: center;
      margin-left: auto;
      margin-right: auto;
      max-width: 100%;
    }

    .hero-title-top {
      justify-content: center;
      gap: 14px;
      margin-bottom: 8px;
    }

    .hero-title-bottom {
      font-size: clamp(2.8rem, 6.4vw, 4.6rem);
    }

    .hero-title-ice {
      font-size: clamp(3.9rem, 8.5vw, 6rem);
    }

    .hero-visual-bg {
      position: relative;
      inset: auto;
      width: 100%;
      height: 48vh;
      min-height: 300px;
      order: 1;
      margin-top: 30px;
      border-radius: 28px;
      left: auto;
    }

    .hero-vignette {
      background:
        linear-gradient(to bottom, rgba(8, 16, 40, 0.55) 0%, transparent 25%),
        linear-gradient(to top, rgba(8, 16, 40, 0.45) 0%, transparent 28%);
    }

    .hero-chip {
      top: 14px;
      left: 50%;
    }

    .hero-pill-1 {
      left: 4%;
      bottom: 16%;
    }

    .hero-pill-2 {
      right: 4%;
      bottom: 8%;
    }
  }

  @media (min-width: 1025px) {
    .hero-title br {
      display: none;
    }
  }

  @media (max-width: 768px) {
    #hero {
      padding: 118px 24px 64px;
    }

    .hero-badge {
      font-size: 0.72rem;
      letter-spacing: 1.4px;
      padding: 9px 14px;
      margin-bottom: 22px;
    }

    .hero-title-top {
      gap: 10px;
      margin-bottom: 6px;
    }

    .hero-title-bottom {
      font-size: clamp(2.5rem, 8vw, 3.8rem);
      letter-spacing: -1.2px;
    }

    .hero-title-ice {
      font-size: clamp(3.4rem, 11vw, 5rem);
    }

    .hero-subtitle {
      font-size: 1rem;
      line-height: 1.75;
      margin-bottom: 28px;
    }

    .hero-checks {
      gap: 12px;
      margin-bottom: 30px;
    }

    .hero-checks li {
      font-size: 0.96rem;
    }

    .hero-buttons {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-cta-primary,
    .hero-cta-secondary {
      width: 100%;
      min-width: 0;
    }

    .hero-visual-bg {
      height: 40vh;
      min-height: 240px;
    }

    .hero-chip,
    .hero-pill {
      transform: scale(0.94);
    }

    .hero-pill-1 {
      left: 3.5%;
      bottom: 14%;
    }

    .hero-pill-2 {
      right: 3.5%;
      bottom: 6%;
    }
  }

  @media (max-width: 480px) {
    #hero {
      padding: 112px 18px 56px;
    }

    .hero-badge {
      width: 100%;
      justify-content: center;
    }

    .hero-title-top {
      gap: 8px;
    }

    .hero-title-bottom {
      font-size: clamp(2.15rem, 8.8vw, 3rem);
      letter-spacing: -1px;
    }

    .hero-title-ice {
      font-size: clamp(2.9rem, 11.8vw, 4rem);
    }

    .hero-checks li {
      gap: 10px;
      font-size: 0.92rem;
    }

    .check-icon {
      width: 22px;
      height: 22px;
      font-size: 0.7rem;
    }

    .hero-visual-bg {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-chip-dot,
    .hero-pill-1,
    .hero-pill-2 {
      animation: none !important;
    }

    .fade-in,
    .hero-visual-bg {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }
</style>
