---
import { buildWhatsAppUrl, commercialContent } from "../../config/commercial";
---

<section id="inicio" class="hero-section">
  <div id="hero">
    <canvas id="hero-particles-canvas" aria-hidden="true"></canvas>

    <div class="hero-noise" aria-hidden="true"></div>
    <div class="hero-bg-glow hero-bg-glow-1"></div>
    <div class="hero-bg-glow hero-bg-glow-2"></div>

    <!-- Imagen integrada -->
    <div class="hero-visual-bg fade-in fade-in-delay-2" aria-hidden="true">
      <picture class="hero-picture">
        <img
          src="/images/Hero4.png"
          alt=""
          class="hero-image"
          width="1024"
          height="1080"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </picture>

      <!--  <div class="hero-vignette"></div>
      <div class="hero-image-overlay"></div>
      <div class="hero-image-shine"></div> -->
    </div>

    <div class="hero-content">
      <div class="hero-left">
        <div class="hero-badge fade-in">
          <span class="hero-badge-dot"></span>
          Suministro B2B premium en Villahermosa
        </div>

        <h1 class="hero-title fade-in fade-in-delay-1">
          <span class="hero-title-top">
            <span class="hero-title-ice">HIELO PREMIUM</span>
          </span>
          <span class="hero-title-bottom">PARA OPERACIÓN COMERCIAL</span>
        </h1>

        <p class="hero-subtitle fade-in fade-in-delay-2">
          Abasto confiable de hielo purificado para negocios que exigen
          continuidad operativa, presentación impecable y atención comercial
          puntual.
        </p>

        <ul class="hero-checks" aria-label="Beneficios principales">
          <li class="fade-in fade-in-delay-2">
            <span class="check-icon">✓</span>
            <span>Stock permanente para operación recurrente</span>
          </li>
          <li class="fade-in fade-in-delay-2">
            <span class="check-icon">✓</span>
            <span>Hielo uniforme con presencia premium</span>
          </li>
          <li class="fade-in fade-in-delay-3">
            <span class="check-icon">✓</span>
            <span>Entrega coordinada para rutas comerciales</span>
          </li>
        </ul>

        <div class="hero-buttons fade-in fade-in-delay-3">
          <a
            href={buildWhatsAppUrl()}
            class="btn-primary hero-cta-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            {commercialContent.ctas.heroPrimary}
          </a>

          <a href="#productos" class="btn-outline hero-cta-secondary">
            Ver producto
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding: 0;
  }

  #hero {
    --hero-blue: #8fd4ff;
    --hero-blue-strong: #5cbdf5;
    --hero-blue-soft: rgba(143, 212, 255, 0.18);
    --hero-ice: #f4f8ff;
    --hero-ink: #ffffff;
    --hero-muted: rgba(230, 238, 247, 0.84);
    --hero-panel: rgba(255, 255, 255, 0.08);
    --hero-panel-border: rgba(255, 255, 255, 0.14);

    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 138px 60px 92px;
    isolation: isolate;
    background:
      radial-gradient(
        circle at 18% 22%,
        rgba(65, 171, 226, 0.22) 0%,
        transparent 32%
      ),
      radial-gradient(
        circle at 82% 30%,
        rgba(157, 212, 242, 0.12) 0%,
        transparent 24%
      ),
      linear-gradient(
        135deg,
        #171d48 0%,
        #232b68 32%,
        #2a4d8f 62%,
        #41abe2 100%
      );
  }

  #hero-particles-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .hero-noise {
    display: none;
  }

  .hero-bg-glow {
    position: absolute;
    border-radius: 999px;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }

  .hero-bg-glow-1 {
    top: 8%;
    left: -4%;
    width: 340px;
    height: 340px;
    background: rgba(65, 171, 226, 0.18);
  }

  .hero-bg-glow-2 {
    right: -4%;
    bottom: 5%;
    width: 420px;
    height: 420px;
    background: rgba(157, 212, 242, 0.12);
  }

  /* ===== Imagen integrada ===== */
  .hero-visual-bg {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 51.5%;
    z-index: 2;
    overflow: hidden;
  }

  .hero-picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 18%;
    filter: saturate(0.92) contrast(1.04) brightness(0.94);
    transform: scale(1.02);
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    background:
      linear-gradient(
        to right,
        rgba(8, 17, 31, 1) 0%,
        rgba(8, 17, 31, 0.95) 9%,
        rgba(8, 17, 31, 0.78) 19%,
        rgba(8, 17, 31, 0.42) 32%,
        transparent 47%
      ),
      linear-gradient(to top, rgba(6, 12, 24, 0.34) 0%, transparent 24%),
      linear-gradient(to bottom, rgba(6, 12, 24, 0.18) 0%, transparent 15%);
  }

  .hero-image-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    background:
      radial-gradient(
        circle at 58% 38%,
        rgba(255, 255, 255, 0.06) 0%,
        transparent 22%
      ),
      radial-gradient(
        circle at 72% 72%,
        rgba(143, 212, 255, 0.08) 0%,
        transparent 20%
      );
    mix-blend-mode: screen;
  }

  .hero-image-shine {
    position: absolute;
    inset: -10%;
    pointer-events: none;
    z-index: 3;
    background: linear-gradient(
      115deg,
      transparent 34%,
      rgba(255, 255, 255, 0.05) 46%,
      rgba(255, 255, 255, 0.015) 54%,
      transparent 64%
    );
    transform: translateX(-8%);
  }

  .hero-content {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
  }

  .hero-left {
    position: relative;
    z-index: 2;
    width: 50%;
    max-width: 645px;
    padding-right: 36px;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 42px;
    padding: 10px 18px;
    margin-bottom: 26px;
    border-radius: 999px;
    border: 1px solid rgba(143, 212, 255, 0.22);
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.12),
      rgba(255, 255, 255, 0.05)
    );
    backdrop-filter: blur(16px) saturate(1.15);
    -webkit-backdrop-filter: blur(16px) saturate(1.15);
    color: rgba(241, 247, 255, 0.92);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    box-shadow:
      0 14px 36px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .hero-badge-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: linear-gradient(180deg, #9addff 0%, #56bdf4 100%);
    box-shadow: 0 0 0 6px rgba(92, 189, 245, 0.12);
    flex-shrink: 0;
  }

  .hero-title {
    width: 100%;
    max-width: 780px;
    margin: 0 0 24px;
    line-height: 0.92;
    text-transform: uppercase;
  }

  .hero-title-top {
    display: block;
    margin-bottom: 8px;
  }

  .hero-title-ice {
    display: inline-block;
    position: relative;
    width: fit-content;
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(4.5rem, 8vw, 7.3rem);
    font-weight: 800;
    line-height: 0.88;
    letter-spacing: -0.04em;
    color: var(--hero-ice);
    text-shadow:
      0 8px 24px rgba(0, 0, 0, 0.16),
      0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .hero-title-bottom {
    display: block;
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(3rem, 6vw, 5.3rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: rgba(255, 255, 255, 0.96);
    text-shadow: 0 10px 34px rgba(0, 0, 0, 0.14);
  }

  .hero-subtitle {
    max-width: 560px;
    margin-bottom: 32px;
    color: rgba(230, 238, 247, 0.82);
    font-size: 1.08rem;
    line-height: 1.85;
    font-weight: 400;
    text-wrap: balance;
  }

  .hero-checks {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin: 0 0 40px;
    padding: 0;
  }

  .hero-checks li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: rgba(250, 252, 255, 0.94);
    font-size: 0.995rem;
    font-weight: 500;
    line-height: 1.58;
  }

  .check-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 23px;
    height: 23px;
    margin-top: 2px;
    border-radius: 999px;
    flex-shrink: 0;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.2),
        rgba(255, 255, 255, 0.06)
      ),
      linear-gradient(135deg, #8fd4ff, #58bdf4);
    color: #ffffff;
    font-size: 0.7rem;
    box-shadow:
      0 8px 20px rgba(8, 27, 48, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.22);
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
  }

  .hero-cta-primary,
  .hero-cta-secondary {
    min-width: 220px;
    text-align: center;
  }

  .hero-cta-primary {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.12),
        rgba(255, 255, 255, 0.04)
      ),
      linear-gradient(135deg, #97dcff 0%, #5fbeef 100%);
    color: #08111f;
    font-weight: 800;
    box-shadow:
      0 18px 40px rgba(0, 0, 0, 0.22),
      0 6px 18px rgba(95, 190, 239, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.22);
  }

  .hero-cta-primary::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      115deg,
      transparent 20%,
      rgba(255, 255, 255, 0.18) 48%,
      transparent 72%
    );
    transform: translateX(-120%);
    transition: transform 0.9s ease;
  }

  .hero-cta-primary:hover::before {
    transform: translateX(120%);
  }

  .hero-cta-secondary {
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: rgba(255, 255, 255, 0.96);
    font-weight: 700;
    background: rgba(255, 255, 255, 0.045);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow:
      0 12px 30px rgba(0, 0, 0, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .hero-cta-secondary:hover {
    border-color: rgba(143, 212, 255, 0.34);
    background: rgba(255, 255, 255, 0.075);
  }

  .fade-in {
    opacity: 0;
    transform: translateY(18px);
    animation: revealUp 0.72s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .fade-in-delay-1 {
    animation-delay: 0.14s;
  }

  .fade-in-delay-2 {
    animation-delay: 0.28s;
  }

  .fade-in-delay-3 {
    animation-delay: 0.42s;
  }

  @keyframes revealUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 1200px) {
    #hero {
      padding: 132px 40px 84px;
    }

    .hero-left {
      width: 52%;
    }

    .hero-visual-bg {
      left: 53%;
    }
  }

  @media (max-width: 1024px) {
    #hero {
      min-height: auto;
      padding: 124px 32px 72px;
      display: flex;
      flex-direction: column;
    }

    .hero-content {
      width: 100%;
      order: 0;
      max-width: 100%;
    }

    .hero-left {
      width: 100%;
      max-width: 100%;
      text-align: center;
      padding-right: 0;
    }

    .hero-title,
    .hero-subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-checks {
      max-width: 740px;
      margin-left: auto;
      margin-right: auto;
      display: grid;
      grid-template-columns: 1fr;
    }

    .hero-checks li {
      text-align: left;
      justify-content: flex-start;
    }

    .hero-buttons {
      justify-content: center;
    }

    .hero-visual-bg {
      position: relative;
      inset: auto;
      width: 100%;
      height: 48vh;
      min-height: 320px;
      order: 1;
      margin-top: 34px;
      border-radius: 30px;
      left: auto;
      border: 1px solid rgba(255, 255, 255, 0.1);
      box-shadow:
        0 26px 60px rgba(0, 0, 0, 0.2),
        inset 0 1px 0 rgba(255, 255, 255, 0.06);
    }

    .hero-vignette {
      background:
        linear-gradient(to bottom, rgba(8, 17, 31, 0.52) 0%, transparent 24%),
        linear-gradient(to top, rgba(8, 17, 31, 0.44) 0%, transparent 24%);
    }
  }

  @media (min-width: 1025px) {
    .hero-title br {
      display: none;
    }
  }

  @media (max-width: 768px) {
    #hero {
      padding: 116px 22px 62px;
    }

    .hero-badge {
      font-size: 0.69rem;
      letter-spacing: 0.14em;
      padding: 9px 14px;
      margin-bottom: 22px;
    }

    .hero-title {
      margin-bottom: 20px;
    }

    .hero-title-top {
      margin-bottom: 6px;
    }

    .hero-title-ice {
      font-size: clamp(3.5rem, 11vw, 5.4rem);
    }

    .hero-title-bottom {
      font-size: clamp(2.45rem, 7.8vw, 3.95rem);
    }

    .hero-subtitle {
      font-size: 0.99rem;
      line-height: 1.78;
      margin-bottom: 28px;
    }

    .hero-checks {
      gap: 12px;
      margin-bottom: 30px;
    }

    .hero-checks li {
      font-size: 0.95rem;
    }

    .hero-buttons {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-cta-primary,
    .hero-cta-secondary {
      width: 100%;
      min-width: 0;
    }

    .hero-visual-bg {
      height: 40vh;
      min-height: 250px;
      border-radius: 24px;
    }
  }

  @media (max-width: 480px) {
    #hero {
      padding: 108px 18px 54px;
    }

    .hero-badge {
      width: 100%;
      justify-content: center;
      margin-bottom: 20px;
    }

    .hero-title-ice {
      font-size: clamp(2.95rem, 12.2vw, 4.15rem);
    }

    .hero-title-bottom {
      font-size: clamp(2.05rem, 8.8vw, 2.85rem);
    }

    .hero-subtitle {
      font-size: 0.95rem;
    }

    .hero-checks li {
      gap: 10px;
      font-size: 0.9rem;
    }

    .check-icon {
      width: 22px;
      height: 22px;
      font-size: 0.68rem;
    }

    .hero-visual-bg {
      display: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fade-in,
    .hero-image-shine {
      animation: none !important;
      transition: none !important;
      opacity: 1 !important;
      transform: none !important;
    }

    .hero-cta-primary::before {
      display: none;
    }
  }
</style>
