---
import { buildWhatsAppUrl, commercialContent } from "../../config/commercial";
---

<section id="inicio" class="hero-section">
  <div id="hero">
    <canvas id="hero-particles-canvas" aria-hidden="true"></canvas>

    <div class="hero-bg-media" aria-hidden="true">
      <picture class="hero-bg-picture">
        <source
          type="image/webp"
          srcset="
            /images/Hero5-512.webp 512w,
            /images/Hero5-768.webp 768w,
            /images/Hero5-1024.webp 1024w,
            /images/Hero5-1536.webp 1536w,
            /images/Hero5-2048.webp 2048w
          "
          sizes="
            (max-width: 480px) 100vw,
            (max-width: 768px) 100vw,
            (max-width: 1200px) 100vw,
            100vw
          "
        />
        <img
          src="/images/Hero5-2048.webp"
          alt="Máquina de hielo industrial produciendo hielo"
          class="hero-bg-image"
          width="2048"
          height="1365"
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      </picture>
      <div class="hero-bg-vignette"></div>
    </div>

    <div class="hero-noise" aria-hidden="true"></div>
    <div class="hero-bg-glow hero-bg-glow-1"></div>
    <div class="hero-bg-glow hero-bg-glow-2"></div>

    <div class="hero-content">
      <div class="hero-left">
        <div class="hero-copy-shell">
          <div class="hero-badge fade-in">
            <span class="hero-badge-dot"></span>
            Suministro en Villahermosa
          </div>

          <h1 class="hero-title fade-in fade-in-delay-1">
            <span class="hero-title-top">
              <span class="hero-title-ice">HIELO PREMIUM</span>
            </span>
            <span class="hero-title-bottom">PARA OPERACIÓN COMERCIAL</span>
          </h1>

          <p class="hero-subtitle fade-in fade-in-delay-2">
            Abasto confiable de hielo purificado para negocios que exigen
            continuidad operativa, presentación impecable y atención comercial
            puntual.
          </p>

          <ul class="hero-checks" aria-label="Beneficios principales">
            <li class="fade-in fade-in-delay-2">
              <span class="check-icon">✓</span>
              <span>Stock permanente para operación recurrente</span>
            </li>
            <li class="fade-in fade-in-delay-2">
              <span class="check-icon">✓</span>
              <span>Hielo uniforme con presencia premium</span>
            </li>
            <li class="fade-in fade-in-delay-3">
              <span class="check-icon">✓</span>
              <span>Entrega coordinada para rutas comerciales</span>
            </li>
          </ul>

          <div class="hero-buttons fade-in fade-in-delay-3">
            <a
              href={buildWhatsAppUrl()}
              class="btn-primary hero-cta-primary"
              target="_blank"
              rel="noopener noreferrer"
            >
              {commercialContent.ctas.heroPrimary}
            </a>

            <a href="#productos" class="btn-outline hero-cta-secondary">
              Ver producto
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding: 0;
  }

  #hero {
    --hero-blue: #8fd4ff;
    --hero-blue-strong: #5cbdf5;
    --hero-blue-soft: rgba(143, 212, 255, 0.18);
    --hero-ice: #f4f8ff;
    --hero-ink: #ffffff;
    --hero-muted: rgba(230, 238, 247, 0.84);

    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    isolation: isolate;
    padding: 138px 60px 92px;
    background:
      radial-gradient(
        circle at 16% 18%,
        rgba(65, 171, 226, 0.14) 0%,
        transparent 28%
      ),
      radial-gradient(
        circle at 86% 72%,
        rgba(157, 212, 242, 0.12) 0%,
        transparent 26%
      ),
      linear-gradient(
        135deg,
        #0d1220 0%,
        #132238 38%,
        #19395b 68%,
        #2d6f9b 100%
      );
  }

  #hero-particles-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 1;
  }

  .hero-bg-media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero-bg-picture {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero-bg-image {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 72% center;
    transform: scale(1.025) translateZ(0);
    filter: saturate(0.92) contrast(1.04) brightness(0.82);
    opacity: 0.96;
    image-rendering: -webkit-optimize-contrast;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
  }

  .hero-bg-vignette {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(
        90deg,
        rgba(7, 12, 20, 0.322) 0%,
        rgba(7, 12, 20, 0.274) 15%,
        rgba(9, 16, 28, 0.082) 28%,
        rgba(10, 19, 34, 0) 40%,
        rgba(10, 19, 34, 0) 56%,
        rgba(10, 19, 34, 0) 72%,
        rgba(10, 19, 34, 0) 100%
      ),
      linear-gradient(
        180deg,
        rgba(4, 9, 16, 0) 0%,
        transparent 22%,
        transparent 76%,
        rgba(4, 9, 16, 0) 100%
      );
  }

  .hero-noise {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    opacity: 0.032;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.025) 1px, transparent 1px);
    background-size:
      4px 4px,
      4px 4px;
    mix-blend-mode: soft-light;
  }

  .hero-bg-glow {
    position: absolute;
    border-radius: 999px;
    filter: blur(88px);
    pointer-events: none;
    z-index: 1;
  }

  .hero-bg-glow-1 {
    top: 4%;
    left: -5%;
    width: 320px;
    height: 320px;
    background: rgba(65, 171, 226, 0.12);
  }

  .hero-bg-glow-2 {
    right: -4%;
    bottom: 2%;
    width: 420px;
    height: 420px;
    background: rgba(157, 212, 242, 0.1);
  }

  .hero-content {
    position: relative;
    z-index: 4;
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
  }

  .hero-left {
    width: 54%;
    max-width: 700px;
  }

  .hero-copy-shell {
    position: relative;
    width: 100%;
    padding: 34px 34px 34px 0;
  }

  .hero-copy-shell::before {
    content: "";
    position: absolute;
    inset: -18px 74px -18px -18px;
    z-index: -1;
    border-radius: 34px;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.08),
      rgba(255, 255, 255, 0.025)
    );
    border: 1px solid rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(10px) saturate(1.06);
    -webkit-backdrop-filter: blur(10px) saturate(1.06);
    box-shadow:
      0 24px 60px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 42px;
    padding: 10px 18px;
    margin-bottom: 26px;
    border-radius: 999px;
    border: 1px solid rgba(143, 212, 255, 0.22);
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.12),
      rgba(255, 255, 255, 0.05)
    );
    backdrop-filter: blur(16px) saturate(1.15);
    -webkit-backdrop-filter: blur(16px) saturate(1.15);
    color: rgba(241, 247, 255, 0.92);
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    box-shadow:
      0 14px 36px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .hero-badge-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: linear-gradient(180deg, #9addff 0%, #56bdf4 100%);
    box-shadow: 0 0 0 6px rgba(92, 189, 245, 0.12);
    flex-shrink: 0;
  }

  .hero-title {
    width: 100%;
    max-width: 780px;
    margin: 0 0 24px;
    line-height: 0.92;
    text-transform: uppercase;
  }

  .hero-title-top {
    display: block;
    margin-bottom: 8px;
  }

  .hero-title-ice {
    display: inline-block;
    position: relative;
    width: fit-content;
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(4.5rem, 8vw, 7.3rem);
    font-weight: 800;
    line-height: 0.88;
    letter-spacing: -0.04em;
    color: var(--hero-ice);
    text-shadow:
      0 8px 24px rgba(0, 0, 0, 0.24),
      0 1px 0 rgba(255, 255, 255, 0.05);
  }

  .hero-title-bottom {
    display: block;
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(3rem, 6vw, 5.3rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: -0.03em;
    color: rgba(255, 255, 255, 0.96);
    text-shadow: 0 10px 34px rgba(0, 0, 0, 0.2);
  }

  .hero-subtitle {
    max-width: 560px;
    margin-bottom: 32px;
    color: rgba(230, 238, 247, 0.84);
    font-size: 1.08rem;
    line-height: 1.85;
    font-weight: 400;
    text-wrap: balance;
  }

  .hero-checks {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin: 0 0 40px;
    padding: 0;
  }

  .hero-checks li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    color: rgba(250, 252, 255, 0.95);
    font-size: 0.995rem;
    font-weight: 500;
    line-height: 1.58;
  }

  .check-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 23px;
    height: 23px;
    margin-top: 2px;
    border-radius: 999px;
    flex-shrink: 0;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.2),
        rgba(255, 255, 255, 0.06)
      ),
      linear-gradient(135deg, #8fd4ff, #58bdf4);
    color: #ffffff;
    font-size: 0.7rem;
    box-shadow:
      0 8px 20px rgba(8, 27, 48, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.22);
  }

  .hero-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
    margin-top: 2px;
  }

  .hero-cta-primary,
  .hero-cta-secondary {
    min-width: 208px;
    text-align: center;
  }

  .hero-cta-primary {
    position: relative;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.14);
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.12),
        rgba(255, 255, 255, 0.04)
      ),
      linear-gradient(135deg, #97dcff 0%, #5fbeef 100%);
    color: #08111f;
    font-weight: 800;
    box-shadow:
      0 18px 40px rgba(0, 0, 0, 0.22),
      0 6px 18px rgba(95, 190, 239, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.22);
  }

  .hero-cta-primary::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      115deg,
      transparent 20%,
      rgba(255, 255, 255, 0.18) 48%,
      transparent 72%
    );
    transform: translateX(-120%);
    transition: transform 0.9s ease;
  }

  .hero-cta-primary:hover::before {
    transform: translateX(120%);
  }

  .hero-cta-secondary {
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: rgba(255, 255, 255, 0.96);
    font-weight: 700;
    background: rgba(255, 255, 255, 0.045);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    box-shadow:
      0 12px 30px rgba(0, 0, 0, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .hero-cta-secondary:hover {
    border-color: rgba(143, 212, 255, 0.34);
    background: rgba(255, 255, 255, 0.075);
  }

  .fade-in {
    opacity: 0;
    transform: translateY(18px);
    animation: revealUp 0.72s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  .fade-in-delay-1 {
    animation-delay: 0.14s;
  }

  .fade-in-delay-2 {
    animation-delay: 0.28s;
  }

  .fade-in-delay-3 {
    animation-delay: 0.42s;
  }

  @keyframes revealUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 1200px) {
    #hero {
      padding: 132px 40px 84px;
    }

    .hero-left {
      width: 58%;
    }

    .hero-copy-shell::before {
      inset: -16px 34px -16px -16px;
    }
  }

  @media (max-width: 1024px) {
    #hero {
      min-height: auto;
      padding: 124px 32px 72px;
    }

    .hero-bg-image {
      object-position: 74% center;
      filter: saturate(0.92) contrast(1.03) brightness(0.72);
    }

    .hero-bg-vignette {
      background: linear-gradient(
        180deg,
        rgba(8, 17, 31, 0) 0%,
        rgba(8, 17, 31, 0) 22%,
        rgba(8, 17, 31, 0.336) 44%,
        rgba(8, 17, 31, 0) 100%
      );
    }

    .hero-left {
      width: 100%;
      max-width: 100%;
      text-align: center;
    }

    .hero-copy-shell {
      padding: 22px 4px 4px;
    }

    .hero-copy-shell::before {
      inset: -16px -8px -16px -8px;
      border-radius: 28px;
    }

    .hero-title,
    .hero-subtitle {
      margin-left: auto;
      margin-right: auto;
    }

    .hero-checks {
      max-width: 740px;
      margin-left: auto;
      margin-right: auto;
    }

    .hero-checks li {
      text-align: left;
    }

    .hero-buttons {
      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    #hero {
      padding: 116px 22px 62px;
    }

    .hero-copy-shell {
      padding: 18px 8px 8px;
    }

    .hero-copy-shell::before {
      inset: -14px -6px -14px -6px;
      border-radius: 26px;
    }

    .hero-badge {
      font-size: 0.69rem;
      letter-spacing: 0.14em;
      padding: 9px 14px;
      margin-bottom: 22px;
    }

    .hero-title {
      margin-bottom: 20px;
    }

    .hero-title-top {
      margin-bottom: 6px;
    }

    .hero-title-ice {
      font-size: clamp(3.5rem, 11vw, 5.4rem);
    }

    .hero-title-bottom {
      font-size: clamp(2.45rem, 7.8vw, 3.95rem);
    }

    .hero-subtitle {
      font-size: 0.99rem;
      line-height: 1.78;
      margin-bottom: 28px;
    }

    .hero-checks {
      gap: 12px;
      margin-bottom: 28px;
    }

    .hero-checks li {
      font-size: 0.95rem;
    }

    .hero-buttons {
      flex-direction: column;
      align-items: center;
      gap: 10px;
      margin-top: 8px;
      padding-top: 4px;
    }

    .hero-cta-primary,
    .hero-cta-secondary {
      width: min(100%, 320px);
      min-width: 0;
    }
  }

  @media (max-width: 480px) {
    #hero {
      padding: 108px 18px 54px;
    }

    .hero-bg-image {
      object-position: 77% center;
      filter: saturate(0.91) contrast(1.02) brightness(0.66);
    }

    .hero-left {
      text-align: center;
    }

    .hero-copy-shell {
      padding: 18px 10px 10px;
    }

    .hero-copy-shell::before {
      inset: -12px 0 -12px 0;
      border-radius: 22px;
    }

    .hero-badge {
      width: 100%;
      max-width: 290px;
      justify-content: center;
      margin: 0 auto 18px;
      padding: 8px 14px;
    }

    .hero-title {
      margin-bottom: 18px;
    }

    .hero-title-ice {
      font-size: clamp(2.95rem, 12.2vw, 4.15rem);
    }

    .hero-title-bottom {
      font-size: clamp(2.05rem, 8.8vw, 2.85rem);
    }

    .hero-subtitle {
      max-width: 31ch;
      font-size: 0.95rem;
      line-height: 1.72;
      margin-bottom: 24px;
    }

    .hero-checks {
      max-width: 300px;
      gap: 11px;
      margin: 0 auto 24px;
      align-items: center;
    }

    .hero-checks li {
      width: 100%;
      justify-content: center;
      gap: 10px;
      font-size: 0.9rem;
      line-height: 1.52;
      text-align: left;
    }

    .hero-checks li span:last-child {
      flex: 1;
      max-width: 240px;
    }

    .check-icon {
      width: 21px;
      height: 21px;
      font-size: 0.66rem;
      margin-top: 1px;
    }

    .hero-buttons {
      gap: 10px;
      margin-top: 10px;
      padding-top: 2px;
      padding-bottom: 2px;
    }

    .hero-cta-primary,
    .hero-cta-secondary {
      width: 100%;
      max-width: 286px;
      min-height: 48px;
      padding: 13px 18px;
      font-size: 0.92rem;
      letter-spacing: 0.04em;
      border-radius: 999px;
    }
  }

  @media (max-width: 380px) {
    #hero {
      padding: 104px 16px 50px;
    }

    .hero-copy-shell {
      padding: 16px 8px 8px;
    }

    .hero-copy-shell::before {
      inset: -10px 0 -10px 0;
      border-radius: 20px;
    }

    .hero-badge {
      max-width: 280px;
      font-size: 0.64rem;
      letter-spacing: 0.12em;
    }

    .hero-subtitle {
      font-size: 0.92rem;
    }

    .hero-checks {
      max-width: 286px;
    }

    .hero-checks li {
      font-size: 0.875rem;
    }

    .hero-cta-primary,
    .hero-cta-secondary {
      max-width: 276px;
      min-height: 46px;
      padding: 12px 16px;
      font-size: 0.88rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .fade-in {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }

    .hero-cta-primary::before {
      display: none;
    }
  }
</style>
