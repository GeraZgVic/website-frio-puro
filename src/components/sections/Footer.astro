---
import { buildWhatsAppUrl, commercialContent } from "../../config/commercial";
import { getHomeSectionHref, getLogoHref } from "../../config/navigation";

const pathname = Astro.url.pathname;
const sectionHref = (id: string): string => getHomeSectionHref(pathname, id);
const logoHref = getLogoHref(pathname);
---

<!-- FOOTER -->
<footer>
  <div class="footer-bg"></div>
  <div class="footer-top-line"></div>

  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href={logoHref} class="footer-logo-link" aria-label="Frío Puro">
          <img
            class="footer-logo-image"
            src="/images/FrioPuroLogo.png"
            alt="Frío Puro"
            loading="lazy"
            decoding="async"
          />
        </a>

        <div class="footer-divider footer-divider-mobile" aria-hidden="true">
        </div>

        <div class="footer-address-block">
          <a
            class="footer-address-text"
            href="https://www.google.com/maps/search/?api=1&query=OFICINA%20Y%20F%C3%81BRICA%20DE%20FRIO%20PURO%2C%20Calle%20Melchor%20Ocampo%20104%2C%20Colonia%20Miguel%20Hidalgo%2C%20Villahermosa%2C%20Tabasco%2C%2086127"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Ver ubicación de Oficina y Fábrica de Frío Puro en Google Maps"
          >
            <strong>OFICINA Y FÁBRICA DE FRÍO PURO</strong><br />
            Calle Melchor Ocampo, Número 104,<br />
            Colonia Miguel Hidalgo, Villahermosa,<br />
            Centro, Tabasco. C.P. 86127
          </a>
        </div>
      </div>

      <div class="footer-divider footer-divider-mobile" aria-hidden="true">
      </div>

      <div class="footer-links-wrap">
        <div class="footer-col footer-nav-col">
          <h4>Navegación</h4>
          <ul class="footer-links">
            <li><a href={sectionHref("inicio")}>Inicio</a></li>
            <li><a href={sectionHref("clientes")}>Clientes</a></li>
            <li><a href={sectionHref("productos")}>Productos</a></li>
            <li><a href={sectionHref("proceso")}>Proceso de producción</a></li>
            <li><a href={sectionHref("contacto")}>Contacto</a></li>
          </ul>
        </div>

        <div class="footer-col footer-contact-col">
          <h4>Contacto</h4>
          <ul class="footer-contact footer-links">
            <li>
              <span class="ic" aria-hidden="true">01</span>
              <a
                href={buildWhatsAppUrl()}
                target="_blank"
                rel="noopener noreferrer"
              >
                {commercialContent.whatsappNumberRaw}
              </a>
            </li>
            <li>
              <span class="ic" aria-hidden="true">02</span>
              <a href="mailto:ventas@friopuro.com.mx">
                ventas@friopuro.com.mx
              </a>
            </li>
          </ul>
        </div>
      </div>

      <div class="footer-divider footer-divider-mobile" aria-hidden="true">
      </div>

      <div class="footer-col footer-social-col">
        <h4>Síguenos</h4>

        <div class="social-icons">
          <a
            href="https://www.facebook.com/people/FR%C3%8DO-PURO/61586180049631/?mibextid=wwXIfr&rdid=w0UEUjDLTAhu7O95&share_url=https%3A%2F%2Fwww.facebook.com%2Fshare%2F17eBLeLQ5Y%2F%3Fmibextid%3DwwXIfr"
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon facebook"
            aria-label="Facebook"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M13.5 21v-7h2.4l.36-2.8H13.5V9.41c0-.81.22-1.36 1.39-1.36H16.4V5.55c-.26-.03-1.14-.1-2.17-.1-2.15 0-3.63 1.31-3.63 3.73v2.02H8.16V14h2.44v7h2.9Z"
              ></path>
            </svg>
          </a>

          <a
            href="https://www.instagram.com/friopuro2024?igsh=MTd5aHZkMHh2a3Zmdw%3D%3D&utm_source=qr"
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon instagram"
            aria-label="Instagram"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2Zm0 1.8A3.95 3.95 0 0 0 3.8 7.75v8.5A3.95 3.95 0 0 0 7.75 20.2h8.5a3.95 3.95 0 0 0 3.95-3.95v-8.5a3.95 3.95 0 0 0-3.95-3.95h-8.5ZM12 7.3A4.7 4.7 0 1 1 7.3 12 4.7 4.7 0 0 1 12 7.3Zm0 1.8A2.9 2.9 0 1 0 14.9 12 2.9 2.9 0 0 0 12 9.1Zm4.95-2.42a1.12 1.12 0 1 1-1.12 1.12 1.12 1.12 0 0 1 1.12-1.12Z"
              ></path>
            </svg>
          </a>

          <a
            href={buildWhatsAppUrl()}
            target="_blank"
            rel="noopener noreferrer"
            class="social-icon whatsapp"
            aria-label="WhatsApp"
          >
            <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path
                d="M20.52 3.48A11.84 11.84 0 0 0 12.08 0C5.57 0 .27 5.29.27 11.81c0 2.08.54 4.11 1.57 5.9L0 24l6.49-1.7a11.78 11.78 0 0 0 5.59 1.42h.01c6.51 0 11.81-5.3 11.81-11.81 0-3.15-1.23-6.11-3.38-8.43ZM12.09 21.7h-.01a9.8 9.8 0 0 1-5-1.37l-.36-.21-3.85 1 1.03-3.75-.23-.38a9.79 9.79 0 0 1-1.5-5.18c0-5.42 4.41-9.83 9.84-9.83 2.63 0 5.09 1.02 6.94 2.88a9.78 9.78 0 0 1 2.88 6.95c0 5.42-4.42 9.83-9.84 9.83Z"
                fill="currentColor"></path>
              <path
                d="M17.48 14.37c-.29-.15-1.73-.85-2-.95-.27-.1-.46-.15-.66.15-.19.29-.76.95-.92 1.14-.17.2-.33.22-.62.08-.29-.15-1.2-.44-2.29-1.41-.84-.75-1.42-1.69-1.59-1.98-.16-.29-.02-.45.12-.59.13-.13.29-.34.44-.51.15-.17.2-.29.29-.49.1-.19.05-.37-.02-.51-.08-.15-.66-1.59-.9-2.17-.24-.57-.49-.49-.67-.5-.17-.01-.37-.01-.56-.01s-.51.07-.78.37c-.27.29-1.03 1.01-1.03 2.46s1.05 2.86 1.2 3.06c.15.19 2.04 3.11 4.93 4.36.69.3 1.22.48 1.64.61.69.22 1.32.19 1.82.12.56-.08 1.73-.71 1.98-1.39.24-.68.24-1.26.17-1.39-.07-.12-.27-.19-.56-.34Z"
                fill="currentColor"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <div class="footer-divider"></div>

    <div class="footer-bottom">
      <span>© 2026 Frío Puro. Todos los derechos reservados.</span>
      <span>Villahermosa, Tabasco, México</span>
    </div>

    <p class="footer-recaptcha-note">
      Este sitio está protegido por reCAPTCHA y aplican la
      <a
        href="https://policies.google.com/privacy"
        target="_blank"
        rel="noopener noreferrer"
      >
        Política de Privacidad
      </a>
      y los
      <a
        href="https://policies.google.com/terms"
        target="_blank"
        rel="noopener noreferrer"
      >
        Términos del Servicio
      </a>
      de Google.
    </p>
  </div>
</footer>

<style>
  :global(.grecaptcha-badge) {
    visibility: hidden;
  }

  footer {
    position: relative;
    overflow: hidden;
    padding: 88px 56px 28px;
    color: rgba(255, 255, 255, 0.72);
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-footer) 62%, #1a2f61 38%) 0%,
      color-mix(in srgb, var(--color-footer) 82%, #081221 18%) 24%,
      #030915 100%
    );
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    isolation: isolate;
  }

  .footer-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(
        circle at 14% 10%,
        rgba(121, 209, 255, 0.07),
        transparent 24%
      ),
      radial-gradient(
        circle at 84% 14%,
        rgba(191, 230, 255, 0.05),
        transparent 18%
      ),
      radial-gradient(
        circle at 50% 0%,
        rgba(255, 255, 255, 0.02),
        transparent 30%
      );
    z-index: 0;
  }

  .footer-top-line {
    position: absolute;
    top: 0;
    left: 50%;
    width: min(1080px, 94vw);
    height: 1px;
    transform: translateX(-50%);
    background: linear-gradient(
      90deg,
      transparent,
      rgba(162, 224, 255, 0.08),
      rgba(255, 255, 255, 0.18),
      rgba(162, 224, 255, 0.08),
      transparent
    );
    pointer-events: none;
    z-index: 1;
  }

  footer .container {
    position: relative;
    z-index: 2;
    width: min(1120px, 100%);
    margin-inline: auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: minmax(300px, 0.98fr) minmax(320px, 1.06fr) minmax(
        180px,
        0.62fr
      );
    gap: 22px;
    margin-bottom: 38px;
    align-items: start;
  }

  .footer-brand {
    max-width: none;
    width: 100%;
    padding-right: 0;
  }

  .footer-logo-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    margin-bottom: 18px;
  }

  .footer-logo-image {
    width: auto;
    height: 64px;
    display: block;
    object-fit: contain;
    opacity: 0.995;
    filter: brightness(1.05) contrast(1.03)
      drop-shadow(0 12px 22px rgba(0, 0, 0, 0.22));
    transition:
      transform 0.28s ease,
      filter 0.28s ease;
  }

  .footer-logo-link:hover .footer-logo-image {
    transform: translateY(-2px);
    filter: brightness(1.07) contrast(1.04)
      drop-shadow(0 16px 28px rgba(0, 0, 0, 0.28));
  }

  .footer-address-block {
    margin-top: 16px;
    width: min(100%, 460px);
    padding: 18px 18px;
    display: grid;
    border-radius: 18px;
    border: 1px solid rgba(184, 226, 255, 0.1);
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.05),
      rgba(7, 18, 38, 0.16)
    );
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 10px 24px rgba(0, 0, 0, 0.14);
  }

  .footer-address-text {
    display: inline-block;
    margin: 0;
    font-size: 0.89rem;
    line-height: 1.68;
    color: rgba(231, 239, 255, 0.62);
    text-decoration: none;
    transition:
      color 0.28s ease,
      transform 0.28s ease;
  }

  .footer-address-text:hover {
    color: rgba(255, 255, 255, 0.9);
    transform: translateY(-1px);
  }

  .footer-address-text:focus-visible {
    outline: 2px solid rgba(176, 229, 255, 0.55);
    outline-offset: 3px;
    border-radius: 8px;
  }

  .footer-address-text strong {
    display: inline-block;
    margin-bottom: 6px;
    font-family: "Barlow Condensed", sans-serif;
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.88);
  }

  .footer-links-wrap {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: 20px;
    min-width: 0;
    align-items: start;
    padding-inline: 0;
    align-self: start;
  }

  .footer-col {
    min-width: 0;
  }

  .footer-col h4 {
    margin: 0 0 16px;
    font-family: "Barlow Condensed", sans-serif;
    font-weight: 700;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 2.4px;
    color: rgba(255, 255, 255, 0.94);
  }

  .footer-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .footer-links a {
    position: relative;
    display: inline-flex;
    align-items: center;
    width: fit-content;
    color: rgba(232, 240, 255, 0.58);
    text-decoration: none;
    font-size: 0.91rem;
    transition:
      color 0.28s ease,
      transform 0.28s ease;
  }

  .footer-links a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -3px;
    width: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(255, 255, 255, 0.68),
      rgba(150, 220, 255, 0.26),
      transparent
    );
    transition: width 0.28s ease;
  }

  .footer-links a:hover {
    color: rgba(255, 255, 255, 0.9);
    transform: translateX(2px);
  }

  .footer-links a:hover::after {
    width: 100%;
  }

  .footer-contact li {
    display: grid;
    grid-template-columns: 30px minmax(0, 1fr);
    align-items: start;
    column-gap: 14px;
    font-size: 0.91rem;
    line-height: 1.6;
    color: rgba(233, 241, 255, 0.58);
  }

  .footer-contact .ic {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    width: 30px;
    padding-top: 2px;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: rgba(122, 212, 255, 0.84);
  }

  .footer-contact a {
    word-break: break-word;
    line-height: 1.65;
  }

  .footer-social-col {
    min-width: 0;
    justify-self: start;
    padding-left: 4px;
  }

  .social-icons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    align-items: center;
    margin-top: 8px;
    justify-content: flex-start;
  }

  .social-icon {
    position: relative;
    flex: 0 0 auto;
    width: 46px;
    height: 46px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 15px;
    text-decoration: none;
    color: rgba(245, 249, 255, 0.9);
    border: 1px solid rgba(190, 225, 255, 0.1);
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.08) 0%,
      rgba(255, 255, 255, 0.03) 100%
    );
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      0 10px 22px rgba(0, 0, 0, 0.14);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition:
      transform 0.28s ease,
      border-color 0.28s ease,
      box-shadow 0.28s ease,
      color 0.28s ease;
  }

  .social-icon svg {
    width: 19px;
    height: 19px;
    transition: transform 0.28s ease;
  }

  .social-icon.whatsapp svg {
    width: 21px;
    height: 21px;
  }

  .social-icon:hover {
    transform: translateY(-3px);
    border-color: rgba(214, 239, 255, 0.18);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.14),
      0 16px 28px rgba(0, 0, 0, 0.2);
  }

  .social-icon:hover svg {
    transform: none;
  }

  .social-icon.facebook:hover {
    color: #7ec2ff;
  }

  .social-icon.instagram:hover {
    color: #ff8fd4;
  }

  .social-icon.whatsapp:hover {
    color: #7cf0a7;
  }

  .social-icon:focus-visible {
    outline: 2px solid rgba(176, 229, 255, 0.55);
    outline-offset: 3px;
  }

  .footer-divider {
    position: relative;
    z-index: 2;
    height: 1px;
    margin-bottom: 16px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(145, 219, 255, 0.08),
      rgba(255, 255, 255, 0.1),
      rgba(145, 219, 255, 0.08),
      transparent
    );
  }

  .footer-divider-mobile {
    display: none;
    margin: 18px 0 0;
  }

  .footer-bottom {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-size: 0.76rem;
    letter-spacing: 0.02em;
    color: rgba(235, 241, 255, 0.3);
  }

  .footer-recaptcha-note {
    position: relative;
    z-index: 2;
    margin: 14px 0 0;
    font-size: 0.72rem;
    line-height: 1.6;
    color: rgba(235, 241, 255, 0.42);
    text-align: center;
  }

  .footer-recaptcha-note a {
    color: rgba(196, 232, 255, 0.82);
    text-decoration: none;
  }

  .footer-recaptcha-note a:hover {
    color: rgba(255, 255, 255, 0.96);
    text-decoration: underline;
  }

  @media (max-width: 1100px) {
    footer {
      padding: 76px 32px 28px;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 26px;
    }

    .footer-brand {
      max-width: 100%;
      padding-right: 0;
    }

    .footer-links-wrap {
      grid-template-columns: 1fr 1fr;
      gap: 24px;
      padding-inline: 0;
    }

    .footer-social-col {
      text-align: center;
      justify-self: stretch;
      padding-left: 0;
    }

    .social-icons {
      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    footer {
      padding: 60px 20px 24px;
    }

    .footer-grid {
      grid-template-columns: 1fr;
      gap: 18px;
      margin-bottom: 24px;
    }

    .footer-brand {
      max-width: 100%;
      text-align: center;
    }

    .footer-logo-link {
      width: 100%;
      justify-content: center;
      margin-bottom: 0;
    }

    .footer-logo-image {
      height: 58px;
    }

    .footer-divider-mobile {
      display: block;
    }

    .footer-address-block {
      margin-top: 18px;
      width: min(100%, 560px);
      margin-inline: auto;
      text-align: center;
    }

    .footer-links-wrap {
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      align-items: start;
      padding-top: 0;
    }

    .footer-nav-col,
    .footer-contact-col {
      min-width: 0;
    }

    .footer-nav-col h4,
    .footer-contact-col h4 {
      margin-bottom: 14px;
      text-align: left;
    }

    .footer-links a {
      width: fit-content;
    }

    .footer-social-col,
    .footer-social-col h4 {
      text-align: center;
    }

    .social-icons {
      justify-content: center;
      gap: 12px;
      margin-top: 12px;
    }

    .social-icon {
      width: 44px;
      height: 44px;
      border-radius: 14px;
    }

    .social-icon svg {
      width: 18px;
      height: 18px;
    }

    .social-icon.whatsapp svg {
      width: 20px;
      height: 20px;
    }

    .footer-divider {
      margin-top: 6px;
      margin-bottom: 18px;
    }

    .footer-bottom {
      flex-direction: column;
      text-align: center;
      gap: 8px;
    }
  }

  @media (max-width: 520px) {
    footer {
      padding: 56px 16px 22px;
    }

    .footer-grid {
      gap: 16px;
      margin-bottom: 22px;
    }

    .footer-logo-image {
      height: 56px;
    }

    .footer-address-block {
      width: 100%;
      padding: 16px 16px;
      border-radius: 16px;
    }

    .footer-address-text {
      font-size: 0.84rem;
      line-height: 1.62;
    }

    .footer-links-wrap {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      gap: 14px;
      align-items: start;
    }

    .footer-col h4 {
      margin-bottom: 12px;
      font-size: 0.72rem;
      letter-spacing: 0.18em;
    }

    .footer-links {
      gap: 8px;
    }

    .footer-links a,
    .footer-contact li {
      font-size: 0.86rem;
    }

    .footer-contact li {
      grid-template-columns: 24px minmax(0, 1fr);
      column-gap: 10px;
    }

    .footer-contact .ic {
      width: 24px;
      font-size: 0.6rem;
      padding-top: 3px;
    }

    .footer-divider-mobile {
      margin-top: 16px;
    }

    .footer-divider {
      margin-top: 4px;
      margin-bottom: 16px;
    }
  }
</style>
