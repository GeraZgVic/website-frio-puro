---
import Container from "../ui/Container.astro";
---

<footer class="bg-[var(--color-primary)] text-[var(--color-white)]">
	<Container>
		<div class="grid gap-8 py-12 lg:grid-cols-3">
			<div class="space-y-4">
				<img
					src="/images/FrioPuroLogo.png"
					alt="Frío Puro"
					class="h-10 w-auto"
					loading="lazy"
				/>
				<p class="text-sm text-white/80">
					Suministro de hielo purificado para operaciones B2B que requieren puntualidad y confianza.
				</p>
			</div>
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/70">Navegacion</p>
				<ul class="mt-4 space-y-2 text-sm">
					<li><a href="#inicio" class="transition hover:text-white/80">Inicio</a></li>
					<li><a href="#nosotros" class="transition hover:text-white/80">Nosotros</a></li>
					<li><a href="#productos" class="transition hover:text-white/80">Productos</a></li>
					<li><a href="#puntos" class="transition hover:text-white/80">Puntos de venta</a></li>
					<li><a href="#contacto" class="transition hover:text-white/80">Contacto</a></li>
				</ul>
			</div>
			<div>
				<p class="text-xs font-semibold uppercase tracking-[0.2em] text-white/70">Contacto</p>
				<div class="mt-4 space-y-3 text-sm">
					<p class="text-white/85">WhatsApp: +52 55 0000 0000</p>
					<a href="#whatsapp" class="inline-flex items-center gap-2 rounded-full border border-white/30 px-4 py-2 text-sm font-semibold transition hover:bg-white/10">
						Escribir por WhatsApp
					</a>
				</div>
			</div>
		</div>
		<div class="border-t border-white/15 py-6 text-xs text-white/70">
			© 2026 Frío Puro. Todos los derechos reservados.
		</div>
	</Container>
</footer>
