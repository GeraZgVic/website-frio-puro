---
import { buildWhatsAppUrl, commercialContent } from "../../config/commercial";
---

<!-- CTA FINAL -->
<section id="contacto" style="padding: 0;">
  <div id="cta-final">
    <div class="cta-base"></div>
    <div class="cta-vignette"></div>
    <div class="cta-top-glow"></div>
    <div class="cta-bottom-glow"></div>
    <div class="cta-noise"></div>
    <div class="cta-beam cta-beam-1"></div>
    <div class="cta-beam cta-beam-2"></div>

    <div class="cta-shell">
      <div class="cta-content fade-in">
        <div class="cta-kicker">
          <span class="cta-kicker-dot"></span>
          <p>Cotización inmediata</p>
        </div>

        <h2 class="cta-title">
          Asegura el stock<br />
          <span>de tu negocio hoy</span>
        </h2>

        <p class="cta-copy">
          {commercialContent.microcopy.finalCtaBody}
        </p>

        <div class="cta-actions">
          <a
            href={buildWhatsAppUrl()}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-wapp-big"
            aria-label={`Enviar mensaje por WhatsApp al ${commercialContent.whatsappNumberRaw}`}
          >
            <span class="btn-wapp-glow"></span>
            <span class="btn-wapp-shine"></span>

            <span class="btn-wapp-content">
              <svg
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                <path
                  d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                ></path>
              </svg>

              <span class="btn-wapp-label">{commercialContent.ctas.finalPrimary}</span>
            </span>
          </a>
        </div>

        <div class="cta-meta">
          <span class="cta-phone">{commercialContent.whatsappNumberRaw}</span>
          <p class="cta-hours">{commercialContent.hours.long}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #cta-final {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background: linear-gradient(
      180deg,
      color-mix(in srgb, var(--color-primary) 88%, #050a1c 12%) 0%,
      color-mix(in srgb, var(--color-accent) 62%, #050a1c 38%) 54%,
      color-mix(in srgb, var(--color-primary) 92%, #050a1c 8%) 100%
    );
  }

  .cta-base,
  .cta-vignette,
  .cta-top-glow,
  .cta-bottom-glow,
  .cta-noise,
  .cta-beam {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .cta-base {
    z-index: 0;
    background:
      radial-gradient(
        circle at 50% 14%,
        rgba(255, 255, 255, 0.08) 0%,
        transparent 22%
      ),
      radial-gradient(
        circle at 50% 62%,
        rgba(255, 255, 255, 0.04) 0%,
        transparent 40%
      ),
      radial-gradient(
        circle at 50% 40%,
        rgba(4, 8, 22, 0.58) 0%,
        rgba(4, 8, 22, 0.22) 40%,
        transparent 70%
      ),
      linear-gradient(
        180deg,
        rgba(4, 8, 22, 0.85) 0%,
        rgba(4, 8, 22, 0.25) 35%,
        transparent 75%
      );
  }

  .cta-vignette {
    z-index: 0;
    background:
      radial-gradient(
        circle at 50% 50%,
        rgba(3, 7, 20, 0.18) 0%,
        transparent 36%,
        rgba(3, 7, 20, 0.45) 100%
      ),
      linear-gradient(
        90deg,
        rgba(4, 9, 24, 0.3) 0%,
        transparent 18%,
        transparent 82%,
        rgba(4, 9, 24, 0.3) 100%
      );
  }

  .cta-top-glow {
    z-index: 0;
    background: linear-gradient(
      180deg,
      rgba(2, 5, 16, 0.9) 0%,
      rgba(2, 5, 16, 0.55) 18%,
      rgba(2, 5, 16, 0.25) 34%,
      transparent 56%
    );
    mix-blend-mode: normal;
  }

  .cta-bottom-glow {
    z-index: 0;
    background: radial-gradient(
      ellipse at 50% 100%,
      rgba(255, 255, 255, 0.04) 0%,
      rgba(255, 255, 255, 0.015) 28%,
      transparent 64%
    );
  }

  .cta-noise {
    z-index: 0;
    opacity: 0.02;
    background-image:
      radial-gradient(
        circle at 20% 20%,
        rgba(255, 255, 255, 0.8) 0.6px,
        transparent 0.8px
      ),
      radial-gradient(
        circle at 80% 30%,
        rgba(255, 255, 255, 0.5) 0.6px,
        transparent 0.8px
      ),
      radial-gradient(
        circle at 35% 75%,
        rgba(255, 255, 255, 0.6) 0.6px,
        transparent 0.8px
      ),
      radial-gradient(
        circle at 70% 80%,
        rgba(255, 255, 255, 0.4) 0.6px,
        transparent 0.8px
      );
    background-size:
      180px 180px,
      220px 220px,
      200px 200px,
      240px 240px;
  }

  .cta-beam {
    z-index: 0;
    opacity: 0.04;
  }

  .cta-beam-1 {
    background: linear-gradient(
      112deg,
      transparent 0%,
      transparent 43%,
      rgba(255, 255, 255, 0.18) 50%,
      transparent 57%,
      transparent 100%
    );
    transform: translateX(-10%);
  }

  .cta-beam-2 {
    background: linear-gradient(
      248deg,
      transparent 0%,
      transparent 45%,
      rgba(255, 255, 255, 0.12) 50%,
      transparent 55%,
      transparent 100%
    );
    transform: translateX(10%);
  }

  .cta-shell {
    position: relative;
    z-index: 2;
    width: min(100%, 1440px);
    margin: 0 auto;
    padding: 92px 28px 86px;
  }

  .cta-content {
    max-width: 720px;
    margin: 0 auto;
    text-align: center;
  }

  .cta-kicker {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-bottom: 20px;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.22);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.36),
      0 8px 24px rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .cta-kicker-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 0 14px rgba(255, 255, 255, 0.6);
    flex: 0 0 auto;
  }

  .cta-kicker p {
    margin: 0;
    color: rgba(255, 255, 255, 0.86);
    font-family: "Barlow", sans-serif;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .cta-title {
    margin: 0;
    color: var(--color-white);
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(2.8rem, 5vw, 5rem);
    font-weight: 800;
    line-height: 0.9;
    letter-spacing: -0.045em;
    text-transform: uppercase;
    text-wrap: balance;
    text-shadow:
      0 18px 44px rgba(2, 6, 18, 0.72),
      0 4px 12px rgba(2, 6, 18, 0.45);
  }

  .cta-title span {
    color: #d2ecff;
    text-shadow:
      0 14px 34px rgba(2, 6, 18, 0.6),
      0 0 16px rgba(65, 171, 226, 0.16);
  }

  .cta-copy {
    max-width: 580px;
    margin: 20px auto 0;
    color: rgba(240, 248, 255, 0.9);
    font-family: "Barlow", sans-serif;
    font-size: clamp(0.96rem, 1.15vw, 1.02rem);
    line-height: 1.62;
    text-wrap: pretty;
    text-shadow: 0 2px 10px rgba(10, 22, 56, 0.06);
  }

  .cta-actions {
    margin-top: 28px;
    display: flex;
    justify-content: center;
  }

  .btn-wapp-big {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 13px;
    width: auto;
    min-height: 60px;
    padding: 17px 28px;
    border-radius: 999px;
    background: linear-gradient(180deg, #6cf7a8 0%, #3fe081 52%, #23bf66 100%);
    color: #f7fffb;
    text-decoration: none;
    font-family: "Barlow", sans-serif;
    font-size: 0.92rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.11em;
    overflow: hidden;
    transform: translateZ(0);
    border: 1px solid rgba(255, 255, 255, 0.24);
    box-shadow:
      0 26px 60px rgba(8, 22, 34, 0.34),
      0 12px 28px rgba(37, 211, 102, 0.3),
      inset 0 1px 0 rgba(255, 255, 255, 0.6),
      inset 0 -3px 0 rgba(0, 0, 0, 0.2);
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease,
      filter 0.35s ease;
  }

  .btn-wapp-big::before {
    content: "";
    position: absolute;
    inset: -6px;
    border-radius: inherit;
    background: radial-gradient(
      circle,
      rgba(37, 211, 102, 0.45) 0%,
      rgba(37, 211, 102, 0) 74%
    );
    opacity: 0.12;
    animation: wapp-pulse 2.25s ease-in-out infinite;
    pointer-events: none;
  }

  .btn-wapp-big::after {
    content: "";
    position: absolute;
    inset: 1px;
    border-radius: inherit;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.46) 0%,
      rgba(255, 255, 255, 0.14) 50%,
      rgba(255, 255, 255, 0.02) 100%
    );
    pointer-events: none;
  }

  .btn-wapp-glow {
    position: absolute;
    inset: auto 16% -68% 16%;
    height: 100%;
    background: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.24) 0%,
      transparent 70%
    );
    filter: blur(18px);
    opacity: 0.3;
    pointer-events: none;
    z-index: 0;
  }

  .btn-wapp-shine {
    position: absolute;
    top: 0;
    left: -30%;
    width: 28%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.32) 50%,
      transparent 100%
    );
    transform: skewX(-22deg);
    animation: wapp-shine 4.8s ease-in-out infinite;
    z-index: 1;
    pointer-events: none;
  }

  .btn-wapp-content {
    position: relative;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
  }

  .btn-wapp-content svg {
    width: 21px;
    height: 21px;
    fill: currentColor;
    flex: 0 0 auto;
    display: block;
  }

  .btn-wapp-label {
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }

  .btn-wapp-big:hover {
    transform: translateY(-2px) scale(1.008);
    box-shadow:
      0 34px 72px rgba(8, 22, 34, 0.38),
      0 18px 38px rgba(37, 211, 102, 0.34),
      inset 0 1px 0 rgba(255, 255, 255, 0.68),
      inset 0 -2px 0 rgba(0, 0, 0, 0.16);
    filter: saturate(1.06);
  }

  .btn-wapp-big:active {
    transform: translateY(0) scale(0.995);
  }

  .cta-meta {
    margin-top: 22px;
  }

  .cta-phone {
    display: block;
    margin: 0;
    color: var(--color-white);
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(1.7rem, 3.2vw, 2.35rem);
    font-weight: 700;
    letter-spacing: 0.04em;
    line-height: 1;
    text-shadow: 0 4px 12px rgba(255, 255, 255, 0.06);
  }

  .cta-hours {
    margin: 9px 0 0;
    color: rgba(255, 255, 255, 0.72);
    font-family: "Barlow", sans-serif;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  @keyframes wapp-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 0.22;
    }
    50% {
      transform: scale(1.08);
      opacity: 0;
    }
  }

  @keyframes wapp-shine {
    0% {
      transform: translateX(0) skewX(-22deg);
      opacity: 0;
    }
    10% {
      opacity: 0.76;
    }
    30% {
      transform: translateX(430%) skewX(-22deg);
      opacity: 0;
    }
    100% {
      transform: translateX(430%) skewX(-22deg);
      opacity: 0;
    }
  }

  @media (max-width: 991px) {
    .cta-shell {
      padding: 84px 22px 80px;
    }
  }

  @media (max-width: 768px) {
    .cta-shell {
      padding: 74px 16px 72px;
    }

    .cta-content {
      max-width: 100%;
    }

    .cta-kicker {
      margin-bottom: 16px;
      padding: 8px 13px;
    }

    .cta-title {
      font-size: clamp(2.45rem, 11vw, 4rem);
      line-height: 0.93;
      letter-spacing: -0.035em;
    }

    .cta-copy {
      margin-top: 16px;
      font-size: 0.94rem;
      line-height: 1.6;
      max-width: 100%;
    }

    .cta-actions {
      margin-top: 24px;
      padding-inline: 0;
    }

    .btn-wapp-big {
      width: min(100%, 340px);
      max-width: 100%;
      min-height: 58px;
      padding: 16px 20px;
      gap: 12px;
      font-size: 0.86rem;
      letter-spacing: 0.09em;
    }

    .btn-wapp-big svg {
      width: 20px;
      height: 20px;
    }

    .cta-meta {
      margin-top: 20px;
    }

    .cta-phone {
      font-size: clamp(1.5rem, 7.6vw, 2rem);
      letter-spacing: 0.03em;
    }

    .cta-hours {
      font-size: 0.68rem;
      letter-spacing: 0.11em;
    }
  }

  @media (max-width: 480px) {
    .cta-shell {
      padding: 68px 14px 66px;
    }

    .cta-title {
      font-size: clamp(2.2rem, 10.5vw, 3.3rem);
    }

    .btn-wapp-big {
      width: min(100%, 320px);
      min-height: 56px;
      padding: 15px 18px;
      font-size: 0.82rem;
      letter-spacing: 0.08em;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .btn-wapp-big,
    .btn-wapp-big::before,
    .btn-wapp-shine {
      animation: none !important;
      transition: none !important;
    }
  }
</style>
