---
import Section from "../ui/Section.astro";
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Button from "../ui/Button.astro";
---

<Section className="bg-gradient-to-br from-[var(--color-primary)] to-[var(--color-accent)] text-[var(--color-white)]">
	<Container>
		<div class="text-center">
			<Heading as="h2" className="text-[var(--color-white)]">
				Suministro de hielo confiable para tu negocio
			</Heading>
			<p class="mt-4 text-sm sm:text-base text-white/90">
				Atención inmediata por WhatsApp. Entregas disponibles todos los días.
			</p>
			<div class="mt-8 flex justify-center">
				<Button href="#whatsapp" className="bg-[var(--color-white)] text-[var(--color-primary)] hover:opacity-90 px-8 py-4 text-base">
					Escribir por WhatsApp
				</Button>
			</div>
		</div>
	</Container>
</Section>
