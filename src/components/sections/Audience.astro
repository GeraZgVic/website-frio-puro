---
// Nosotros Section — Liquid Glass Ultra Premium v3 Optimized
---

<!-- NOSOTROS -->
<section id="nosotros" class="audience-section">
  <canvas id="audience-particles-canvas"></canvas>

  <div class="bg-orb bg-orb-1"></div>
  <div class="bg-orb bg-orb-2"></div>
  <div class="bg-orb bg-orb-3"></div>

  <div class="glass-blob glass-blob-1"></div>
  <div class="glass-blob glass-blob-2"></div>
  <div class="glass-blob glass-blob-3"></div>
  <div class="glass-blob glass-blob-4"></div>

  <div class="volumetric-light vl-1"></div>
  <div class="volumetric-light vl-2"></div>
  <div class="volumetric-light vl-3"></div>

  <div class="audience-ambient audience-ambient-1"></div>
  <div class="audience-ambient audience-ambient-2"></div>
  <div class="audience-noise"></div>
  <div class="audience-grid-overlay"></div>
  <div class="scan-lines"></div>

  <div class="container audience-container">
    <div class="audience-header fade-in">
      <div class="audience-header-main">
        <h2
          class="section-title audience-title word-reveal"
          style="color: var(--color-primary);"
        >
          <span>Servimos&nbsp;a</span><br /><span>Toda&nbsp;la</span>&nbsp;<span
            >Industria</span
          >

          <span class="title-bar"></span>
        </h2>
        <p class="section-subtitle audience-subtitle">
          Desde pequeños negocios hasta grandes cadenas, entregamos hielo con la
          calidad, consistencia y capacidad operativa que cada cliente necesita.
        </p>
      </div>
    </div>

    <div class="clients-grid" data-audience-grid>
      <article class="client-card fade-in fade-in-delay-1" data-premium-card>
        <div class="glass-surface"></div>
        <div class="glass-highlight"></div>
        <div class="glass-depth"></div>
        <div class="liquid-glass-layer"></div>
        <div class="liquid-refraction"></div>
        <div class="card-caustics"></div>
        <div class="client-card-border"></div>
        <div class="card-ring"></div>
        <div class="prism-light"></div>
        <div class="bottom-reflection"></div>
        <div class="ice-edge ice-edge-top"></div>
        <div class="ice-edge ice-edge-left"></div>

        <div class="client-card-inner">
          <div class="client-card-top">
            <div class="client-icon-wrap">
              <div class="icon-glass-bg"></div>
              <div class="icon-glow-ring"></div>
              <span class="card-icon">🍽️</span>
            </div>
            <span class="client-card-chip">
              <span class="chip-dot"></span>
              Servicio continuo
            </span>
          </div>

          <h3>Restaurantes</h3>
          <p>
            Hielo ideal para bebidas, conservación de alimentos y presentaciones
            gourmet con entregas puntuales y operación constante.
          </p>

          <div class="client-card-footer">
            <span class="client-card-line"></span>
            <span class="client-card-note">Calidad para operación diaria</span>
            <span class="footer-arrow">→</span>
          </div>
        </div>
      </article>

      <article class="client-card fade-in fade-in-delay-2" data-premium-card>
        <div class="glass-surface"></div>
        <div class="glass-highlight"></div>
        <div class="glass-depth"></div>
        <div class="liquid-glass-layer"></div>
        <div class="liquid-refraction"></div>
        <div class="card-caustics"></div>
        <div class="client-card-border"></div>
        <div class="card-ring"></div>
        <div class="prism-light"></div>
        <div class="bottom-reflection"></div>
        <div class="ice-edge ice-edge-top"></div>
        <div class="ice-edge ice-edge-left"></div>

        <div class="client-card-inner">
          <div class="client-card-top">
            <div class="client-icon-wrap">
              <div class="icon-glass-bg"></div>
              <div class="icon-glow-ring"></div>
              <span class="card-icon">🍸</span>
            </div>
            <span class="client-card-chip">
              <span class="chip-dot"></span>
              Entrega flexible
            </span>
          </div>

          <h3>Bares & Cantinas</h3>
          <p>
            Cubos perfectos para cócteles y tragos con suministro confiable y
            entregas adaptadas al ritmo operativo nocturno.
          </p>

          <div class="client-card-footer">
            <span class="client-card-line"></span>
            <span class="client-card-note"
              >Cobertura para horarios extendidos</span
            >
            <span class="footer-arrow">→</span>
          </div>
        </div>
      </article>

      <article class="client-card fade-in fade-in-delay-3" data-premium-card>
        <div class="glass-surface"></div>
        <div class="glass-highlight"></div>
        <div class="glass-depth"></div>
        <div class="liquid-glass-layer"></div>
        <div class="liquid-refraction"></div>
        <div class="card-caustics"></div>
        <div class="client-card-border"></div>
        <div class="card-ring"></div>
        <div class="prism-light"></div>
        <div class="bottom-reflection"></div>
        <div class="ice-edge ice-edge-top"></div>
        <div class="ice-edge ice-edge-left"></div>

        <div class="client-card-inner">
          <div class="client-card-top">
            <div class="client-icon-wrap">
              <div class="icon-glass-bg"></div>
              <div class="icon-glow-ring"></div>
              <span class="card-icon">🎉</span>
            </div>
            <span class="client-card-chip">
              <span class="chip-dot"></span>
              Alto volumen
            </span>
          </div>

          <h3>Eventos</h3>
          <p>
            Soluciones para bodas, fiestas corporativas y celebraciones con
            atención por volumen, logística ágil y respuesta rápida.
          </p>

          <div class="client-card-footer">
            <span class="client-card-line"></span>
            <span class="client-card-note">Escalable según demanda</span>
            <span class="footer-arrow">→</span>
          </div>
        </div>
      </article>

      <article class="client-card fade-in fade-in-delay-4" data-premium-card>
        <div class="glass-surface"></div>
        <div class="glass-highlight"></div>
        <div class="glass-depth"></div>
        <div class="liquid-glass-layer"></div>
        <div class="liquid-refraction"></div>
        <div class="card-caustics"></div>
        <div class="client-card-border"></div>
        <div class="card-ring"></div>
        <div class="prism-light"></div>
        <div class="bottom-reflection"></div>
        <div class="ice-edge ice-edge-top"></div>
        <div class="ice-edge ice-edge-left"></div>

        <div class="client-card-inner">
          <div class="client-card-top">
            <div class="client-icon-wrap">
              <div class="icon-glass-bg"></div>
              <div class="icon-glow-ring"></div>
              <span class="card-icon">🏪</span>
            </div>
            <span class="client-card-chip">
              <span class="chip-dot"></span>
              Abasto regular
            </span>
          </div>

          <h3>Tiendas & Minisupers</h3>
          <p>
            Abastecimiento regular y confiable para puntos de venta que
            requieren continuidad operativa y reposición constante.
          </p>

          <div class="client-card-footer">
            <span class="client-card-line"></span>
            <span class="client-card-note">Reposición pensada para retail</span>
            <span class="footer-arrow">→</span>
          </div>
        </div>
      </article>

      <article class="client-card fade-in fade-in-delay-5" data-premium-card>
        <div class="glass-surface"></div>
        <div class="glass-highlight"></div>
        <div class="glass-depth"></div>
        <div class="liquid-glass-layer"></div>
        <div class="liquid-refraction"></div>
        <div class="card-caustics"></div>
        <div class="client-card-border"></div>
        <div class="card-ring"></div>
        <div class="prism-light"></div>
        <div class="bottom-reflection"></div>
        <div class="ice-edge ice-edge-top"></div>
        <div class="ice-edge ice-edge-left"></div>

        <div class="client-card-inner">
          <div class="client-card-top">
            <div class="client-icon-wrap">
              <div class="icon-glass-bg"></div>
              <div class="icon-glow-ring"></div>
              <span class="card-icon">🏨</span>
            </div>
            <span class="client-card-chip">
              <span class="chip-dot"></span>
              Cobertura premium
            </span>
          </div>

          <h3>Hoteles</h3>
          <p>
            Suministro continuo para room service, restaurantes, bares y eventos
            dentro de sus instalaciones con servicio de alto estándar.
          </p>

          <div class="client-card-footer">
            <span class="client-card-line"></span>
            <span class="client-card-note"
              >Operación orientada a hospitalidad</span
            >
            <span class="footer-arrow">→</span>
          </div>
        </div>
      </article>

      <article class="client-card fade-in fade-in-delay-6" data-premium-card>
        <div class="glass-surface"></div>
        <div class="glass-highlight"></div>
        <div class="glass-depth"></div>
        <div class="liquid-glass-layer"></div>
        <div class="liquid-refraction"></div>
        <div class="card-caustics"></div>
        <div class="client-card-border"></div>
        <div class="card-ring"></div>
        <div class="prism-light"></div>
        <div class="bottom-reflection"></div>
        <div class="ice-edge ice-edge-top"></div>
        <div class="ice-edge ice-edge-left"></div>

        <div class="client-card-inner">
          <div class="client-card-top">
            <div class="client-icon-wrap">
              <div class="icon-glass-bg"></div>
              <div class="icon-glow-ring"></div>
              <span class="card-icon">🐟</span>
            </div>
            <span class="client-card-chip">
              <span class="chip-dot"></span>
              Conservación eficaz
            </span>
          </div>

          <h3>Pescaderías</h3>
          <p>
            Hielo en alto volumen para conservación eficiente de mariscos y
            productos frescos durante toda la jornada.
          </p>

          <div class="client-card-footer">
            <span class="client-card-line"></span>
            <span class="client-card-note">Soporte para cadena de frío</span>
            <span class="footer-arrow">→</span>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  :root {
    --mouse-x: 50%;
    --mouse-y: 50%;
  }

  #audience-particles-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    opacity: 0.42;
  }

  .volumetric-light {
    position: absolute;
    pointer-events: none;
    z-index: 1;
    border-radius: 999px;
    will-change: transform, opacity;
  }

  .vl-1 {
    top: -10%;
    left: 15%;
    width: 2px;
    height: 56%;
    background: linear-gradient(
      180deg,
      rgba(157, 212, 242, 0.26) 0%,
      rgba(65, 171, 226, 0.08) 50%,
      transparent 100%
    );
    filter: blur(6px);
    transform: rotate(-15deg);
    animation: vlDrift1 14s ease-in-out infinite;
  }

  .vl-2 {
    top: -5%;
    right: 25%;
    width: 1px;
    height: 42%;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.35) 0%,
      rgba(157, 212, 242, 0.12) 60%,
      transparent 100%
    );
    filter: blur(4px);
    transform: rotate(8deg);
    animation: vlDrift2 18s ease-in-out infinite;
  }

  .vl-3 {
    top: -8%;
    left: 55%;
    width: 1px;
    height: 34%;
    background: linear-gradient(
      180deg,
      rgba(65, 171, 226, 0.26) 0%,
      rgba(50, 59, 129, 0.06) 55%,
      transparent 100%
    );
    filter: blur(7px);
    transform: rotate(-5deg);
    animation: vlDrift3 22s ease-in-out infinite;
  }

  @keyframes vlDrift1 {
    0%,
    100% {
      opacity: 0.45;
      transform: rotate(-15deg) translateX(0);
    }
    50% {
      opacity: 0.8;
      transform: rotate(-12deg) translateX(8px);
    }
  }
  @keyframes vlDrift2 {
    0%,
    100% {
      opacity: 0.35;
      transform: rotate(8deg);
    }
    50% {
      opacity: 0.65;
      transform: rotate(10deg) translateX(-6px);
    }
  }
  @keyframes vlDrift3 {
    0%,
    100% {
      opacity: 0.4;
      transform: rotate(-5deg);
    }
    50% {
      opacity: 0.7;
      transform: rotate(-3deg) translateX(4px);
    }
  }

  .glass-blob {
    position: absolute;
    border-radius: 999px;
    pointer-events: none;
    z-index: 1;
    filter: blur(64px);
    will-change: transform;
    opacity: 0.78;
  }

  .glass-blob-1 {
    top: 30%;
    left: 5%;
    width: 320px;
    height: 240px;
    background: radial-gradient(
      ellipse,
      rgba(65, 171, 226, 0.2),
      transparent 70%
    );
    animation: blobDrift1 24s ease-in-out infinite;
  }

  .glass-blob-2 {
    top: 15%;
    right: 8%;
    width: 280px;
    height: 280px;
    background: radial-gradient(
      ellipse,
      rgba(50, 59, 129, 0.14),
      transparent 70%
    );
    animation: blobDrift2 28s ease-in-out infinite;
  }

  .glass-blob-3 {
    bottom: 10%;
    left: 30%;
    width: 420px;
    height: 220px;
    background: radial-gradient(
      ellipse,
      rgba(157, 212, 242, 0.16),
      transparent 70%
    );
    animation: blobDrift3 22s ease-in-out infinite;
  }

  .glass-blob-4 {
    top: 55%;
    right: 20%;
    width: 220px;
    height: 220px;
    background: radial-gradient(
      ellipse,
      rgba(65, 171, 226, 0.12),
      transparent 70%
    );
    animation: blobDrift4 26s ease-in-out infinite;
  }

  @keyframes blobDrift1 {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    33% {
      transform: translate3d(28px, -18px, 0) scale(1.04);
    }
    66% {
      transform: translate3d(-16px, 16px, 0) scale(0.98);
    }
  }
  @keyframes blobDrift2 {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    40% {
      transform: translate3d(-32px, 28px, 0) scale(1.05);
    }
    70% {
      transform: translate3d(14px, -14px, 0) scale(0.97);
    }
  }
  @keyframes blobDrift3 {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(18px, -22px, 0) scale(1.05);
    }
  }
  @keyframes blobDrift4 {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(-18px, 18px, 0) scale(1.04);
    }
  }

  .bg-orb {
    position: absolute;
    border-radius: 999px;
    pointer-events: none;
    z-index: 0;
    filter: blur(80px);
    opacity: 0.9;
  }
  .bg-orb-1 {
    top: -80px;
    left: -100px;
    width: 360px;
    height: 360px;
    background: radial-gradient(
      circle,
      rgba(65, 171, 226, 0.14),
      transparent 70%
    );
    animation: orbFloat1 18s ease-in-out infinite;
  }
  .bg-orb-2 {
    bottom: -100px;
    right: -80px;
    width: 400px;
    height: 400px;
    background: radial-gradient(
      circle,
      rgba(50, 59, 129, 0.1),
      transparent 70%
    );
    animation: orbFloat2 22s ease-in-out infinite;
  }
  .bg-orb-3 {
    top: 50%;
    left: 50%;
    transform: translate3d(-50%, -50%, 0);
    width: 620px;
    height: 460px;
    background: radial-gradient(
      ellipse,
      rgba(157, 212, 242, 0.05),
      transparent 65%
    );
    animation: orbFloat3 28s ease-in-out infinite;
  }

  @keyframes orbFloat1 {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(22px, 28px, 0);
    }
  }
  @keyframes orbFloat2 {
    0%,
    100% {
      transform: translate3d(0, 0, 0);
    }
    50% {
      transform: translate3d(-28px, -20px, 0);
    }
  }
  @keyframes orbFloat3 {
    0%,
    100% {
      transform: translate3d(-50%, -50%, 0) scale(1);
    }
    50% {
      transform: translate3d(-50%, -50%, 0) scale(1.05);
    }
  }

  .scan-lines {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: repeating-linear-gradient(
      0deg,
      transparent,
      transparent 4px,
      rgba(65, 171, 226, 0.01) 4px,
      rgba(65, 171, 226, 0.01) 5px
    );
    opacity: 0.38;
  }

  .audience-section {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    background:
      radial-gradient(
        circle at 10% 18%,
        rgba(65, 171, 226, 0.12) 0%,
        transparent 28%
      ),
      radial-gradient(
        circle at 88% 84%,
        rgba(50, 59, 129, 0.08) 0%,
        transparent 24%
      ),
      linear-gradient(180deg, #eef6fb 0%, #f7fbfe 40%, #ffffff 100%);
  }

  .audience-ambient,
  .audience-noise,
  .audience-grid-overlay {
    pointer-events: none;
    position: absolute;
  }

  .audience-ambient {
    border-radius: 999px;
    filter: blur(88px);
    z-index: 0;
  }

  .audience-ambient-1 {
    top: -120px;
    left: -140px;
    width: 340px;
    height: 340px;
    background: rgba(65, 171, 226, 0.1);
  }

  .audience-ambient-2 {
    right: -140px;
    bottom: -140px;
    width: 360px;
    height: 360px;
    background: rgba(50, 59, 129, 0.07);
  }

  .audience-noise {
    inset: 0;
    z-index: 0;
    opacity: 0.03;
    background-image:
      radial-gradient(circle at 20% 20%, #ffffff 0.6px, transparent 0.8px),
      radial-gradient(circle at 80% 30%, #ffffff 0.6px, transparent 0.8px),
      radial-gradient(circle at 50% 75%, #ffffff 0.6px, transparent 0.8px);
    background-size:
      24px 24px,
      30px 30px,
      22px 22px;
  }

  .audience-grid-overlay {
    inset: 0;
    z-index: 0;
    opacity: 0.14;
    background-image:
      linear-gradient(rgba(65, 171, 226, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(65, 171, 226, 0.05) 1px, transparent 1px);
    background-size: 110px 110px;
    mask-image: radial-gradient(circle at center, black 42%, transparent 88%);
    -webkit-mask-image: radial-gradient(
      circle at center,
      black 42%,
      transparent 88%
    );
  }

  .audience-container {
    position: relative;
    z-index: 2;
  }

  .audience-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px;
    align-items: end;
    justify-items: center;
    text-align: center;
    margin-bottom: 56px;
    opacity: 0;
    animation: headerReveal 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
  }

  @keyframes headerReveal {
    from {
      opacity: 0;
      transform: translate3d(0, 32px, 0);
    }
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  .audience-header-main {
    max-width: 780px;
    text-align: center;
  }

  .audience-kicker {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 44px;
    margin-bottom: 18px;
    padding: 10px 16px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.78);
    border: 1px solid rgba(65, 171, 226, 0.14);
    backdrop-filter: blur(10px);
    box-shadow:
      0 12px 28px rgba(50, 59, 129, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.86);
    position: relative;
  }

  .audience-kicker-dot {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 6px rgba(65, 171, 226, 0.12);
    flex-shrink: 0;
    animation: dotPulse 2.6s ease-in-out infinite;
    position: relative;
    z-index: 1;
  }

  .audience-kicker-ring {
    position: absolute;
    left: 16px;
    width: 22px;
    height: 22px;
    border-radius: 999px;
    border: 1px solid rgba(65, 171, 226, 0.28);
    animation: ringExpand 2.6s ease-in-out infinite;
    pointer-events: none;
  }

  @keyframes ringExpand {
    0% {
      transform: scale(0.6);
      opacity: 0.7;
    }
    100% {
      transform: scale(1.65);
      opacity: 0;
    }
  }

  @keyframes dotPulse {
    0%,
    100% {
      box-shadow: 0 0 0 6px rgba(65, 171, 226, 0.16);
    }
    50% {
      box-shadow: 0 0 0 10px rgba(65, 171, 226, 0.05);
    }
  }

  .audience-kicker .section-label {
    margin-bottom: 0;
    letter-spacing: 3px;
  }

  .audience-title {
    margin-bottom: 0;
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    line-height: 0.92;
    letter-spacing: -1.4px;
    text-shadow: 0 12px 26px rgba(50, 59, 129, 0.05);
    position: relative;
  }

  .title-bar {
    display: block;
    height: 5px;
    width: 0;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      var(--color-primary),
      var(--color-accent),
      #9dd4f2
    );
    margin: 18px auto 0;
    animation: barGrow 1s cubic-bezier(0.22, 1, 0.36, 1) 0.75s forwards;
  }

  @keyframes barGrow {
    to {
      width: 100px;
    }
  }

  .word-reveal span {
    display: inline-block;
    opacity: 0;
    transform: translate3d(0, 22px, 0) skewX(-3deg);
    animation: wordIn 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  .word-reveal span:nth-child(1) {
    animation-delay: 0.28s;
  }
  .word-reveal span:nth-child(2) {
    animation-delay: 0.42s;
  }
  .word-reveal span:nth-child(3) {
    animation-delay: 0.56s;
  }

  @keyframes wordIn {
    to {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }
  }

  .audience-header-side {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .audience-subtitle {
    max-width: 520px;
    margin: 0 auto;
    font-size: 1.02rem;
    line-height: 1.9;
    color: rgba(50, 59, 129, 0.78);
  }

  .audience-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .audience-metric {
    min-width: 132px;
    padding: 14px 16px;
    border-radius: 20px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.82) 0%,
      rgba(255, 255, 255, 0.62) 100%
    );
    border: 1px solid rgba(65, 171, 226, 0.12);
    box-shadow:
      0 12px 28px rgba(50, 59, 129, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.86);
    backdrop-filter: blur(10px);
    position: relative;
    overflow: hidden;
    transition:
      transform 0.22s ease-out,
      box-shadow 0.24s ease-out;
    will-change: transform;
  }

  .metric-glow {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(
      ellipse at 50% 0%,
      rgba(65, 171, 226, 0.12) 0%,
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.28s ease-out;
    pointer-events: none;
  }

  .audience-metric:hover .metric-glow {
    opacity: 1;
  }

  .audience-metric::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(
      90deg,
      var(--color-primary),
      var(--color-accent)
    );
    border-radius: 999px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .audience-metric:hover {
    transform: translate3d(0, -3px, 0);
    box-shadow:
      0 18px 38px rgba(50, 59, 129, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.94);
  }

  .audience-metric:hover::before {
    transform: scaleX(1);
  }

  .audience-metric-value {
    display: block;
    font-family: "Barlow Condensed", sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.4px;
    color: var(--color-primary);
    text-transform: uppercase;
    position: relative;
    z-index: 1;
  }

  .audience-metric-label {
    display: block;
    margin-top: 6px;
    font-size: 0.76rem;
    line-height: 1.45;
    text-transform: uppercase;
    letter-spacing: 1.1px;
    color: rgba(50, 59, 129, 0.62);
    position: relative;
    z-index: 1;
  }

  .clients-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 24px;
  }

  .client-card {
    --card-tilt-x: 0deg;
    --card-tilt-y: 0deg;
    --card-shift-y: 0px;
    --card-scale: 1;
    --glass-x: 50%;
    --glass-y: 50%;
    --depth-x: 18%;
    --depth-y: 12%;
    --depth-x2: 82%;
    --depth-y2: 88%;

    position: relative;
    min-height: 100%;
    border-radius: 30px;
    overflow: hidden;
    transform-style: preserve-3d;
    transition:
      transform 0.22s ease-out,
      box-shadow 0.26s ease-out,
      border-color 0.24s ease-out;

    perspective: 1400px;
    transform: translate3d(0, var(--card-shift-y), 0) scale(var(--card-scale));

    background: linear-gradient(
      160deg,
      rgba(255, 255, 255, 0.78) 0%,
      rgba(240, 250, 255, 0.62) 35%,
      rgba(220, 242, 254, 0.48) 65%,
      rgba(255, 255, 255, 0.55) 100%
    );

    border: 1px solid rgba(255, 255, 255, 0.76);

    box-shadow:
      0 12px 34px rgba(50, 59, 129, 0.09),
      0 4px 14px rgba(65, 171, 226, 0.06),
      0 24px 48px rgba(50, 59, 129, 0.05),
      inset 0 1px 0 rgba(255, 255, 255, 0.96),
      inset 0 -1px 0 rgba(65, 171, 226, 0.06),
      inset 1px 0 0 rgba(255, 255, 255, 0.5),
      inset -1px 0 0 rgba(65, 171, 226, 0.04);

    backdrop-filter: blur(18px) saturate(1.35) brightness(1.02);
    -webkit-backdrop-filter: blur(18px) saturate(1.35) brightness(1.02);

    isolation: isolate;
    opacity: 0;
    will-change: transform;
  }

  .glass-surface {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    z-index: 0;
    pointer-events: none;
    background: linear-gradient(
      145deg,
      rgba(255, 255, 255, 0.1) 0%,
      rgba(255, 255, 255, 0.03) 50%,
      rgba(157, 212, 242, 0.04) 100%
    );
    opacity: 1;
  }

  .glass-highlight {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 55%;
    border-radius: inherit;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      165deg,
      rgba(255, 255, 255, 0.58) 0%,
      rgba(255, 255, 255, 0.18) 22%,
      rgba(255, 255, 255, 0.04) 45%,
      transparent 60%
    );
    mask-image: linear-gradient(180deg, black 0%, transparent 100%);
    -webkit-mask-image: linear-gradient(180deg, black 0%, transparent 100%);
    transition: opacity 0.24s ease-out;
  }

  .glass-depth {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(
        ellipse 80% 60% at var(--depth-x) var(--depth-y),
        rgba(200, 234, 250, 0.22) 0%,
        transparent 65%
      ),
      radial-gradient(
        ellipse 60% 70% at var(--depth-x2) var(--depth-y2),
        rgba(65, 171, 226, 0.1) 0%,
        transparent 60%
      ),
      radial-gradient(
        ellipse 50% 40% at 50% 50%,
        rgba(157, 212, 242, 0.06) 0%,
        transparent 70%
      );
    transition: background 0.12s linear;
  }

  .liquid-glass-layer {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    z-index: 2;
    pointer-events: none;
    background:
      radial-gradient(
        ellipse 180px 120px at var(--glass-x) var(--glass-y),
        rgba(255, 255, 255, 0.32) 0%,
        rgba(255, 255, 255, 0.08) 40%,
        transparent 70%
      ),
      linear-gradient(
        160deg,
        rgba(255, 255, 255, 0.34) 0%,
        rgba(255, 255, 255, 0.05) 35%,
        transparent 60%
      ),
      radial-gradient(
        ellipse at 20% 10%,
        rgba(157, 212, 242, 0.16) 0%,
        transparent 60%
      ),
      radial-gradient(
        ellipse at 80% 90%,
        rgba(65, 171, 226, 0.08) 0%,
        transparent 55%
      );
    opacity: 0.9;
    transition: opacity 0.2s ease-out;
  }

  .liquid-refraction {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    z-index: 1;
    pointer-events: none;
    background: conic-gradient(
      from 180deg at 50% 0%,
      rgba(255, 255, 255, 0.08) 0deg,
      rgba(157, 212, 242, 0.06) 60deg,
      rgba(65, 171, 226, 0.04) 120deg,
      rgba(50, 59, 129, 0.03) 180deg,
      rgba(255, 255, 255, 0.08) 240deg,
      rgba(157, 212, 242, 0.05) 300deg,
      rgba(255, 255, 255, 0.08) 360deg
    );
    opacity: 0.42;
    animation: refractionShift 10s linear infinite;
  }

  @keyframes refractionShift {
    0% {
      transform: rotate(0deg) scale(1);
    }
    50% {
      transform: rotate(2deg) scale(1.01);
    }
    100% {
      transform: rotate(0deg) scale(1);
    }
  }

  .card-caustics {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    z-index: 2;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.24s ease-out;
    background:
      radial-gradient(
        ellipse 70px 45px at 18% 14%,
        rgba(255, 255, 255, 0.4) 0%,
        transparent 70%
      ),
      radial-gradient(
        ellipse 45px 35px at 72% 22%,
        rgba(157, 212, 242, 0.26) 0%,
        transparent 70%
      ),
      radial-gradient(
        ellipse 55px 40px at 48% 68%,
        rgba(255, 255, 255, 0.24) 0%,
        transparent 70%
      );
  }

  .prism-light {
    position: absolute;
    top: -20%;
    left: -10%;
    width: 50%;
    height: 180%;
    background: linear-gradient(
      105deg,
      transparent 38%,
      rgba(255, 255, 255, 0.08) 44%,
      rgba(157, 212, 242, 0.05) 47%,
      rgba(65, 171, 226, 0.04) 50%,
      rgba(255, 255, 255, 0.08) 53%,
      transparent 59%
    );
    z-index: 3;
    pointer-events: none;
    transform: translate3d(-100%, 0, 0);
    transition: transform 0s;
  }

  .client-card:hover .prism-light {
    transform: translate3d(320%, 0, 0);
    transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .bottom-reflection {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 36%;
    border-radius: inherit;
    z-index: 1;
    pointer-events: none;
    background: linear-gradient(
      0deg,
      rgba(157, 212, 242, 0.08) 0%,
      rgba(65, 171, 226, 0.03) 40%,
      transparent 100%
    );
    mask-image: linear-gradient(0deg, black 0%, transparent 100%);
    -webkit-mask-image: linear-gradient(0deg, black 0%, transparent 100%);
  }

  .ice-edge {
    position: absolute;
    pointer-events: none;
    z-index: 5;
  }

  .ice-edge-top {
    top: 0;
    left: 16px;
    right: 16px;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.8) 20%,
      rgba(255, 255, 255, 0.95) 50%,
      rgba(255, 255, 255, 0.8) 80%,
      transparent 100%
    );
    box-shadow: 0 1px 4px rgba(255, 255, 255, 0.35);
    opacity: 0.78;
    transition:
      opacity 0.2s ease-out,
      box-shadow 0.2s ease-out;
  }

  .ice-edge-left {
    top: 16px;
    bottom: 16px;
    left: 0;
    width: 1px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(255, 255, 255, 0.55) 20%,
      rgba(255, 255, 255, 0.72) 50%,
      rgba(255, 255, 255, 0.5) 80%,
      transparent 100%
    );
    opacity: 0.6;
    transition: opacity 0.2s ease-out;
  }

  .client-card.is-visible {
    animation: cardIn 0.68s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes cardIn {
    from {
      opacity: 0;
      transform: translate3d(0, 40px, 0) scale(0.975);
    }
    to {
      opacity: 1;
      transform: translate3d(0, var(--card-shift-y), 0)
        scale(var(--card-scale));
    }
  }

  .fade-in-delay-1 {
    animation-delay: 0.05s;
  }
  .fade-in-delay-2 {
    animation-delay: 0.15s;
  }
  .fade-in-delay-3 {
    animation-delay: 0.25s;
  }
  .fade-in-delay-4 {
    animation-delay: 0.35s;
  }
  .fade-in-delay-5 {
    animation-delay: 0.45s;
  }
  .fade-in-delay-6 {
    animation-delay: 0.55s;
  }

  .client-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 22px;
    right: 22px;
    height: 3px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      var(--color-primary) 0%,
      var(--color-accent) 60%,
      rgba(157, 212, 242, 0.95) 100%
    );
    z-index: 6;
    transform: scaleX(0.35);
    transform-origin: left;
    transition: transform 0.34s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow:
      0 0 10px rgba(65, 171, 226, 0.38),
      0 0 22px rgba(65, 171, 226, 0.16);
  }

  .client-card:hover::before {
    transform: scaleX(1);
  }

  .client-card::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      108deg,
      transparent 30%,
      rgba(255, 255, 255, 0.18) 48%,
      rgba(157, 212, 242, 0.1) 52%,
      transparent 70%
    );
    background-size: 250% 100%;
    background-position: -150% 0;
    transition: background-position 0.65s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 5;
    pointer-events: none;
    border-radius: inherit;
  }

  .client-card:hover::after {
    background-position: 180% 0;
  }

  .client-card:hover {
    --card-shift-y: 0px;
    --card-scale: 1;
    border-color: rgba(255, 255, 255, 0.9);
    box-shadow:
      0 28px 52px rgba(50, 59, 129, 0.12),
      0 14px 28px rgba(65, 171, 226, 0.08),
      0 6px 16px rgba(65, 171, 226, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(65, 171, 226, 0.08),
      0 0 0 1px rgba(65, 171, 226, 0.1),
      0 0 36px rgba(65, 171, 226, 0.04);
  }

  .client-card:hover .liquid-glass-layer {
    opacity: 1;
  }

  .client-card:hover .card-caustics {
    opacity: 0.55;
  }

  .card-ring {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1.5px;
    background: linear-gradient(
      140deg,
      rgba(255, 255, 255, 0.85),
      rgba(157, 212, 242, 0.32),
      rgba(65, 171, 226, 0.24),
      rgba(50, 59, 129, 0.14),
      rgba(255, 255, 255, 0.6),
      rgba(157, 212, 242, 0.24)
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 4;
    opacity: 0;
    transition: opacity 0.22s ease-out;
  }

  .client-card:hover .card-ring {
    opacity: 1;
  }

  .client-card-border {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.86) 0%,
      rgba(157, 212, 242, 0.28) 35%,
      rgba(65, 171, 226, 0.18) 65%,
      rgba(255, 255, 255, 0.5) 100%
    );
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 4;
    opacity: 1;
  }

  .client-card-inner {
    position: relative;
    z-index: 7;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 34px 28px 28px;
    transform-style: preserve-3d;
    transform: rotateX(var(--card-tilt-x)) rotateY(var(--card-tilt-y));
  }

  .client-card-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 24px;
  }

  .client-icon-wrap {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 76px;
    height: 76px;
    border-radius: 24px;
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.9) 0%,
      rgba(220, 242, 254, 0.72) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.85);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      inset 0 -1px 0 rgba(65, 171, 226, 0.08),
      inset 1px 0 0 rgba(255, 255, 255, 0.7),
      0 8px 24px rgba(65, 171, 226, 0.12),
      0 2px 8px rgba(50, 59, 129, 0.06);
    backdrop-filter: blur(14px) saturate(1.5);
    -webkit-backdrop-filter: blur(14px) saturate(1.5);
    transition:
      transform 0.24s ease-out,
      box-shadow 0.24s ease-out;
  }

  .icon-glass-bg {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(
      145deg,
      rgba(255, 255, 255, 0.7) 0%,
      transparent 55%
    );
    pointer-events: none;
    z-index: 0;
  }

  .icon-glow-ring {
    position: absolute;
    inset: -3px;
    border-radius: 27px;
    border: 1.5px solid rgba(65, 171, 226, 0.22);
    opacity: 0;
    transition:
      opacity 0.22s ease-out,
      transform 0.22s ease-out;
    pointer-events: none;
    z-index: 0;
  }

  .client-card:hover .icon-glow-ring {
    opacity: 1;
    transform: scale(1.05);
  }

  .client-card:hover .client-icon-wrap {
    transform: translate3d(0, -2px, 0) scale(1.06) rotate(-3deg);
    box-shadow:
      0 14px 30px rgba(65, 171, 226, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 0 0 3px rgba(65, 171, 226, 0.08);
  }

  .card-icon {
    display: block;
    font-size: 2.35rem;
    line-height: 1;
    position: relative;
    z-index: 1;
    filter: drop-shadow(0 4px 8px rgba(50, 59, 129, 0.08));
    transition:
      filter 0.22s ease-out,
      transform 0.22s ease-out;
  }

  .client-card:hover .card-icon {
    filter: drop-shadow(0 6px 12px rgba(50, 59, 129, 0.14));
    transform: scale(1.05);
  }

  .client-card-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 34px;
    padding: 7px 12px 7px 10px;
    border-radius: 999px;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.75),
      rgba(220, 242, 254, 0.55)
    );
    border: 1px solid rgba(65, 171, 226, 0.22);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.94),
      0 4px 12px rgba(65, 171, 226, 0.08);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--color-primary);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 1.1px;
    text-transform: uppercase;
    white-space: nowrap;
    transition:
      background 0.22s ease-out,
      border-color 0.22s ease-out,
      color 0.22s ease-out,
      box-shadow 0.22s ease-out;
  }

  .chip-dot {
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: var(--color-accent);
    flex-shrink: 0;
    box-shadow: 0 0 4px rgba(65, 171, 226, 0.42);
    animation: chipDotPulse 3s ease-in-out infinite;
  }

  @keyframes chipDotPulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.55;
      transform: scale(0.78);
    }
  }

  .client-card:hover .client-card-chip {
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.9),
      rgba(200, 235, 252, 0.68)
    );
    border-color: rgba(65, 171, 226, 0.3);
    color: var(--color-accent);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 6px 16px rgba(65, 171, 226, 0.12);
  }

  .client-card h3 {
    margin: 0;
    font-family: "Barlow Condensed", sans-serif;
    font-weight: 700;
    font-size: 1.52rem;
    line-height: 1;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    color: var(--color-primary);
    position: relative;
    display: inline-block;
  }

  .client-card h3::after {
    content: "";
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--color-accent), #9dd4f2);
    transition: width 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 0 8px rgba(65, 171, 226, 0.28);
  }

  .client-card:hover h3::after {
    width: 100%;
  }

  .client-card p {
    margin-top: 16px;
    max-width: 32ch;
    font-size: 0.97rem;
    line-height: 1.8;
    color: rgba(26, 31, 78, 0.7);
  }

  .client-card-footer {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: auto;
    padding-top: 22px;
  }

  .client-card-line {
    width: 42px;
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(
      90deg,
      var(--color-accent),
      rgba(65, 171, 226, 0.2)
    );
    flex-shrink: 0;
    transform: scaleX(0.5);
    transform-origin: left;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 0 6px rgba(65, 171, 226, 0.24);
  }

  .client-card:hover .client-card-line {
    transform: scaleX(1);
  }

  .client-card-note {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.3px;
    color: rgba(50, 59, 129, 0.58);
    transition: color 0.22s ease-out;
    flex: 1;
  }

  .client-card:hover .client-card-note {
    color: rgba(50, 59, 129, 0.82);
  }

  .footer-arrow {
    font-size: 0.9rem;
    color: rgba(65, 171, 226, 0.4);
    opacity: 0;
    transform: translate3d(-6px, 0, 0);
    transition:
      opacity 0.22s ease-out,
      transform 0.22s cubic-bezier(0.22, 1, 0.36, 1),
      color 0.22s ease-out;
    line-height: 1;
  }

  .client-card:hover .footer-arrow {
    opacity: 1;
    transform: translate3d(0, 0, 0);
    color: var(--color-accent);
  }

  @media (max-width: 1200px) {
    .audience-header {
      gap: 40px;
    }
    .clients-grid {
      gap: 20px;
    }
    .client-card-top {
      align-items: flex-start;
      flex-direction: column;
    }
    .client-card-inner {
      padding: 30px 24px 24px;
    }
  }

  @media (max-width: 1024px) {
    .audience-header {
      grid-template-columns: 1fr;
      gap: 22px;
      margin-bottom: 42px;
    }
    .audience-title {
      font-size: clamp(2.9rem, 7vw, 4.6rem);
    }
    .clients-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .glass-blob-4,
    .vl-3 {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .audience-header {
      margin-bottom: 34px;
    }
    .audience-kicker {
      padding: 8px 13px;
      min-height: 40px;
    }
    .audience-subtitle {
      max-width: 100%;
      font-size: 0.98rem;
      line-height: 1.78;
    }
    .audience-metrics {
      gap: 10px;
    }
    .audience-metric {
      min-width: calc(50% - 5px);
      padding: 12px 14px;
      border-radius: 18px;
    }
    .clients-grid {
      grid-template-columns: 1fr;
      gap: 18px;
    }
    .client-card {
      border-radius: 24px;
      transform: none !important;
      backdrop-filter: blur(14px) saturate(1.2);
      -webkit-backdrop-filter: blur(14px) saturate(1.2);
      transition:
        transform 0.22s ease-out,
        box-shadow 0.24s ease-out;
    }
    .client-card-inner {
      padding: 24px 20px 22px;
    }
    .client-icon-wrap {
      width: 66px;
      height: 66px;
      border-radius: 18px;
    }
    .card-icon {
      font-size: 2rem;
    }
    .client-card-chip {
      font-size: 0.68rem;
      letter-spacing: 1px;
      min-height: 32px;
      padding: 7px 11px;
      white-space: normal;
    }
    .client-card h3 {
      font-size: 1.24rem;
    }
    .client-card p {
      max-width: 100%;
      font-size: 0.92rem;
      line-height: 1.68;
    }
    .client-card-footer {
      padding-top: 18px;
    }
    .vl-1,
    .vl-2,
    .vl-3,
    .prism-light,
    .scan-lines,
    .glass-blob-3,
    .glass-blob-4 {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .audience-kicker {
      width: 100%;
      justify-content: center;
    }
    .audience-title {
      font-size: clamp(2.45rem, 12vw, 3.4rem);
      letter-spacing: -1px;
    }
    .audience-metric {
      min-width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .client-card,
    .audience-metric,
    .client-icon-wrap,
    .client-card-line,
    .client-card h3::after,
    .card-ring,
    .liquid-refraction,
    .card-caustics,
    .glass-blob,
    .audience-kicker-dot,
    .audience-kicker-ring,
    .chip-dot,
    .bg-orb-1,
    .bg-orb-2,
    .bg-orb-3,
    .vl-1,
    .vl-2,
    .vl-3 {
      animation: none !important;
      transition: none !important;
    }

    .prism-light,
    .scan-lines {
      display: none;
    }
  }
</style>

<script is:inline>
  (() => {
    /** @type {HTMLElement | null} */
    const section = document.getElementById("nosotros");
    /** @type {HTMLCanvasElement | null} */
    const canvas = document.getElementById("audience-particles-canvas");

    if (!section) return;

    const ctx = canvas?.getContext("2d") ?? null;
    const particlesEnabled = !!canvas && !!ctx;

    let W = 0;
    let H = 0;
    let animationId;
    let particlesActive = true;
    let sectionVisible = false;
    let particles = [];

    const dpr = Math.min(window.devicePixelRatio || 1, 1.5);
    const reducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const isMobile = window.matchMedia("(max-width: 768px)").matches;

    const PARTICLE_COUNT =
      particlesEnabled && !reducedMotion ? (isMobile ? 24 : 46) : 0;
    const COLORS = ["rgba(65,171,226,", "rgba(50,59,129,", "rgba(157,212,242,"];

    function resize() {
      if (!particlesEnabled) return;
      const rect = section.getBoundingClientRect();
      W = Math.max(1, Math.floor(rect.width));
      H = Math.max(1, Math.floor(rect.height));

      canvas.width = Math.floor(W * dpr);
      canvas.height = Math.floor(H * dpr);
      canvas.style.width = `${W}px`;
      canvas.style.height = `${H}px`;

      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    }

    class Particle {
      x = 0;
      y = 0;
      r = 0;
      vx = 0;
      vy = 0;
      alpha = 0;
      color = COLORS[0];
      life = 0;
      maxLife = 0;

      constructor() {
        this.reset(true);
      }

      reset(initial = false) {
        this.x = Math.random() * W;
        this.y = initial ? Math.random() * H : Math.random() * H;
        this.r = Math.random() * 1.25 + 0.45;
        this.vx = (Math.random() - 0.5) * 0.12;
        this.vy = (Math.random() - 0.5) * 0.12;
        this.alpha = Math.random() * 0.32 + 0.1;
        this.color = COLORS[Math.floor(Math.random() * COLORS.length)];
        this.life = 0;
        this.maxLife = Math.random() * 260 + 220;
      }

      update() {
        this.x += this.vx;
        this.y += this.vy;
        this.life++;

        if (
          this.life >= this.maxLife ||
          this.x < -10 ||
          this.x > W + 10 ||
          this.y < -10 ||
          this.y > H + 10
        ) {
          this.reset();
        }
      }

      draw() {
        const fade =
          this.life < 40
            ? this.life / 40
            : this.life > this.maxLife - 40
              ? (this.maxLife - this.life) / 40
              : 1;

        ctx.beginPath();
        ctx.arc(this.x, this.y, this.r, 0, Math.PI * 2);
        ctx.fillStyle = this.color + this.alpha * Math.max(fade, 0) + ")";
        ctx.fill();
      }
    }

    function initParticles() {
      if (!particlesEnabled) return;
      particles = [];
      for (let i = 0; i < PARTICLE_COUNT; i++) {
        particles.push(new Particle());
      }
    }

    function renderParticles() {
      if (!particlesEnabled) return;
      ctx.clearRect(0, 0, W, H);

      for (let i = 0; i < particles.length; i++) {
        particles[i].update();
        particles[i].draw();
      }
    }

    function tick() {
      if (
        !particlesEnabled ||
        !particlesActive ||
        !sectionVisible ||
        PARTICLE_COUNT === 0
      ) {
        animationId = undefined;
        return;
      }
      renderParticles();
      animationId = window.requestAnimationFrame(tick);
    }

    function startParticles() {
      if (!particlesEnabled || animationId !== undefined) {
        return;
      }
      if (PARTICLE_COUNT === 0 || !particlesActive || !sectionVisible) {
        return;
      }
      if (animationId === undefined) {
        animationId = window.requestAnimationFrame(tick);
      }
    }

    function stopParticles() {
      if (animationId !== undefined) {
        window.cancelAnimationFrame(animationId);
        animationId = undefined;
      }
    }

    let sectionObserver;
    if ("IntersectionObserver" in window) {
      sectionObserver = new IntersectionObserver(
        (entries) => {
          sectionVisible = !!entries[0]?.isIntersecting;
          if (particlesActive && sectionVisible && PARTICLE_COUNT > 0) {
            startParticles();
            return;
          }
          stopParticles();
        },
        { threshold: 0.08 },
      );

      sectionObserver.observe(section);
    } else {
      sectionVisible = true;
      if (particlesActive && PARTICLE_COUNT > 0) {
        startParticles();
      }
    }

    document.addEventListener("visibilitychange", () => {
      particlesActive = document.visibilityState === "visible";
      if (particlesActive && sectionVisible && PARTICLE_COUNT > 0) {
        startParticles();
      } else {
        stopParticles();
      }
    });

    resize();
    initParticles();

    let resizeRaf = 0;
    window.addEventListener(
      "resize",
      () => {
        cancelAnimationFrame(resizeRaf);
        resizeRaf = window.requestAnimationFrame(() => {
          resize();
          initParticles();
        });
      },
      { passive: true },
    );

    /** @type {NodeListOf<HTMLElement>} */
    const cards = document.querySelectorAll(".client-card");

    let revealObserver;
    if ("IntersectionObserver" in window) {
      revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const target = entry.target;
              if (target instanceof HTMLElement) {
                target.classList.add("is-visible");
                revealObserver?.unobserve(target);
              }
            }
          });
        },
        { threshold: 0.12 },
      );

      cards.forEach((card) => revealObserver.observe(card));
    } else {
      cards.forEach((card) => card.classList.add("is-visible"));
    }

    const canHover =
      window.matchMedia("(hover: hover) and (pointer: fine)").matches &&
      !reducedMotion;

    if (canHover) {
      const MAX_ROT = 5.2;

      cards.forEach((card) => {
        let raf = 0;
        let hovered = false;
        let targetX = 0;
        let targetY = 0;
        const inner = card.querySelector(".client-card-inner");

        const updateCard = () => {
          raf = 0;
          if (!hovered) return;

          const rect = card.getBoundingClientRect();
          const x = targetX - rect.left;
          const y = targetY - rect.top;

          const centerX = rect.width / 2;
          const centerY = rect.height / 2;

          const rotateY = ((x - centerX) / centerX) * MAX_ROT;
          const rotateX = -((y - centerY) / centerY) * (MAX_ROT * 0.72);

          const pctX = Math.max(0, Math.min(100, (x / rect.width) * 100));
          const pctY = Math.max(0, Math.min(100, (y / rect.height) * 100));

          card.style.setProperty("--card-tilt-x", `${rotateX}deg`);
          card.style.setProperty("--card-tilt-y", `${rotateY}deg`);
          card.style.setProperty("--glass-x", `${pctX}%`);
          card.style.setProperty("--glass-y", `${pctY}%`);
          card.style.setProperty("--depth-x", `${pctX * 0.28 + 8}%`);
          card.style.setProperty("--depth-y", `${pctY * 0.28 + 8}%`);
          card.style.setProperty("--depth-x2", `${100 - pctX * 0.28}%`);
          card.style.setProperty("--depth-y2", `${100 - pctY * 0.28}%`);
        };

        /** @param {PointerEvent} event */
        const onMove = (event) => {
          targetX = event.clientX;
          targetY = event.clientY;

          if (!raf) {
            raf = window.requestAnimationFrame(updateCard);
          }
        };

        const onEnter = () => {
          hovered = true;
          if (inner instanceof HTMLElement) {
            inner.style.willChange = "transform";
          }
        };

        const onLeave = () => {
          hovered = false;
          if (raf) {
            cancelAnimationFrame(raf);
            raf = 0;
          }

          card.style.setProperty("--card-tilt-x", "0deg");
          card.style.setProperty("--card-tilt-y", "0deg");
          card.style.setProperty("--glass-x", "50%");
          card.style.setProperty("--glass-y", "50%");
          card.style.setProperty("--depth-x", "18%");
          card.style.setProperty("--depth-y", "12%");
          card.style.setProperty("--depth-x2", "82%");
          card.style.setProperty("--depth-y2", "88%");

          window.setTimeout(() => {
            if (!hovered) {
              if (inner instanceof HTMLElement) {
                inner.style.willChange = "auto";
              }
            }
          }, 180);
        };

        card.addEventListener("pointerenter", onEnter);
        card.addEventListener("pointermove", onMove);
        card.addEventListener("pointerleave", onLeave);
      });
    }

    window.addEventListener("beforeunload", () => {
      stopParticles();
      sectionObserver?.disconnect();
      revealObserver?.disconnect();
    });
  })();
</script>
