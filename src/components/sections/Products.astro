---
import { buildWhatsAppUrl, commercialContent } from "../../config/commercial";
---

<!-- PRODUCTO DESTACADO -->
<section id="productos">
  <div class="products-ambient products-ambient-1"></div>
  <div class="products-ambient products-ambient-2"></div>
  <div class="products-noise" aria-hidden="true"></div>

  <div class="container">
    <div class="products-head">
      <div class="products-heading fade-in">
        <h2
          class="section-title products-title"
          style="color: var(--color-primary);"
        >
          HIELO EN TUBO
        </h2>

        <p class="products-intro">Diseñado para operación comercial</p>
      </div>
    </div>

    <div class="products-showcase">
      <article
        class="featured-product-card fade-in fade-in-delay-1 js-featured-product"
      >
        <div class="featured-product-shell">
          <div class="featured-product-layout">
            <!-- MEDIA -->
            <div class="featured-product-media">
              <div class="featured-product-spotlight"></div>
              <div class="featured-product-vignette"></div>

              <picture>
                <source
                  type="image/webp"
                  srcset="/gallery/HieloenTubo01-640.webp 640w, /gallery/HieloenTubo01-960.webp 960w, /gallery/HieloenTubo01-1280.webp 1280w"
                  sizes="(min-width: 980px) 58vw, 100vw"
                />
                <img
                  src="/gallery/HieloenTubo01.png"
                  alt="Hielo en tubo para operación comercial"
                  class="featured-product-image"
                  width="1920"
                  height="1080"
                  loading="lazy"
                  decoding="async"
                />
              </picture>

              <div class="featured-product-overlay"></div>
              <div class="featured-product-rim-light"></div>

              <div class="featured-product-media-footer">
                <div class="featured-product-media-label">
                  <span class="featured-media-line"></span>
                  <p>Presentación uniforme para operación comercial</p>
                </div>
              </div>
            </div>

            <!-- PANEL -->
            <div class="featured-product-panel">
              <div class="featured-product-panel-inner">
                <div class="featured-product-copy">
                  <p class="featured-product-eyebrow">Producto para negocio</p>

                  <h3 class="featured-product-title">Hielo en Tubo</h3>

                  <p class="featured-product-text">
                    Caracterizado por su transparencia, tamaño uniforme, alta
                    densidad, resistencia al derretimiento y facilidad de
                    manejo. Ideal para restaurantes, bares, hoteles, eventos y
                    negocios que requieren una presentación confiable y abasto
                    constante.
                  </p>
                </div>

                <div class="featured-product-tags">
                  <span class="featured-chip">Bolsa de 5 kg</span>
                  <span class="featured-chip">Alta densidad</span>
                  <span class="featured-chip">Manejo práctico</span>
                </div>

                <div class="featured-product-cta-group">
                  <a
                    href={buildWhatsAppUrl(
                      commercialContent.whatsappMessages.quoteIceTube,
                    )}
                    class="featured-product-cta"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={commercialContent.aria.quoteIceTube}
                  >
                    <span class="featured-product-cta-icon" aria-hidden="true">
                      <span class="featured-cta-dot"></span>
                    </span>
                    <span>{commercialContent.ctas.productsPrimary}</span>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  #productos {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding-block: clamp(80px, 8vw, 122px);
    background:
      radial-gradient(
        ellipse 68% 50% at 12% 8%,
        rgba(157, 212, 242, 0.12),
        transparent 58%
      ),
      radial-gradient(
        ellipse 52% 62% at 92% 86%,
        rgba(65, 171, 226, 0.05),
        transparent 56%
      ),
      linear-gradient(180deg, #f8fbff 0%, #eef4fa 48%, #f7fbff 100%);
  }

  #productos .container {
    position: relative;
    z-index: 2;
  }

  .products-noise {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0.012;
    background-image:
      radial-gradient(
        circle at 20% 20%,
        rgba(16, 33, 73, 0.08) 0.7px,
        transparent 0.8px
      ),
      radial-gradient(
        circle at 80% 40%,
        rgba(16, 33, 73, 0.08) 0.7px,
        transparent 0.8px
      );
    background-size:
      28px 28px,
      34px 34px;
  }

  .products-ambient {
    position: absolute;
    border-radius: 999px;
    pointer-events: none;
    z-index: 0;
  }

  .products-ambient-1 {
    top: -140px;
    left: -140px;
    width: 540px;
    height: 540px;
    filter: blur(82px);
    background: radial-gradient(
      circle,
      rgba(157, 212, 242, 0.14) 0%,
      rgba(65, 171, 226, 0.05) 54%,
      transparent 74%
    );
    animation: ambientFloat1 16s ease-in-out infinite;
  }

  .products-ambient-2 {
    right: -100px;
    bottom: 0;
    width: 460px;
    height: 460px;
    filter: blur(82px);
    background: radial-gradient(
      circle,
      rgba(65, 171, 226, 0.07) 0%,
      rgba(50, 59, 129, 0.04) 58%,
      transparent 76%
    );
    animation: ambientFloat2 18s ease-in-out infinite;
  }

  .products-head {
    display: grid;
    gap: 18px;
    margin-bottom: 30px;
  }

  .products-heading {
    max-width: 760px;
  }

  .products-title {
    margin: 0 0 10px;
    line-height: 0.92;
    letter-spacing: -0.03em;
    text-wrap: balance;
    text-transform: uppercase;
  }

  .products-intro {
    max-width: 620px;
    margin: 0;
    font-size: 1rem;
    line-height: 1.68;
    color: rgba(16, 33, 73, 0.74);
    text-wrap: pretty;
  }

  .products-showcase {
    display: grid;
  }

  .featured-product-card {
    position: relative;
  }

  .featured-product-shell {
    position: relative;
    padding: 1px;
    border-radius: 30px;
    background: linear-gradient(
      145deg,
      rgba(255, 255, 255, 0.94) 0%,
      rgba(255, 255, 255, 0.72) 34%,
      rgba(255, 255, 255, 0.3) 100%
    );
    box-shadow:
      0 24px 56px rgba(27, 47, 94, 0.08),
      0 12px 24px rgba(27, 47, 94, 0.05);
  }

  .featured-product-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.16fr) minmax(320px, 0.84fr);
    min-height: 540px;
    overflow: hidden;
    border-radius: 29px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.84) 0%,
      rgba(255, 255, 255, 0.92) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(14px) saturate(135%);
    -webkit-backdrop-filter: blur(14px) saturate(135%);
  }

  .featured-product-media {
    position: relative;
    min-height: 540px;
    overflow: hidden;
    background:
      radial-gradient(
        circle at 50% 34%,
        rgba(157, 212, 242, 0.11) 0%,
        transparent 30%
      ),
      linear-gradient(
        180deg,
        rgba(16, 32, 68, 0.96) 0%,
        rgba(12, 24, 54, 1) 100%
      );
    border-right: 1px solid rgba(255, 255, 255, 0.14);
  }

  .featured-product-spotlight {
    position: absolute;
    top: 10%;
    left: 50%;
    z-index: 0;
    width: 72%;
    height: 52%;
    transform: translateX(-50%);
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.18) 0%,
      rgba(157, 212, 242, 0.1) 30%,
      rgba(65, 171, 226, 0.05) 46%,
      transparent 72%
    );
    filter: blur(24px);
    pointer-events: none;
  }

  .featured-product-vignette {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(
      circle at 50% 42%,
      transparent 0%,
      transparent 42%,
      rgba(7, 16, 42, 0.12) 72%,
      rgba(7, 16, 42, 0.24) 100%
    );
    pointer-events: none;
  }

  .featured-product-image {
    position: absolute;
    inset: -1.5% -1.5% 0 -1.5%;
    z-index: 1;
    width: 103%;
    height: 103%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.025);
    filter: saturate(1.02) contrast(1.02) brightness(1.01);
    transition:
      transform 0.7s ease,
      filter 0.7s ease;
    will-change: transform;
  }

  .featured-product-card:hover .featured-product-image {
    transform: scale(1.045);
    filter: saturate(1.04) contrast(1.04) brightness(1.02);
  }

  .featured-product-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(
        180deg,
        rgba(16, 33, 73, 0.02) 0%,
        rgba(16, 33, 73, 0.06) 28%,
        rgba(16, 33, 73, 0.16) 54%,
        rgba(16, 33, 73, 0.48) 100%
      ),
      linear-gradient(
        135deg,
        rgba(36, 48, 111, 0.05) 0%,
        rgba(81, 181, 234, 0.04) 100%
      );
  }

  .featured-product-rim-light {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.14),
      inset 0 -70px 100px rgba(5, 12, 34, 0.04);
  }

  .featured-product-media-footer {
    position: absolute;
    left: 22px;
    right: 22px;
    bottom: 22px;
    z-index: 4;
  }

  .featured-product-media-label {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 12px;
    align-items: center;
    max-width: 310px;
    padding: 14px 16px;
    border-radius: 18px;
    background: rgba(17, 31, 69, 0.42);
    border: 1px solid rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.1),
      0 12px 30px rgba(8, 18, 56, 0.12);
  }

  .featured-media-line {
    display: block;
    width: 3px;
    min-height: 34px;
    border-radius: 999px;
    background: linear-gradient(
      180deg,
      rgba(157, 212, 242, 1) 0%,
      rgba(65, 171, 226, 1) 100%
    );
  }

  .featured-product-media-label p {
    margin: 0;
    color: rgba(255, 255, 255, 0.94);
    font-size: 0.82rem;
    line-height: 1.42;
    font-weight: 600;
  }

  .featured-product-panel {
    position: relative;
    display: flex;
    align-items: stretch;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.74) 0%,
      rgba(255, 255, 255, 0.94) 100%
    );
  }

  .featured-product-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        circle at top right,
        rgba(157, 212, 242, 0.14) 0%,
        transparent 34%
      ),
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.1) 0%,
        rgba(255, 255, 255, 0) 100%
      );
    pointer-events: none;
  }

  .featured-product-panel-inner {
    position: relative;
    z-index: 1;
    display: grid;
    align-content: center;
    gap: 18px;
    width: 100%;
    padding: 38px 32px;
  }

  .featured-product-copy {
    display: grid;
    gap: 10px;
  }

  .featured-product-eyebrow {
    margin: 0;
    color: rgba(16, 33, 73, 0.6);
    font-family: "Barlow", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 1.35px;
    text-transform: uppercase;
  }

  .featured-product-title {
    margin: 0;
    color: #102149;
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(2.05rem, 3.2vw, 2.9rem);
    font-weight: 700;
    line-height: 0.92;
    letter-spacing: 0.12px;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .featured-product-text {
    margin: 0;
    color: rgba(16, 33, 73, 0.78);
    font-size: 0.94rem;
    line-height: 1.68;
    text-wrap: pretty;
    max-width: 37ch;
  }

  .featured-product-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .featured-chip {
    display: inline-flex;
    align-items: center;
    min-height: 31px;
    padding: 0 12px;
    border-radius: 999px;
    color: var(--color-primary);
    font-size: 0.61rem;
    font-weight: 700;
    letter-spacing: 0.74px;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(16, 33, 73, 0.08);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.84),
      0 8px 18px rgba(27, 47, 94, 0.04);
  }

  .featured-product-cta-group {
    display: grid;
    gap: 10px;
    margin-top: 2px;
  }

  .featured-product-cta {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    min-height: 56px;
    padding: 0 22px;
    border-radius: 999px;
    text-decoration: none;
    color: #ffffff;
    background: linear-gradient(
      135deg,
      var(--color-primary) 0%,
      #324e97 58%,
      var(--color-accent) 100%
    );
    border: 1px solid transparent;
    font-family: "Barlow", sans-serif;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.32px;
    box-shadow:
      0 16px 34px rgba(8, 18, 56, 0.16),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
    transition:
      transform 0.28s ease,
      box-shadow 0.28s ease,
      filter 0.28s ease;
  }

  .featured-product-cta::after {
    content: "";
    position: absolute;
    top: 0;
    left: -130%;
    width: 70%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.4) 50%,
      transparent 100%
    );
    transform: skewX(-20deg);
    transition: left 0.7s ease;
    pointer-events: none;
  }

  .featured-product-cta:hover::after,
  .featured-product-cta:focus-visible::after {
    left: 160%;
  }

  .featured-product-cta > * {
    position: relative;
    z-index: 1;
  }

  .featured-product-cta-icon {
    display: inline-grid;
    place-items: center;
    width: 20px;
    height: 20px;
  }

  .featured-cta-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: currentColor;
    box-shadow: 0 0 0 5px rgba(255, 255, 255, 0.14);
    transition: box-shadow 0.28s ease;
  }

  .featured-product-cta:hover,
  .featured-product-cta:focus-visible {
    transform: translateY(-3px);
    filter: brightness(1.03);
    box-shadow:
      0 20px 42px rgba(8, 18, 56, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.14);
    outline: none;
  }

  .featured-product-cta:hover .featured-cta-dot,
  .featured-product-cta:focus-visible .featured-cta-dot {
    box-shadow: 0 0 0 5px rgba(255, 255, 255, 0.18);
  }

  .js-featured-product.is-visible .featured-product-shell {
    animation: productLiftIn 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .js-featured-product.is-visible .featured-product-panel-inner > * {
    animation: productFadeUp 0.85s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .js-featured-product.is-visible
    .featured-product-panel-inner
    > *:nth-child(1) {
    animation-delay: 0.08s;
  }

  .js-featured-product.is-visible
    .featured-product-panel-inner
    > *:nth-child(2) {
    animation-delay: 0.15s;
  }

  .js-featured-product.is-visible
    .featured-product-panel-inner
    > *:nth-child(3) {
    animation-delay: 0.22s;
  }

  @keyframes ambientFloat1 {
    0%,
    100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(28px, 18px) scale(1.04);
    }
  }

  @keyframes ambientFloat2 {
    0%,
    100% {
      transform: translate(0, 0) scale(1);
    }
    50% {
      transform: translate(-20px, -28px) scale(1.04);
    }
  }

  @keyframes productLiftIn {
    from {
      opacity: 0;
      transform: translateY(28px) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes productFadeUp {
    from {
      opacity: 0;
      transform: translateY(18px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 980px) {
    .featured-product-layout {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .featured-product-media {
      min-height: 500px;
      border-right: 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.14);
    }

    .featured-product-image {
      inset: -1% -1% 0 -1%;
      width: 102%;
      height: 102%;
      transform: scale(1.03);
    }

    .featured-product-panel-inner {
      padding: 28px 24px 26px;
    }

    .featured-product-text {
      max-width: unset;
    }
  }

  @media (max-width: 768px) {
    #productos {
      padding-block: 72px;
    }

    .products-head {
      gap: 16px;
      margin-bottom: 24px;
    }

    .products-title {
      margin-bottom: 10px;
    }

    .products-intro {
      max-width: 100%;
      font-size: 0.95rem;
      line-height: 1.62;
    }

    .featured-product-shell {
      border-radius: 24px;
      box-shadow:
        0 20px 48px rgba(27, 47, 94, 0.08),
        0 10px 24px rgba(27, 47, 94, 0.05);
    }

    .featured-product-layout {
      position: relative;
      display: block;
      border-radius: 23px;
      overflow: visible;
      background: transparent;
      border: 0;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      min-height: unset;
    }

    .featured-product-media {
      min-height: 430px;
      border-right: 0;
      border-bottom: 0;
      border-radius: 23px;
      overflow: hidden;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.08),
        0 20px 42px rgba(10, 24, 58, 0.14);
    }

    .featured-product-media-footer {
      left: 16px;
      right: 16px;
      bottom: 78px;
    }

    .featured-product-media-label {
      max-width: 230px;
      padding: 12px 14px;
      border-radius: 16px;
    }

    .featured-product-panel {
      position: relative;
      z-index: 5;
      width: calc(100% - 24px);
      margin: -52px auto 0;
      border-radius: 20px;
      background: linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.84) 0%,
        rgba(255, 255, 255, 0.97) 100%
      );
      border: 1px solid rgba(255, 255, 255, 0.84);
      backdrop-filter: blur(14px) saturate(140%);
      -webkit-backdrop-filter: blur(14px) saturate(140%);
      box-shadow:
        0 18px 40px rgba(11, 24, 57, 0.12),
        0 6px 16px rgba(11, 24, 57, 0.07),
        inset 0 1px 0 rgba(255, 255, 255, 0.95);
    }

    .featured-product-panel::before {
      border-radius: inherit;
      background:
        radial-gradient(
          circle at top right,
          rgba(157, 212, 242, 0.18) 0%,
          transparent 34%
        ),
        linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.16) 0%,
          rgba(255, 255, 255, 0) 100%
        );
    }

    .featured-product-panel-inner {
      gap: 14px;
      padding: 22px 20px 20px;
    }

    .featured-product-copy {
      gap: 8px;
    }

    .featured-product-eyebrow {
      font-size: 0.64rem;
      letter-spacing: 1.2px;
    }

    .featured-product-title {
      font-size: 2rem;
      line-height: 0.92;
    }

    .featured-product-text {
      font-size: 0.9rem;
      line-height: 1.6;
    }

    .featured-product-tags {
      gap: 7px;
    }

    .featured-chip {
      min-height: 29px;
      font-size: 0.58rem;
      padding: 0 11px;
    }

    .featured-product-cta {
      min-height: 52px;
      font-size: 0.84rem;
      padding-inline: 16px;
    }
  }

  @media (max-width: 520px) {
    #productos {
      padding-block: 66px;
    }

    .products-head {
      margin-bottom: 22px;
    }

    .products-title {
      font-size: clamp(2.45rem, 11vw, 3.5rem);
      line-height: 0.92;
      letter-spacing: -0.03em;
    }

    .products-intro {
      font-size: 0.9rem;
      line-height: 1.56;
      color: rgba(16, 33, 73, 0.76);
    }

    .featured-product-shell {
      border-radius: 22px;
    }

    .featured-product-layout {
      border-radius: 21px;
    }

    .featured-product-media {
      min-height: 370px;
      border-radius: 21px;
    }

    .featured-product-image {
      inset: -1% -6% 0 -6%;
      width: 112%;
      height: 103%;
      object-position: center;
      transform: scale(1.02);
    }

    .featured-product-spotlight {
      width: 92%;
      height: 52%;
      top: 8%;
    }

    .featured-product-media-footer {
      left: 13px;
      right: 13px;
      bottom: 70px;
    }

    .featured-product-media-label {
      max-width: 210px;
      gap: 10px;
      padding: 10px 12px;
      border-radius: 15px;
      box-shadow:
        inset 0 1px 0 rgba(255, 255, 255, 0.12),
        0 10px 24px rgba(8, 18, 56, 0.12);
    }

    .featured-media-line {
      min-height: 28px;
