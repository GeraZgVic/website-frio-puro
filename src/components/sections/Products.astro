---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import Section from "../ui/Section.astro";
import Container from "../ui/Container.astro";
import Heading from "../ui/Heading.astro";
import Card from "../ui/Card.astro";
import placeholderImage from "../../assets/products/placeholder-product.png";

const products = await getCollection("products");
const isImageMetadata = (value) =>
	typeof value === "object" && value !== null && "src" in value;
---

<Section className="bg-[var(--color-white)]">
	<Container>
		<div class="text-center">
			<Heading as="h2" className="text-[var(--color-text)]">
				Nuestra línea de hielo
			</Heading>
		</div>
		<div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{products.map((product) => (
				<Card className="flex flex-col gap-4">
					<div class="aspect-[4/3] w-full overflow-hidden rounded-xl bg-[var(--color-bg-soft)]">
						<Image
							src={isImageMetadata(product.data.image) ? product.data.image : placeholderImage}
							alt={product.data.title}
							class="h-full w-full object-cover rounded-xl"
							widths={[400, 600, 800]}
							sizes="(max-width: 768px) 100vw, 33vw"
						/>
					</div>
					<div class="space-y-3">
						<div>
							<h3 class="text-lg font-semibold text-[var(--color-text-strong)]">
								{product.data.title}
							</h3>
							<p class="mt-2 text-sm text-[var(--color-text)]/80">
								{product.data.description}
							</p>
						</div>
						<div>
							<p class="text-xs font-semibold uppercase tracking-[0.2em] text-[var(--color-text-strong)]/70">
								Presentaciones
							</p>
							<ul class="mt-3 space-y-2 text-sm text-[var(--color-text)]/85">
								{product.data.presentations.map((item) => (
									<li class="flex items-center gap-2">
										<span class="text-[var(--color-accent)]">•</span>
										<span>{item}</span>
									</li>
								))}
							</ul>
						</div>
					</div>
				</Card>
			))}
		</div>
	</Container>
</Section>
