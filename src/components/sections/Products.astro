---
import { buildWhatsAppUrl, commercialContent } from "../../config/commercial";
---

<!-- PRODUCTO DESTACADO -->
<section id="productos">
  <div class="products-ambient products-ambient-1"></div>
  <div class="products-ambient products-ambient-2"></div>
  <div class="products-noise" aria-hidden="true"></div>

  <div class="container">
    <div class="products-head">
      <div class="products-heading fade-in">
        <h2
          class="section-title products-title"
          style="color: var(--color-primary);"
        >
          Hielo en Tubo<br />de calidad premium
        </h2>

        <p class="products-intro">
          Diseñado para operación comercial continua, conservación confiable y
          presentación impecable para negocios que exigen calidad, puntualidad y
          consistencia.
        </p>
      </div>
    </div>

    <div class="products-showcase">
      <article
        class="featured-product-card fade-in fade-in-delay-1 js-featured-product"
      >
        <div class="featured-product-shell">
          <div class="featured-product-layout">
            <!-- MEDIA -->
            <div class="featured-product-media">
              <div class="featured-product-spotlight"></div>
              <div class="featured-product-vignette"></div>

              <picture>
                <source
                  type="image/webp"
                  srcset="/gallery/HieloenTubo01-640.webp 640w, /gallery/HieloenTubo01-960.webp 960w, /gallery/HieloenTubo01-1280.webp 1280w"
                  sizes="(min-width: 980px) 60vw, 90vw"
                />
                <img
                  src="/gallery/HieloenTubo01.png"
                  alt="Hielo en tubo premium"
                  class="featured-product-image"
                  width="1920"
                  height="1080"
                  loading="lazy"
                  decoding="async"
                />
              </picture>

              <div class="featured-product-overlay"></div>
              <div class="featured-product-glow"></div>
              <div class="featured-product-shine"></div>
              <div class="featured-product-rim-light"></div>

              <div class="featured-product-topbar">
                <span class="featured-pill featured-pill--ghost">
                  Producto estrella
                </span>

                <span class="featured-icon-badge" aria-hidden="true">
                  <span class="featured-icon-core"></span>
                </span>
              </div>

              <div class="featured-product-media-footer">
                <div class="featured-product-media-label">
                  <span class="featured-media-line"></span>
                  <p>Presentación uniforme para operación comercial exigente</p>
                </div>
              </div>
            </div>

            <!-- PANEL -->
            <div class="featured-product-panel">
              <div class="featured-product-panel-inner">
                <div class="featured-product-status-row">
                  <span class="featured-availability-badge">
                    <span class="featured-availability-dot"></span>
                    {commercialContent.badges.availability247}
                  </span>
                </div>

                <div class="featured-product-copy">
                  <p class="featured-product-eyebrow">
                    Solución premium para negocio
                  </p>

                  <h3 class="featured-product-title">Hielo en Tubo</h3>

                  <p class="featured-product-text">
                    Tubos uniformes y transparentes elaborados con agua
                    purificada. Ideales para restaurantes, bares, hoteles,
                    eventos y negocios que necesitan excelente presentación,
                    disponibilidad constante y una entrega confiable.
                  </p>
                </div>

                <div class="featured-product-tags">
                  <span class="featured-chip">Bolsas 5 y 10 kg</span>
                  <span class="featured-chip">Alta rotación</span>
                  <span class="featured-chip">Entrega puntual</span>
                </div>

                <div class="featured-product-cta-group">
                  <a
                    href={buildWhatsAppUrl(
                      commercialContent.whatsappMessages.quoteIceTube,
                    )}
                    class="featured-product-cta"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label={commercialContent.aria.quoteIceTube}
                  >
                    <span class="featured-product-cta-icon" aria-hidden="true">
                      <span class="featured-cta-dot"></span>
                    </span>
                    <span>{commercialContent.ctas.productsPrimary}</span>
                  </a>

                  <p class="featured-product-cta-note">
                    {commercialContent.microcopy.productsCtaNote}
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </article>
    </div>
  </div>
</section>

<style>
  #productos {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    padding-block: clamp(84px, 9vw, 132px);
    background:
      radial-gradient(
        ellipse 76% 56% at 10% 8%,
        rgba(157, 212, 242, 0.16),
        transparent 56%
      ),
      radial-gradient(
        ellipse 58% 68% at 92% 86%,
        rgba(65, 171, 226, 0.08),
        transparent 54%
      ),
      linear-gradient(180deg, #f8fbff 0%, #eef5fb 48%, #f7fbff 100%);
  }

  #productos .container {
    position: relative;
    z-index: 2;
  }

  .products-noise {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 0.02;
    background-image:
      radial-gradient(
        circle at 20% 20%,
        rgba(16, 33, 73, 0.08) 0.7px,
        transparent 0.8px
      ),
      radial-gradient(
        circle at 80% 40%,
        rgba(16, 33, 73, 0.08) 0.7px,
        transparent 0.8px
      );
    background-size:
      28px 28px,
      34px 34px;
  }

  .products-ambient {
    position: absolute;
    border-radius: 999px;
    pointer-events: none;
    z-index: 0;
  }

  .products-ambient-1 {
    top: -140px;
    left: -140px;
    width: 540px;
    height: 540px;
    filter: blur(80px);
    background: radial-gradient(
      circle,
      rgba(157, 212, 242, 0.22) 0%,
      rgba(65, 171, 226, 0.08) 52%,
      transparent 74%
    );
    animation: ambientFloat1 16s ease-in-out infinite;
  }

  .products-ambient-2 {
    right: -100px;
    bottom: 0;
    width: 460px;
    height: 460px;
    filter: blur(80px);
    background: radial-gradient(
      circle,
      rgba(65, 171, 226, 0.12) 0%,
      rgba(50, 59, 129, 0.05) 56%,
      transparent 76%
    );
    animation: ambientFloat2 18s ease-in-out infinite;
  }

  .products-head {
    display: grid;
    gap: 18px;
    margin-bottom: 34px;
  }

  .products-kicker-wrap {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    width: fit-content;
    padding: 8px 16px 8px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.68);
    border: 1px solid rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(16px) saturate(160%);
    -webkit-backdrop-filter: blur(16px) saturate(160%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.96),
      0 10px 28px rgba(65, 171, 226, 0.08);
  }

  .products-kicker-dot {
    width: 10px;
    height: 10px;
    flex-shrink: 0;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow:
      0 0 0 4px rgba(65, 171, 226, 0.12),
      0 0 18px rgba(65, 171, 226, 0.24);
    animation: dotPulse 2.8s ease-in-out infinite;
  }

  .products-heading {
    max-width: 840px;
  }

  .products-title {
    margin: 0 0 16px;
    line-height: 0.9;
    letter-spacing: -0.02em;
    text-wrap: balance;
  }

  .products-intro {
    max-width: 700px;
    margin: 0;
    font-size: 1rem;
    line-height: 1.8;
    color: rgba(50, 59, 129, 0.72);
    text-wrap: pretty;
  }

  .products-showcase {
    display: grid;
  }

  .featured-product-card {
    position: relative;
  }

  .featured-product-shell {
    position: relative;
    padding: 1px;
    border-radius: 34px;
    background: linear-gradient(
      145deg,
      rgba(255, 255, 255, 0.96) 0%,
      rgba(255, 255, 255, 0.52) 28%,
      rgba(255, 255, 255, 0.16) 100%
    );
    box-shadow:
      0 28px 70px rgba(27, 47, 94, 0.1),
      0 14px 28px rgba(27, 47, 94, 0.06);
  }

  .featured-product-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.28fr) minmax(320px, 0.72fr);
    min-height: 620px;
    overflow: hidden;
    border-radius: 33px;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.78) 0%,
      rgba(255, 255, 255, 0.54) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.38);
    backdrop-filter: blur(18px) saturate(155%);
    -webkit-backdrop-filter: blur(18px) saturate(155%);
  }

  .featured-product-media {
    position: relative;
    min-height: 620px;
    overflow: hidden;
    background:
      radial-gradient(
        circle at 50% 35%,
        rgba(157, 212, 242, 0.18) 0%,
        transparent 30%
      ),
      linear-gradient(
        180deg,
        rgba(16, 32, 68, 0.98) 0%,
        rgba(12, 24, 54, 1) 100%
      );
    border-right: 1px solid rgba(255, 255, 255, 0.14);
  }

  .featured-product-spotlight {
    position: absolute;
    top: 10%;
    left: 50%;
    z-index: 0;
    width: 76%;
    height: 58%;
    transform: translateX(-50%);
    border-radius: 50%;
    background: radial-gradient(
      circle,
      rgba(255, 255, 255, 0.22) 0%,
      rgba(157, 212, 242, 0.14) 28%,
      rgba(65, 171, 226, 0.08) 46%,
      transparent 72%
    );
    filter: blur(22px);
    pointer-events: none;
  }

  .featured-product-vignette {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(
      circle at 50% 42%,
      transparent 0%,
      transparent 40%,
      rgba(7, 16, 42, 0.14) 72%,
      rgba(7, 16, 42, 0.28) 100%
    );
    pointer-events: none;
  }

  .featured-product-image {
    position: absolute;
    inset: -1.5% -1.5% 0 -1.5%;
    z-index: 1;
    width: 103%;
    height: 103%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.045);
    filter: saturate(1.04) contrast(1.04) brightness(1.02);
    transition:
      transform 0.8s ease,
      filter 0.8s ease;
    will-change: transform;
  }

  .featured-product-card:hover .featured-product-image {
    transform: scale(1.07);
    filter: saturate(1.08) contrast(1.06) brightness(1.04);
  }

  .featured-product-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      linear-gradient(
        180deg,
        rgba(16, 33, 73, 0.02) 0%,
        rgba(16, 33, 73, 0.06) 20%,
        rgba(16, 33, 73, 0.16) 48%,
        rgba(16, 33, 73, 0.58) 100%
      ),
      linear-gradient(
        135deg,
        rgba(36, 48, 111, 0.08) 0%,
        rgba(81, 181, 234, 0.06) 100%
      );
  }

  .featured-product-glow {
    position: absolute;
    inset: auto auto 10% -6%;
    z-index: 2;
    width: 56%;
    height: 34%;
    border-radius: 999px;
    filter: blur(54px);
    background: radial-gradient(
      circle,
      rgba(157, 212, 242, 0.18) 0%,
      rgba(65, 171, 226, 0.06) 44%,
      transparent 72%
    );
    pointer-events: none;
    opacity: 0.78;
  }

  .featured-product-shine {
    position: absolute;
    top: -16%;
    right: -10%;
    z-index: 3;
    width: 46%;
    height: 46%;
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.2) 0%,
      rgba(255, 255, 255, 0.06) 38%,
      rgba(255, 255, 255, 0) 72%
    );
    transform: rotate(7deg);
    pointer-events: none;
    mix-blend-mode: screen;
  }

  .featured-product-rim-light {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      inset 0 -70px 100px rgba(5, 12, 34, 0.06);
  }

  .featured-product-topbar {
    position: absolute;
    top: 22px;
    left: 22px;
    right: 22px;
    z-index: 4;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  .featured-product-media-footer {
    position: absolute;
    left: 22px;
    right: 22px;
    bottom: 22px;
    z-index: 4;
  }

  .featured-product-media-label {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 12px;
    align-items: start;
    max-width: 340px;
    padding: 15px 16px;
    border-radius: 20px;
    background: rgba(108, 144, 205, 0.22);
    border: 1px solid rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(16px) saturate(150%);
    -webkit-backdrop-filter: blur(16px) saturate(150%);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.14),
      0 12px 30px rgba(8, 18, 56, 0.14);
  }

  .featured-media-line {
    display: block;
    width: 3px;
    min-height: 40px;
    border-radius: 999px;
    background: linear-gradient(
      180deg,
      rgba(157, 212, 242, 1) 0%,
      rgba(65, 171, 226, 1) 100%
    );
    box-shadow: 0 0 18px rgba(65, 171, 226, 0.24);
  }

  .featured-product-media-label p {
    margin: 0;
    color: rgba(255, 255, 255, 0.92);
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .featured-pill,
  .featured-chip,
  .featured-icon-badge,
  .featured-availability-badge {
    backdrop-filter: blur(14px) saturate(160%);
    -webkit-backdrop-filter: blur(14px) saturate(160%);
  }

  .featured-pill {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    font-size: 0.66rem;
    font-weight: 700;
    letter-spacing: 1.15px;
    text-transform: uppercase;
  }

  .featured-pill--ghost {
    color: #fff;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.18),
      0 6px 16px rgba(9, 17, 49, 0.12);
  }

  .featured-icon-badge {
    position: relative;
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 999px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.18) 0%,
      rgba(255, 255, 255, 0.06) 100%
    );
    border: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.16),
      0 6px 18px rgba(9, 17, 49, 0.14);
  }

  .featured-icon-badge::before {
    content: "";
    position: absolute;
    inset: 7px;
    border-radius: 999px;
    border: 1px solid rgba(157, 212, 242, 0.38);
    opacity: 0.9;
  }

  .featured-icon-core {
    position: relative;
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.98) 0%,
      rgba(157, 212, 242, 0.96) 100%
    );
    box-shadow:
      0 0 0 6px rgba(157, 212, 242, 0.08),
      0 0 18px rgba(157, 212, 242, 0.24);
  }

  .featured-product-panel {
    position: relative;
    display: flex;
    align-items: stretch;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.52) 0%,
      rgba(255, 255, 255, 0.74) 100%
    );
  }

  .featured-product-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        circle at top right,
        rgba(157, 212, 242, 0.2) 0%,
        transparent 34%
      ),
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.14) 0%,
        rgba(255, 255, 255, 0) 100%
      );
    pointer-events: none;
  }

  .featured-product-panel-inner {
    position: relative;
    z-index: 1;
    display: grid;
    align-content: center;
    gap: 18px;
    width: 100%;
    padding: 38px 34px;
  }

  .featured-product-status-row {
    display: flex;
    align-items: center;
  }

  .featured-availability-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    min-height: 34px;
    padding: 0 14px;
    border-radius: 999px;
    color: var(--color-primary);
    font-family: "Barlow", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.85px;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(16, 33, 73, 0.08);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.88),
      0 10px 22px rgba(27, 47, 94, 0.06);
  }

  .featured-availability-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow:
      0 0 0 5px rgba(65, 171, 226, 0.12),
      0 0 16px rgba(65, 171, 226, 0.24);
    animation: availabilityPulse 2.6s ease-in-out infinite;
    flex-shrink: 0;
  }

  .featured-product-copy {
    display: grid;
    gap: 10px;
  }

  .featured-product-eyebrow {
    margin: 0;
    color: rgba(50, 59, 129, 0.7);
    font-family: "Barlow", sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 1.4px;
    text-transform: uppercase;
  }

  .featured-product-title {
    margin: 0;
    color: #102149;
    font-family: "Barlow Condensed", sans-serif;
    font-size: clamp(2.2rem, 3.5vw, 3.2rem);
    font-weight: 700;
    line-height: 0.9;
    letter-spacing: 0.18px;
    text-transform: uppercase;
    text-wrap: balance;
  }

  .featured-product-text {
    margin: 0;
    color: rgba(16, 33, 73, 0.76);
    font-size: 0.95rem;
    line-height: 1.72;
    text-wrap: pretty;
    max-width: 36ch;
  }

  .featured-product-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .featured-chip {
    display: inline-flex;
    align-items: center;
    min-height: 30px;
    padding: 0 12px;
    border-radius: 999px;
    color: var(--color-primary);
    font-size: 0.61rem;
    font-weight: 700;
    letter-spacing: 0.78px;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.74);
    border: 1px solid rgba(16, 33, 73, 0.08);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.84),
      0 8px 18px rgba(27, 47, 94, 0.05);
  }

  .featured-product-cta-group {
    display: grid;
    gap: 10px;
  }

  .featured-product-cta {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    min-height: 58px;
    margin-top: 2px;
    padding: 0 22px;
    border-radius: 999px;
    text-decoration: none;
    color: #102149;
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid rgba(255, 255, 255, 0.92);
    font-family: "Barlow", sans-serif;
    font-size: 0.92rem;
    font-weight: 700;
    letter-spacing: 0.35px;
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 1),
      0 14px 34px rgba(8, 18, 56, 0.1);
    transition:
      transform 0.28s ease,
      box-shadow 0.28s ease,
      background 0.28s ease,
      color 0.28s ease,
      border-color 0.28s ease;
  }

  .featured-product-cta::before {
    content: "";
    position: absolute;
    inset: 1px;
    border-radius: inherit;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.78),
      rgba(255, 255, 255, 0.06)
    );
    opacity: 0.34;
    pointer-events: none;
  }

  .featured-product-cta::after {
    content: "";
    position: absolute;
    top: 0;
    left: -130%;
    width: 70%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 255, 255, 0.55) 50%,
      transparent 100%
    );
    transform: skewX(-20deg);
    transition: left 0.7s ease;
    pointer-events: none;
  }

  .featured-product-cta:hover::after,
  .featured-product-cta:focus-visible::after {
    left: 160%;
  }

  .featured-product-cta > * {
    position: relative;
    z-index: 1;
  }

  .featured-product-cta-icon {
    display: inline-grid;
    place-items: center;
    width: 20px;
    height: 20px;
  }

  .featured-cta-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: currentColor;
    box-shadow: 0 0 0 5px rgba(16, 33, 73, 0.08);
    transition: box-shadow 0.28s ease;
  }

  .featured-product-cta:hover,
  .featured-product-cta:focus-visible {
    transform: translateY(-3px);
    color: #fff;
    background: linear-gradient(
      135deg,
      var(--color-primary) 0%,
      #4853aa 56%,
      var(--color-accent) 100%
    );
    border-color: transparent;
    box-shadow:
      0 18px 42px rgba(8, 18, 56, 0.18),
      inset 0 1px 0 rgba(255, 255, 255, 0.14);
    outline: none;
  }

  .featured-product-cta:hover .featured-cta-dot,
  .featured-product-cta:focus-visible .featured-cta-dot {
    box-shadow: 0 0 0 5px rgba(255, 255, 255, 0.12);
  }

  .featured-product-cta-note {
    margin: 0;
    color: rgba(16, 33, 73, 0.62);
    font-size: 0.82rem;
    line-height: 1.5;
    text-align: center;
    text-wrap: pretty;
  }

  .js-featured-product.is-visible .featured-product-shell {
    animation: productLiftIn 0.9s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .js-featured-product.is-visible .featured-product-panel-inner > * {
