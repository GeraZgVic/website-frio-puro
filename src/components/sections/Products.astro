<script is:inline>
  (() => {
    const cards = document.querySelectorAll(".js-featured-product");

    if (!cards.length) return;

    const isReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;
    const isTouchDevice = window.matchMedia(
      "(hover: none) and (pointer: coarse)",
    ).matches;

    const revealCards = () => {
      if (isReducedMotion || !("IntersectionObserver" in window)) {
        cards.forEach((card) => card.classList.add("is-visible"));
        return;
      }

      const observer = new IntersectionObserver(
        (entries, obs) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add("is-visible");
            obs.unobserve(entry.target);
          });
        },
        {
          threshold: 0.2,
          rootMargin: "0px 0px -8% 0px",
        },
      );

      cards.forEach((card) => observer.observe(card));
    };

    const addTouchFeedback = () => {
      if (!isTouchDevice) return;

      const ctas = document.querySelectorAll(".featured-product-cta");

      ctas.forEach((cta) => {
        cta.addEventListener(
          "touchstart",
          () => {
            cta.classList.add("is-pressed");
          },
          { passive: true },
        );

        cta.addEventListener(
          "touchend",
          () => {
            window.setTimeout(() => {
              cta.classList.remove("is-pressed");
            }, 180);
          },
          { passive: true },
        );
      });
    };

    const addSubtleParallax = () => {
      if (isTouchDevice || isReducedMotion) return;

      cards.forEach((card) => {
        const image = card.querySelector(".featured-product-image");
        const glow = card.querySelector(".featured-product-glow");

        if (!image || !glow) return;

        let frame = null;

        const reset = () => {
          image.style.transform = "";
          glow.style.transform = "";
        };

        const handleMove = (event) => {
          const rect = card.getBoundingClientRect();
          const offsetX = (event.clientX - rect.left) / rect.width - 0.5;
          const offsetY = (event.clientY - rect.top) / rect.height - 0.5;

          if (frame) cancelAnimationFrame(frame);

          frame = requestAnimationFrame(() => {
            image.style.transform = `scale(1.06) translate3d(${offsetX * 10}px, ${offsetY * 10}px, 0)`;
            glow.style.transform = `translate3d(${offsetX * 18}px, ${offsetY * 18}px, 0)`;
          });
        };

        card.addEventListener("mousemove", handleMove);
        card.addEventListener("mouseleave", reset);
      });
    };

    revealCards();
    addTouchFeedback();
    addSubtleParallax();
  })();
</script>
