---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  author?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const {
  title = "Frío Puro",
  description = "Frío Puro — Hielo premium para negocios.",
  keywords = "hielo, distribuidor, mayoreo, Villahermosa Tabasco",
  author = "Frío Puro",
  ogTitle = title,
  ogDescription = description
} = Astro.props;

const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : Astro.url;
const ogImageUrl = new URL("/images/Hero5-1536.webp", Astro.site ?? Astro.url);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Frío Puro",
  url: "https://friopuro.com.mx",
  description,
  areaServed: "Villahermosa, Tabasco, MX",
};

const GA4_ID = ((import.meta.env.PUBLIC_GA4_ID as string | undefined) ?? "").trim();
const META_PIXEL_ID = ((import.meta.env.PUBLIC_META_PIXEL_ID as string | undefined) ?? "").trim();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={author} />
    <meta name="theme-color" content="#323b81" />
    <meta name="color-scheme" content="light" />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageUrl.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <link
      rel="preload"
      as="image"
      href="/images/Hero5-1024.webp"
      type="image/webp"
      imagesrcset="/images/Hero5-512.webp 512w, /images/Hero5-768.webp 768w, /images/Hero5-1024.webp 1024w, /images/Hero5-1536.webp 1536w"
      imagesizes="(min-width: 1025px) 520px, 1px"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      (() => {
        if (typeof window === "undefined") return;

        const GA4_ID = {JSON.stringify(GA4_ID)};
        const META_PIXEL_ID = {JSON.stringify(META_PIXEL_ID)};

        const safe = (value, pattern) => {
          if (typeof value !== "string") return "";
          const trimmed = value.trim();
          return pattern.test(trimmed) ? trimmed : "";
        };

        const ga4Id = safe(GA4_ID, /^G-[A-Z0-9]+$/);
        const metaId = safe(META_PIXEL_ID, /^\d{5,}$/);

        const w = window;
        if (!w.__frioPuroTracking) {
          w.__frioPuroTracking = {
            initializedAt: Date.now(),
            pageviewSent: false,
            dedupe: new Set(),
          };
        } else if (w.__frioPuroTracking.initializedAt) {
          return;
        }

        const ensureGtag = () => {
          if (!ga4Id) return;

          w.dataLayer = w.dataLayer || [];

          if (!w.gtag) {
            w.gtag = function gtag() {
              // eslint-disable-next-line prefer-rest-params
              w.dataLayer.push(arguments);
            };
          }

          if (!w.__frioPuroGtagLoaded) {
            const script = document.createElement("script");
            script.async = true;
            script.src = `https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(ga4Id)}`;
            script.onload = () => {
              w.__frioPuroGtagLoaded = true;
            };
            document.head.appendChild(script);
          }

          try {
            w.gtag("js", new Date());
            if (ga4Id) w.gtag("config", ga4Id, { send_page_view: false });
          } catch {
            // ignore
          }
        };

        const ensureMetaPixel = () => {
          if (!metaId) return;
          if (w.fbq && w.fbq.loaded) return;
          if (w.__frioPuroMetaLoaded) return;
          w.__frioPuroMetaLoaded = true;

          /* eslint-disable */
          !(function (f, b, e, v, n, t, s) {
            if (f.fbq) return;
            n = (f.fbq = function () {
              // eslint-disable-next-line prefer-rest-params
              n.callMethod ? n.callMethod.apply(n, arguments) : n.queue.push(arguments);
            });
            if (!f._fbq) f._fbq = n;
            n.push = n;
            n.loaded = true;
            n.version = "2.0";
            n.queue = [];
            t = b.createElement(e);
            t.async = true;
            t.src = v;
            s = b.getElementsByTagName(e)[0];
            s.parentNode.insertBefore(t, s);
          })(w, document, "script", "https://connect.facebook.net/en_US/fbevents.js");
          /* eslint-enable */

          try {
            w.fbq("init", metaId);
          } catch {
            // ignore
          }
        };

        const dedupeOnce = (name, eventId) => {
          if (!eventId) return false;
          const key = `${name}|${eventId}`;
          if (w.__frioPuroTracking.dedupe.has(key)) return true;
          w.__frioPuroTracking.dedupe.add(key);
          return false;
        };

        w.frioPuroTrackEvent = (name, params) => {
          try {
            const eventId = params && typeof params.event_id === "string" ? params.event_id : "";
            if (dedupeOnce(name, eventId)) return;

            if (typeof w.gtag === "function" && ga4Id) {
              w.gtag("event", name, params || {});
            }

            if (typeof w.fbq === "function" && metaId) {
              w.fbq("trackCustom", name, params || {});
            }
          } catch {
            // ignore
          }
        };

        w.frioPuroTrackPageView = () => {
          try {
            if (w.__frioPuroTracking.pageviewSent) return;
            w.__frioPuroTracking.pageviewSent = true;
            w.frioPuroTrackEvent("page_view", {
              page_location: location.href,
              page_path: location.pathname,
              page_title: document.title,
            });
          } catch {
            // ignore
          }
        };

        ensureGtag();
        ensureMetaPixel();

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", () => w.frioPuroTrackPageView(), { once: true });
        } else {
          w.frioPuroTrackPageView();
        }
      })();
    </script>
    <script is:inline>
      (() => {
        try {
          const raw = sessionStorage.getItem("__frioPuroPageTransition");
          if (!raw) return;
          const parsed = JSON.parse(raw);
          if (!parsed || typeof parsed.ts !== "number") return;
          if (Date.now() - parsed.ts > 12000) {
            sessionStorage.removeItem("__frioPuroPageTransition");
            return;
          }

          const rawVariant = typeof parsed.variant === "string" ? parsed.variant : "";
          const variant = rawVariant
            .trim()
            .toLowerCase()
            .replace(/[^a-z0-9_-]+/g, "-")
            .replace(/-+/g, "-")
            .replace(/^-|-$/g, "");

          document.documentElement.classList.add("pt-enter");
          if (variant) document.documentElement.classList.add(`pt-variant-${variant}`);
          sessionStorage.removeItem("__frioPuroPageTransition");
        } catch {
          // ignore
        }
      })();
    </script>
    <script is:inline>
      (() => {
        const hash = window.location.hash;
        if (!hash || hash === "#") return;

        try {
          if ("scrollRestoration" in history) history.scrollRestoration = "manual";
        } catch {
          // ignore
        }

        try {
          const payload = {
            hash,
            ts: Date.now(),
            pathname: window.location.pathname,
            search: window.location.search,
          };
          sessionStorage.setItem("__frioPuroPendingHash", JSON.stringify(payload));
        } catch {
          // ignore
        }

        history.replaceState(
          history.state,
          "",
          window.location.pathname + window.location.search,
        );
      })();
    </script>
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLd)}
    />
  </head>
  <body>
    <div id="pageTransitionLayer" aria-hidden="true"></div>
    <slot />
    <script is:inline>
      (() => {
        const root = document.documentElement;
        if (!root.classList.contains("pt-enter")) return;

        try {
          if ("matchMedia" in window) {
            const reduce = window.matchMedia(
              "(prefers-reduced-motion: reduce)",
            ).matches;
            if (reduce) {
              root.classList.remove("pt-enter");
              root.classList.remove("pt-leave");
              root.classList.forEach((c) => {
                if (c.startsWith("pt-variant-")) {
                  root.classList.remove(c);
                }
              });
              return;
            }
          }
        } catch {
          // ignore
        }

        requestAnimationFrame(() => {
          requestAnimationFrame(() => {
            root.classList.remove("pt-enter");

            // Failsafe: always clear transition state.
            setTimeout(() => {
              root.classList.remove("pt-enter");
              root.classList.remove("pt-leave");

              // Clear variants too.
              root.classList.forEach((c) => {
                if (c.startsWith("pt-variant-")) {
                  root.classList.remove(c);
                }
              });
            }, 200);
          });
        });
      })();
    </script>
  </body>
</html>
