---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  author?: string;
  ogTitle?: string;
  ogDescription?: string;
}

const {
  title = "Frío Puro",
  description = "Frío Puro — Hielo premium para negocios.",
  keywords = "hielo, distribuidor, mayoreo, Villahermosa Tabasco",
  author = "Frío Puro",
  ogTitle = title,
  ogDescription = description
} = Astro.props;

const canonicalUrl = Astro.site
  ? new URL(Astro.url.pathname, Astro.site)
  : Astro.url;
const ogImageUrl = new URL("/images/Hero5-1536.webp", Astro.site ?? Astro.url);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  name: "Frío Puro",
  url: "https://friopuro.com.mx",
  description,
  areaServed: "Villahermosa, Tabasco, MX",
};
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content={author} />
    <meta name="theme-color" content="#323b81" />
    <meta name="color-scheme" content="light" />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImageUrl.toString()} />
    <meta name="twitter:card" content="summary_large_image" />
    <link
      rel="preload"
      as="image"
      href="/images/Hero5-1024.webp"
      type="image/webp"
      imagesrcset="/images/Hero5-512.webp 512w, /images/Hero5-768.webp 768w, /images/Hero5-1024.webp 1024w, /images/Hero5-1536.webp 1536w"
      imagesizes="(min-width: 1025px) 520px, 1px"
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Barlow:wght@400;600&display=swap"
      rel="stylesheet"
    />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(jsonLd)}
    />
  </head>
  <body>
    <slot />
  </body>
</html>
