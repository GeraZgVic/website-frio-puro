## Email delivery (Gmail SMTP)
# Gmail address with 2-step verification enabled.
GMAIL_USER=

# Gmail app password generated for that account.
GMAIL_APP_PASSWORD=

# Optional inbox where new leads should arrive.
# If omitted, emails are sent to GMAIL_USER.
LEAD_DESTINATION_EMAIL=

## Google reCAPTCHA v3
PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5
